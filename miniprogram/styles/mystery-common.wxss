/* ===== 神秘特产通用样式 - 炫酷版 ===== */

/* 基础渐变背景 */
.mystery-bg-purple {
  background: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #1a0a2e 100%);
}

.mystery-bg-blue {
  background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0a1628 100%);
}

.mystery-bg-green {
  background: linear-gradient(135deg, #0a1f0a 0%, #1a3a1a 50%, #0a1f0a 100%);
}

.mystery-bg-red {
  background: linear-gradient(135deg, #1f0a0a 0%, #3a1a1a 50%, #1f0a0a 100%);
}

.mystery-bg-gold {
  background: linear-gradient(135deg, #1f1a0a 0%, #3a3015 50%, #1f1a0a 100%);
}

/* 发光效果 */
.mystery-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  height: 80%;
  background: radial-gradient(circle, rgba(138, 43, 226, 0.4) 0%, rgba(138, 43, 226, 0.1) 40%, transparent 70%);
  border-radius: 50%;
  animation: mysteryGlowPulse 3s ease-in-out infinite;
}

@keyframes mysteryGlowPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
}

/* 星星装饰 */
.mystery-stars {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.mystery-star {
  position: absolute;
  font-size: 24rpx;
  opacity: 0;
  animation: starTwinkle 2s ease-in-out infinite;
}

.mystery-star:nth-child(1) { top: 15%; left: 15%; animation-delay: 0s; }
.mystery-star:nth-child(2) { top: 25%; right: 20%; animation-delay: 0.5s; }
.mystery-star:nth-child(3) { bottom: 30%; left: 25%; animation-delay: 1s; }
.mystery-star:nth-child(4) { top: 60%; right: 15%; animation-delay: 1.5s; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.2; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 礼盒容器 */
.mystery-box-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

/* 礼盒emoji */
.mystery-box-emoji {
  font-size: 80rpx;
  animation: boxFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 20rpx rgba(0,0,0,0.3));
}

@keyframes boxFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); }
  50% { transform: translateY(-10rpx) rotate(3deg); }
}

/* 光环效果 */
.mystery-ring-gold {
  position: absolute;
  width: 140%;
  height: 140%;
  border: 3rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 50%;
  animation: ringPulseGold 2s ease-out infinite;
}

.mystery-ring-gold::before {
  content: '';
  position: absolute;
  top: 15rpx;
  left: 15rpx;
  right: 15rpx;
  bottom: 15rpx;
  border: 2rpx solid rgba(138, 43, 226, 0.3);
  border-radius: 50%;
}

@keyframes ringPulseGold {
  0% { transform: scale(0.9); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0; }
}

/* 标签 */
.mystery-tag-badge {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  background: linear-gradient(90deg, rgba(138, 43, 226, 0.4), rgba(10, 132, 255, 0.4));
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 16rpx rgba(138, 43, 226, 0.3);
  white-space: nowrap;
}

/* 小尺寸版本（用于列表） */
.mystery-mini {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.mystery-mini .mystery-glow {
  width: 120%;
  height: 120%;
}

.mystery-mini .mystery-box-emoji {
  font-size: 60rpx;
}

.mystery-mini .mystery-ring-gold {
  width: 120%;
  height: 120%;
}

.mystery-mini .mystery-star {
  font-size: 18rpx;
}
