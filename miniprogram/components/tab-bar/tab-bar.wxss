/* components/tab-bar/tab-bar.wxss - 统一底部导航样式 */

.tab-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: rgba(30, 30, 32, 0.85);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  pointer-events: auto;
}

.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 100rpx;
  padding: 0 20rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  transition: all 0.2s ease;
  pointer-events: auto;
  z-index: 10000;
}

.tab-item:active {
  transform: scale(0.92);
}

.tab-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10001;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  transition: all 0.2s ease;
}

/* 特殊按钮（发布）样式 - iOS 26 玻璃拟态风格 */
.tab-item.special {
  position: relative;
  top: -20rpx;
  z-index: 10002;
}

.tab-item.special .tab-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #0A84FF 0%, #0066CC 100%);
  border-radius: 28rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(10, 132, 255, 0.4),
    0 4rpx 8rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.3);
  margin-bottom: 0;
  overflow: hidden;
  position: relative;
  transform: rotate(0deg);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 玻璃高光效果 */
.tab-item.special .tab-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, transparent 100%);
  border-radius: 28rpx 28rpx 0 0;
}

/* 底部阴影 */
.tab-item.special .tab-icon-wrap::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(0deg, rgba(0,0,0,0.1) 0%, transparent 100%);
  border-radius: 0 0 28rpx 28rpx;
}

.tab-item.special:active .tab-icon-wrap {
  transform: scale(0.92) rotate(90deg);
  box-shadow: 
    0 4rpx 16rpx rgba(10, 132, 255, 0.35),
    0 2rpx 4rpx rgba(0, 0, 0, 0.15),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.2);
}

.tab-item.special .tab-label {
  color: #0A84FF;
  font-weight: 600;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.tab-label {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 500;
  transition: all 0.2s ease;
}

/* 激活状态 - iOS 26 蓝色 */
.tab-item.active .tab-label {
  color: #0A84FF;
  font-weight: 600;
}

.tab-item.special .tab-label {
  color: #0A84FF;
}

/* 图标样式 - 使用CSS绘制 */
.icon-home,
.icon-swap,
.icon-publish,
.icon-order,
.icon-mine {
  width: 28rpx;
  height: 28rpx;
  position: relative;
  transition: all 0.2s ease;
}

/* 首页图标 */
.icon-home::before {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 20rpx;
  border: 3rpx solid #8E8E93;
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
  top: 8rpx;
  left: 2rpx;
}

.icon-home::after {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 3rpx;
  background: #8E8E93;
  bottom: 0;
  left: 0;
  border-radius: 2rpx;
}

.icon-home.active::before {
  border-color: #007AFF;
}

.icon-home.active::after {
  background: #007AFF;
}

/* 互换图标 */
.icon-swap::before {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid #8E8E93;
  top: 2rpx;
  left: 8rpx;
}

.icon-swap::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid #8E8E93;
  bottom: 2rpx;
  left: 8rpx;
}

.icon-swap.active::before {
  border-bottom-color: #007AFF;
}

.icon-swap.active::after {
  border-top-color: #007AFF;
}

/* 发布图标（加号）- 更大更清晰 */
.icon-publish {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  z-index: 1;
}

.icon-publish::before {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 4rpx;
  background: #fff;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 2rpx;
  box-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

.icon-publish::after {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 28rpx;
  background: #fff;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 2rpx;
  box-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

/* 订单图标 */
.icon-order::before {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 24rpx;
  border: 3rpx solid #8E8E93;
  border-radius: 2rpx;
  top: 2rpx;
  left: 4rpx;
}

.icon-order::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 3rpx;
  background: #8E8E93;
  top: 8rpx;
  left: 10rpx;
  border-radius: 1rpx;
}

.icon-order.active::before {
  border-color: #007AFF;
}

.icon-order.active::after {
  background: #007AFF;
}

/* 我的图标 */
.icon-mine::before {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #8E8E93;
  border-radius: 50%;
  top: 2rpx;
  left: 8rpx;
}

.icon-mine::after {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 10rpx;
  border: 3rpx solid #8E8E93;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
  bottom: 0;
  left: 4rpx;
}

.icon-mine.active::before,
.icon-mine.active::after {
  border-color: #007AFF;
}
