/* app.wxss - 全局样式 - iOS 27 液态玻璃 (Liquid Glass) 设计系统 */

/* ============================================
   TDesign 图标字体
   ============================================ */
@font-face {
  font-family: t;
  src: url('https://tdesign.gtimg.com/icon/0.4.1/fonts/t.ttf') format('truetype');
  font-weight: 400;
  font-style: normal;
}

/* ============================================
   1. CSS 变量系统 - iOS 27 液态玻璃设计令牌
   ============================================ */
page {
  
  /* --- iOS 27 主色调 - 更鲜活 --- */
  --color-primary: #0A84FF;
  --color-primary-light: #64D2FF;
  --color-primary-gradient: linear-gradient(135deg, #0A84FF 0%, #5AC8FA 100%);
  --color-secondary: #30D158;
  --color-secondary-gradient: linear-gradient(135deg, #30D158 0%, #34C759 100%);
  --color-warning: #FF9F0A;
  --color-warning-gradient: linear-gradient(135deg, #FF9F0A 0%, #FF9500 100%);
  --color-danger: #FF453A;
  --color-danger-gradient: linear-gradient(135deg, #FF453A 0%, #FF3B30 100%);
  --color-purple: #BF5AF2;
  --color-purple-gradient: linear-gradient(135deg, #BF5AF2 0%, #AF52DE 100%);
  --color-indigo: #5E5CE6;
  --color-pink: #FF375F;
  --color-pink-gradient: linear-gradient(135deg, #FF375F 0%, #FF2D55 100%);
  --color-teal: #64D2FF;
  --color-yellow: #FFD60A;
  
  /* --- iOS 27 背景系统 - 更深邃 --- */
  --color-bg: #000000;
  --color-bg-secondary: #0D0D0F;
  --color-bg-tertiary: #161619;
  --color-bg-elevated: #1C1C1E;
  
  /* --- iOS 27 液态玻璃表面 --- */
  --liquid-surface: rgba(255, 255, 255, 0.08);
  --liquid-surface-hover: rgba(255, 255, 255, 0.12);
  --liquid-surface-active: rgba(255, 255, 255, 0.16);
  --liquid-surface-solid: rgba(30, 30, 32, 0.95);
  
  /* --- iOS 27 高级玻璃效果 --- */
  --glass-primary: rgba(10, 132, 255, 0.15);
  --glass-secondary: rgba(48, 209, 88, 0.12);
  --glass-purple: rgba(191, 90, 242, 0.12);
  --glass-pink: rgba(255, 55, 95, 0.12);
  --glass-orange: rgba(255, 159, 10, 0.12);
  --glass-teal: rgba(100, 210, 255, 0.12);
  
  /* --- iOS 27 文字色 --- */
  --color-text: #FFFFFF;
  --color-text-secondary: rgba(255, 255, 255, 0.8);
  --color-text-tertiary: rgba(255, 255, 255, 0.5);
  --color-text-quaternary: rgba(255, 255, 255, 0.3);
  --color-text-light: #8E8E93;
  --color-text-inverse: #000000;
  
  /* --- iOS 27 分割线 --- */
  --color-divider: rgba(255, 255, 255, 0.08);
  --color-divider-strong: rgba(255, 255, 255, 0.15);
  
  /* --- 圆角系统 - iOS 27 更圆润 --- */
  --radius-xs: 6rpx;
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 28rpx;
  --radius-3xl: 36rpx;
  --radius-full: 9999rpx;
  
  /* --- 阴影系统 - iOS 27 更柔和 --- */
  --shadow-xs: 0 1rpx 3rpx rgba(0, 0, 0, 0.12);
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  --shadow-md: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  --shadow-lg: 0 12rpx 40rpx rgba(0, 0, 0, 0.25);
  --shadow-xl: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  
  /* --- iOS 27 液态玻璃专用阴影 --- */
  --shadow-liquid: 0 8rpx 32rpx rgba(0, 0, 0, 0.2), 
                    inset 0 1rpx 0 rgba(255, 255, 255, 0.15),
                    inset 0 -1rpx 0 rgba(255, 255, 255, 0.05);
  --shadow-liquid-hover: 0 12rpx 40rpx rgba(0, 0, 0, 0.25),
                          inset 0 1rpx 0 rgba(255, 255, 255, 0.2),
                          inset 0 -1rpx 0 rgba(255, 255, 255, 0.08);
  --shadow-glow-blue: 0 0 40rpx rgba(10, 132, 255, 0.3);
  --shadow-glow-purple: 0 0 40rpx rgba(191, 90, 242, 0.3);
  --shadow-glow-pink: 0 0 40rpx rgba(255, 55, 95, 0.3);
  --shadow-glow-green: 0 0 40rpx rgba(48, 209, 88, 0.3);
  
  /* --- 间距系统 --- */
  --space-1: 4rpx;
  --space-2: 8rpx;
  --space-3: 12rpx;
  --space-4: 16rpx;
  --space-5: 20rpx;
  --space-6: 24rpx;
  --space-8: 32rpx;
  --space-10: 40rpx;
  --space-12: 48rpx;
  --space-16: 64rpx;
  
  /* --- 字体系统 --- */
  --font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Segoe UI', Roboto, sans-serif;
  --font-mono: 'SF Mono', SFMono-Regular, Consolas, monospace;
  
  /* --- iOS 27 液态玻璃模糊效果 --- */
  --blur-sm: blur(12px);
  --blur-md: blur(24px);
  --blur-lg: blur(40px);
  --blur-xl: blur(60px);
  
  /* --- 别名变量（兼容页面使用的变量名）--- */
  --bg-primary: var(--color-bg);
  --bg-secondary: var(--color-bg-secondary);
  --bg-tertiary: var(--color-bg-tertiary);
  --bg-elevated: var(--color-bg-elevated);
  --text-primary: var(--color-text);
  --text-secondary: var(--color-text-secondary);
  --text-tertiary: var(--color-text-tertiary);
  --text-quaternary: var(--color-text-quaternary);
  --text-inverse: var(--color-text-inverse);
  --separator: var(--color-divider);
  --separator-strong: var(--color-divider-strong);
  --accent-blue: var(--color-primary);
  --accent-green: var(--color-secondary);
  --accent-orange: var(--color-warning);
  --accent-red: var(--color-danger);
  --accent-purple: var(--color-purple);
  --accent-pink: var(--color-pink);
  --radius-card: var(--radius-lg);
  --radius-modal: var(--radius-2xl);
  
  /* 页面基础 */
  background-color: var(--color-bg);
  font-family: var(--font-family);
  color: var(--color-text);
  font-size: 28rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ============================================
   2. 全局重置
   ============================================ */
view, text, image, navigator, input, textarea, button, scroll-view, 
swiper, swiper-item, picker, picker-view, picker-view-column {
  box-sizing: border-box;
}

/* 去除按钮默认样式 */
button::after {
  border: none;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  line-height: inherit;
}

/* ============================================
   3. iOS 27 液态玻璃核心类
   ============================================ */

/* 标准液态玻璃效果 */
.liquid {
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: var(--shadow-liquid);
}

/* 液态玻璃卡片 */
.liquid-card {
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.1) 0%, 
    rgba(255, 255, 255, 0.05) 100%);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: var(--shadow-liquid);
  position: relative;
  overflow: hidden;
}

/* 液态玻璃卡片光泽层 */
.liquid-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 200%;
  height: 50%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.08),
    transparent
  );
  transform: skewX(-15deg);
  transition: transform 0.6s ease;
  pointer-events: none;
}

.liquid-card:hover::before,
.liquid-card:active::before {
  animation: liquidShine 0.8s ease;
}

@keyframes liquidShine {
  0% { transform: skewX(-15deg) translateX(-100%); }
  100% { transform: skewX(-15deg) translateX(200%); }
}

.liquid-card-hover:active {
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.12) 0%, 
    rgba(255, 255, 255, 0.06) 100%);
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-liquid-hover);
}

/* 高级液态玻璃 - 带彩色渐变 */
.liquid-premium {
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.12) 0%, 
    rgba(255, 255, 255, 0.04) 50%,
    rgba(255, 255, 255, 0.08) 100%);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: var(--shadow-liquid);
}

/* 彩色液态玻璃 */
.liquid-glass-blue {
  background: var(--glass-primary);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(10, 132, 255, 0.2);
}

.liquid-glass-purple {
  background: var(--glass-purple);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(191, 90, 242, 0.2);
}

.liquid-glass-pink {
  background: var(--glass-pink);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 55, 95, 0.2);
}

.liquid-glass-green {
  background: var(--glass-secondary);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(48, 209, 88, 0.2);
}

.liquid-glass-orange {
  background: var(--glass-orange);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 159, 10, 0.2);
}

/* 液态玻璃按钮 */
.liquid-btn {
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-liquid);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* 液态按钮光泽 */
.liquid-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.12),
    transparent
  );
  pointer-events: none;
}

.liquid-btn:active {
  background: var(--liquid-surface-active);
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

/* 纯色液态按钮 */
.liquid-btn-primary {
  background: var(--color-primary-gradient);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: var(--shadow-liquid), var(--shadow-glow-blue);
}

.liquid-btn-primary:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm), 0 0 20rpx rgba(10, 132, 255, 0.3);
}

.liquid-btn-success {
  background: var(--color-secondary-gradient);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: var(--shadow-liquid), var(--shadow-glow-green);
}

.liquid-btn-danger {
  background: var(--color-danger-gradient);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: var(--shadow-liquid), var(--shadow-glow-pink);
}

/* ============================================
   4. 卡片组件 - 液态玻璃风格
   ============================================ */
.card {
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.08) 0%, 
    rgba(255, 255, 255, 0.03) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow-liquid);
  overflow: hidden;
}

.card-elevated {
  box-shadow: var(--shadow-liquid-hover);
}

.card-flat {
  box-shadow: none;
  border: 1rpx solid var(--color-divider);
}

/* ============================================
   5. 按钮组件
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0 40rpx;
  height: 88rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.15),
    transparent
  );
  pointer-events: none;
}

.btn-full {
  width: 100%;
}

.btn-sm {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.btn-lg {
  height: 104rpx;
  padding: 0 48rpx;
  font-size: 30rpx;
}

/* 主要按钮 - 带发光效果 */
.btn-primary {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-liquid), var(--shadow-glow-blue);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

/* 次要按钮 */
.btn-secondary {
  background: var(--glass-primary);
  color: var(--color-primary);
  border: 1rpx solid rgba(10, 132, 255, 0.3);
}

.btn-secondary:active {
  background: rgba(10, 132, 255, 0.2);
}

/* 幽灵按钮 */
.btn-ghost {
  background: var(--liquid-surface);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color: var(--color-text);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.btn-ghost:active {
  background: var(--liquid-surface-active);
}

/* 危险按钮 */
.btn-danger {
  background: var(--color-danger-gradient);
  color: #fff;
  box-shadow: var(--shadow-liquid), var(--shadow-glow-pink);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.btn-danger:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 48, 0.3);
}

/* 成功按钮 */
.btn-success {
  background: var(--color-secondary-gradient);
  color: #fff;
  box-shadow: var(--shadow-liquid), var(--shadow-glow-green);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.btn-success:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.3);
}

/* ============================================
   6. 标签组件
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-lg);
  font-size: 22rpx;
  font-weight: 600;
}

.tag-blue { 
  background: var(--glass-primary); 
  color: var(--color-primary);
  border: 1rpx solid rgba(10, 132, 255, 0.25);
}
.tag-green { 
  background: var(--glass-secondary); 
  color: var(--color-secondary);
  border: 1rpx solid rgba(48, 209, 88, 0.25);
}
.tag-orange { 
  background: var(--glass-orange); 
  color: var(--color-warning);
  border: 1rpx solid rgba(255, 159, 10, 0.25);
}
.tag-red { 
  background: var(--glass-pink); 
  color: var(--color-danger);
  border: 1rpx solid rgba(255, 59, 48, 0.25);
}
.tag-purple { 
  background: var(--glass-purple); 
  color: var(--color-purple);
  border: 1rpx solid rgba(191, 90, 242, 0.25);
}
.tag-gray { 
  background: var(--liquid-surface); 
  color: var(--color-text-tertiary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 胶囊标签 */
.tag-pill {
  border-radius: var(--radius-full);
  padding: 10rpx 24rpx;
}

/* ============================================
   7. 输入框组件
   ============================================ */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--liquid-surface);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 2rpx solid transparent;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text);
  transition: all 0.2s ease;
}

.input::placeholder {
  color: var(--color-text-quaternary);
}

.input:focus {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.15), var(--shadow-liquid);
}

/* 液态输入框 */
.input-liquid {
  background: var(--liquid-surface);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-lg);
}

/* ============================================
   8. 工具类 - Flexbox
   ============================================ */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-nowrap { flex-wrap: nowrap; }

.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.items-stretch { align-items: stretch; }

.justify-start { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-evenly { justify-content: space-evenly; }

.flex-1 { flex: 1; }
.flex-auto { flex: 1 1 auto; }
.flex-none { flex: none; }

.gap-1 { gap: 4rpx; }
.gap-2 { gap: 8rpx; }
.gap-3 { gap: 12rpx; }
.gap-4 { gap: 16rpx; }
.gap-5 { gap: 20rpx; }
.gap-6 { gap: 24rpx; }
.gap-8 { gap: 32rpx; }

/* ============================================
   9. 工具类 - 间距
   ============================================ */
.m-0 { margin: 0; }
.m-1 { margin: 4rpx; }
.m-2 { margin: 8rpx; }
.m-3 { margin: 12rpx; }
.m-4 { margin: 16rpx; }
.m-5 { margin: 20rpx; }
.m-6 { margin: 24rpx; }
.m-8 { margin: 32rpx; }

/* 页面左右边距 */
.mx-sm { margin-left: 12rpx; margin-right: 12rpx; }
.mx-4 { margin-left: 16rpx; margin-right: 16rpx; }
.mx-5 { margin-left: 20rpx; margin-right: 20rpx; }
.mx-md { margin-left: 20rpx; margin-right: 20rpx; }
.mx-6 { margin-left: 24rpx; margin-right: 24rpx; }
.mx-8 { margin-left: 32rpx; margin-right: 32rpx; }

.my-4 { margin-top: 16rpx; margin-bottom: 16rpx; }
.my-6 { margin-top: 24rpx; margin-bottom: 24rpx; }

.mt-2 { margin-top: 8rpx; }
.mt-4 { margin-top: 16rpx; }
.mt-6 { margin-top: 24rpx; }
.mt-8 { margin-top: 32rpx; }

.mb-2 { margin-bottom: 8rpx; }
.mb-4 { margin-bottom: 16rpx; }
.mb-6 { margin-bottom: 24rpx; }
.mb-8 { margin-bottom: 32rpx; }

/* 通用 padding 工具类 */
.p-4 { padding: 16rpx; }
.p-5 { padding: 20rpx; }
.p-6 { padding: 24rpx; }
.p-8 { padding: 32rpx; }
.p-10 { padding: 40rpx; }

.py-4 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-5 { padding-top: 20rpx; padding-bottom: 20rpx; }
.py-6 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-8 { padding-top: 32rpx; padding-bottom: 32rpx; }
.py-10 { padding-top: 40rpx; padding-bottom: 40rpx; }

.px-4 { padding-left: 16rpx; padding-right: 16rpx; }
.px-5 { padding-left: 20rpx; padding-right: 20rpx; }
.px-6 { padding-left: 24rpx; padding-right: 24rpx; }
.px-8 { padding-left: 32rpx; padding-right: 32rpx; }

.p-0 { padding: 0; }

/* ============================================
   10. 工具类 - 文字
   ============================================ */
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }

.text-regular { font-weight: 400; }
.text-medium { font-weight: 500; }
.text-semibold { font-weight: 600; }
.text-bold { font-weight: 700; }

.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-light { color: var(--color-text-light); }
.text-success { color: var(--color-secondary); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-inverse { color: var(--color-text-inverse); }

/* 文字截断 */
.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ============================================
   11. 工具类 - 其他
   ============================================ */
.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-full { border-radius: var(--radius-full); }

.divider {
  height: 1rpx;
  background: var(--color-divider);
}

.divider-v {
  width: 1rpx;
  background: var(--color-divider);
}

/* 安全区 */
.safe-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}

.safe-top {
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
}

/* ============================================
   12. 状态样式
   ============================================ */

/* 信用分颜色 */
.credit-high { color: var(--color-secondary); }
.credit-mid { color: var(--color-warning); }
.credit-low { color: var(--color-danger); }

.credit-bg-high { background: var(--glass-secondary); }
.credit-bg-mid { background: var(--glass-orange); }
.credit-bg-low { background: var(--glass-pink); }

/* ============================================
   13. 空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--color-text-tertiary);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
}

/* ============================================
   14. 加载状态
   ============================================ */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================
   15. iOS 27 液态动画系统
   ============================================ */

/* 淡入 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 滑入 */
@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(20rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-slide-up {
  animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 液态弹跳 */
@keyframes liquidBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  30% { transform: translateY(-8rpx) scale(0.98); }
  50% { transform: translateY(0) scale(1.02); }
  70% { transform: translateY(-4rpx) scale(0.99); }
}

.animate-liquid-bounce {
  animation: liquidBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 缩放 */
@keyframes scaleIn {
  from { 
    opacity: 0;
    transform: scale(0.9);
  }
  to { 
    opacity: 1;
    transform: scale(1);
  }
}

.animate-scale-in {
  animation: scaleIn 0.3s ease-out;
}

/* 脉冲 */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 液态浮动 */
@keyframes liquidFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.animate-liquid-float {
  animation: liquidFloat 3s ease-in-out infinite;
}

/* 液态光泽流动 */
@keyframes liquidFlow {
  0% { transform: translateX(-100%) skewX(-15deg); }
  100% { transform: translateX(200%) skewX(-15deg); }
}

.animate-liquid-flow {
  animation: liquidFlow 1.5s ease-in-out;
}

/* 悬停效果 */
.hover-lift {
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.hover-lift:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-liquid-hover);
}

/* 按压效果 */
.press-scale {
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.press-scale:active {
  transform: scale(0.94);
}

/* ============================================
   16. 页面容器
   ============================================ */
.page {
  min-height: 100vh;
  background: var(--color-bg);
}

.page-with-tabbar {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

