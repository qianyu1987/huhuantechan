  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 纯净白主题 - 我的页面卡片覆盖 */
.theme-light .profile-card,
.theme-light .admin-notify,
.theme-light .section {
  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 纯净白主题 - 发布页面覆盖 */
.theme-light .page-header {
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.theme-light .section {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 纯净白主题 - 神秘特产开关覆盖 */
.theme-light .mystery-toggle-section {
  background: linear-gradient(135deg, rgba(191, 90, 242, 0.08) 0%, rgba(98, 40, 215, 0.08) 100%) !important;
  border: 1rpx solid rgba(191, 90, 242, 0.2) !important;
}

.theme-light .mystery-toggle-title {
  color: #000000 !important;
}

.theme-light .mystery-toggle-desc {
  color: rgba(0, 0, 0, 0.5) !important;
}

/* 纯净白主题 - 分割线覆盖 */
.theme-light .divider,
.theme-light .menu-item,
.theme-light .deposit-bar {
  border-color: rgba(0, 0, 0, 0.1) !important;
}

/* 纯净白主题 - 功能未开放提示 */
.theme-light .feature-disabled-title {
  color: #000000 !important;
}

.theme-light .feature-disabled-desc {
  color: rgba(0, 0, 0, 0.5) !important;
}

.theme-light .feature-disabled-btn {
  background: rgba(0, 0, 0, 0.06);
  color: rgba(0, 0, 0, 0.6);
}

/* 纯净白主题导航栏 */
.theme-light .nav-bar,
.theme-light .glass-nav {
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
}

/* 纯净白主题底部标签栏 */
.theme-light .tab-bar {
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
}

/* 纯净白主题玻璃效果 */
.theme-light .glass-primary {
  background: rgba(0, 122, 255, 0.1);
}

.theme-light .glass-secondary {
  background: rgba(52, 199, 89, 0.1);
}

/* ============================================
   17. 导航栏 - 液态玻璃
   ============================================ */
.nav-bar {
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* ============================================
   18. 底部标签栏 - 液态玻璃
   ============================================ */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

/* 液态光泽 */
.tab-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100rpx;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 600;
}

/* 活跃标签发光点 */
.tab-item.active .tab-icon::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  width: 12rpx;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
  box-shadow: 0 0 12rpx var(--color-primary);
}

/* ============================================
   19. iOS 27 特殊效果
   ============================================ */

/* 液态边框 */
.liquid-border {
  position: relative;
}

.liquid-border::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1rpx;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.2),
    rgba(255, 255, 255, 0.05),
    rgba(255, 255, 255, 0.15)
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* 发光效果 */
.glow-blue {
  box-shadow: var(--shadow-glow-blue);
}

.glow-purple {
  box-shadow: var(--shadow-glow-purple);
}

.glow-pink {
  box-shadow: var(--shadow-glow-pink);
}

.glow-green {
  box-shadow: var(--shadow-glow-green);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #0A84FF 0%, #5AC8FA 50%, #BF5AF2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gradient-text-warm {
  background: linear-gradient(135deg, #FF9F0A 0%, #FF375F 50%, #BF5AF2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 液态背景装饰 */
.liquid-decoration {
  position: relative;
  overflow: hidden;
}

.liquid-decoration::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, 
    rgba(10, 132, 255, 0.1) 0%, 
    transparent 50%
  );
  animation: liquidFloat 6s ease-in-out infinite;
}

.liquid-decoration::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -30%;
  width: 80%;
  height: 80%;
  background: radial-gradient(circle, 
    rgba(191, 90, 242, 0.08) 0%, 
    transparent 50%
  );
  animation: liquidFloat 8s ease-in-out infinite reverse;
}

/* ============================================
   20. 表单组件 - 液态玻璃
   ============================================ */

/* 开关 */
.switch {
  width: 104rpx;
  height: 60rpx;
  background: var(--liquid-surface);
  border-radius: 30rpx;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.switch::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: white;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.switch.active {
  background: var(--color-primary-gradient);
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: var(--shadow-glow-blue);
}

.switch.active::after {
  transform: translateX(44rpx);
}

/* 单选/复选框 */
.checkbox, .radio {
  width: 44rpx;
  height: 44rpx;
  background: var(--liquid-surface);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked, .radio.checked {
  background: var(--color-primary-gradient);
  border-color: transparent;
  box-shadow: var(--shadow-glow-blue);
}

.radio {
  border-radius: 50%;
}

/* 下拉选择器 */
.picker {
  background: var(--liquid-surface);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  color: var(--color-text);
}

/* ============================================
   21. 徽章组件
   ============================================ */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: var(--color-danger-gradient);
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(255, 59, 48, 0.3);
}

.badge-primary {
  background: var(--color-primary-gradient);
  box-shadow: 0 2rpx 8rpx rgba(10, 132, 255, 0.3);
}

.badge-success {
  background: var(--color-secondary-gradient);
  box-shadow: 0 2rpx 8rpx rgba(48, 209, 88, 0.3);
}

/* ============================================
   22. 进度条
   ============================================ */
.progress {
  height: 12rpx;
  background: var(--liquid-surface);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: 6rpx;
  transition: width 0.3s ease;
  position: relative;
}

.progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.25),
    transparent
  );
}

/* ============================================
   23. 骨架屏 - 液态
   ============================================ */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.03) 25%,
    rgba(255, 255, 255, 0.08) 50%,
    rgba(255, 255, 255, 0.03) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}

/* ============================================
   24. 弹窗/Modal - 液态玻璃
   ============================================ */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
}

.modal {
  width: 80%;
  max-width: 600rpx;
  background: linear-gradient(135deg, 
    rgba(30, 30, 32, 0.95) 0%, 
    rgba(20, 20, 22, 0.98) 100%
  );
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border-radius: var(--radius-2xl);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: var(--shadow-xl);
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-overlay.show .modal {
  transform: scale(1);
}

/* ============================================
   25. Toast/提示 - 液态
   ============================================ */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(30, 30, 32, 0.9);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 24rpx 40rpx;
  box-shadow: var(--shadow-liquid);
  z-index: 2000;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.toast.show {
  opacity: 1;
}

/* ============================================
   26. ActionSheet/底部操作栏 - 液态
   ============================================ */
.action-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-bottom: none;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  z-index: 1000;
}

.action-sheet.show {
  transform: translateY(0);
}

.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.action-sheet-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.action-sheet-handle {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 12rpx;
}

.action-sheet-handle-bar {
  width: 80rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
}

.action-sheet-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
  transition: background 0.2s ease;
}

.action-sheet-item:last-child {
  border-bottom: none;
}

.action-sheet-item:active {
  background: var(--liquid-surface-hover);
}

.action-sheet-cancel {
  margin-top: 16rpx;
  background: var(--liquid-surface);
  border-radius: 0;
}
