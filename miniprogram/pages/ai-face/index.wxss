/* pages/ai-face/index.wxss - 三合一版本 */

/* ========== 页面根容器 ========== */
.ai-face-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F0;
}

/* ========== Tab 栏 ========== */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 16rpx 32rpx;
  border-bottom: 2rpx solid #F5F5F0;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  width: 40rpx;
  height: 4rpx;
  background: #9CAF88;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #7A8B6E;
}

.tab-item.active .tab-text {
  color: #9CAF88;
  font-weight: 500;
}

/* ========== 滚动容器 ========== */
.tab-content-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.tab-content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.settings-scroll {
  padding-bottom: 40rpx;
}

/* ========== 拍照页面 ========== */
.camera-section {
  position: relative;
  padding: 20rpx;
  min-height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  margin-bottom: 20rpx;
}

.balance-info {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.15);
}

.balance-icon { font-size: 32rpx; margin-right: 8rpx; }
.balance-text { font-size: 28rpx; font-weight: 600; color: #9CAF88; }

.count-info { display: flex; flex-direction: column; align-items: flex-end; }
.count-text { font-size: 28rpx; color: #4A4A42; font-weight: 500; }
.count-hint { font-size: 22rpx; color: #E8B86D; margin-top: 4rpx; }

.camera-switch {
  position: absolute;
  top: 120rpx;
  right: 40rpx;
  z-index: 10;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.switch-icon { font-size: 40rpx; }

.camera-container {
  position: relative;
  flex: 1;
  width: 100%;
  min-height: 600rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #1a1a2e;
  box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.15);
}

.camera { 
  width: 100%; 
  height: 100%;
  min-height: 600rpx;
  display: block;
}

.focus-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 500rpx;
  border: 2rpx dashed rgba(156, 175, 136, 0.5);
  border-radius: 24rpx;
}

.focus-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #9CAF88;
  border-style: solid;
}

.focus-corner.top-left { top: -4rpx; left: -4rpx; border-width: 4rpx 0 0 4rpx; border-top-left-radius: 16rpx; }
.focus-corner.top-right { top: -4rpx; right: -4rpx; border-width: 4rpx 4rpx 0 0; border-top-right-radius: 16rpx; }
.focus-corner.bottom-left { bottom: -4rpx; left: -4rpx; border-width: 0 0 4rpx 4rpx; border-bottom-left-radius: 16rpx; }
.focus-corner.bottom-right { bottom: -4rpx; right: -4rpx; border-width: 0 4rpx 4rpx 0; border-bottom-right-radius: 16rpx; }

.focus-text {
  position: absolute;
  bottom: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 26rpx;
  color: #9CAF88;
  white-space: nowrap;
}

.camera-controls {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.camera-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(156, 175, 136, 0.3);
}

.camera-btn-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 4rpx solid #F5E6C8;
}

.camera-hint {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #7A8B6E;
}

.album-btn {
  text-align: center;
  padding-bottom: 40rpx;
}

.album-text {
  font-size: 28rpx;
  color: #9CAF88;
  text-decoration: underline;
}

/* ========== 结果页 ========== */
.result-section { padding: 32rpx; padding-bottom: 180rpx; min-height: 100%; box-sizing: border-box; }

.result-header { margin-bottom: 24rpx; }
.back-btn { font-size: 30rpx; color: #9CAF88; font-weight: 500; }

.photo-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.1);
  margin-bottom: 32rpx;
}

.result-photo { width: 100%; height: 500rpx; border-radius: 24rpx; }

.score-badge {
  position: absolute;
  top: 48rpx;
  right: 48rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F5E6C8 0%, #F5F5F0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(245, 230, 200, 0.4);
  border: 4rpx solid #FFFFFF;
}

.score-number { font-size: 52rpx; font-weight: 700; color: #9CAF88; }
.score-label { font-size: 22rpx; color: #7A8B6E; margin-top: 4rpx; }

.chart-card, .analysis-card, .calendar-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.1);
  margin-bottom: 32rpx;
}

.chart-title, .card-title { font-size: 32rpx; font-weight: 600; color: #4A4A42; margin-bottom: 32rpx; text-align: center; }

.donut-charts { display: flex; justify-content: space-around; flex-wrap: wrap; }
.donut-item { display: flex; flex-direction: column; align-items: center; margin: 16rpx; }

.donut-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: conic-gradient(var(--color) calc(var(--percent) * 3.6deg), #E8E8E0 calc(var(--percent) * 3.6deg));
  display: flex;
  align-items: center;
  justify-content: center;
}

.donut-inner { width: 90rpx; height: 90rpx; border-radius: 50%; background: #FFFFFF; display: flex; align-items: center; justify-content: center; }
.donut-score { font-size: 28rpx; font-weight: 600; color: var(--color); }
.donut-label { font-size: 24rpx; color: #7A8B6E; margin-top: 12rpx; }

.analysis-grid { display: flex; flex-wrap: wrap; margin: 0 -8rpx; }
.analysis-item { width: 50%; padding: 8rpx; box-sizing: border-box; }
.analysis-item::before {
  content: '';
  display: block;
  background: #F5F5F0;
  border-radius: 16rpx;
  padding: 20rpx;
}

.item-label { font-size: 24rpx; color: #7A8B6E; display: block; margin-bottom: 8rpx; }
.item-value { font-size: 32rpx; font-weight: 600; color: #4A4A42; }

.ai-comment {
  margin-top: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #F5E6C8 0%, #F5F5F0 100%);
  border-radius: 16rpx;
}

.comment-title { display: block; font-size: 26rpx; font-weight: 600; color: #9CAF88; margin-bottom: 12rpx; }
.comment-text { display: block; font-size: 28rpx; color: #4A4A42; line-height: 1.6; }

/* ========== 今日运势卡片 - 全新设计 ========== */
.fortune-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFAF8 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.12);
  margin-bottom: 32rpx;
}

/* 头部标题区 */
.fortune-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(156, 175, 136, 0.15);
}

.fortune-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fortune-icon {
  font-size: 40rpx;
}

.fortune-title {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #9CAF88 0%, #7A8B6E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.fortune-date {
  font-size: 26rpx;
  color: #9CAF88;
  font-weight: 500;
  background: rgba(156, 175, 136, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 幸运信息速览 */
.lucky-info-bar {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #F5F5F0 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(156, 175, 136, 0.1);
}

.lucky-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.lucky-label {
  font-size: 22rpx;
  color: #7A8B6E;
}

.lucky-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #9CAF88;
}

/* 七日历 */
.calendar-grid { 
  display: flex; 
  justify-content: space-between; 
  margin-bottom: 28rpx;
  padding: 16rpx;
  background: #FAFAF8;
  border-radius: 20rpx;
}

.calendar-item { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 16rpx 14rpx; 
  border-radius: 16rpx; 
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  min-width: 64rpx;
}

.calendar-item.active { 
  background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%);
  box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.3);
}

.calendar-day { 
  font-size: 30rpx; 
  font-weight: 700; 
  color: #4A4A42; 
}

.calendar-item.active .calendar-day { 
  color: #FFFFFF; 
}

.calendar-week { 
  font-size: 20rpx; 
  color: #7A8B6E; 
  margin-top: 6rpx; 
}

.calendar-item.active .calendar-week { 
  color: rgba(255, 255, 255, 0.9); 
}

/* 综合运势 */
.fortune-summary {
  background: linear-gradient(135deg, #F5E6C8 0%, #F5F5F0 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  border-left: 6rpx solid #E8B86D;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.summary-icon {
  font-size: 32rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #9CAF88;
}

.summary-text {
  font-size: 28rpx;
  color: #4A4A42;
  line-height: 1.7;
  text-align: justify;
}

/* 详细运势分析 */
.fortune-details {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.detail-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(156, 175, 136, 0.12);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.detail-icon {
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5E6C8 0%, #F5F5F0 100%);
  border-radius: 50%;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4A4A42;
}

.detail-content {
  font-size: 27rpx;
  color: #5A5A52;
  line-height: 1.7;
  margin-bottom: 16rpx;
  text-align: justify;
}

.detail-advice {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  background: rgba(156, 175, 136, 0.08);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
}

.advice-label {
  font-size: 26rpx;
  flex-shrink: 0;
}

.advice-text {
  font-size: 26rpx;
  color: #9CAF88;
  font-weight: 500;
  line-height: 1.5;
}

/* 幸运提示 */
.lucky-tips {
  display: flex;
  gap: 16rpx;
}

.tip-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%);
  padding: 20rpx;
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.today-count-hint { background: #FFFFFF; border-radius: 20rpx; padding: 24rpx 32rpx; margin: 0 32rpx 32rpx; box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.1); }
.hint-text { display: block; font-size: 26rpx; color: #7A8B6E; margin-bottom: 12rpx; text-align: center; }
.hint-progress { height: 8rpx; background: #F5F5F0; border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #9CAF88 0%, #B5C4A8 100%); border-radius: 4rpx; }

.share-section { display: flex; gap: 16rpx; padding: 0 24rpx 48rpx; flex-wrap: wrap; }
.share-btn, .save-btn, .moments-btn { flex: 1; min-width: 200rpx; height: 96rpx; border-radius: 48rpx; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; border: none; }
.share-btn { background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%); color: #FFFFFF; box-shadow: 0 8rpx 24rpx rgba(156, 175, 136, 0.3); }
.save-btn { background: #F5E6C8; color: #7A8B6E; }
.moments-btn { background: linear-gradient(135deg, #E8B86D 0%, #F5D89A 100%); color: #FFFFFF; box-shadow: 0 8rpx 24rpx rgba(232, 184, 109, 0.3); }
.share-btn::after, .save-btn::after, .moments-btn::after { border: none; }

/* ========== 日历页面 ========== */
.calendar-page { padding: 32rpx; padding-bottom: 200rpx; min-height: 100%; box-sizing: border-box; }

.calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.month-nav { display: flex; align-items: center; gap: 24rpx; }
.nav-btn { width: 56rpx; height: 56rpx; border-radius: 50%; background: #FFFFFF; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #9CAF88; box-shadow: 0 4rpx 12rpx rgba(156, 175, 136, 0.15); }
.current-month { font-size: 36rpx; font-weight: 600; color: #4A4A42; }
.today-btn { padding: 12rpx 24rpx; background: #9CAF88; border-radius: 24rpx; font-size: 26rpx; color: #FFFFFF; }

.week-header { display: flex; justify-content: space-around; padding: 24rpx 0; border-bottom: 2rpx solid rgba(156, 175, 136, 0.2); margin-bottom: 16rpx; }
.week-day { font-size: 28rpx; color: #7A8B6E; width: 80rpx; text-align: center; }

.calendar-grid { display: flex; flex-wrap: wrap; background: #FFFFFF; border-radius: 24rpx; padding: 16rpx; box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.1); margin-bottom: 32rpx; }
.calendar-cell { width: 14.28%; height: 100rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 12rpx; position: relative; box-sizing: border-box; }
.calendar-cell.other-month { opacity: 0.4; }
.calendar-cell.today { background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%); }
.calendar-cell.has-data { background: #F5E6C8; }
.cell-day { font-size: 28rpx; color: #4A4A42; line-height: 1.2; }
.calendar-cell.today .cell-day { color: #FFFFFF; font-weight: 600; }
.cell-mark { margin-top: 2rpx; height: 28rpx; display: flex; align-items: center; justify-content: center; }
.score-mini { font-size: 20rpx; color: #9CAF88; font-weight: 600; line-height: 1; }
.calendar-cell.today .score-mini { color: #FFFFFF; }

/* 详情卡片 */
.detail-card { background: #FFFFFF; border-radius: 32rpx; padding: 32rpx; box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.1); margin-bottom: 32rpx; }
.detail-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; padding-bottom: 24rpx; border-bottom: 2rpx solid #F5F5F0; }
.detail-date-info { display: flex; flex-direction: column; }
.detail-date { font-size: 36rpx; font-weight: 600; color: #4A4A42; }
.detail-week { font-size: 26rpx; color: #9CAF88; margin-top: 4rpx; }
.detail-count { display: flex; align-items: baseline; background: #F5E6C8; padding: 12rpx 24rpx; border-radius: 24rpx; }
.count-num { font-size: 32rpx; font-weight: 700; color: #9CAF88; margin-right: 8rpx; }
.count-text { font-size: 22rpx; color: #7A8B6E; }

.record-indicator { display: flex; justify-content: center; gap: 12rpx; margin-bottom: 24rpx; }
.indicator-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #E8E8E0; }
.indicator-dot.active { background: #9CAF88; }

.record-time { text-align: center; font-size: 26rpx; color: #7A8B6E; margin-bottom: 16rpx; }

.detail-photo-section { position: relative; width: 100%; height: 400rpx; border-radius: 24rpx; overflow: hidden; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08); }
.detail-photo-large { width: 100%; height: 100%; }
.photo-score-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); padding: 24rpx; display: flex; align-items: baseline; justify-content: center; }
.score-big { font-size: 56rpx; font-weight: 700; color: #F5E6C8; }
.score-unit { font-size: 28rpx; color: #F5E6C8; margin-left: 8rpx; }

.detail-info-grid { display: flex; flex-wrap: wrap; margin: 0 -8rpx 24rpx; }
.info-card-wrap { width: 50%; padding: 8rpx; box-sizing: border-box; }
.info-card { background: linear-gradient(135deg, #F5F5F0 0%, #FFFFFF 100%); border-radius: 20rpx; padding: 24rpx 16rpx; display: flex; flex-direction: column; align-items: center; border: 2rpx solid rgba(156, 175, 136, 0.15); }
.info-icon { font-size: 40rpx; margin-bottom: 8rpx; line-height: 1; }
.info-card-label { font-size: 24rpx; color: #7A8B6E; margin-bottom: 8rpx; line-height: 1; }
.info-card-value { font-size: 28rpx; font-weight: 600; color: #4A4A42; text-align: center; line-height: 1.2; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.detail-comment-card { background: linear-gradient(135deg, #F5E6C8 0%, #F5F5F0 100%); border-radius: 20rpx; padding: 24rpx; }
.comment-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.comment-icon { font-size: 32rpx; margin-right: 8rpx; }
.comment-title { font-size: 28rpx; font-weight: 600; color: #9CAF88; }

.record-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; padding: 24rpx 0; border-top: 2rpx solid #F5F5F0; width: 100%; box-sizing: border-box; }
.record-nav .nav-btn { padding: 20rpx 40rpx; background: #F5F5F0; border-radius: 32rpx; font-size: 28rpx; color: #4A4A42; min-width: 140rpx; text-align: center; }
.record-nav .nav-btn.disabled { opacity: 0.4; background: #E8E8E0; }
.record-page { font-size: 28rpx; color: #7A8B6E; font-weight: 500; }

.empty-detail { text-align: center; padding: 64rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #7A8B6E; display: block; margin-bottom: 32rpx; }
.take-photo-btn { display: inline-block; padding: 24rpx 56rpx; background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%); border-radius: 40rpx; font-size: 30rpx; color: #FFFFFF; font-weight: 500; box-shadow: 0 8rpx 24rpx rgba(156, 175, 136, 0.3); }

.stats-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.1); }
.stats-title { font-size: 30rpx; font-weight: 600; color: #4A4A42; margin-bottom: 24rpx; text-align: center; }
.stats-grid { display: flex; justify-content: space-around; }
.stat-item { text-align: center; }
.stat-num { display: block; font-size: 48rpx; font-weight: 700; color: #9CAF88; margin-bottom: 8rpx; }
.stat-label { display: block; font-size: 24rpx; color: #7A8B6E; }

/* ========== 设置页面 ========== */
.settings-page { padding: 32rpx; padding-bottom: 120rpx; min-height: 100%; box-sizing: border-box; }

.header-card { background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%); border-radius: 32rpx; padding: 48rpx; text-align: center; margin-bottom: 32rpx; box-shadow: 0 8rpx 32rpx rgba(156, 175, 136, 0.2); }
.header-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.header-title { display: block; font-size: 40rpx; font-weight: 600; color: #FFFFFF; margin-bottom: 12rpx; }
.header-desc { display: block; font-size: 26rpx; color: rgba(255, 255, 255, 0.9); }

.setting-card { background: #FFFFFF; border-radius: 24rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.1); overflow: hidden; }
.setting-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; }
.setting-left { display: flex; align-items: center; flex: 1; }
.setting-icon { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-right: 20rpx; }
.icon-reminder { background: #F5E6C8; }
.icon-time { background: #E8F4F8; }
.icon-subscribe { background: #F0E8F8; }
.setting-info { display: flex; flex-direction: column; }
.setting-title { font-size: 30rpx; font-weight: 500; color: #4A4A42; margin-bottom: 4rpx; }
.setting-desc { font-size: 24rpx; color: #7A8B6E; }
.setting-switch { transform: scale(0.9); }
.time-picker { display: flex; align-items: center; background: #F5F5F0; padding: 16rpx 24rpx; border-radius: 12rpx; }
.time-value { font-size: 30rpx; color: #9CAF88; font-weight: 500; margin-right: 8rpx; }
.time-arrow { font-size: 28rpx; color: #7A8B6E; }
.subscribe-btn { padding: 16rpx 32rpx; background: linear-gradient(135deg, #9CAF88 0%, #B5C4A8 100%); border-radius: 28rpx; font-size: 26rpx; color: #FFFFFF; font-weight: 500; }
.subscribe-btn.subscribed { background: #E8E8E0; color: #7A8B6E; }
.subscribe-hint { padding: 0 32rpx 24rpx; }
.subscribe-hint .hint-text { font-size: 24rpx; color: #E8B86D; }

.tips-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx; margin-bottom: 32rpx; box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.1); }
.tips-title { font-size: 30rpx; font-weight: 600; color: #4A4A42; margin-bottom: 20rpx; }
.tips-list { display: flex; flex-direction: column; gap: 12rpx; }
.tips-item { display: flex; align-items: flex-start; }
.tips-dot { font-size: 28rpx; color: #9CAF88; margin-right: 12rpx; line-height: 1.4; }
.tips-text { font-size: 26rpx; color: #4A4A42; line-height: 1.4; }

/* ========== 消费明细卡片 ========== */
.cost-detail-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(156, 175, 136, 0.1); }
.cost-detail-title { font-size: 30rpx; font-weight: 600; color: #4A4A42; margin-bottom: 20rpx; display: flex; align-items: center; }
.cost-detail-title::before { content: '💰'; margin-right: 12rpx; }
.cost-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F5F5F0; }
.cost-item:last-child { border-bottom: none; }
.cost-label { font-size: 26rpx; color: #7A8B6E; }
.cost-value { font-size: 28rpx; font-weight: 600; color: #4A4A42; }
.cost-value.free { color: #9CAF88; }
.cost-value.paid { color: #E8B86D; }
.cost-hint { font-size: 22rpx; color: #9CAF88; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx dashed #E8E8E0; }

.records-container { margin-top: 20rpx; }
.record-item { background: #FAFAF8; border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; }
