/* pages/privacy-policy/index.wxss - 隐私政策页面 */

page {
  background: #f5f5f5;
}

.privacy-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  z-index: 100;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 内容区域 */
.privacy-content {
  padding-top: calc(88rpx + constant(safe-area-inset-top));
  padding-top: calc(88rpx + env(safe-area-inset-top));
  height: 100vh;
  box-sizing: border-box;
}

.content-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
}

/* 头部区域 */
.header-section {
  text-align: center;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 40rpx;
}

.main-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.update-date {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 章节样式 */
.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.section-subtitle {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #444;
  margin: 24rpx 0 16rpx;
  line-height: 1.5;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
  text-align: justify;
}

/* 列表项 */
.list-item {
  display: flex;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.list-marker {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.list-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 高亮文字 */
.highlight {
  color: #07c160;
  font-weight: 500;
}

/* 联系信息 */
.contact-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin: 20rpx 0;
}

.contact-item {
  display: flex;
  margin-bottom: 12rpx;
}

.contact-item:last-child {
  margin-bottom: 0;
}

.contact-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  border-top: 1rpx solid #eee;
  margin-top: 40rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.bottom-safe {
  height: 40rpx;
}
