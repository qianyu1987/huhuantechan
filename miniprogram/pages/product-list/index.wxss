/* pages/product-list/index.wxss - iOS 26 毛玻璃风格 */

page {
  background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
  min-height: 100vh;
}

.product-list-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部区域 ===== */
.header-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx 16rpx;
  margin-top: 10rpx;
}

/* ===== 标语栏 ===== */
.slogan-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.1) 0%, 
    rgba(255, 255, 255, 0.04) 100%);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12px);
}

.slogan-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.slogan-emoji {
  font-size: 24rpx;
}

.slogan-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.slogan-dot {
  width: 6rpx;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin: 0 32rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.25s ease;
}

.search-bar:active {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.15);
}

.search-emoji {
  font-size: 32rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== Banner 区域 ===== */
.banner-section {
  position: relative;
  margin: 0 32rpx 24rpx;
  height: 80rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.banner-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, 
    rgba(94, 92, 230, 0.3) 0%, 
    rgba(10, 132, 255, 0.2) 40%,
    rgba(48, 209, 88, 0.1) 100%);
}

.banner-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(94, 92, 230, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(10, 132, 255, 0.15) 0%, transparent 50%);
}

.banner-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  gap: 24rpx;
}

.banner-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 14rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  font-weight: 500;
}

.banner-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
}

.deco-circle.c1 {
  width: 60rpx;
  height: 60rpx;
  top: -15rpx;
  right: 30rpx;
}

.deco-circle.c2 {
  width: 40rpx;
  height: 40rpx;
  bottom: 10rpx;
  right: 60rpx;
  background: radial-gradient(circle, rgba(94, 92, 230, 0.2) 0%, transparent 70%);
}

.deco-circle.c3 {
  width: 30rpx;
  height: 30rpx;
  top: 20rpx;
  right: 10rpx;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.15) 0%, transparent 70%);
}

/* ===== 平台数据概览卡片 ===== */
.stats-overview {
  padding: 24rpx 32rpx;
}

.stats-card {
  position: relative;
  background: linear-gradient(135deg, rgba(94, 92, 230, 0.25) 0%, rgba(10, 132, 255, 0.15) 50%, rgba(48, 209, 88, 0.1) 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 
    0 8rpx 32rpx rgba(94, 92, 230, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  overflow: hidden;
}

.stats-bg-glow {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(94, 92, 230, 0.4) 0%, transparent 70%);
  border-radius: 50%;
  filter: blur(40rpx);
}

.stats-content {
  position: relative;
  z-index: 1;
}

.stats-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stats-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #5E5CE6 0%, #0A84FF 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(94, 92, 230, 0.4);
}

.stats-icon {
  font-size: 28rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(94, 92, 230, 0.5);
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.2) 50%, transparent 100%);
}

/* ===== 分类快捷入口 ===== */
.category-quick-access {
  padding: 0 32rpx 20rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-chip.active {
  background: linear-gradient(135deg, #0A84FF 0%, #5E5CE6 100%);
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.35);
}

.category-chip:active {
  transform: scale(0.95);
}

.category-emoji {
  font-size: 28rpx;
}

.category-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.category-chip.active .category-name {
  color: #ffffff;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-icon {
  font-size: 24rpx;
}

.filter-title text:last-child {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.filter-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 32rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.filter-item.active {
  background: linear-gradient(135deg, #0A84FF 0%, #5E5CE6 100%);
  border-color: rgba(255, 255, 255, 0.25);
  box-shadow: 0 4rpx 20rpx rgba(10, 132, 255, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item text:last-child {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.filter-item.active text:last-child {
  color: #ffffff;
  font-weight: 600;
}

.filter-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #30D158;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.filter-dot.show {
  opacity: 1;
}

/* ===== 产品列表 ===== */
.product-scroll {
  flex: 1;
  padding: 24rpx 24rpx 40rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* ===== 产品卡片 ===== */
.product-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.product-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
}

.product-img {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.product-card:active .product-img {
  transform: scale(1.05);
}

/* 惊喜特产样式 */
.mystery-img-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 深色渐变背景 */
.mystery-img-wrap.purple {
  background: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #1a0a2e 100%);
}

.mystery-img-wrap.blue {
  background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0a1628 100%);
}

.mystery-img-wrap.green {
  background: linear-gradient(135deg, #0a1f0a 0%, #1a3a1a 50%, #0a1f0a 100%);
}

.mystery-img-wrap.red {
  background: linear-gradient(135deg, #1f0a0a 0%, #3a1a1a 50%, #1f0a0a 100%);
}

.mystery-img-wrap.gold {
  background: linear-gradient(135deg, #1a1505 0%, #3a3010 50%, #1a1505 100%);
}

/* 发光效果 */
.mystery-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
}

/* 星星装饰 */
.mystery-stars {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.mystery-star {
  position: absolute;
  font-size: 24rpx;
  animation: starTwinkle 2s ease-in-out infinite;
}

.mystery-star:nth-child(1) {
  top: 15%;
  left: 15%;
  animation-delay: 0s;
}

.mystery-star:nth-child(2) {
  top: 25%;
  right: 20%;
  animation-delay: 0.5s;
}

.mystery-star:nth-child(3) {
  bottom: 25%;
  left: 20%;
  animation-delay: 1s;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 礼盒 */
.mystery-box-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.mystery-box-emoji {
  font-size: 100rpx;
  filter: drop-shadow(0 8rpx 24rpx rgba(0, 0, 0, 0.5));
  animation: boxFloat 3s ease-in-out infinite;
}

@keyframes boxFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 金色光环 */
.mystery-ring-gold {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 140rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 50%;
  animation: ringPulse 2s ease-out infinite;
}

.mystery-ring-gold::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 50%;
  animation: ringPulse 2s ease-out infinite 0.5s;
}

@keyframes ringPulse {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
}

/* 标签 */
.mystery-tag-badge {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #FFD700;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  white-space: nowrap;
}

/* 状态标签 */
.product-status-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 600;
  backdrop-filter: blur(20rpx);
  background: rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.product-status-badge.swapped {
  background: linear-gradient(135deg, #30D158 0%, #28BD4A 100%);
}

.product-status-badge.in_swap {
  background: linear-gradient(135deg, #FF9F0A 0%, #FF8A00 100%);
}

/* 产品信息 */
.product-info {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.product-province {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.08);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.product-category {
  font-size: 22rpx;
  color: #0A84FF;
  background: rgba(10, 132, 255, 0.15);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.product-status {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.product-status.active {
  color: #30D158;
  background: rgba(48, 209, 88, 0.15);
}

.product-status.swapped {
  color: #8E8E93;
  background: rgba(142, 142, 147, 0.15);
}

.product-status.in_swap {
  color: #FF9F0A;
  background: rgba(255, 159, 10, 0.15);
}

/* 用户信息 */
.product-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.user-nickname {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ===== 加载更多 ===== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #0A84FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 48rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #0A84FF 0%, #5E5CE6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 100rpx;
  box-shadow: 0 8rpx 32rpx rgba(10, 132, 255, 0.4);
  transition: all 0.25s ease;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.3);
}

/* 代购角标 - 橙色渐变 */
.daigou-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF9F0A 0%, #FF6B35 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  z-index: 2;
}
