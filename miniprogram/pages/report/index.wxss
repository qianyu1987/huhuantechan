/* pages/report/index.wxss - 举报页面样式 */

page {
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  min-height: 100vh;
}

.report-page {
  padding: 0 32rpx 160rpx;
}

/* 页面标题 */
.page-header {
  padding: 40rpx 0 32rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1C1C1E;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8E8E93;
}

/* 被举报对象卡片 */
.target-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.target-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.target-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
}

.target-image-icon {
  font-size: 56rpx;
}

.target-info {
  flex: 1;
  min-width: 0;
}

.target-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.target-type {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.section-required {
  font-size: 30rpx;
  color: #FF3B30;
}

.section-optional {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 400;
}

/* 举报类型选择 */
.report-types {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item.selected {
  border-color: #FF3B30;
  background: rgba(255, 59, 48, 0.04);
}

.type-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.type-info {
  flex: 1;
  min-width: 0;
}

.type-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 6rpx;
}

.type-desc {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
}

.type-check {
  flex-shrink: 0;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #C7C7CC;
  transition: all 0.2s;
}

.check-circle.checked {
  border-color: #FF3B30;
  background: #FF3B30;
  position: relative;
}

.check-circle.checked::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 描述输入 */
.desc-input-wrap {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.desc-input {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1C1C1E;
}

.desc-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.uploaded-image-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.delete-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FF3B30;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 59, 48, 0.3);
}

.delete-icon {
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #C7C7CC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(0,0,0,0.02);
}

.upload-icon {
  font-size: 48rpx;
  color: #8E8E93;
  font-weight: 300;
}

.upload-text {
  font-size: 24rpx;
  color: #8E8E93;
}

/* 提示卡片 */
.tips-card {
  padding: 28rpx;
  background: rgba(0, 122, 255, 0.06);
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 122, 255, 0.15);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #007AFF;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #636366;
  line-height: 1.5;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}

/* 底部提交栏 */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
}

.footer-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.footer-btn.disabled {
  background: #E5E5EA;
  color: #8E8E93;
}

.footer-btn.active {
  background: linear-gradient(135deg, #FF3B30 0%, #FF6B6B 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 59, 48, 0.3);
}

.footer-btn-text {
  font-size: 32rpx;
  font-weight: 700;
}
