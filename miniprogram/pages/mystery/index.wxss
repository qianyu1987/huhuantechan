/* pages/mystery/index.wxss - 神秘特产 - iOS 26 毛玻璃风格 */

.mystery-page {
  min-height: 100vh;
  background: #000000;
  position: relative;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse 90% 60% at 50% 0%, rgba(191, 90, 242, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 20% 100%, rgba(10, 132, 255, 0.1) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
}

/* ===== 顶部介绍 ===== */
.mystery-header {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #BF5AF2 0%, #6228D7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(191, 90, 242, 0.4);
  margin-bottom: 20rpx;
}

.icon-mystery-lg {
  width: 60rpx;
  height: 60rpx;
  background: url('https://img.icons8.com/ios-filled/100/ffffff/mystery.png') no-repeat center;
  background-size: contain;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 滚动区域 ===== */
.mystery-scroll {
  position: relative;
  z-index: 1;
  padding: 0 24rpx;
}

/* ===== 通用区块 ===== */
.section {
  background: rgba(60, 60, 64, 0.25);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
}

.section-icon.active {
  background: linear-gradient(180deg, #30D158 0%, #34C759 100%);
}

.section-icon.publish {
  background: linear-gradient(180deg, #BF5AF2 0%, #5E5CE6 100%);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex: 1;
}

.section-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* ===== 神秘互换卡片 ===== */
.swap-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.swap-card {
  background: rgba(30, 30, 32, 0.5);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.swap-status-bar {
  height: 6rpx;
}

.swap-status-bar.pending {
  background: linear-gradient(90deg, #FF9F0A 0%, #FF6B00 100%);
}

.swap-status-bar.confirmed {
  background: linear-gradient(90deg, #0A84FF 0%, #5E5CE6 100%);
}

.swap-status-bar.completed {
  background: linear-gradient(90deg, #30D158 0%, #34C759 100%);
}

.swap-content {
  padding: 20rpx;
}

.swap-products {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.swap-product {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.swap-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.mystery-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(191, 90, 242, 0.3) 0%, rgba(98, 40, 215, 0.3) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-mystery-sm {
  width: 44rpx;
  height: 44rpx;
  background: url('https://img.icons8.com/ios-filled/100/ffffff/mystery.png') no-repeat center;
  background-size: contain;
  opacity: 0.6;
}

.swap-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.swap-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

.swap-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.swap-partner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.partner-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.partner-name {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.swap-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.empty-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: rgba(191, 90, 242, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.icon-mystery-md {
  width: 48rpx;
  height: 48rpx;
  background: url('https://img.icons8.com/ios-filled/100/cccccc/mystery.png') no-repeat center;
  background-size: contain;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ===== 产品列表 ===== */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(30, 30, 32, 0.4);
  border-radius: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.product-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.meta-divider {
  color: rgba(255, 255, 255, 0.2);
}

.product-status {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.product-status.active {
  background: rgba(48, 209, 88, 0.15);
  color: #30D158;
}

.product-status.in_swap {
  background: rgba(255, 159, 10, 0.15);
  color: #FF9F0A;
}

/* ===== 玩法说明 ===== */
.explain-section {
  background: transparent;
  border: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  padding: 0;
}

.explain-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  text-align: center;
}

.explain-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.explain-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.explain-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #BF5AF2 0%, #5E5CE6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
}

.explain-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.explain-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.explain-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 参与按钮 ===== */
.action-section {
  margin-top: 32rpx;
}

.publish-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #BF5AF2 0%, #6228D7 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(191, 90, 242, 0.4);
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 300;
  color: #FFFFFF;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(191, 90, 242, 0.3);
}

/* ===== 神秘特产彩色渐变卡片网格 ===== */
.mystery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 8rpx 0;
}

.mystery-card {
  aspect-ratio: 1;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
}

.mystery-card:active {
  transform: scale(0.96);
}

/* 渐变背景色 */
.mystery-card.color-1 {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A24 100%);
}

.mystery-card.color-2 {
  background: linear-gradient(135deg, #FECA57 0%, #FF9F43 100%);
}

.mystery-card.color-3 {
  background: linear-gradient(135deg, #48DBFB 0%, #0ABDE3 100%);
}

.mystery-card.color-4 {
  background: linear-gradient(135deg, #A55EEA 0%, #8854D0 100%);
}

.mystery-card.color-5 {
  background: linear-gradient(135deg, #26DE81 0%, #20BF6B 100%);
}

.mystery-card.color-6 {
  background: linear-gradient(135deg, #FED330 0%, #F79F1F 100%);
}

.mystery-card.color-7 {
  background: linear-gradient(135deg, #FC5C65 0%, #EB3B5A 100%);
}

.mystery-card.color-8 {
  background: linear-gradient(135deg, #45AAF2 0%, #2D98DA 100%);
}

.mystery-card.color-9 {
  background: linear-gradient(135deg, #4B7BEC 0%, #3867D6 100%);
}

.mystery-card.color-10 {
  background: linear-gradient(135deg, #778CA3 0%, #4B6584 100%);
}

/* 添加卡片 */
.add-card {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
}

.add-card .mystery-card-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
}

.add-card .mystery-card-province {
  color: rgba(255, 255, 255, 0.5);
}

/* 卡片内容 */
.mystery-card-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.mystery-card-province {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
  text-align: center;
}

.mystery-card-status {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.3);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  color: #FFFFFF;
}

/* 神秘产品卡片（小尺寸） */
.mystery-product-card {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #A55EEA 0%, #8854D0 100%);
}

.mystery-product-card.mystery {
  background: linear-gradient(135deg, #778CA3 0%, #4B6584 100%);
}

.mystery-product-card .card-icon {
  font-size: 40rpx;
}
