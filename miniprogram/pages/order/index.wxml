<!-- pages/order/index.wxml - 互换记录页（iOS 26 毛玻璃风格） -->
<view class="order-page theme-{{pageTheme}}">

  <!-- 功能未开放占位 -->
  <view wx:if="{{featureDisabled}}" class="feature-disabled-wrap">
    <view class="feature-disabled-icon">🔧</view>
    <view class="feature-disabled-title">功能开发中</view>
    <view class="feature-disabled-desc">该功能正在升级优化，敬请期待</view>
    <view class="feature-disabled-btn" bindtap="goHome">返回首页</view>
  </view>

  <block wx:else>
  <!-- 动态模糊背景 -->
  <view class="bg-gradient"></view>

  <!-- 状态切换 - 毛玻璃胶囊 -->
  <view class="tab-wrapper">
    <view class="glass-tabs">
      <block wx:for="{{tabs}}" wx:key="id">
        <view 
          class="tab-item {{activeTab === item.id ? 'active' : ''}}"
          bindtap="switchTab"
          data-id="{{item.id}}"
        >
          <text>{{item.label}}</text>
          <view class="tab-count" wx:if="{{item.count > 0}}">{{item.count}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view 
    scroll-y 
    class="order-scroll"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="loadMore"
  >
    <!-- 加载态 -->
    <view wx:if="{{loading && orders.length === 0}}" class="loading-state">
      <view class="loading-orbs">
        <view class="orb orb-1"></view>
        <view class="orb orb-2"></view>
        <view class="orb orb-3"></view>
      </view>
      <text class="loading-text">正在加载...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-state">
      <view class="empty-glass-card">
        <view class="empty-glow"></view>
        <view class="empty-icon-wrap">
          <text class="empty-icon">🔄</text>
        </view>
        <text class="empty-title">暂无{{currentTabLabel}}记录</text>
        <text class="empty-desc" wx:if="{{activeTab === 'all'}}">发现喜欢的特产，快去看看吧</text>
        <view class="empty-action" wx:if="{{activeTab === 'all'}}">
          <button class="btn-discover" bindtap="goToMatch">
            <text>发现特产</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 订单卡片列表 -->
    <view class="order-list" wx:else>
      <block wx:for="{{orders}}" wx:key="_id">
        <view class="glass-card-item" bindtap="goToOrderDetail" data-id="{{item._id}}">
          <!-- 状态条 -->
          <view class="card-status-bar" style="background: {{item.statusBg}}"></view>
          
          <!-- 卡片内容 -->
          <view class="card-content">
            <!-- 状态 + 时间 -->
            <view class="card-header">
              <view class="status-chip" style="background: {{item.statusBg}}20; color: {{item.statusColor}}">
                <view class="chip-dot" style="background: {{item.statusColor}}"></view>
                <text>{{item.statusLabel}}</text>
              </view>
              <text class="time-label">{{item.timeLabel}}</text>
            </view>

            <!-- 特产交换区 -->
            <view class="swap-zone">
              <!-- 我的特产 -->
              <view class="product-col">
                <view class="col-label give">我给出</view>
                <view class="product-card">
                  <block wx:if="{{item.myProduct.isMystery}}">
                    <view class="product-mystery-card {{item.myProduct.colorClass}}">
                      <text class="mystery-emoji">{{item.myProduct.emoji || '🎁'}}</text>
                      <text class="mystery-province">{{item.myProduct.provinceName}}</text>
                    </view>
                  </block>
                  <block wx:else>
                    <image class="product-img" src="{{item.myProduct.coverUrl}}" mode="aspectFill" lazy-load="{{true}}" binderror="handleProductImageError" data-index="{{index}}" data-type="my"/>
                  </block>
                  <view class="product-info">
                    <text class="product-name">{{item.myProduct.isMystery ? '神秘特产' : item.myProduct.name}}</text>
                    <text class="product-province" style="color: {{item.myProduct.provinceColor}}">{{item.myProduct.provinceName}}</text>
                  </view>
                </view>
              </view>

              <!-- 交换指示器 -->
              <view class="swap-indicator">
                <view class="indicator-line"></view>
                <view class="indicator-arrow">
                  <text>⇄</text>
                </view>
              </view>

              <!-- 对方特产 -->
              <view class="product-col">
                <view class="col-label receive">我收到</view>
                <view class="product-card">
                  <block wx:if="{{item.theirProduct.isMystery}}">
                    <view class="product-mystery-card their-mystery">
                      <text class="mystery-emoji">{{item.theirProduct.emoji || '🎁'}}</text>
                      <text class="mystery-province">{{item.theirProduct.provinceName}}</text>
                    </view>
                  </block>
                  <block wx:else>
                    <image class="product-img" src="{{item.theirProduct.coverUrl}}" mode="aspectFill" lazy-load="{{true}}" binderror="handleProductImageError" data-index="{{index}}" data-type="theirs"/>
                  </block>
                  <view class="product-info">
                    <text class="product-name">{{item.theirProduct.isMystery ? '神秘特产' : item.theirProduct.name}}</text>
                    <text class="product-province" style="color: {{item.theirProduct.provinceColor}}">{{item.theirProduct.provinceName}}</text>
                  </view>
                </view>
              </view>
            </view>

            <!-- 用户信息 - 加大版 -->
            <view class="card-footer-large">
              <view class="user-pair-large">
                <image class="user-avatar-large" src="{{item.initiatorInfo.avatarUrl}}" mode="aspectFill" lazy-load="{{true}}" binderror="handleAvatarError" data-index="{{index}}" data-field="initiator"/>
                <text class="user-name-large">{{item.initiatorInfo.nickName || '用户'}}</text>
                <view class="credit-badge-large {{item.initiatorInfo.creditClass}}">
                  <text>{{item.initiatorInfo.creditScore || 100}}</text>
                </view>
              </view>
              <view class="swap-symbol">
                <text>⇄</text>
              </view>
              <view class="user-pair-large">
                <image class="user-avatar-large" src="{{item.receiverInfo.avatarUrl}}" mode="aspectFill" lazy-load="{{true}}" binderror="handleAvatarError" data-index="{{index}}" data-field="receiver"/>
                <text class="user-name-large">{{item.receiverInfo.nickName || '用户'}}</text>
                <view class="credit-badge-large {{item.receiverInfo.creditClass}}">
                  <text>{{item.receiverInfo.creditScore || 100}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{noMore && orders.length > 0}}">
      <text>— 已显示全部 —</text>
    </view>
    <view style="height:120rpx"/>
  </scroll-view>

  <!-- 底部导航 -->
  <tab-bar active="order" />
  </block>
</view>
