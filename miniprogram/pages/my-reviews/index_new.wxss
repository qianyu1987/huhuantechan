/* pages/my-reviews/index_new.wxss - 我的评价（全新设计） */

/* 基础样式 */
.reviews-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0F0F0F 0%, #1A1A1A 100%);
  position: relative;
}

/* 安全区 */
.safe-top {
  height: env(safe-area-inset-top);
  background: transparent;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
  background: transparent;
}

.safe-bottom-placeholder {
  height: 120rpx;
}

/* 头部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: rgba(20, 20, 22, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #0A84FF;
  font-weight: 300;
}

.back-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.header-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

.header-right {
  display: flex;
  align-items: center;
}

.header-action {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.header-action:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.action-icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* 统计数据卡片 */
.stats-card {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background: rgba(30, 30, 32, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0A84FF;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

.stats-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.stats-footer-text {
  font-size: 26rpx;
  color: #FFD700;
  font-weight: 500;
}

.stats-footer-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* Tab切换 */
.tabs-container {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 100rpx;
  padding: 4rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 100rpx;
  transition: all 0.3s ease;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-item-active {
  background: rgba(10, 132, 255, 0.2);
}

.tab-item-active .tab-text {
  color: #0A84FF;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #0A84FF;
  border-radius: 2rpx;
}

/* 内容滚动区域 */
.content-scroll {
  height: calc(100vh - 340rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-illustration {
  margin-bottom: 40rpx;
}

.empty-emoji {
  font-size: 120rpx;
  display: block;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.empty-actions {
  display: flex;
  gap: 24rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: rgba(10, 132, 255, 0.2);
  border: 1rpx solid rgba(10, 132, 255, 0.4);
  border-radius: 100rpx;
  transition: all 0.2s ease;
}

.empty-btn text {
  font-size: 28rpx;
  color: #0A84FF;
  font-weight: 600;
}

.empty-btn:active {
  background: rgba(10, 132, 255, 0.3);
  transform: scale(0.95);
}

/* 评价列表 */
.reviews-list {
  padding: 0 32rpx 32rpx;
}

/* 评价卡片 */
.review-card {
  background: rgba(40, 40, 42, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.review-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.review-type {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.review-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.header-right {
  display: flex;
  align-items: center;
}

.review-status {
  padding: 6rpx 16rpx;
  background: rgba(52, 199, 89, 0.2);
  border: 1rpx solid rgba(52, 199, 89, 0.4);
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #34C759;
  font-weight: 600;
}

.review-badge {
  font-size: 32rpx;
}

.review-badge.excellent { color: #FFD700; }
.review-badge.good { color: #34C759; }
.review-badge.normal { color: #FF9500; }
.review-badge.bad { color: #FF3B30; }
.review-badge.terrible { color: #FF2D55; }

/* 用户信息 */
.user-info,
.reviewer-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.user-info:active,
.reviewer-info:active {
  background: rgba(255, 255, 255, 0.08);
}

.user-avatar,
.reviewer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.user-avatar-placeholder,
.reviewer-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-placeholder text,
.reviewer-avatar-placeholder text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-details,
.reviewer-details {
  flex: 1;
}

.user-name,
.reviewer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.reviewer-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.reviewer-action {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.reviewer-rating {
  font-size: 22rpx;
  font-weight: 600;
}

.reviewer-rating.excellent { color: #FFD700; }
.reviewer-rating.good { color: #34C759; }
.reviewer-rating.normal { color: #FF9500; }
.reviewer-rating.bad { color: #FF3B30; }
.reviewer-rating.terrible { color: #FF2D55; }

/* 产品信息 */
.product-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.product-image-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-image-placeholder text {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.7);
}

.product-details {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 评分区域 */
.rating-section {
  margin-bottom: 24rpx;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.star {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.2);
}

.star-active {
  color: #FFD700;
}

.rating-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rating-text {
  font-size: 26rpx;
  font-weight: 600;
}

.rating-text.excellent { color: #FFD700; }
.rating-text.good { color: #34C759; }
.rating-text.normal { color: #FF9500; }
.rating-text.bad { color: #FF3B30; }
.rating-text.terrible { color: #FF2D55; }

/* 评价内容 */
.review-content {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #0A84FF;
}

.content-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

/* 标签 */
.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: rgba(10, 132, 255, 0.1);
  border: 1rpx solid rgba(10, 132, 255, 0.2);
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #0A84FF;
  font-weight: 500;
}

/* 产品信息（小尺寸） */
.product-mini {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.product-mini-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.product-mini-image-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-mini-image-placeholder text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
}

.product-mini-name {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 卡片底部 */
.card-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.footer-actions {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.05);
  transform: scale(0.95);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.action-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.06);
}

.footer-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-spinner {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.spinner-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0A84FF;
  animation: bounce 1.4s infinite ease-in-out both;
}

.spinner-dot:nth-child(1) { animation-delay: -0.32s; }
.spinner-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 下拉刷新样式 */
.refresher {
  background: transparent !important;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .reviews-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24rpx;
  }
  
  .review-card {
    margin-bottom: 0;
  }
}

/* 暗色模式适配 */
@media (prefers-color-scheme: dark) {
  .reviews-page {
    background: linear-gradient(135deg, #000000 0%, #0A0A0A 100%);
  }
  
  .header,
  .stats-card,
  .tabs,
  .review-card,
  .user-info,
  .reviewer-info,
  .product-info,
  .review-content,
  .product-mini {
    background: rgba(15, 15, 17, 0.95);
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.review-card {
  animation: fadeIn 0.4s ease forwards;
  animation-delay: calc(var(--item-index, 0) * 0.05s);
  opacity: 0;
}

/* 触摸反馈 */
.touch-feedback {
  transition: transform 0.1s ease;
}

.touch-feedback:active {
  transform: scale(0.98);
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* 优化卡片动画延迟 */
.review-card:nth-child(1) { --item-index: 1; }
.review-card:nth-child(2) { --item-index: 2; }
.review-card:nth-child(3) { --item-index: 3; }
.review-card:nth-child(4) { --item-index: 4; }
.review-card:nth-child(5) { --item-index: 5; }
.review-card:nth-child(6) { --item-index: 6; }
.review-card:nth-child(7) { --item-index: 7; }
.review-card:nth-child(8) { --item-index: 8; }
.review-card:nth-child(9) { --item-index: 9; }
.review-card:nth-child(10) { --item-index: 10; }
