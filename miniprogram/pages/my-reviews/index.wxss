/* pages/my-reviews/index.wxss - 我的评价记录 - iOS 26 毛玻璃风格 */

.reviews-page {
  min-height: 100vh;
  background: #000000;
  position: relative;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse 80% 50% at 20% 0%, rgba(48, 209, 88, 0.08) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 100%, rgba(10, 132, 255, 0.06) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
}

/* 导航栏 */
.glass-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(30, 30, 32, 0.7);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #0A84FF;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.nav-placeholder {
  width: 60rpx;
}

/* ===== Tab 栏 ===== */
.tab-wrapper {
  position: sticky;
  top: calc(100rpx + env(safe-area-inset-top));
  z-index: 99;
  padding: 16rpx 24rpx 16rpx;
  background: rgba(30, 30, 32, 0.7);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.glass-tabs {
  display: flex;
  gap: 12rpx;
  background: rgba(60, 60, 64, 0.4);
  border-radius: 20rpx;
  padding: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item.active {
  background: rgba(10, 132, 255, 0.2);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.25);
}

/* 滚动区域 */
.reviews-scroll {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  height: calc(100vh - 200rpx - env(safe-area-inset-top));
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 评价列表 */
.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 发出的评价卡片 ===== */
.review-card {
  position: relative;
  background: rgba(60, 60, 64, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx;
  transition: transform 0.2s ease;
}

.review-card:active {
  transform: scale(0.98);
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.review-status {
  font-size: 22rpx;
  color: #30D158;
  background: rgba(48, 209, 88, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.review-product {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.product-img-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.product-detail {
  flex: 1;
  margin-left: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-user {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 评分（共用） */
.review-rating {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.2);
}

.star.active {
  color: #FFD700;
}

.rating-text {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.rating-text.good {
  background: rgba(48, 209, 88, 0.15);
  color: #30D158;
}

.rating-text.normal {
  background: rgba(255, 170, 0, 0.15);
  color: #FF9500;
}

.rating-text.bad {
  background: rgba(255, 59, 48, 0.15);
  color: #FF453A;
}

/* 标签（共用） */
.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.review-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ===== 收到的评价卡片 ===== */
.received-card {
  background: rgba(60, 60, 64, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx;
  transition: transform 0.2s ease;
}

.received-card:active {
  transform: scale(0.98);
}

/* 评价者头部 */
.reviewer-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.reviewer-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.reviewer-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.reviewer-info {
  flex: 1;
}

.reviewer-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.reviewer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.reviewer-action {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.reviewer-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* 评价引用块 */
.review-quote {
  background: rgba(255, 255, 255, 0.05);
  border-left: 6rpx solid rgba(10, 132, 255, 0.5);
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 底部产品信息（小尺寸） */
.review-product-mini {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.product-img-mini {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
}

.product-name-mini {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #30D158;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 32rpx 20rpx;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
}
