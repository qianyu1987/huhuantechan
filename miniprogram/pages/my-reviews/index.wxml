<!-- pages/my-reviews/index.wxml - 我的评价记录（双Tab） -->
<view class="reviews-page">
  <view class="bg-gradient"></view>

  <!-- 毛玻璃导航栏 -->
  <view class="glass-nav">
    <view class="nav-back" bindtap="goBack">
      <text>‹</text>
    </view>
    <text class="nav-title">我的评价</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- Tab 栏 -->
  <view class="tab-wrapper">
    <view class="glass-tabs">
      <view class="tab-item {{activeTab === 'sent' ? 'active' : ''}}" bindtap="switchTab" data-tab="sent">
        <text>我发出的</text>
      </view>
      <view class="tab-item {{activeTab === 'received' ? 'active' : ''}}" bindtap="switchTab" data-tab="received">
        <text>收到的评价</text>
      </view>
    </view>
  </view>

  <!-- Tab 1: 我发出的评价 -->
  <scroll-view scroll-y class="reviews-scroll" hidden="{{activeTab !== 'sent'}}" refresher-enabled bindrefresherrefresh="refreshSent" refresher-triggered="{{sentRefreshing}}" bindscrolltolower="loadMoreSent">

    <!-- 空状态 -->
    <view wx:if="{{sentReviews.length === 0 && !sentLoading}}" class="empty-state">
      <view class="empty-icon">📝</view>
      <view class="empty-title">还没有评价</view>
      <view class="empty-desc">完成分享后可以发表评价哦</view>
    </view>

    <!-- 评价列表 -->
    <view class="reviews-list" wx:else>
      <block wx:for="{{sentReviews}}" wx:key="_id">
        <view class="review-card" bindtap="goToOrderDetail" data-orderid="{{item.orderId}}">
          <view class="review-header">
            <text class="review-time">{{item.createTimeText}}</text>
            <text class="review-status">已评价</text>
          </view>

          <view class="review-product">
            <image class="product-img" src="{{item.coverUrl}}" mode="aspectFill" lazy-load="{{true}}" wx:if="{{item.coverUrl}}"/>
            <view class="product-img-placeholder" wx:else>📦</view>
            <view class="product-detail">
              <view class="product-name">{{item.productName || '特产'}}</view>
              <view class="product-user">分享用户: {{item.reviewee.nickName || '用户'}}</view>
            </view>
          </view>

          <view class="review-rating">
            <view class="stars">
              <text wx:for="{{5}}" wx:for-item="i" wx:key="i" class="star {{i < item.rating ? 'active' : ''}}">★</text>
            </view>
            <text class="rating-text {{item.ratingClass}}">{{item.ratingText}}</text>
          </view>

          <view class="review-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tagItem" wx:key="*this">{{tagItem}}</text>
          </view>

          <view class="review-arrow">›</view>
        </view>
      </block>

      <view class="loading-more" wx:if="{{sentLoading}}">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view class="no-more" wx:if="{{sentNoMore && sentReviews.length > 0}}">
        <text>没有更多评价了</text>
      </view>
    </view>
    <view style="height: 60rpx"/>
  </scroll-view>

  <!-- Tab 2: 收到的评价 -->
  <scroll-view scroll-y class="reviews-scroll" hidden="{{activeTab !== 'received'}}" refresher-enabled bindrefresherrefresh="refreshReceived" refresher-triggered="{{receivedRefreshing}}" bindscrolltolower="loadMoreReceived">

    <!-- 空状态 -->
    <view wx:if="{{receivedReviews.length === 0 && !receivedLoading}}" class="empty-state">
      <view class="empty-icon">💌</view>
      <view class="empty-title">还没收到评价</view>
      <view class="empty-desc">完成分享后等待对方评价吧</view>
    </view>

    <!-- 评价列表 -->
    <view class="reviews-list" wx:else>
      <block wx:for="{{receivedReviews}}" wx:key="_id">
        <view class="received-card" bindtap="goToOrderDetail" data-orderid="{{item.orderId}}">
          <!-- 头部：谁评了我 -->
          <view class="reviewer-header">
            <image class="reviewer-avatar" src="{{item.reviewerAvatar}}" mode="aspectFill" wx:if="{{item.reviewerAvatar}}"/>
            <view class="reviewer-avatar-placeholder" wx:else>👤</view>
            <view class="reviewer-info">
              <view class="reviewer-name-row">
                <text class="reviewer-name">{{item.reviewerName}}</text>
                <text class="reviewer-action">评价了你</text>
              </view>
              <text class="reviewer-time">{{item.createTimeText}}</text>
            </view>
          </view>

          <!-- 评分 -->
          <view class="review-rating">
            <view class="stars">
              <text wx:for="{{5}}" wx:for-item="i" wx:key="i" class="star {{i < item.rating ? 'active' : ''}}">★</text>
            </view>
            <text class="rating-text {{item.ratingClass}}">{{item.ratingText}}</text>
          </view>

          <!-- 评价内容引用块 -->
          <view class="review-quote" wx:if="{{item.content}}">
            <text>{{item.content}}</text>
          </view>

          <!-- 标签 -->
          <view class="review-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tagItem" wx:key="*this">{{tagItem}}</text>
          </view>

          <!-- 底部产品信息（小尺寸） -->
          <view class="review-product-mini" wx:if="{{item.productName}}">
            <image class="product-img-mini" src="{{item.coverUrl}}" mode="aspectFill" lazy-load="{{true}}" wx:if="{{item.coverUrl}}"/>
            <text class="product-name-mini">分享特产: {{item.productName}}</text>
          </view>
        </view>
      </block>

      <view class="loading-more" wx:if="{{receivedLoading}}">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view class="no-more" wx:if="{{receivedNoMore && receivedReviews.length > 0}}">
        <text>没有更多评价了</text>
      </view>
    </view>
    <view style="height: 60rpx"/>
  </scroll-view>
</view>
