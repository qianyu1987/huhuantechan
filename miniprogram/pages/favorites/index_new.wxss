/* pages/favorites/index_new.wxss - 我的收藏（全新设计） */

/* 基础样式 */
.favorites-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0F0F0F 0%, #1A1A1A 100%);
  position: relative;
}

/* 安全区 */
.safe-top {
  height: env(safe-area-inset-top);
  background: transparent;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
  background: transparent;
}

.safe-bottom-placeholder {
  height: 120rpx;
}

/* 头部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: rgba(20, 20, 22, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #0A84FF;
  font-weight: 300;
}

.back-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.header-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

.header-right {
  display: flex;
  align-items: center;
}

.header-action {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.header-action:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.refresh-icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* 筛选区域 */
.filter-section {
  padding: 20rpx 32rpx;
  background: rgba(25, 25, 27, 0.9);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.filter-tag text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.filter-tag-active {
  background: rgba(10, 132, 255, 0.2);
  border-color: rgba(10, 132, 255, 0.4);
}

.filter-tag-active text {
  color: #0A84FF;
}

.filter-tag:active {
  transform: scale(0.95);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.spinner-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0A84FF;
  animation: bounce 1.4s infinite ease-in-out both;
}

.spinner-dot:nth-child(1) { animation-delay: -0.32s; }
.spinner-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-illustration {
  position: relative;
  margin-bottom: 48rpx;
}

.empty-emoji {
  font-size: 120rpx;
  display: block;
}

.empty-heartbeat {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 59, 48, 0.1);
  animation: heartbeat 2s infinite ease-in-out;
}

@keyframes heartbeat {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -50%) scale(1.1); }
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.empty-actions {
  display: flex;
  gap: 24rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: rgba(10, 132, 255, 0.2);
  border: 1rpx solid rgba(10, 132, 255, 0.4);
  border-radius: 100rpx;
  transition: all 0.2s ease;
}

.empty-btn text {
  font-size: 28rpx;
  color: #0A84FF;
  font-weight: 600;
}

.empty-btn:active {
  background: rgba(10, 132, 255, 0.3);
  transform: scale(0.95);
}

.empty-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.empty-btn.secondary text {
  color: rgba(255, 255, 255, 0.8);
}

/* 内容滚动区域 */
.content-scroll {
  height: calc(100vh - 240rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
}

/* 统计卡片 */
.stats-card {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background: rgba(30, 30, 32, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0A84FF;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 收藏网格 */
.favorites-grid {
  padding: 0 32rpx 32rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

/* 收藏卡片 */
.favorite-card {
  background: rgba(40, 40, 42, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  transition: all 0.3s ease;
  position: relative;
}

.favorite-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 卡片顶部 */
.card-top {
  position: relative;
  height: 320rpx;
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 徽章区域 */
.card-badges {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.badge {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-badge {
  background: rgba(255, 59, 48, 0.2);
  border: 1rpx solid rgba(255, 59, 48, 0.4);
  color: #FF3B30;
}

.daigou-badge {
  background: rgba(255, 149, 0, 0.2);
  border: 1rpx solid rgba(255, 149, 0, 0.4);
  color: #FF9500;
}

.mystery-badge {
  background: rgba(175, 82, 222, 0.2);
  border: 1rpx solid rgba(175, 82, 222, 0.4);
  color: #AF52DE;
}

/* 移除按钮 */
.remove-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.remove-btn:active {
  background: rgba(255, 59, 48, 0.8);
  transform: scale(0.9);
}

.remove-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* 卡片内容 */
.card-content {
  padding: 24rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
  opacity: 0.7;
}

.meta-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.value-range {
  padding: 8rpx 20rpx;
  background: rgba(10, 132, 255, 0.1);
  border-radius: 100rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.2);
}

.value-text {
  font-size: 22rpx;
  color: #0A84FF;
  font-weight: 600;
}

.collect-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-icon {
  font-size: 20rpx;
  opacity: 0.6;
}

.time-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 卡片操作 */
.card-actions {
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.05);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.action-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.06);
}

/* 底部提示 */
.bottom-tips {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(20, 20, 22, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  z-index: 90;
}

.bottom-actions {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.bottom-btn:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.95);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

/* 管理面板 */
.manage-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.manage-panel-show {
  opacity: 1;
  pointer-events: auto;
}

.panel-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.panel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(30, 30, 32, 0.95);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.manage-panel-show .panel-content {
  transform: translateY(0);
}

.panel-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.panel-close:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.9);
}

.panel-close text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.panel-options {
  padding: 20rpx 0;
}

.panel-option {
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.2s ease;
  position: relative;
}

.panel-option:active {
  background: rgba(255, 255, 255, 0.05);
}

.option-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.option-check {
  font-size: 28rpx;
  color: #0A84FF;
  font-weight: 700;
}

.option-count {
  padding: 6rpx 16rpx;
  background: rgba(255, 59, 48, 0.2);
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #FF3B30;
  font-weight: 600;
}

/* 下拉刷新样式 */
.refresher {
  background: transparent !important;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .favorites-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .favorite-card {
    max-width: 400rpx;
    margin: 0 auto;
  }
}

/* 暗色模式适配 */
@media (prefers-color-scheme: dark) {
  .favorites-page {
    background: linear-gradient(135deg, #000000 0%, #0A0A0A 100%);
  }
  
  .header,
  .filter-section,
  .stats-card,
  .favorite-card,
  .bottom-bar,
  .panel-content {
    background: rgba(15, 15, 17, 0.95);
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.favorite-card {
  animation: fadeIn 0.4s ease forwards;
  animation-delay: calc(var(--item-index, 0) * 0.05s);
  opacity: 0;
}

/* 触摸反馈 */
.touch-feedback {
  transition: transform 0.1s ease;
}

.touch-feedback:active {
  transform: scale(0.98);
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}