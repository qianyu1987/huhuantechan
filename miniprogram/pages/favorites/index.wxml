<!-- pages/favorites/index.wxml - 我的收藏 -->
<view class="favorites-page">
  <view class="bg-gradient"></view>

  <!-- 毛玻璃导航栏 -->
  <view class="glass-nav">
    <view class="nav-back" bindtap="goBack">
      <text class="back-arrow">‹</text>
    </view>
    <text class="nav-title">我的收藏</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-dot"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <scroll-view wx:else scroll-y class="favorites-scroll"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}">

    <!-- 空状态 -->
    <view wx:if="{{favorites.length === 0}}" class="empty-state">
      <view class="empty-icon">❤️</view>
      <view class="empty-title">还没有收藏</view>
      <view class="empty-desc">发现喜欢的特产可以收藏哦</view>
    </view>

    <!-- 收藏列表 -->
    <view class="favorites-grid" wx:else>
      <block wx:for="{{favorites}}" wx:key="_id">
        <view class="product-card" bindtap="goToDetail" data-id="{{item._id}}">
          <view class="card-img-wrap">
            <image class="product-cover" src="{{item.coverUrl}}" mode="aspectFill" lazy-load="{{true}}"/>
            <view wx:if="{{item.status !== 'active'}}" class="status-mask">
              <text class="status-text">{{item.status === 'removed' ? '已下架' : item.status === 'swapped' ? '已分享' : '进行中'}}</text>
            </view>
          </view>
          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-meta">
              <text class="product-province" style="color: {{item.provinceColor}}">{{item.provinceName}}</text>
            </view>
          </view>
          <view class="remove-btn" catchtap="removeFavorite" data-id="{{item._id}}">
            <text>×</text>
          </view>
        </view>
      </block>
    </view>

    <view style="height: 80rpx"/>
  </scroll-view>
</view>
