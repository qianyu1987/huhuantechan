<!-- pages/deposit-apply/index.wxml -->
<view class="da-page">

  <!-- 顶部安全区 -->
  <view class="da-safe-top"/>

  <!-- ===== 已有待审核/通过申请时，直接显示状态卡片 ===== -->
  <block wx:if="{{!loadingExisting && existingApply && existingApply.status !== 'rejected' && !submitResult}}">
    <view class="da-header">
      <view class="da-back" bindtap="goToMine">
        <text class="da-back-icon">‹</text>
        <text>返回</text>
      </view>
      <text class="da-title">押金申请</text>
      <view style="width:80rpx"/>
    </view>

    <view class="status-card {{existingApply.status}}">
      <view class="sc-icon-wrap">
        <text class="sc-icon">{{existingApply.status === 'pending' ? '⏳' : '✅'}}</text>
      </view>
      <view class="sc-title">
        {{existingApply.status === 'pending' ? '申请审核中' : '审核已通过'}}
      </view>
      <view class="sc-desc">
        {{existingApply.status === 'pending' ? '我们将在1-3个工作日内完成审核，请耐心等待' : '恭喜！押金审核通过，代购权益已开通'}}
      </view>
      <view class="sc-divider"/>
      <view class="sc-info-row">
        <text class="sc-info-label">申请档位</text>
        <text class="sc-info-val">LV{{existingApply.targetLevel}} · ¥{{existingApply.depositAmount}}</text>
      </view>
      <view class="sc-info-row">
        <text class="sc-info-label">申请时间</text>
        <text class="sc-info-val">{{existingApply.createTimeText}}</text>
      </view>
      <view class="sc-info-row" wx:if="{{existingApply.status === 'approved'}}">
        <text class="sc-info-label">审核时间</text>
        <text class="sc-info-val">{{existingApply.handleTimeText || '-'}}</text>
      </view>
      <view class="sc-divider" wx:if="{{existingApply.status === 'pending'}}"/>
      <view class="sc-cs-bar" wx:if="{{existingApply.status === 'pending'}}">
        <text class="sc-cs-tip">💬 转账后记得联系客服确认</text>
        <view class="sc-cs-btns">
          <view class="sc-cs-btn sc-wechat" bindtap="copyWechat">
            <text class="sc-cs-btn-icon">💬</text>
            <text>复制微信号</text>
          </view>
          <view class="sc-cs-btn sc-phone" bindtap="callCs">
            <text class="sc-cs-btn-icon">📞</text>
            <text>拨打电话</text>
          </view>
        </view>
      </view>
    </view>

    <view class="da-bottom-btn-wrap">
      <view class="da-btn-ghost" bindtap="goToMine">返回我的</view>
    </view>
  </block>

  <!-- ===== 提交成功结果页 ===== -->
  <block wx:elif="{{submitResult === 'success'}}">
    <view class="da-header">
      <view style="width:80rpx"/>
      <text class="da-title">申请已提交</text>
      <view style="width:80rpx"/>
    </view>
    <view class="result-success-card">
      <view class="rsc-anim">
        <text class="rsc-icon">🎉</text>
      </view>
      <view class="rsc-title">申请已提交！</view>
      <view class="rsc-desc">管理员将在1-3个工作日内审核\n审核结果将通过消息通知您</view>
      <view class="rsc-divider"/>
      <!-- 转账引导 -->
      <view class="transfer-guide">
        <view class="tg-title">📢 重要提示：请完成线下转账</view>
        <view class="tg-step">
          <view class="tgs-num">1</view>
          <view class="tgs-text">添加客服微信，备注"押金申请+姓名"</view>
        </view>
        <view class="tg-step">
          <view class="tgs-num">2</view>
          <view class="tgs-text">向客服微信转账 <text class="tgs-amount">¥{{selectedTier.amount}}</text></view>
        </view>
        <view class="tg-step">
          <view class="tgs-num">3</view>
          <view class="tgs-text">转账后发截图给客服确认，等待审核通过</view>
        </view>
        <view class="tg-cs-bar">
          <view class="tg-cs-item" bindtap="copyWechat">
            <text class="tg-cs-icon">💬</text>
            <view>
              <text class="tg-cs-label">客服微信</text>
              <text class="tg-cs-val">{{wechatCs}}</text>
            </view>
            <text class="tg-cs-copy">复制</text>
          </view>
          <view class="tg-cs-item" bindtap="callCs">
            <text class="tg-cs-icon">📞</text>
            <view>
              <text class="tg-cs-label">客服电话</text>
              <text class="tg-cs-val">{{phoneCs}}</text>
            </view>
            <text class="tg-cs-call">拨打</text>
          </view>
        </view>
      </view>
    </view>
    <view class="da-bottom-btn-wrap">
      <view class="da-btn-primary" bindtap="goToMine">返回我的</view>
    </view>
  </block>

  <!-- ===== 主流程（步骤1/2/3）===== -->
  <block wx:elif="{{!submitResult}}">
    <!-- 页头 -->
    <view class="da-header">
      <view class="da-back" bindtap="goBack">
        <text class="da-back-icon">‹</text>
        <text>{{currentStep > 1 ? '上一步' : '返回'}}</text>
      </view>
      <text class="da-title">代购押金申请</text>
      <view style="width:80rpx"/>
    </view>

    <!-- 步骤条 -->
    <view class="step-bar">
      <block wx:for="{{steps}}" wx:key="id">
        <view class="step-item {{item.id <= currentStep ? 'step-active' : ''}} {{item.id < currentStep ? 'step-done' : ''}}">
          <view class="step-dot">
            <text wx:if="{{item.id < currentStep}}">✓</text>
            <text wx:else>{{item.id}}</text>
          </view>
          <text class="step-label">{{item.label}}</text>
        </view>
        <view class="step-line {{item.id < currentStep ? 'step-line-done' : ''}}" wx:if="{{item.id < steps.length}}"/>
      </block>
    </view>

    <!-- ======= 步骤1：选择档位 ======= -->
    <scroll-view scroll-y class="da-body" wx:if="{{currentStep === 1}}">
      <view class="da-section-title">选择押金档位</view>
      <view class="da-section-sub">押金越高，等级越高，费率越低，每日限额越大</view>

      <!-- 档位卡片列表 -->
      <block wx:for="{{tiers}}" wx:key="level">
        <view
          class="tier-card {{selectedTierIndex === index ? 'tier-selected' : ''}}"
          style="{{selectedTierIndex === index ? 'border-color:' + item.color : ''}}"
          bindtap="selectTier"
          data-index="{{index}}"
        >
          <!-- 选中指示器 -->
          <view class="tier-check" style="{{selectedTierIndex === index ? 'background:' + item.color : ''}}">
            <text wx:if="{{selectedTierIndex === index}}">✓</text>
          </view>
          <!-- 档位信息 -->
          <view class="tier-left">
            <view class="tier-icon-wrap" style="background:{{item.colorLight}}">
              <text class="tier-icon">{{item.icon}}</text>
            </view>
            <view class="tier-info">
              <text class="tier-name" style="{{selectedTierIndex === index ? 'color:' + item.color : ''}}">{{item.name}}</text>
              <text class="tier-desc">{{item.desc}}</text>
            </view>
          </view>
          <!-- 押金金额 -->
          <view class="tier-right">
            <view class="tier-amount-wrap" style="background:{{item.colorLight}}">
              <text class="tier-currency">¥</text>
              <text class="tier-amount" style="color:{{item.color}}">{{item.amount}}</text>
            </view>
            <view class="tier-badges">
              <view class="tier-badge" style="background:{{item.colorLight}};color:{{item.color}}">费率{{item.feeRate}}</view>
              <view class="tier-badge tier-badge-gray">限{{item.dailyLimit}}件/日</view>
            </view>
          </view>
        </view>
      </block>

      <!-- 说明区 -->
      <view class="notice-card">
        <view class="nc-title">💡 押金说明</view>
        <view class="nc-item">• 押金是代购履约保证金，正常经营全额保留</view>
        <view class="nc-item">• 纠纷败诉、严重违规才会扣除</view>
        <view class="nc-item">• 可随时申请退出代购，剩余余额退还</view>
        <view class="nc-item bindtap" bindtap="showNotice">› 查看完整申请须知</view>
      </view>

      <view style="height:200rpx"/>
    </scroll-view>

    <!-- 步骤1底部按钮 -->
    <view class="da-footer" wx:if="{{currentStep === 1}}">
      <view class="da-btn-primary {{selectedTierIndex < 0 ? 'da-btn-disabled' : ''}}" bindtap="goStep2">
        <text>下一步：填写申请信息</text>
        <text class="da-btn-arrow">›</text>
      </view>
    </view>

    <!-- ======= 步骤2：填写信息 ======= -->
    <scroll-view scroll-y class="da-body" wx:if="{{currentStep === 2}}">
      <!-- 已选档位摘要 -->
      <view class="selected-tier-bar" style="border-color:{{selectedTier.color}}">
        <text class="stb-icon">{{selectedTier.icon}}</text>
        <text class="stb-name">{{selectedTier.name}}</text>
        <text class="stb-amount" style="color:{{selectedTier.color}}">¥{{selectedTier.amount}}</text>
        <view class="stb-change" bindtap="goBack">修改</view>
      </view>

      <!-- 客服联系引导（最醒目位置） -->
      <view class="cs-guide-card">
        <view class="cgc-title">📱 第一步：添加客服微信</view>
        <view class="cgc-desc">请先添加客服微信，转账完成后需要发截图确认</view>
        <view class="cgc-cs-bar">
          <view class="cgc-cs-item" bindtap="copyWechat">
            <text class="cgc-cs-icon">💬</text>
            <view class="cgc-cs-info">
              <text class="cgc-cs-label">客服微信</text>
              <text class="cgc-cs-val">{{wechatCs}}</text>
            </view>
            <view class="cgc-copy-btn">复制</view>
          </view>
          <view class="cgc-cs-divider"/>
          <view class="cgc-cs-item" bindtap="callCs">
            <text class="cgc-cs-icon">📞</text>
            <view class="cgc-cs-info">
              <text class="cgc-cs-label">客服电话</text>
              <text class="cgc-cs-val">{{phoneCs}}</text>
            </view>
            <view class="cgc-call-btn">拨打</view>
          </view>
        </view>
      </view>

      <!-- 申请表单 -->
      <view class="da-section-title">填写申请信息</view>

      <view class="form-card">
        <!-- 真实姓名 -->
        <view class="form-field">
          <view class="ff-label-row">
            <text class="ff-label">真实姓名</text>
            <text class="ff-required">*</text>
          </view>
          <input
            class="ff-input {{formErrors.realName ? 'ff-input-error' : ''}}"
            placeholder="请填写真实姓名"
            placeholder-class="ff-placeholder"
            value="{{form.realName}}"
            bindinput="onInput"
            data-field="realName"
            maxlength="20"
          />
          <text class="ff-error" wx:if="{{formErrors.realName}}">{{formErrors.realName}}</text>
        </view>

        <view class="form-divider"/>

        <!-- 手机号 -->
        <view class="form-field">
          <view class="ff-label-row">
            <text class="ff-label">手机号</text>
            <text class="ff-required">*</text>
          </view>
          <input
            class="ff-input {{formErrors.phone ? 'ff-input-error' : ''}}"
            placeholder="请填写本人手机号"
            placeholder-class="ff-placeholder"
            value="{{form.phone}}"
            bindinput="onInput"
            data-field="phone"
            type="number"
            maxlength="11"
          />
          <text class="ff-error" wx:if="{{formErrors.phone}}">{{formErrors.phone}}</text>
        </view>

        <view class="form-divider"/>

        <!-- 微信号 -->
        <view class="form-field">
          <view class="ff-label-row">
            <text class="ff-label">微信号</text>
            <text class="ff-required">*</text>
          </view>
          <input
            class="ff-input {{formErrors.wechatId ? 'ff-input-error' : ''}}"
            placeholder="请填写您的微信号"
            placeholder-class="ff-placeholder"
            value="{{form.wechatId}}"
            bindinput="onInput"
            data-field="wechatId"
            maxlength="30"
          />
          <text class="ff-error" wx:if="{{formErrors.wechatId}}">{{formErrors.wechatId}}</text>
          <text class="ff-tip">填写后管理员将通过此微信联系您确认转账</text>
        </view>

        <view class="form-divider"/>

        <!-- 备注 -->
        <view class="form-field">
          <view class="ff-label-row">
            <text class="ff-label">备注（选填）</text>
          </view>
          <textarea
            class="ff-textarea"
            placeholder="可填写经营品类、所在城市等信息"
            placeholder-class="ff-placeholder"
            value="{{form.remark}}"
            bindinput="onInput"
            data-field="remark"
            maxlength="100"
          />
        </view>
      </view>

      <!-- 上传转账截图（选填，鼓励上传加速审核） -->
      <view class="da-section-title" style="margin-top:40rpx">上传转账截图（可选）</view>
      <view class="da-section-sub">上传截图后审核更快，也可以申请后再联系客服上传</view>

      <view class="upload-area" bindtap="{{!transferProof ? 'chooseTransferProof' : ''}}">
        <block wx:if="{{transferProof}}">
          <image class="upload-preview" src="{{transferProofUrl}}" mode="aspectFill" bindtap="previewProof"/>
          <view class="upload-remove" catchtap="removeProof">×</view>
          <view class="upload-replace" catchtap="chooseTransferProof">重新上传</view>
        </block>
        <block wx:elif="{{uploadingProof}}">
          <view class="upload-loading">
            <view class="upload-spin"/>
            <text class="upload-loading-text">上传中...</text>
          </view>
        </block>
        <block wx:else>
          <text class="upload-plus">+</text>
          <text class="upload-hint">点击上传转账截图</text>
        </block>
      </view>

      <!-- 协议勾选 -->
      <view class="agree-row" bindtap="toggleAgreed">
        <view class="agree-checkbox {{agreed ? 'agree-checked' : ''}} {{formErrors.agreed ? 'agree-error' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <view class="agree-text">
          <text>我已阅读并同意</text>
          <text class="agree-link" bindtap="showNotice" catchtap="showNotice">《押金申请须知》</text>
          <text>，了解押金规则</text>
        </view>
      </view>
      <text class="ff-error" style="padding:0 32rpx" wx:if="{{formErrors.agreed}}">{{formErrors.agreed}}</text>

      <view style="height:200rpx"/>
    </scroll-view>

    <!-- 步骤2底部按钮 -->
    <view class="da-footer" wx:if="{{currentStep === 2}}">
      <view class="da-btn-primary" bindtap="goStep3">
        <text>下一步：确认提交</text>
        <text class="da-btn-arrow">›</text>
      </view>
    </view>

    <!-- ======= 步骤3：确认提交 ======= -->
    <scroll-view scroll-y class="da-body" wx:if="{{currentStep === 3}}">
      <!-- 确认卡片 -->
      <view class="confirm-card">
        <view class="cc-title">📋 请确认申请信息</view>

        <view class="cc-row">
          <text class="cc-label">申请档位</text>
          <view class="cc-tier-tag" style="background:{{selectedTier.colorLight}};color:{{selectedTier.color}}">
            {{selectedTier.icon}} {{selectedTier.name}}
          </view>
        </view>
        <view class="cc-divider"/>
        <view class="cc-row">
          <text class="cc-label">押金金额</text>
          <text class="cc-val cc-amount">¥{{selectedTier.amount}}</text>
        </view>
        <view class="cc-divider"/>
        <view class="cc-row">
          <text class="cc-label">真实姓名</text>
          <text class="cc-val">{{form.realName}}</text>
        </view>
        <view class="cc-divider"/>
        <view class="cc-row">
          <text class="cc-label">手机号</text>
          <text class="cc-val">{{form.phone}}</text>
        </view>
        <view class="cc-divider"/>
        <view class="cc-row">
          <text class="cc-label">微信号</text>
          <text class="cc-val">{{form.wechatId}}</text>
        </view>
        <view class="cc-divider" wx:if="{{form.remark}}"/>
        <view class="cc-row" wx:if="{{form.remark}}">
          <text class="cc-label">备注</text>
          <text class="cc-val cc-remark">{{form.remark}}</text>
        </view>
        <view class="cc-divider" wx:if="{{transferProofUrl}}"/>
        <view class="cc-row" wx:if="{{transferProofUrl}}">
          <text class="cc-label">转账截图</text>
          <image class="cc-proof-img" src="{{transferProofUrl}}" mode="aspectFill" bindtap="previewProof"/>
        </view>
      </view>

      <!-- 转账流程提示 -->
      <view class="flow-tips-card">
        <view class="ftc-title">🗂 完成押金流程</view>
        <view class="ftc-step">
          <view class="ftc-step-num done">1</view>
          <view class="ftc-step-content">
            <text class="ftc-step-title">提交申请 ← 当前步骤</text>
            <text class="ftc-step-desc">确认信息无误后点击提交</text>
          </view>
        </view>
        <view class="ftc-connector"/>
        <view class="ftc-step">
          <view class="ftc-step-num">2</view>
          <view class="ftc-step-content">
            <text class="ftc-step-title">添加客服微信 {{wechatCs}}</text>
            <text class="ftc-step-desc">备注"押金申请+{{form.realName}}"</text>
          </view>
        </view>
        <view class="ftc-connector"/>
        <view class="ftc-step">
          <view class="ftc-step-num">3</view>
          <view class="ftc-step-content">
            <text class="ftc-step-title">向客服转账 ¥{{selectedTier.amount}}</text>
            <text class="ftc-step-desc">转账后发截图给客服确认</text>
          </view>
        </view>
        <view class="ftc-connector"/>
        <view class="ftc-step">
          <view class="ftc-step-num">4</view>
          <view class="ftc-step-content">
            <text class="ftc-step-title">等待审核（1-3工作日）</text>
            <text class="ftc-step-desc">审核通过后代购权益自动开通</text>
          </view>
        </view>
      </view>

      <!-- 客服快捷联系 -->
      <view class="cs-quick-bar">
        <view class="cqb-item" bindtap="copyWechat">
          <text class="cqb-icon">💬</text>
          <view>
            <text class="cqb-label">客服微信</text>
            <text class="cqb-val">{{wechatCs}}</text>
          </view>
          <view class="cqb-btn">复制</view>
        </view>
        <view class="cqb-item" bindtap="callCs">
          <text class="cqb-icon">📞</text>
          <view>
            <text class="cqb-label">客服电话</text>
            <text class="cqb-val">{{phoneCs}}</text>
          </view>
          <view class="cqb-btn cqb-call">拨打</view>
        </view>
      </view>

      <view style="height:200rpx"/>
    </scroll-view>

    <!-- 步骤3底部按钮 -->
    <view class="da-footer" wx:if="{{currentStep === 3}}">
      <view class="da-btn-primary {{submitting ? 'da-btn-loading' : ''}}" bindtap="submitApply">
        <view wx:if="{{submitting}}" class="da-btn-spin"/>
        <text>{{submitting ? '提交中...' : '确认提交申请'}}</text>
      </view>
    </view>
  </block>

  <!-- 已被拒绝，展示拒绝原因+重新申请 -->
  <block wx:if="{{!loadingExisting && existingApply && existingApply.status === 'rejected' && !submitResult}}">
    <view class="da-header">
      <view class="da-back" bindtap="goToMine">
        <text class="da-back-icon">‹</text>
        <text>返回</text>
      </view>
      <text class="da-title">押金申请</text>
      <view style="width:80rpx"/>
    </view>
    <view class="status-card rejected">
      <view class="sc-icon-wrap">
        <text class="sc-icon">❌</text>
      </view>
      <view class="sc-title">申请未通过</view>
      <view class="sc-desc">您的押金申请未通过审核，可重新提交或联系客服</view>
      <view class="sc-divider"/>
      <view class="sc-info-row">
        <text class="sc-info-label">拒绝原因</text>
        <text class="sc-info-val sc-reject-reason">{{existingApply.rejectReason || '审核未通过'}}</text>
      </view>
      <view class="sc-info-row">
        <text class="sc-info-label">申请档位</text>
        <text class="sc-info-val">LV{{existingApply.targetLevel || '-'}} · ¥{{existingApply.depositAmount}}</text>
      </view>
      <view class="sc-divider"/>
      <view class="sc-cs-bar">
        <text class="sc-cs-tip">💬 有疑问？联系客服了解详情</text>
        <view class="sc-cs-btns">
          <view class="sc-cs-btn sc-wechat" bindtap="copyWechat">
            <text class="sc-cs-btn-icon">💬</text>
            <text>复制微信号</text>
          </view>
          <view class="sc-cs-btn sc-phone" bindtap="callCs">
            <text class="sc-cs-btn-icon">📞</text>
            <text>拨打电话</text>
          </view>
        </view>
      </view>
    </view>
    <view class="da-bottom-btn-wrap" style="gap:20rpx">
      <view class="da-btn-ghost" bindtap="goToMine">返回我的</view>
      <view class="da-btn-primary" bindtap="reApply">重新申请</view>
    </view>
  </block>

  <!-- 加载中 -->
  <block wx:if="{{loadingExisting}}">
    <view class="da-loading-wrap">
      <view class="da-loading-spin"/>
      <text class="da-loading-text">加载中...</text>
    </view>
  </block>

</view>
