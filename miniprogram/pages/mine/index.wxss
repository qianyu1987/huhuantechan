/* pages/mine/index.wxss - iOS 风格个人中心 */

/* ===== 基础变量 ===== */
page {
  --bg-primary: #000000;
  --bg-secondary: #1C1C1E;
  --bg-tertiary: #2C2C2E;
  --separator: rgba(255, 255, 255, 0.1);
  --text-primary: #FFFFFF;
  --text-secondary: rgba(255, 255, 255, 0.6);
  --text-tertiary: rgba(255, 255, 255, 0.3);
  --accent-blue: #0A84FF;
  --accent-green: #30D158;
  --accent-orange: #FF9F0A;
  --accent-red: #FF453A;
  --accent-purple: #BF5AF2;
  --accent-teal: #5AC8FA;
  --accent-yellow: #FFD60A;
  --radius-card: 12px;
  --radius-sm: 8px;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
}

/* ===== 页面基础 ===== */
.mine-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面内容区 */
.mine-content {
  padding: 0 32rpx;
}

/* ===== 个人资料卡片 ===== */
.profile-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-card);
  margin: 16rpx 0;
  overflow: hidden;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  flex-shrink: 0;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.admin-tag {
  font-size: 22rpx;
  color: var(--accent-orange);
  background: rgba(255, 159, 10, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.profile-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: nowrap;
  margin-top: 12rpx;
}

.location-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.location-icon {
  font-size: 24rpx;
}

.level-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.level-tag.daigou {
  color: var(--accent-orange);
  background: rgba(255, 159, 10, 0.15);
}

.level-tag.swap {
  color: var(--accent-blue);
  background: rgba(10, 132, 255, 0.15);
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: none;
  border: none;
  padding: 0;
  height: auto;
  min-height: auto;
}

.profile-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: var(--bg-tertiary);
  border-radius: 50%;
  flex-shrink: 0;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--separator);
  margin: 0 32rpx;
}

/* ===== 统计数据 ===== */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stat-value.credit {
  color: var(--accent-green);
}

.stat-value.points {
  color: var(--accent-orange);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 代购押金 ===== */
.deposit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--separator);
}

.deposit-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.deposit-icon {
  font-size: 40rpx;
}

.deposit-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
}

.deposit-sub {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.deposit-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.deposit-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.deposit-amount.ok {
  color: var(--accent-green);
}

.deposit-amount.low {
  color: var(--accent-red);
}

.deposit-total {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin-left: 8rpx;
}

/* ===== 管理员通知 ===== */
.admin-notify {
  background: var(--bg-secondary);
  border-radius: var(--radius-card);
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
}

.notify-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.notify-icon {
  font-size: 36rpx;
}

.notify-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.notify-count {
  font-size: 24rpx;
  color: var(--accent-red);
  background: rgba(255, 69, 58, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.notify-items {
  display: flex;
  justify-content: space-around;
}

.notify-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.notify-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.notify-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 区块卡片 ===== */
.section {
  background: var(--bg-secondary);
  border-radius: var(--radius-card);
  margin-bottom: 16rpx;
  overflow: hidden;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  padding: 24rpx 32rpx 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.section-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.badge-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.expand-icon {
  font-size: 24rpx;
}

/* ===== 菜单列表 ===== */
.menu-list {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.highlight {
  background: rgba(10, 132, 255, 0.08);
  margin: 0 -32rpx;
  padding: 24rpx 32rpx;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-gift { background: rgba(255, 214, 10, 0.15); }
.icon-heart { background: rgba(255, 69, 58, 0.15); }
.icon-swap { background: rgba(10, 132, 255, 0.15); }
.icon-star { background: rgba(255, 159, 10, 0.15); }
.icon-box { background: rgba(191, 90, 242, 0.15); }
.icon-verify { background: rgba(48, 209, 88, 0.15); }
.icon-wallet { background: rgba(10, 132, 255, 0.15); }

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.menu-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 工具网格 ===== */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 16rpx 32rpx 32rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

.tool-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.icon-teal { background: rgba(90, 200, 250, 0.15); }
.icon-purple { background: rgba(191, 90, 242, 0.15); }
.icon-blue { background: rgba(10, 132, 255, 0.15); }
.icon-gray { background: rgba(142, 142, 147, 0.15); }
.icon-orange { background: rgba(255, 149, 0, 0.15); }

.tool-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 省份徽章 ===== */
.badge-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  padding: 16rpx 32rpx 32rpx;
}

.badge-grid.collapsed {
  max-height: 200rpx;
  overflow: hidden;
}

.badge-item {
  display: flex;
  justify-content: center;
}

.badge-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--separator);
}

.badge-item.collected .badge-circle {
  border-color: var(--accent-green);
}

.badge-item.uncollected .badge-circle {
  opacity: 0.4;
}

.badge-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.badge-hint {
  text-align: center;
  padding: 16rpx 32rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  border-top: 1rpx solid var(--separator);
}

/* ===== 底部安全区 ===== */
.bottom-safe {
  height: calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 客服面板 ===== */
.service-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
}

.service-panel.show {
  pointer-events: auto;
  opacity: 1;
}

.service-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.service-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-secondary);
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}

.service-panel.show .service-content {
  transform: translateY(0);
}

.service-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--separator);
}

.service-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.service-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
}

.service-messages {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 600rpx;
}

.message {
  margin-bottom: 24rpx;
}

.message.bot .message-text {
  display: inline-block;
  background: var(--bg-tertiary);
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  max-width: 80%;
}

.faq-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: var(--bg-tertiary);
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.faq-num {
  width: 40rpx;
  height: 40rpx;
  background: var(--accent-blue);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: white;
  flex-shrink: 0;
}

.faq-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.service-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  border-top: 1rpx solid var(--separator);
}

.quick-tag {
  font-size: 24rpx;
  color: var(--accent-blue);
  background: rgba(10, 132, 255, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.service-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--separator);
}

.service-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-tertiary);
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.service-send {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 16rpx 24rpx;
}

.service-send.active {
  color: var(--accent-blue);
}

/* ===== 引导弹窗 ===== */
.guide-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-modal.show {
  pointer-events: auto;
  opacity: 1;
}

.guide-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
}

.guide-content {
  position: relative;
  background: var(--bg-secondary);
  border-radius: var(--radius-card);
  padding: 48rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.guide-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.guide-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.guide-avatar {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  padding: 0;
  background: none;
  line-height: 1;
}

.guide-avatar::after {
  border: none;
}

.guide-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--bg-tertiary);
}

.guide-avatar-mask {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: var(--accent-blue);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.guide-avatar-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.guide-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-tertiary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 48rpx;
  box-sizing: border-box;
}

.guide-btns {
  display: flex;
  gap: 24rpx;
}

.guide-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.guide-btn.skip {
  color: var(--text-secondary);
  background: var(--bg-tertiary);
}

.guide-btn.save {
  color: var(--text-tertiary);
  background: var(--bg-tertiary);
}

.guide-btn.save.active {
  color: white;
  background: var(--accent-blue);
}
