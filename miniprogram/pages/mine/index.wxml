<!-- pages/mine/index.wxml - 个人中心 - iOS 风格 -->
<view class="mine-page">

  <!-- 用户信息 + 统计 合并卡片 -->
  <view class="profile-card">
    <!-- 用户信息 -->
    <view class="profile-header">
      <block wx:if="{{userInfo && userInfo.avatarUrl && userInfo.nickName}}">
        <image class="profile-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" binderror="onAvatarError"/>
        <view class="profile-info">
          <view class="profile-name-row">
            <text class="profile-name">{{userInfo.nickName || '特产达人'}}</text>
            <view class="admin-tag" wx:if="{{isAdmin}}" bindtap="goToAdmin">管理</view>
          </view>
          <view class="profile-meta">
            <view class="location-tag" bindtap="editProfile">
              <text class="location-icon">📍</text>
              <text>{{provinceName || '设置城市'}}</text>
            </view>
            <view class="level-tag daigou" wx:if="{{userInfo && userInfo.isDaigouVerified}}">
              <text>{{daigouLevelEmoji}} {{daigouLevelName}}</text>
            </view>
            <view class="level-tag swap">
              <text>{{swapLevelEmoji}} {{swapLevelName}}</text>
            </view>
          </view>
        </view>
      </block>
      <block wx:else>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="profile-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        </button>
        <view class="profile-info">
          <input class="nickname-input" type="nickname" placeholder="点击设置昵称" value="{{userInfo.nickName}}" bindinput="onNicknameInput" bindblur="saveUserProfile"/>
          <view class="profile-tip" wx:if="{{!userInfo.nickName}}">点击头像和昵称完成设置</view>
        </view>
      </block>
      <view class="edit-btn" bindtap="editProfile">✏️</view>
    </view>

    <!-- 分割线 -->
    <view class="divider"/>

    <!-- 统计数据 -->
    <view class="stats-row">
      <view class="stat-item" bindtap="goToCredit">
        <text class="stat-value credit {{creditClass}}">{{creditScore}}</text>
        <text class="stat-label">信用分</text>
      </view>
      <view class="stat-item" bindtap="goToPoints">
        <text class="stat-value points">{{points || 0}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-item" bindtap="goToMyProducts" wx:if="{{featureFlags.tab_publish !== false}}">
        <text class="stat-value">{{publishCount}}</text>
        <text class="stat-label">发布</text>
      </view>
      <view class="stat-item" bindtap="goToOrders" wx:if="{{featureFlags.feature_swap !== false}}">
        <text class="stat-value">{{swapCount}}</text>
        <text class="stat-label">互换</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{badgeCount}}</text>
        <text class="stat-label">集章</text>
      </view>
    </view>

    <!-- 代购押金（已认证显示） -->
    <view class="deposit-bar" wx:if="{{userInfo.isDaigouVerified}}" bindtap="goToDaigouDeposit">
      <view class="deposit-left">
        <text class="deposit-icon">💰</text>
        <view>
          <text class="deposit-title">代购押金余额</text>
          <text class="deposit-sub">{{daigouLevelName}} · 费率 {{daigouFeeRate}}%</text>
        </view>
      </view>
      <view class="deposit-right">
        <text class="deposit-amount {{userInfo.daigouStats.depositBalance > 0 ? 'ok' : 'low'}}">¥{{userInfo.daigouStats.depositBalance || 0}}</text>
        <text class="deposit-total">/¥{{userInfo.daigouStats.depositPaid || 0}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 管理员通知 -->
  <view class="admin-notify" wx:if="{{isAdmin}}" bindtap="goToAdmin">
    <view class="notify-header">
      <text class="notify-icon">🔔</text>
      <text class="notify-title">运营数据</text>
      <text class="notify-count" wx:if="{{adminNotifications.totalCount > 0}}">{{adminNotifications.totalCount}} 待处理</text>
    </view>
    <view class="notify-items">
      <view class="notify-item">
        <text class="notify-num">{{adminNotifications.newUsers}}</text>
        <text class="notify-label">新增用户</text>
      </view>
      <view class="notify-item">
        <text class="notify-num">{{adminNotifications.newProducts}}</text>
        <text class="notify-label">新增特产</text>
      </view>
      <view class="notify-item">
        <text class="notify-num">{{adminNotifications.pendingReview}}</text>
        <text class="notify-label">待审核</text>
      </view>
      <view class="notify-item">
        <text class="notify-num">{{adminNotifications.withdrawApply}}</text>
        <text class="notify-label">提现申请</text>
      </view>
    </view>
  </view>

  <!-- 页面内容 -->
  <view class="mine-content">

    <!-- 我的内容 -->
    <view class="section">
      <view class="section-title">我的内容</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToMyProducts">
          <view class="menu-icon icon-gift">🎁</view>
          <view class="menu-content">
            <text class="menu-title">我的特产</text>
            <text class="menu-sub">{{publishCount || 0}} 个已发布</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToFavorites">
          <view class="menu-icon icon-heart">❤️</view>
          <view class="menu-content">
            <text class="menu-title">我的收藏</text>
            <text class="menu-sub">收藏的特产</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToOrders" wx:if="{{featureFlags.feature_swap !== false}}">
          <view class="menu-icon icon-swap">🔄</view>
          <view class="menu-content">
            <text class="menu-title">互换记录</text>
            <text class="menu-sub">分享 {{swapCount || 0}} 次</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToReview" wx:if="{{featureFlags.feature_swap !== false}}">
          <view class="menu-icon icon-star">⭐</view>
          <view class="menu-content">
            <text class="menu-title">我的评价</text>
            <text class="menu-sub">收到的评价</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 代购服务 -->
    <view class="section" wx:if="{{userInfo.isDaigouVerified || featureFlags.feature_daigou !== false}}">
      <view class="section-title">代购服务</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToDaigouOrders">
          <view class="menu-icon icon-box">📦</view>
          <view class="menu-content">
            <text class="menu-title">代购订单</text>
            <text class="menu-sub">{{userInfo.isDaigouVerified ? '查看代购记录' : '申请成为代购'}}</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goDaigouVerify">
          <view class="menu-icon icon-verify">✅</view>
          <view class="menu-content">
            <text class="menu-title">代购认证</text>
            <text class="menu-sub">{{userInfo.isDaigouVerified ? '已认证 · ' + daigouLevelName : '申请代购资质'}}</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 我的资产 -->
    <view class="section">
      <view class="section-title">我的资产</view>
      <view class="menu-list">
        <view class="menu-item highlight" bindtap="goToWallet">
          <view class="menu-icon icon-wallet">💳</view>
          <view class="menu-content">
            <text class="menu-title">我的钱包</text>
            <text class="menu-sub">押金 · 余额 · 交易记录</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 省份集章 -->
    <view class="section">
      <view class="section-header" bindtap="toggleBadgeExpand">
        <text class="section-title">省份集章</text>
        <view class="section-right">
          <text class="badge-count">{{badgeCount}}/34</text>
          <text class="expand-icon">{{badgeExpanded ? '⬆️' : '⬇️'}}</text>
        </view>
      </view>
      <view class="badge-grid {{badgeExpanded ? 'expanded' : 'collapsed'}}">
        <block wx:for="{{provinces}}" wx:key="code">
          <view class="badge-item {{item.collected ? 'collected' : 'uncollected'}}" wx:if="{{badgeExpanded || item.collected}}">
            <view class="badge-circle" style="{{item.collected ? 'background:' + item.color + '22;border-color:' + item.color : ''}}">
              <text class="badge-name">{{item.name}}</text>
            </view>
          </view>
        </block>
      </view>
      <view class="badge-hint" wx:if="{{!badgeExpanded && badgeCount > 0}}" bindtap="toggleBadgeExpand">
        <text>已收集 {{badgeCount}} 个省份，点击展开全部</text>
      </view>
    </view>

    <!-- 常用工具 -->
    <view class="section">
      <view class="section-title">常用工具</view>
      <view class="tool-grid">
        <view class="tool-item" bindtap="goToAddress" wx:if="{{featureFlags.feature_swap !== false}}">
          <view class="tool-icon icon-teal">📍</view>
          <text class="tool-label">收货地址</text>
        </view>
        <view class="tool-item" bindtap="goToMystery" wx:if="{{featureFlags.feature_mystery !== false}}">
          <view class="tool-icon icon-purple">🎁</view>
          <text class="tool-label">神秘特产</text>
        </view>
        <view class="tool-item" bindtap="showService">
          <view class="tool-icon icon-blue">🤖</view>
          <text class="tool-label">智能客服</text>
        </view>
        <view class="tool-item" bindtap="goToSettings">
          <view class="tool-icon icon-gray">⚙️</view>
          <text class="tool-label">系统设置</text>
        </view>
        <view class="tool-item" bindtap="testSubscribeMessage">
          <view class="tool-icon icon-orange">🔔</view>
          <text class="tool-label">测试订阅</text>
        </view>
      </view>
    </view>

    <!-- 账号与安全 -->
    <view class="section">
      <view class="section-title">账号与安全</view>
      <view class="menu-list">
        <phone-verify 
          id="phoneVerify"
          phone="{{phoneNumber}}" 
          verified="{{phoneVerified}}" 
          bind:verified="onPhoneVerified"
        />
      </view>
    </view>

    <!-- 底部间距 -->
    <view class="bottom-safe"/>

  </view>

  <!-- 底部导航 -->
  <tab-bar active="mine" />

  <!-- 客服面板 -->
  <view class="service-panel {{showServicePanel ? 'show' : ''}}">
    <view class="service-mask" bindtap="hideService"/>
    <view class="service-content">
      <view class="service-header">
        <text class="service-title">智能客服</text>
        <view class="service-close" bindtap="hideService">✕</view>
      </view>
      <scroll-view scroll-y class="service-messages">
        <view class="message bot">
          <text class="message-text">👋 您好！我是特产互换小助手，请问有什么可以帮您？</text>
        </view>
        <view class="message bot" wx:for="{{serviceFaqs}}" wx:key="index">
          <view class="faq-item" bindtap="sendFaq" data-index="{{index}}">
            <text class="faq-num">{{index + 1}}</text>
            <text class="faq-text">{{item.q}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="service-quick">
        <text class="quick-tag" wx:for="{{serviceQuick}}" wx:key="index" bindtap="sendQuick" data-text="{{item}}">{{item}}</text>
      </view>
      <view class="service-input-bar">
        <input class="service-input" placeholder="输入问题..." value="{{serviceInput}}" bindinput="onServiceInput" confirm-type="send" bindconfirm="sendServiceMessage"/>
        <view class="service-send {{serviceInput ? 'active' : ''}}" bindtap="sendServiceMessage">发送</view>
      </view>
    </view>
  </view>

  <!-- 授权引导弹窗 -->
  <view class="guide-modal {{showProfileGuide ? 'show' : ''}}">
    <view class="guide-mask" bindtap="skipProfileGuide"/>
    <view class="guide-content">
      <view class="guide-title">完善个人信息</view>
      <view class="guide-subtitle">设置头像和昵称，让更多人认识你</view>
      <button class="guide-avatar" open-type="chooseAvatar" bindchooseavatar="onGuideAvatar">
        <image src="{{guideAvatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="guide-avatar-mask">📷</view>
      </button>
      <view class="guide-avatar-tip">{{guideAvatarUrl ? '✅ 头像已获取' : '点击获取微信头像'}}</view>
      <input class="guide-input" type="nickname" placeholder="点击自动填入微信昵称" value="{{guideNickName}}" bindinput="onGuideNickNameInput"/>
      <view class="guide-btns">
        <view class="guide-btn skip" bindtap="skipProfileGuide">稍后设置</view>
        <view class="guide-btn save {{guideAvatarUrl && guideNickName ? 'active' : ''}}" bindtap="saveGuideProfile">完成设置</view>
      </view>
    </view>
  </view>

</view>