<!-- pages/admin-article-list/index.wxml - 文章管理页面 -->
<view class="admin-page theme-{{pageTheme}}">
  <!-- 导航栏 -->
  <view class="glass-nav">
    <view class="nav-back" bindtap="goBack">
      <text>‹</text>
    </view>
    <text class="nav-title">文章管理</text>
    <view class="nav-action" bindtap="syncArticles">
      <text>同步</text>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-btn primary" bindtap="goToAdd">
      <text>+ 添加文章</text>
    </view>
  </view>

  <!-- 文章列表 -->
  <scroll-view scroll-y class="article-list">
    <view 
      class="article-item" 
      wx:for="{{articles}}" 
      wx:key="_id"
    >
      <image 
        class="article-cover" 
        src="{{item.coverUrl || '/images/default-cover.png'}}" 
        mode="aspectFill"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      />
      <view class="article-info">
        <text class="article-title" bindtap="goToDetail" data-id="{{item._id}}">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-time">{{item.publishTime}}</text>
          <text class="article-views">阅读 {{item.viewCount || 0}}</text>
        </view>
      </view>
      <view class="article-actions">
        <view class="action-icon edit" bindtap="goToEdit" data-id="{{item._id}}">✏️</view>
        <view class="action-icon delete" bindtap="deleteArticle" data-id="{{item._id}}" data-title="{{item.title}}">🗑️</view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && articles.length > 0}}">
      <text>没有更多了</text>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && articles.length === 0}}">
      <text class="empty-icon">📝</text>
      <text class="empty-title">暂无文章</text>
      <text class="empty-desc">点击"同步"添加示例文章</text>
    </view>
  </scroll-view>
</view>