/* pages/admin-article-list/index.wxss - 文章管理页面 */

.admin-page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 导航栏 */
.glass-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: var(--liquid-surface);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--color-divider);
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--color-primary);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.nav-action {
  padding: 8rpx 24rpx;
  background: var(--color-primary);
  border-radius: var(--radius-full);
}

.nav-action text {
  font-size: 26rpx;
  color: white;
  font-weight: 500;
}

/* 操作栏 */
.action-bar {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: var(--color-primary);
  color: white;
}

/* 文章列表 */
.article-list {
  height: calc(100vh - 180rpx - env(safe-area-inset-top));
  padding: 0 24rpx;
}

.article-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--liquid-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-divider);
  margin-bottom: 20rpx;
}

.article-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-tertiary);
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.article-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 操作图标 */
.article-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 32rpx;
}

.action-icon.edit {
  background: var(--glass-primary);
}

.action-icon.delete {
  background: var(--glass-pink);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}