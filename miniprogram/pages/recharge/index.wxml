<!-- pages/recharge/index.wxml - 钱包充值 -->
<view class="recharge-page theme-{{pageTheme}}">

  <!-- 顶部导航 -->
  <view class="page-header safe-top">
    <view class="header-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="header-title">钱包充值</text>
    <view class="header-right"/>
  </view>

  <!-- 当前余额卡片 -->
  <view class="balance-card">
    <view class="balance-bg-circle1"/>
    <view class="balance-bg-circle2"/>
    <text class="balance-label">当前余额</text>
    <text class="balance-amount">¥<text class="balance-num">{{walletBalance.toFixed ? walletBalance.toFixed(2) : walletBalance}}</text></text>
    <text class="balance-tip">余额可用于支付代购平台服务费</text>
  </view>

  <scroll-view scroll-y class="content-scroll" bindscrolltolower="onLoadMore">

    <!-- 充值金额选择 -->
    <view class="section-card">
      <view class="section-title-row">
        <text class="section-icon">💰</text>
        <text class="section-title">选择充值金额</text>
      </view>

      <!-- 预设金额 -->
      <view class="preset-grid">
        <view
          wx:for="{{presets}}"
          wx:key="index"
          class="preset-item {{selectedPreset === index ? 'selected' : ''}}"
          bindtap="onSelectPreset"
          data-index="{{index}}"
        >
          <text class="preset-amount">¥{{item}}</text>
        </view>
      </view>

      <!-- 自定义金额 -->
      <view class="custom-amount-row">
        <text class="custom-label">其他金额</text>
        <view class="custom-input-wrap {{selectedPreset === null && customAmount ? 'active' : ''}}">
          <text class="currency-symbol">¥</text>
          <input
            class="custom-input"
            type="digit"
            placeholder="输入充值金额（1~10000）"
            placeholder-class="input-placeholder"
            value="{{customAmount}}"
            bindinput="onCustomAmountInput"
          />
        </view>
      </view>

      <!-- 当前金额展示 -->
      <view class="amount-summary" wx:if="{{currentAmount > 0}}">
        <text class="amount-summary-text">充值金额：<text class="amount-highlight">¥{{currentAmount}}</text></text>
      </view>
    </view>

    <!-- 微信支付按钮 -->
    <view class="wechat-pay-section" wx:if="{{currentAmount > 0}}">
      <view class="wechat-pay-btn" bindtap="onWechatPay">
        <view class="wechat-pay-icon">
          <text class="wechat-pay-icon-text">微</text>
        </view>
        <view class="wechat-pay-info">
          <text class="wechat-pay-title">微信支付</text>
          <text class="wechat-pay-desc">秒充到账，无需等待</text>
        </view>
        <view class="wechat-pay-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 充值说明 -->
    <view class="section-card notice-card">
      <view class="section-title-row">
        <text class="section-icon">📋</text>
        <text class="section-title">充值说明</text>
      </view>
      <view class="notice-list">
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">支持微信支付，充值金额实时到账</text>
        </view>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">单次充值金额范围：¥1 ~ ¥10,000</text>
        </view>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">充值金额可用于支付代购平台服务费</text>
        </view>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">如有问题请联系客服微信：{{serviceWechat}}</text>
        </view>
      </view>
    </view>

    <!-- 充值记录 -->
    <view class="section-card" wx:if="{{applyList.length > 0}}">
      <view class="section-title-row">
        <text class="section-icon">📝</text>
        <text class="section-title">充值记录</text>
      </view>
      <view class="apply-list">
        <view wx:for="{{applyList}}" wx:key="id" class="apply-item">
          <view class="apply-left">
            <text class="apply-amount">¥{{item.amount}}</text>
            <text class="apply-time">{{item.createTime}}</text>
            <text class="apply-no">单号：{{item.orderNo || item.applyNo}}</text>
          </view>
          <view class="apply-right">
            <view class="apply-status status-{{item.status}}">
              <text class="apply-status-text">{{item.statusText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="load-more" wx:if="{{applyList.length < applyTotal}}" bindtap="onLoadMore">
        <text class="load-more-text">{{applyLoading ? '加载中...' : '加载更多'}}</text>
      </view>
    </view>

    <view style="height: calc(80rpx + env(safe-area-inset-bottom))"/>
  </scroll-view>

</view>

<!-- 微信支付结果弹窗 -->
<view class="wechat-pay-modal" wx:if="{{showWechatPayModal}}">
  <view class="wechat-pay-modal-content" catchtap="noop">

    <!-- 滚动内容区 -->
    <scroll-view scroll-y class="wechat-pay-modal-scroll">

      <!-- 加载动画 -->
      <view class="wechat-pay-loading">
        <view class="wechat-pay-loading-icon">
          <text class="wechat-pay-loading-icon-text">💳</text>
        </view>
        <text class="wechat-pay-title">{{checkingPayment ? '支付处理中...' : '支付完成'}}</text>
        <text class="wechat-pay-subtitle">{{checkingPayment ? '请稍候，系统正在确认支付结果' : '充值已成功到账'}}</text>
      </view>

      <!-- 订单信息 -->
      <view class="wechat-pay-info-card">
        <view class="wechat-pay-info-row">
          <text class="wechat-pay-info-label">充值金额</text>
          <text class="wechat-pay-amount">¥{{currentAmount}}</text>
        </view>
        <view class="wechat-pay-info-row">
          <text class="wechat-pay-info-label">订单号</text>
          <text class="wechat-pay-info-value" style="font-size: 22rpx;">{{wechatPayOrderNo}}</text>
        </view>
        <view class="wechat-pay-info-row" wx:if="{{checkingPayment}}">
          <text class="wechat-pay-info-label">查询进度</text>
          <text class="wechat-pay-info-value">{{paymentCheckCount < 10 ? '已查询 ' + paymentCheckCount + '/10 次' : '查询超时'}}</text>
        </view>
      </view>

      <!-- 提示 -->
      <view class="screenshot-hint" wx:if="{{checkingPayment}}">
        <text class="screenshot-hint-icon">⏳</text>
        <text class="screenshot-hint-text">请耐心等待，系统正在确认支付结果</text>
      </view>

    </scroll-view>

    <!-- 底部操作区 -->
    <view class="wechat-pay-modal-footer">
      <view class="wechat-pay-modal-btn {{checkingPayment ? 'disabled' : ''}}" bindtap="closeWechatPayModal">
        <text class="wechat-pay-modal-btn-text">
          <view class="wechat-pay-spinner" wx:if="{{checkingPayment}}"></view>
          {{checkingPayment ? '等待确认中...' : '我知道了'}}
        </text>
      </view>
      <view class="wechat-pay-cancel-btn" bindtap="copyWechatPayOrderNo" wx:if="{{!checkingPayment}}">
        <text class="wechat-pay-cancel-text">复制订单号</text>
      </view>
    </view>

  </view>

</view>
