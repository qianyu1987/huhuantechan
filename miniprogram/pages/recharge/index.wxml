<!-- pages/recharge/index.wxml - 钱包充值 -->
<view class="recharge-page">

  <!-- 顶部导航 -->
  <view class="page-header safe-top">
    <view class="header-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="header-title">钱包充值</text>
    <view class="header-right"/>
  </view>

  <!-- 当前余额卡片 -->
  <view class="balance-card">
    <view class="balance-bg-circle1"/>
    <view class="balance-bg-circle2"/>
    <text class="balance-label">当前余额</text>
    <text class="balance-amount">¥<text class="balance-num">{{walletBalance.toFixed ? walletBalance.toFixed(2) : walletBalance}}</text></text>
    <text class="balance-tip">余额可用于支付代购平台服务费</text>
  </view>

  <scroll-view scroll-y class="content-scroll" bindscrolltolower="onLoadMore">

    <!-- 充值金额选择 -->
    <view class="section-card">
      <view class="section-title-row">
        <text class="section-icon">💰</text>
        <text class="section-title">选择充值金额</text>
      </view>

      <!-- 预设金额 -->
      <view class="preset-grid">
        <view
          wx:for="{{presets}}"
          wx:key="index"
          class="preset-item {{selectedPreset === index ? 'selected' : ''}}"
          bindtap="onSelectPreset"
          data-index="{{index}}"
        >
          <text class="preset-amount">¥{{item}}</text>
        </view>
      </view>

      <!-- 自定义金额 -->
      <view class="custom-amount-row">
        <text class="custom-label">其他金额</text>
        <view class="custom-input-wrap {{selectedPreset === null && customAmount ? 'active' : ''}}">
          <text class="currency-symbol">¥</text>
          <input
            class="custom-input"
            type="digit"
            placeholder="输入充值金额（10~10000）"
            placeholder-class="input-placeholder"
            value="{{customAmount}}"
            bindinput="onCustomAmountInput"
          />
        </view>
      </view>

      <!-- 当前金额展示 -->
      <view class="amount-summary" wx:if="{{currentAmount > 0}}">
        <text class="amount-summary-text">充值金额：<text class="amount-highlight">¥{{currentAmount}}</text></text>
      </view>
    </view>

    <!-- 微信支付按钮（新增） -->
    <view class="section-card wechat-pay-section" wx:if="{{currentAmount > 0}}">
      <view class="wechat-pay-btn" bindtap="onWechatPay">
        <view class="wechat-pay-icon">
          <text class="wechat-pay-icon-text">微</text>
        </view>
        <view class="wechat-pay-info">
          <text class="wechat-pay-title">微信支付</text>
          <text class="wechat-pay-desc">推荐 - 秒充到账</text>
        </view>
        <view class="wechat-pay-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 分隔线 -->
    <view class="divider-text" wx:if="{{currentAmount > 0}}">
      <text class="divider-line"/>
      <text class="divider-label">或选择其他方式</text>
      <text class="divider-line"/>
    </view>

    <!-- 充值说明 -->
    <view class="section-card notice-card">
      <view class="section-title-row">
        <text class="section-icon">📋</text>
        <text class="section-title">充值流程说明</text>
      </view>
      <view class="steps-list">
        <view class="step-item">
          <view class="step-num">1</view>
          <view class="step-content">
            <text class="step-title">提交充值申请</text>
            <text class="step-desc">选择或填写充值金额，点击提交申请</text>
          </view>
        </view>
        <view class="step-item">
          <view class="step-num">2</view>
          <view class="step-content">
            <text class="step-title">联系管理员转账</text>
            <text class="step-desc">添加管理员微信，备注申请单号后完成转账</text>
          </view>
        </view>
        <view class="step-item">
          <view class="step-num">3</view>
          <view class="step-content">
            <text class="step-title">等待审核到账</text>
            <text class="step-desc">管理员确认收款后，余额将自动到账</text>
          </view>
        </view>
      </view>

      <!-- 管理员微信 -->
      <view class="admin-wechat-row" bindtap="copyAdminWechat">
        <text class="admin-wechat-icon">💬</text>
        <view class="admin-wechat-info">
          <text class="admin-wechat-label">管理员微信</text>
          <text class="admin-wechat-id">xiaoqiange12315</text>
        </view>
        <view class="copy-btn">
          <text class="copy-btn-text">复制</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="section-card">
      <view class="section-title-row">
        <text class="section-icon">✏️</text>
        <text class="section-title">备注（选填）</text>
      </view>
      <textarea
        class="remark-input"
        placeholder="可填写转账备注，方便管理员核对"
        placeholder-class="input-placeholder"
        value="{{remark}}"
        bindinput="onRemarkInput"
        maxlength="100"
        auto-height
      />
    </view>

    <!-- 提交按钮（手动转账方式） -->
    <view class="submit-wrap">
      <view
        class="submit-btn secondary {{(!currentAmount || currentAmount <= 0 || submitting) ? 'disabled' : ''}}"
        bindtap="onSubmit"
      >
        <text class="submit-text">{{submitting ? '提交中...' : '手动转账充值'}}</text>
      </view>
    </view>

    <!-- 充值记录 -->
    <view class="section-card" wx:if="{{applyList.length > 0}}">
      <view class="section-title-row">
        <text class="section-icon">📝</text>
        <text class="section-title">充值记录</text>
      </view>
      <view class="apply-list">
        <view wx:for="{{applyList}}" wx:key="id" class="apply-item">
          <view class="apply-left">
            <text class="apply-amount">¥{{item.amount}}</text>
            <text class="apply-time">{{item.createTime}}</text>
            <text class="apply-no">单号：{{item.applyNo}}</text>
            <text wx:if="{{item.adminNote}}" class="apply-admin-note">备注：{{item.adminNote}}</text>
          </view>
          <view class="apply-right">
            <view class="apply-status status-{{item.status}}">
              <text class="apply-status-text">{{item.statusText}}</text>
            </view>
            <view
              wx:if="{{item.status === 'pending'}}"
              class="cancel-btn"
              bindtap="onCancelApply"
              data-id="{{item.id}}"
            >
              <text class="cancel-btn-text">取消</text>
            </view>
          </view>
        </view>
      </view>
      <view class="load-more" wx:if="{{applyList.length < applyTotal}}" bindtap="onLoadMore">
        <text class="load-more-text">{{applyLoading ? '加载中...' : '加载更多'}}</text>
      </view>
    </view>

    <view style="height: calc(80rpx + env(safe-area-inset-bottom))"/>
  </scroll-view>

</view>

<!-- 微信支付结果弹窗 -->
<view class="wechat-pay-modal" wx:if="{{showWechatPayModal}}">
  <view class="wechat-pay-modal-content" catchtap="noop">

    <!-- 滚动内容区 -->
    <scroll-view scroll-y class="wechat-pay-modal-scroll">

      <!-- 加载动画 -->
      <view class="wechat-pay-loading">
        <view class="wechat-pay-loading-icon">
          <text class="wechat-pay-loading-icon-text">💳</text>
        </view>
        <text class="wechat-pay-title">{{checkingPayment ? '支付处理中...' : '支付完成'}}</text>
        <text class="wechat-pay-subtitle">{{checkingPayment ? '请稍候，系统正在确认支付结果' : '支付已成功'}}</text>
      </view>

      <!-- 订单信息 -->
      <view class="wechat-pay-info-card">
        <view class="wechat-pay-info-row">
          <text class="wechat-pay-info-label">充值金额</text>
          <text class="wechat-pay-amount">¥{{currentAmount}}</text>
        </view>
        <view class="wechat-pay-info-row">
          <text class="wechat-pay-info-label">订单号</text>
          <text class="wechat-pay-info-value" style="font-size: 22rpx;">{{wechatPayOrderNo}}</text>
        </view>
        <view class="wechat-pay-info-row" wx:if="{{checkingPayment}}">
          <text class="wechat-pay-info-label">查询进度</text>
          <text class="wechat-pay-info-value">{{paymentCheckCount < 10 ? '已查询 ' + paymentCheckCount + '/10 次' : '查询超时'}}</text>
        </view>
      </view>

      <!-- 提示 -->
      <view class="screenshot-hint" wx:if="{{checkingPayment}}">
        <text class="screenshot-hint-icon">⏳</text>
        <text class="screenshot-hint-text">请耐心等待，系统正在确认支付结果</text>
      </view>

    </scroll-view>

    <!-- 底部操作区 -->
    <view class="wechat-pay-modal-footer">
      <view class="wechat-pay-modal-btn {{checkingPayment ? 'disabled' : ''}}" bindtap="closeWechatPayModal">
        <text class="wechat-pay-modal-btn-text">
          <view class="wechat-pay-spinner" wx:if="{{checkingPayment}}"></view>
          {{checkingPayment ? '等待确认中...' : '我知道了'}}
        </text>
      </view>
      <view class="wechat-pay-cancel-btn" bindtap="copyWechatPayOrderNo" wx:if="{{!checkingPayment}}">
        <text class="wechat-pay-cancel-text">复制订单号</text>
      </view>
    </view>

  </view>

</view>

<!-- 提交成功弹窗 -->
<view class="modal-mask" wx:if="{{showResultModal}}">
  <view class="modal-content" catchtap="noop">

    <!-- 滚动内容区 -->
    <scroll-view scroll-y class="modal-scroll">

      <!-- 顶部成功标识 -->
      <view class="modal-success-header">
        <view class="modal-success-ring">
          <text class="modal-icon">✅</text>
        </view>
        <text class="modal-title">申请提交成功！</text>
        <text class="modal-desc">请截图保存以下凭证，转账时备注单号</text>
      </view>

      <!-- 截图引导提示（凭证上方，更醒目） -->
      <view class="screenshot-hint-top">
        <text class="screenshot-hint-top-icon">📸</text>
        <view>
          <text class="screenshot-hint-top-text">请截图保存此凭证</text>
          <text class="screenshot-hint-top-sub">转账时向管理员出示，备注申请单号</text>
        </view>
      </view>

      <!-- 凭证卡片（截图核心区域） -->
      <view class="voucher-card">
        <view class="voucher-header">
          <text class="voucher-header-icon">🧾</text>
          <text class="voucher-header-title">充值凭证</text>
          <text class="voucher-header-sub">互换特产平台</text>
        </view>

        <view class="voucher-divider">
          <view class="voucher-divider-dot left"/>
          <view class="voucher-divider-line"/>
          <view class="voucher-divider-dot right"/>
        </view>

        <view class="voucher-row">
          <text class="voucher-label">充值金额</text>
          <text class="voucher-value voucher-amount">¥{{resultAmount}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">客服微信</text>
          <text class="voucher-value voucher-wechat">{{serviceWechat || '未配置'}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">申请单号</text>
          <text class="voucher-value voucher-no">{{resultApplyNo}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">申请时间</text>
          <text class="voucher-value voucher-time">{{resultCreateTime}}</text>
        </view>

        <view class="voucher-divider">
          <view class="voucher-divider-dot left"/>
          <view class="voucher-divider-line"/>
          <view class="voucher-divider-dot right"/>
        </view>

        <view class="voucher-tip-row">
          <text class="voucher-tip-text">转账时请备注以上单号，方便管理员核对</text>
        </view>
      </view>

      <!-- 截图引导提示（凭证下方辅助说明） -->
      <view class="screenshot-hint">
        <text class="screenshot-hint-icon">💡</text>
        <text class="screenshot-hint-text">长按屏幕可截图，或使用手机截图功能保存</text>
      </view>

    </scroll-view>

    <!-- 底部固定操作区 -->
    <view class="modal-footer">
      <view class="modal-actions">
        <view class="modal-btn secondary" bindtap="copyApplyNo">
          <text class="modal-btn-icon">📋</text>
          <text>复制单号</text>
        </view>
        <view class="modal-btn primary" bindtap="copyAdminWechat">
          <text class="modal-btn-icon">💬</text>
          <text>复制微信号</text>
        </view>
      </view>
      <view class="modal-close-btn" bindtap="closeResultModal">
        <text class="modal-close-text">我已保存凭证，关闭</text>
      </view>
    </view>

  </view>
</view>
