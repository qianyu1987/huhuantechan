/* pages/recharge/index.wxss - 钱包充值页 */

.recharge-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #ffffff;
}

/* ── 顶部导航 ── */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}
.safe-top { padding-top: calc(56rpx + env(safe-area-inset-top)); }
.header-back {
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.back-icon { font-size: 52rpx; color: #fff; line-height: 1; margin-top: -4rpx; }
.header-title { font-size: 34rpx; font-weight: 700; color: #fff; }
.header-right { width: 72rpx; }

/* ── 余额卡片 ── */
.balance-card {
  position: relative;
  margin: 32rpx;
  padding: 48rpx 40rpx 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(102,126,234,0.4);
}
.balance-bg-circle1 {
  position: absolute; width: 300rpx; height: 300rpx;
  border-radius: 50%; background: rgba(255,255,255,0.08);
  top: -100rpx; right: -60rpx;
}
.balance-bg-circle2 {
  position: absolute; width: 200rpx; height: 200rpx;
  border-radius: 50%; background: rgba(255,255,255,0.06);
  bottom: -80rpx; left: -40rpx;
}
.balance-label {
  font-size: 26rpx; color: rgba(255,255,255,0.85); display: block; margin-bottom: 16rpx;
}
.balance-amount {
  font-size: 36rpx; color: #fff; font-weight: 600; display: block; margin-bottom: 12rpx;
}
.balance-num { font-size: 72rpx; font-weight: 800; }
.balance-tip {
  font-size: 22rpx; color: rgba(255,255,255,0.7); display: block;
}

/* ── 内容滚动区 ── */
.content-scroll {
  padding: 0 32rpx;
}

/* ── 通用卡片 ── */
.section-card {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}
.section-title-row {
  display: flex; align-items: center; margin-bottom: 28rpx;
}
.section-icon { font-size: 36rpx; margin-right: 14rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #fff; }

/* ── 预设金额网格 ── */
.preset-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 28rpx;
}
.preset-item {
  padding: 28rpx 0;
  text-align: center;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 18rpx;
  transition: all 0.2s;
}
.preset-item.selected {
  background: linear-gradient(135deg, rgba(102,126,234,0.5) 0%, rgba(118,75,162,0.5) 100%);
  border-color: #667eea;
  box-shadow: 0 0 20rpx rgba(102,126,234,0.4);
}
.preset-amount {
  font-size: 32rpx; font-weight: 700; color: #fff;
}
.preset-item.selected .preset-amount { color: #fff; }

/* ── 自定义金额 ── */
.custom-amount-row {
  display: flex; align-items: center; gap: 20rpx;
}
.custom-label {
  font-size: 26rpx; color: rgba(255,255,255,0.7);
  white-space: nowrap;
}
.custom-input-wrap {
  flex: 1;
  display: flex; align-items: center;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  transition: border-color 0.2s;
}
.custom-input-wrap.active {
  border-color: #667eea;
}
.currency-symbol {
  font-size: 28rpx; color: rgba(255,255,255,0.6); margin-right: 8rpx;
}
.custom-input {
  flex: 1; font-size: 32rpx; font-weight: 600;
  color: #fff; background: transparent;
}
.input-placeholder { color: rgba(255,255,255,0.35); font-size: 26rpx; font-weight: 400; }

.amount-summary {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx;
  background: rgba(102,126,234,0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(102,126,234,0.3);
}
.amount-summary-text { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.amount-highlight { font-size: 32rpx; font-weight: 700; color: #667eea; }

/* ── 充值说明 ── */
.notice-card { background: rgba(102,126,234,0.08); border-color: rgba(102,126,234,0.2); }

.steps-list { margin-bottom: 28rpx; }
.step-item {
  display: flex; align-items: flex-start; margin-bottom: 20rpx;
}
.step-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700; color: #fff;
  flex-shrink: 0; margin-right: 20rpx; margin-top: 4rpx;
}
.step-content { flex: 1; }
.step-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 6rpx; }
.step-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); }

.admin-wechat-row {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx; padding: 20rpx 24rpx;
}
.admin-wechat-icon { font-size: 40rpx; margin-right: 16rpx; }
.admin-wechat-info { flex: 1; }
.admin-wechat-label { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 6rpx; }
.admin-wechat-id { font-size: 28rpx; font-weight: 600; color: #fff; }
.copy-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 12rpx 24rpx; border-radius: 24rpx;
}
.copy-btn-text { font-size: 24rpx; color: #fff; font-weight: 600; }

/* ── 备注输入 ── */
.remark-input {
  width: 100%; min-height: 120rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx; padding: 20rpx;
  font-size: 28rpx; color: #fff;
  box-sizing: border-box;
}

/* ── 提交按钮 ── */
.submit-wrap { padding: 8rpx 0 24rpx; }
.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 60rpx;
  padding: 32rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.5);
  transition: all 0.2s;
}
.submit-btn.disabled {
  background: rgba(255,255,255,0.15);
  box-shadow: none;
  opacity: 0.6;
}
.submit-text { font-size: 32rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }

/* ── 充值记录 ── */
.apply-list {}
.apply-item {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.apply-item:last-child { border-bottom: none; }
.apply-left { flex: 1; }
.apply-amount { font-size: 32rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.apply-time { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 4rpx; }
.apply-no { font-size: 20rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 4rpx; }
.apply-admin-note { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; }

.apply-right {
  display: flex; flex-direction: column; align-items: flex-end; gap: 12rpx;
}
.apply-status {
  padding: 8rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 600;
}
.apply-status.status-pending { background: rgba(255,165,0,0.15); color: #FFA500; border: 1rpx solid rgba(255,165,0,0.3); }
.apply-status.status-approved { background: rgba(76,175,80,0.15); color: #4CAF50; border: 1rpx solid rgba(76,175,80,0.3); }
.apply-status.status-rejected { background: rgba(244,67,54,0.15); color: #F44336; border: 1rpx solid rgba(244,67,54,0.3); }
.apply-status.status-cancelled { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); border: 1rpx solid rgba(255,255,255,0.1); }

.cancel-btn {
  padding: 8rpx 16rpx; border-radius: 16rpx;
  background: rgba(244,67,54,0.1); border: 1rpx solid rgba(244,67,54,0.3);
}
.cancel-btn-text { font-size: 22rpx; color: #F44336; }

.load-more {
  text-align: center; padding: 20rpx 0;
}
.load-more-text { font-size: 26rpx; color: rgba(255,255,255,0.45); }

/* ── 结果弹窗 ── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(16rpx);
  padding: 40rpx 0;
  box-sizing: border-box;
}
.modal-content {
  background: linear-gradient(160deg, #1e2a4a 0%, #2d1b69 60%, #1a1a2e 100%);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 32rpx;
  margin: 0 40rpx;
  width: calc(100% - 80rpx);
  box-sizing: border-box;
  max-height: calc(100vh - 120rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.6), 0 0 0 1rpx rgba(102,126,234,0.2);
}

/* 弹窗滚动区 */
.modal-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 48rpx 40rpx 32rpx;
}

/* 顶部成功区 */
.modal-success-header {
  text-align: center; margin-bottom: 32rpx;
}
.modal-success-ring {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, rgba(76,175,80,0.25), rgba(76,175,80,0.08));
  border: 3rpx solid rgba(76,175,80,0.6);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 0 40rpx rgba(76,175,80,0.35), 0 0 80rpx rgba(76,175,80,0.15);
}
.modal-icon { font-size: 64rpx; display: block; }
.modal-title { font-size: 38rpx; font-weight: 800; color: #fff; display: block; margin-bottom: 12rpx; }
.modal-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; }

/* 截图引导 - 凭证区域上方显眼提示 */
.screenshot-hint-top {
  display: flex; align-items: center;
  background: linear-gradient(135deg, rgba(255,193,7,0.18), rgba(255,152,0,0.12));
  border: 1.5rpx solid rgba(255,193,7,0.55);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
  gap: 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,193,7,0.1);
}
.screenshot-hint-top-icon { font-size: 40rpx; flex-shrink: 0; animation: pulse 1.5s ease-in-out infinite; }
.screenshot-hint-top-text {
  font-size: 26rpx; color: #FFD54F; font-weight: 700; line-height: 1.5; flex: 1;
}
.screenshot-hint-top-sub {
  font-size: 22rpx; color: rgba(255,213,79,0.75); display: block; margin-top: 4rpx;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

/* 凭证卡片 */
.voucher-card {
  background: linear-gradient(135deg, #fffbf0 0%, #fff9e6 100%);
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.35), 0 0 0 2rpx rgba(255,200,0,0.4);
  position: relative;
  overflow: hidden;
}
.voucher-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 6rpx;
  background: linear-gradient(90deg, #667eea, #f6a623, #764ba2);
}
/* 凭证水印角标 */
.voucher-card::after {
  content: '截图保存';
  position: absolute; top: 20rpx; right: -28rpx;
  background: linear-gradient(135deg, #f6a623, #e65c00);
  color: #fff; font-size: 18rpx; font-weight: 700;
  padding: 6rpx 40rpx;
  transform: rotate(45deg);
  letter-spacing: 2rpx;
}

.voucher-header {
  display: flex; align-items: center; margin-bottom: 24rpx;
}
.voucher-header-icon { font-size: 36rpx; margin-right: 12rpx; }
.voucher-header-title { font-size: 28rpx; font-weight: 800; color: #1a1a2e; flex: 1; }
.voucher-header-sub { font-size: 20rpx; color: rgba(26,26,46,0.45); }

/* 虚线分割 */
.voucher-divider {
  display: flex; align-items: center; margin: 16rpx -36rpx;
  position: relative;
}
.voucher-divider-line {
  flex: 1;
  border-top: 2rpx dashed rgba(26,26,46,0.2);
  margin: 0 8rpx;
}
.voucher-divider-dot {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: linear-gradient(160deg, #1e2a4a 0%, #2d1b69 100%);
  flex-shrink: 0;
}
.voucher-divider-dot.left { margin-left: -16rpx; }
.voucher-divider-dot.right { margin-right: -16rpx; }

.voucher-row {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 14rpx 0;
}
.voucher-label {
  font-size: 24rpx; color: rgba(26,26,46,0.55); flex-shrink: 0; margin-right: 20rpx;
}
.voucher-value {
  font-size: 26rpx; font-weight: 600; color: #1a1a2e; text-align: right; flex: 1;
}
.voucher-amount {
  font-size: 36rpx; font-weight: 800;
  color: #e65c00;
}
.voucher-wechat {
  color: #07c160; font-weight: 700;
}
.voucher-no {
  color: #5546D1; font-size: 22rpx; word-break: break-all;
  font-family: monospace;
  letter-spacing: 1rpx;
}
.voucher-time {
  font-size: 22rpx; color: rgba(26,26,46,0.55);
}

.voucher-tip-row {
  padding-top: 8rpx; text-align: center;
}
.voucher-tip-text {
  font-size: 22rpx; color: rgba(26,26,46,0.5); line-height: 1.6;
}

/* 截图引导下方 */
.screenshot-hint {
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,193,7,0.1);
  border: 1rpx dashed rgba(255,193,7,0.45);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  gap: 10rpx;
}
.screenshot-hint-icon { font-size: 30rpx; flex-shrink: 0; }
.screenshot-hint-text {
  font-size: 22rpx; color: rgba(255,193,7,0.85); font-weight: 500; line-height: 1.5;
}

/* 弹窗底部固定操作区 */
.modal-footer {
  padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.08);
  background: linear-gradient(180deg, transparent, rgba(26,26,46,0.4));
}

/* 操作按钮 */
.modal-actions {
  display: flex; gap: 20rpx; margin-bottom: 20rpx;
}
.modal-btn {
  flex: 1; padding: 26rpx 0; border-radius: 48rpx; text-align: center;
  font-size: 26rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}
.modal-btn-icon { font-size: 28rpx; }
.modal-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.4);
}
.modal-btn.secondary {
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.2);
}

/* 关闭按钮 */
.modal-close-btn {
  text-align: center; padding: 10rpx 0;
}
.modal-close-text {
  font-size: 26rpx; color: rgba(255,255,255,0.4);
  text-decoration: underline;
}
