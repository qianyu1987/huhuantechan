/* pages/detail/index.wxss - iOS 26 深色玻璃风 */

.detail-page {
  background: var(--color-bg);
  padding-bottom: 0;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 16rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== 图片轮播（圆角+渐变融入 4:3） ===== */
.img-container {
  position: relative;
  margin: 20rpx 24rpx 0;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  background: rgba(120, 120, 128, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 75%;  /* 4:3 比例 */
}

.img-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.img-fade-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, var(--color-bg) 0%, transparent 100%);
  pointer-events: none;
}

.img-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(0, 0, 0, 0.35);
  border-radius: var(--radius-full);
}

/* ===== 神秘特产头图 ===== */
.mystery-hero {
  width: 100%;
  height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.mystery-hero.color-1 { background: linear-gradient(135deg, #FF6B6B 0%, #EE5A24 100%); }
.mystery-hero.color-2 { background: linear-gradient(135deg, #FECA57 0%, #FF9F43 100%); }
.mystery-hero.color-3 { background: linear-gradient(135deg, #48DBFB 0%, #0ABDE3 100%); }
.mystery-hero.color-4 { background: linear-gradient(135deg, #A55EEA 0%, #8854D0 100%); }
.mystery-hero.color-5 { background: linear-gradient(135deg, #26DE81 0%, #20BF6B 100%); }
.mystery-hero.color-6 { background: linear-gradient(135deg, #FED330 0%, #F79F1F 100%); }
.mystery-hero.color-7 { background: linear-gradient(135deg, #FC5C65 0%, #EB3B5A 100%); }
.mystery-hero.color-8 { background: linear-gradient(135deg, #45AAF2 0%, #2D98DA 100%); }
.mystery-hero.color-9 { background: linear-gradient(135deg, #4B7BEC 0%, #3867D6 100%); }
.mystery-hero.color-10 { background: linear-gradient(135deg, #778CA3 0%, #4B6584 100%); }

.mystery-emoji {
  font-size: 160rpx;
  margin-bottom: 20rpx;
}

.mystery-label {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 700;
  padding: 12rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
}

/* ===== 玻璃卡片基础 ===== */
.glass-card {
  background: rgba(120, 120, 128, 0.16);
  border-radius: var(--radius-2xl);
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* 底部占位，防止内容被固定栏遮挡 */
.bottom-placeholder {
  height: 180rpx;
}

/* ===== 卡片头部 ===== */
.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-header-icon {
  font-size: 32rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: rgba(10, 132, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
}

/* ===== 基础信息卡 ===== */
.product-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text);
  line-height: 1.3;
  letter-spacing: -0.5rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.info-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(120, 120, 128, 0.12);
  color: var(--color-text-secondary);
}

.location-pill {
  background: rgba(10, 132, 255, 0.1);
  color: var(--color-primary);
  border: 1rpx solid rgba(10, 132, 255, 0.15);
}

.category-pill {
  background: rgba(48, 209, 88, 0.1);
  color: #30D158;
  border: 1rpx solid rgba(48, 209, 88, 0.15);
}

.value-pill {
  background: rgba(255, 159, 10, 0.1);
  color: #FF9F0A;
  border: 1rpx solid rgba(255, 159, 10, 0.15);
}

/* 描述标签行 */
.desc-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.desc-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  background: rgba(88, 86, 214, 0.1);
  color: #8E8AFF;
  border: 1rpx solid rgba(88, 86, 214, 0.15);
}

/* 神秘提示 */
.mystery-hint-box {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(191, 90, 242, 0.08);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(191, 90, 242, 0.15);
}

.mystery-hint-text {
  font-size: 24rpx;
  color: #BF5AF2;
  font-weight: 500;
  line-height: 1.6;
}

/* ===== 想换卡片 ===== */
.want-card .card-header-icon {
  background: rgba(255, 107, 53, 0.12);
}

.want-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.want-loc-pill {
  background: rgba(100, 210, 255, 0.1);
  color: #64D2FF;
  border: 1rpx solid rgba(100, 210, 255, 0.15);
}

.want-cat-pill {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  border: 1rpx solid rgba(255, 107, 53, 0.15);
}

/* ===== 发布者卡片 ===== */
.publisher-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.2s ease;
}

.publisher-card:active {
  transform: scale(0.98);
}

.pub-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  background: var(--color-bg-secondary);
}

.pub-info { flex: 1; }

.pub-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pub-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

/* 性别标签 */
.gender-badge {
  font-size: 24rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.gender-male {
  background: rgba(10, 132, 255, 0.15);
  color: #0A84FF;
}

.gender-female {
  background: rgba(255, 45, 85, 0.15);
  color: #FF2D55;
}

.pub-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  font-size: 24rpx;
}

.pub-dot {
  color: rgba(255, 255, 255, 0.2);
}

.pub-stat {
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.credit-high { color: #30D158; font-weight: 600; }
.credit-mid { color: #FF9F0A; font-weight: 600; }
.credit-low { color: #FF453A; font-weight: 600; }

.pub-arrow {
  font-size: 36rpx;
  color: var(--color-text-quaternary);
  font-weight: 300;
}

/* ===== 评价卡片 ===== */
.review-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-item {
  padding: 20rpx;
  background: rgba(120, 120, 128, 0.08);
  border-radius: var(--radius-lg);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.review-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-secondary);
}

.review-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.review-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.review-time {
  font-size: 20rpx;
  color: var(--color-text-quaternary);
}

.review-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
}

.review-badge.good {
  background: rgba(48, 209, 88, 0.12);
  color: #30D158;
}

.review-badge.bad {
  background: rgba(255, 69, 58, 0.12);
  color: #FF453A;
}

.review-content {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
  padding-left: 70rpx;
}

/* 评价空状态 */
.reviews-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  gap: 12rpx;
}

.reviews-empty-icon {
  font-size: 56rpx;
  opacity: 0.5;
}

.reviews-empty-text {
  font-size: 24rpx;
  color: var(--color-text-quaternary);
  font-weight: 500;
}

/* ===== 时间行 ===== */
.time-row {
  padding: 24rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: var(--color-text-quaternary);
  font-weight: 500;
  text-align: center;
}

/* ===== 底部操作栏（固定悬浮） ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(30, 30, 32, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid var(--color-divider);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
}

/* 收藏按钮 */
.fav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 100rpx;
  padding: 8rpx;
  transition: all 0.2s ease;
}

.fav-btn:active { transform: scale(0.9); }

.fav-icon { font-size: 40rpx; }

.fav-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* 操作按钮 */
.bar-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-btn::after { border: none; }
.bar-btn:active { transform: scale(0.97); }

.bar-btn-ghost {
  background: rgba(120, 120, 128, 0.16);
  color: var(--color-text);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.bar-btn-danger {
  background: rgba(255, 69, 58, 0.12);
  color: #FF453A;
  border: 1rpx solid rgba(255, 69, 58, 0.15);
}

.bar-btn-swap {
  background: linear-gradient(135deg, #0A84FF 0%, #5856D6 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(10, 132, 255, 0.35);
}

.bar-btn-swap:active {
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.25);
}
