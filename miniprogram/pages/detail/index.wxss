/* pages/detail/index.wxss - iOS 27 液态玻璃风格 */

.detail-page {
  background: var(--color-bg);
  padding-bottom: 0;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 16rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== 图片轮播（圆角+渐变融入 4:3） ===== */
.img-container {
  position: relative;
  margin: 20rpx 24rpx 0;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  background: var(--liquid-surface);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 75%;  /* 4:3 比例 */
  box-shadow: var(--shadow-liquid);
}

.img-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.img-fade-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, var(--color-bg) 0%, transparent 100%);
  pointer-events: none;
}

.img-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* ===== 神秘特产头图 - 炫酷版 ===== */
.mystery-hero {
  width: 100%;
  height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 深色渐变背景 */
.mystery-hero.purple { background: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #1a0a2e 100%); }
.mystery-hero.blue { background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0a1628 100%); }
.mystery-hero.green { background: linear-gradient(135deg, #0a1f0a 0%, #1a3a1a 50%, #0a1f0a 100%); }
.mystery-hero.red { background: linear-gradient(135deg, #1f0a0a 0%, #3a1a1a 50%, #1f0a0a 100%); }
.mystery-hero.gold { background: linear-gradient(135deg, #1f1a0a 0%, #3a3015 50%, #1f1a0a 100%); }

/* 发光效果 */
.mystery-hero-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(138, 43, 226, 0.4) 0%, rgba(138, 43, 226, 0.1) 40%, transparent 70%);
  border-radius: 50%;
  animation: heroGlowPulse 3s ease-in-out infinite;
}

@keyframes heroGlowPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.4); opacity: 1; }
}

/* 星星装饰 */
.mystery-hero-stars {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.hero-star {
  position: absolute;
  font-size: 36rpx;
  opacity: 0;
  animation: heroStarTwinkle 2s ease-in-out infinite;
}

.hero-star:nth-child(1) { top: 15%; left: 15%; animation-delay: 0s; }
.hero-star:nth-child(2) { top: 25%; right: 20%; animation-delay: 0.5s; }
.hero-star:nth-child(3) { bottom: 30%; left: 25%; animation-delay: 1s; }
.hero-star:nth-child(4) { top: 60%; right: 15%; animation-delay: 1.5s; }

@keyframes heroStarTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* 礼盒容器 */
.mystery-hero-box {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  margin-bottom: 30rpx;
}

.mystery-hero-emoji {
  font-size: 160rpx;
  animation: heroBoxFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 8rpx 40rpx rgba(0,0,0,0.4));
}

@keyframes heroBoxFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); }
  50% { transform: translateY(-20rpx) rotate(3deg); }
}

/* 光环效果 */
.mystery-hero-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border: 4rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 50%;
  animation: heroRingPulse 2s ease-out infinite;
}

.mystery-hero-ring::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border: 3rpx solid rgba(138, 43, 226, 0.3);
  border-radius: 50%;
}

@keyframes heroRingPulse {
  0% { transform: scale(0.9); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* 标签 */
.mystery-hero-label {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 700;
  padding: 14rpx 44rpx;
  background: linear-gradient(90deg, rgba(138, 43, 226, 0.4), rgba(10, 132, 255, 0.4));
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(138, 43, 226, 0.3);
  z-index: 1;
}

.mystery-hero-province {
  position: absolute;
  bottom: 30rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  z-index: 1;
}

/* 兼容旧样式 */
.mystery-emoji {
  font-size: 160rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.mystery-label {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 700;
  padding: 14rpx 44rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  position: relative;
  z-index: 1;
}

/* ===== 液态玻璃卡片基础 ===== */
.glass-card {
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-radius: var(--radius-2xl);
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow-liquid);
  transition: all 0.25s ease;
}

.glass-card:active {
  background: var(--liquid-surface-hover);
}

/* 底部占位 */
.bottom-placeholder {
  height: 180rpx;
}

/* ===== 卡片头部 ===== */
.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-header-icon {
  font-size: 32rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: var(--glass-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(10, 132, 255, 0.2);
}

.card-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
}

/* ===== 基础信息卡 ===== */
.product-header-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.product-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text);
  line-height: 1.3;
  letter-spacing: -0.5rpx;
  flex: 1;
}

/* 举报按钮 - 底部操作栏 */
.report-btn-bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  background: var(--liquid-surface);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.25s ease;
}

.report-btn-bottom:active {
  transform: scale(0.9);
  background: var(--liquid-surface-hover);
}

.report-btn-bottom .report-icon {
  font-size: 28rpx;
}

.report-btn-bottom .report-text {
  font-size: 18rpx;
  font-weight: 500;
  color: #FF453A;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.info-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  background: var(--liquid-surface);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.location-pill {
  background: var(--glass-primary);
  color: var(--color-primary);
  border: 1rpx solid rgba(10, 132, 255, 0.2);
}

.category-pill {
  background: var(--glass-secondary);
  color: #30D158;
  border: 1rpx solid rgba(48, 209, 88, 0.2);
}

.value-pill {
  background: var(--glass-orange);
  color: #FF9F0A;
  border: 1rpx solid rgba(255, 159, 10, 0.2);
}

/* 描述标签行 */
.desc-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.desc-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--glass-purple);
  color: #BF5AF2;
  border: 1rpx solid rgba(191, 90, 242, 0.2);
}

/* 神秘提示 */
.mystery-hint-box {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--glass-purple);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(191, 90, 242, 0.2);
}

.mystery-hint-text {
  font-size: 24rpx;
  color: #BF5AF2;
  font-weight: 500;
  line-height: 1.6;
}

/* ===== 想换卡片 ===== */
.want-card .card-header-icon {
  background: var(--glass-orange);
  border: 1rpx solid rgba(255, 159, 10, 0.2);
}

.want-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.want-loc-pill {
  background: var(--glass-teal);
  color: #64D2FF;
  border: 1rpx solid rgba(100, 210, 255, 0.2);
}

.want-cat-pill {
  background: var(--glass-orange);
  color: #FF6B35;
  border: 1rpx solid rgba(255, 107, 53, 0.2);
}

/* ===== 发布者卡片 ===== */
.publisher-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.25s ease;
  padding: 12rpx;
  border-radius: var(--radius-lg);
}

.publisher-card:active {
  transform: scale(0.98);
  background: var(--liquid-surface-hover);
}

.pub-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  background: var(--color-bg-secondary);
  box-shadow: var(--shadow-liquid);
  position: relative;
}

/* 头像光泽 */
.pub-avatar::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 15%;
  width: 25%;
  height: 20%;
  background: radial-gradient(ellipse, rgba(255,255,255,0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.pub-info { flex: 1; }

.pub-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pub-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

/* 性别标签 */
.gender-badge {
  font-size: 24rpx;
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  display: inline-block;
}

.gender-male {
  background: var(--glass-primary);
  color: #0A84FF;
}

.gender-female {
  background: var(--glass-pink);
  color: #FF2D55;
}

.pub-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  font-size: 24rpx;
}

.pub-dot {
  color: rgba(255, 255, 255, 0.2);
}

.pub-stat {
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.credit-high { color: #30D158; font-weight: 600; }
.credit-mid { color: #FF9F0A; font-weight: 600; }
.credit-low { color: #FF453A; font-weight: 600; }

.pub-arrow {
  font-size: 36rpx;
  color: var(--color-text-quaternary);
  font-weight: 300;
}

/* ===== 评价卡片 ===== */
.review-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-item {
  padding: 20rpx;
  background: var(--liquid-surface);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.review-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-secondary);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.review-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.review-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.review-time {
  font-size: 20rpx;
  color: var(--color-text-quaternary);
}

.review-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
}

.review-badge.good {
  background: var(--glass-secondary);
  color: #30D158;
  border: 1rpx solid rgba(48, 209, 88, 0.2);
}

.review-badge.bad {
  background: var(--glass-pink);
  color: #FF453A;
  border: 1rpx solid rgba(255, 69, 58, 0.2);
}

.review-content {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
  padding-left: 70rpx;
}

/* 评价空状态 */
.reviews-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  gap: 12rpx;
}

.reviews-empty-icon {
  font-size: 56rpx;
  opacity: 0.5;
}

.reviews-empty-text {
  font-size: 24rpx;
  color: var(--color-text-quaternary);
  font-weight: 500;
}

/* ===== 时间行 ===== */
.time-row {
  padding: 24rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: var(--color-text-quaternary);
  font-weight: 500;
  text-align: center;
}

/* ===== 底部操作栏（固定悬浮） ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--liquid-surface);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.15);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
}

/* 收藏按钮 - 正方形小按钮 */
.fav-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  background: var(--liquid-surface);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.25s ease;
}

.fav-btn:active {
  transform: scale(0.9);
  background: var(--liquid-surface-hover);
}

.fav-icon {
  font-size: 32rpx;
}

.fav-label {
  display: none;
}

/* 操作按钮 */
.bar-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-btn::after { border: none; }
.bar-btn:active { transform: scale(0.96); }

.bar-btn-ghost {
  background: var(--liquid-surface);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  color: var(--color-text);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: var(--shadow-liquid);
}

.bar-btn-danger {
  background: var(--glass-pink);
  color: #FF453A;
  border: 1rpx solid rgba(255, 69, 58, 0.2);
}

.bar-btn-swap {
  background: linear-gradient(135deg, #0A84FF 0%, #5856D6 100%);
  color: white;
  box-shadow: var(--shadow-liquid), var(--shadow-glow-blue);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.bar-btn-swap:active {
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.25);
}

/* 代购购买按钮 */
.bar-btn-buy {
  background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
  color: white;
  box-shadow: var(--shadow-liquid), 0 0 30rpx rgba(255, 149, 0, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.bar-btn-buy:active {
  box-shadow: 0 4rpx 16rpx rgba(255, 149, 0, 0.25);
}

.bar-btn-disabled {
  background: var(--liquid-surface);
  color: rgba(60, 60, 67, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* ===== 代购信息卡 ===== */
.daigou-card {
  border: 1.5rpx solid rgba(255, 149, 0, 0.25);
  background: linear-gradient(135deg, 
    rgba(255, 149, 0, 0.06) 0%, 
    rgba(255, 149, 0, 0.02) 100%);
}

.daigou-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.daigou-card-badge {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF9500;
  background: var(--glass-orange);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 149, 0, 0.2);
}

.daigou-stock-tag {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  background: var(--liquid-surface);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.daigou-stock-tag.sold-out {
  color: #FF453A;
  background: var(--glass-pink);
  border-color: rgba(255, 69, 58, 0.2);
}

.daigou-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.daigou-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.daigou-price-symbol {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF453A;
}

.daigou-price-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #FF453A;
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(255, 69, 58, 0.3);
}

.daigou-original-price {
  font-size: 26rpx;
  color: var(--color-text-quaternary);
  text-decoration: line-through;
}

.daigou-sold-row {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.daigou-tips-row {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.daigou-tip-item {
  font-size: 23rpx;
  color: var(--color-text-secondary);
}

/* 代购卖家信息行 */
.daigou-seller-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 149, 0, 0.12);
  border-bottom: 1rpx solid rgba(255, 149, 0, 0.12);
  margin: 10rpx 0 14rpx;
}
.dsi-level {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dsi-icon {
  font-size: 28rpx;
}
.dsi-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}
.dsi-verified-badge {
  background: var(--glass-secondary);
  color: #30D158;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 600;
  border: 1rpx solid rgba(48, 209, 88, 0.2);
}
.dsi-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.dsi-star {
  font-size: 24rpx;
}
.dsi-rating-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF9500;
}
.dsi-completed {
  font-size: 22rpx;
  color: var(--color-text-quaternary);
}

/* ═══════════════════════════════════════
   代购买家评价区块
═══════════════════════════════════════ */
.daigou-reviews-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 149, 0, 0.12);
}

.daigou-reviews-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.daigou-reviews-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
}

.daigou-reviews-count {
  font-size: 22rpx;
  color: var(--color-text-quaternary);
}

.daigou-reviews-loading {
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--color-text-quaternary);
}

.daigou-reviews-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.daigou-review-item {
  background: rgba(255, 149, 0, 0.04);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(255, 149, 0, 0.08);
}

.dr-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.dr-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dr-meta {
  flex: 1;
  min-width: 0;
}

.dr-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.dr-time {
  font-size: 20rpx;
  color: var(--color-text-quaternary);
}

.dr-badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.dr-badge.good {
  background: rgba(48, 209, 88, 0.1);
  color: #30D158;
  border: 1rpx solid rgba(48, 209, 88, 0.2);
}

.dr-badge.neutral {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
  border: 1rpx solid rgba(255, 149, 0, 0.2);
}

.dr-badge.bad {
  background: rgba(255, 69, 58, 0.08);
  color: #FF453A;
  border: 1rpx solid rgba(255, 69, 58, 0.15);
}

.dr-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

.dr-images {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.dr-img {
  width: 130rpx;
  height: 130rpx;
  border-radius: 10rpx;
  object-fit: cover;
}

.dr-load-more {
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #FF9500;
  font-weight: 500;
}

