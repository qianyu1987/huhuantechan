<!-- pages/detail/index.wxml - 特产详情页 - iOS 26 -->
<view class="detail-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:elif="{{product}}">
    <!-- 惊喜特产头图 -->
    <view class="mystery-hero {{mysteryColorClass}}" wx:if="{{product.isMystery}}">
      <view class="mystery-emoji">{{mysteryEmoji}}</view>
      <view class="mystery-label">惊喜特产</view>
    </view>

    <!-- 普通特产 - 图片轮播（圆角+渐变融入） -->
    <view wx:else class="img-container">
      <swiper class="img-swiper" indicator-dots indicator-active-color="#0A84FF" circular autoplay>
        <block wx:for="{{product.images}}" wx:key="index">
          <swiper-item>
            <image class="swiper-img" src="{{item}}" mode="aspectFill" bindtap="previewImages" data-index="{{index}}" binderror="onImageError" data-img-index="{{index}}"/>
          </swiper-item>
        </block>
      </swiper>
      <view class="img-fade-bottom"></view>
      <view class="img-count">{{product.images.length}} 张</view>
    </view>

    <!-- 基础信息卡 -->
    <view class="glass-card info-card">
      <text class="product-name">{{product.isMystery ? '惊喜特产' : product.name}}</text>

      <!-- 标签行：地区 + 品类 + 估值 -->
      <view class="tags-row">
        <view class="info-pill location-pill">📍 {{locationText}}</view>
        <view class="info-pill category-pill" wx:if="{{categoryName && !product.isMystery}}">{{categoryEmoji}} {{categoryName}}</view>
        <view class="info-pill value-pill" wx:if="{{valueLabel && !product.isMystery && featureFlags.feature_value_display !== false}}">{{valueEmoji}} {{valueLabel}}</view>
      </view>

      <!-- 描述标签 -->
      <view class="desc-tags-row" wx:if="{{descTagList.length > 0 && !product.isMystery}}">
        <view class="desc-pill" wx:for="{{descTagList}}" wx:key="id">{{item.emoji}} {{item.label}}</view>
      </view>

      <!-- 惊喜提示 -->
      <view class="mystery-hint-box" wx:if="{{product.isMystery}}">
        <text class="mystery-hint-text">🎁 这是一份惊喜特产，匹配成功后才能揭晓内容</text>
      </view>
    </view>

    <!-- 想换的特产 -->
    <view class="glass-card want-card" wx:if="{{wantLocationText || wantCategoryName}}">
      <view class="card-header">
        <view class="card-header-icon">🔄</view>
        <text class="card-header-title">感兴趣的特产</text>
      </view>
      <view class="want-tags-row">
        <view class="info-pill want-loc-pill" wx:if="{{wantLocationText}}">📍 {{wantLocationText}}</view>
        <view class="info-pill want-cat-pill" wx:if="{{wantCategoryName}}">{{wantCategoryEmoji}} {{wantCategoryName}}</view>
        <view class="info-pill" wx:if="{{!wantLocationText && !wantCategoryName}}">🌏 任意特产均可</view>
      </view>
    </view>

    <!-- 代购信息卡 -->
    <view class="glass-card daigou-card" wx:if="{{product.daigou && product.daigou.enabled}}">
      <view class="daigou-card-header">
        <view class="daigou-card-badge">🛒 支持代购</view>
        <view class="daigou-stock-tag" wx:if="{{product.daigou.stock > 0}}">库存 {{product.daigou.stock}} 件</view>
        <view class="daigou-stock-tag sold-out" wx:else>已售罄</view>
      </view>
      <view class="daigou-price-row">
        <view class="daigou-price-wrap">
          <text class="daigou-price-symbol">¥</text>
          <text class="daigou-price-num">{{product.daigou.price}}</text>
        </view>
        <view class="daigou-original-price" wx:if="{{product.daigou.originalPrice > product.daigou.price}}">
          原价 ¥{{product.daigou.originalPrice}}
        </view>
      </view>
      <view class="daigou-sold-row" wx:if="{{product.daigou.soldCount && product.daigou.soldCount > 0}}">
        已有 {{product.daigou.soldCount}} 人购买
      </view>
      <!-- 卖家代购等级信息（异步加载） -->
      <view wx:if="{{sellerDaigouInfo && sellerDaigouInfo.levelInfo}}" class="daigou-seller-info-row">
        <view class="dsi-level">
          <text class="dsi-icon">{{sellerDaigouInfo.levelInfo.icon}}</text>
          <text class="dsi-name" style="color:{{sellerDaigouInfo.levelInfo.color}}">{{sellerDaigouInfo.levelInfo.name}}</text>
          <view wx:if="{{sellerDaigouInfo.isVerified}}" class="dsi-verified-badge">✓ 已认证</view>
        </view>
        <view wx:if="{{sellerDaigouInfo.avgRating > 0}}" class="dsi-rating">
          <text class="dsi-star">⭐</text>
          <text class="dsi-rating-num">{{sellerDaigouInfo.avgRating}}</text>
          <text class="dsi-completed">· {{sellerDaigouInfo.completedOrders}}单</text>
        </view>
      </view>
      <view class="daigou-tips-row">
        <text class="daigou-tip-item">✅ 卖家亲选特产</text>
        <text class="daigou-tip-item">📦 48h内发货</text>
        <text class="daigou-tip-item">🔒 平台担保</text>
      </view>

      <!-- 代购买家评价 -->
      <view wx:if="{{daigouReviewCount > 0 || daigouReviewsLoading}}" class="daigou-reviews-section">
        <view class="daigou-reviews-header">
          <text class="daigou-reviews-title">🌟 买家评价</text>
          <text class="daigou-reviews-count" wx:if="{{daigouReviewCount > 0}}">{{daigouReviewCount}}条</text>
        </view>
        <view wx:if="{{daigouReviewsLoading && daigouReviews.length === 0}}" class="daigou-reviews-loading">
          <text>加载评价中...</text>
        </view>
        <view class="daigou-reviews-list" wx:elif="{{daigouReviews.length > 0}}">
          <view class="daigou-review-item" wx:for="{{daigouReviews}}" wx:key="_id">
            <view class="dr-top">
              <image class="dr-avatar" src="{{item.reviewerAvatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
              <view class="dr-meta">
                <text class="dr-name">{{item.reviewerName || '用户***'}}</text>
                <text class="dr-time">{{item.timeText}}</text>
              </view>
              <view class="dr-badge {{item.ratingClass}}">{{item.ratingLabel}}</view>
            </view>
            <text class="dr-content" wx:if="{{item.content}}">{{item.content}}</text>
            <view class="dr-images" wx:if="{{item.images && item.images.length > 0}}">
              <image
                class="dr-img"
                wx:for="{{item.images}}"
                wx:for-item="img"
                wx:key="index"
                src="{{img}}"
                mode="aspectFill"
              />
            </view>
          </view>
          <!-- 加载更多 -->
          <view wx:if="{{daigouReviewsHasMore}}" class="dr-load-more" bindtap="loadMoreDaigouReviews">
            <text wx:if="{{!daigouReviewsLoading}}">查看更多评价 ›</text>
            <text wx:else>加载中...</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 发布者卡片 -->
    <view class="glass-card publisher-card" bindtap="goToUserProfile" data-openid="{{publisher.openid || publisher._openid || product.openid || product._openid}}">
      <image class="pub-avatar" src="{{publisher.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="pub-info">
        <view class="pub-name-row">
          <text class="pub-name">{{publisher.nickName || '特产达人'}}</text>
          <view class="gender-badge {{publisher.gender === 'male' ? 'gender-male' : (publisher.gender === 'female' ? 'gender-female' : '')}}" wx:if="{{publisher.gender}}">
            {{publisher.gender === 'male' ? '👨' : (publisher.gender === 'female' ? '👩' : '')}}
          </view>
        </view>
        <view class="pub-meta">
          <text class="{{creditClass}}">信用 {{publisher.creditScore || 100}}分</text>
          <text class="pub-dot">·</text>
          <text class="pub-stat">已完成{{publisherSwapCount}}次分享</text>
        </view>
      </view>
      <view class="pub-arrow">›</view>
    </view>

    <!-- 发布者评价 -->
    <view class="glass-card reviews-card">
      <view class="card-header">
        <view class="card-header-icon">⭐</view>
        <text class="card-header-title">收到的评价</text>
        <text class="review-count" wx:if="{{reviewCount > 0}}">{{reviewCount}}条</text>
      </view>
      <view class="reviews-list" wx:if="{{reviews.length > 0}}">
        <view class="review-item" wx:for="{{reviews}}" wx:key="_id">
          <view class="review-top">
            <image class="review-avatar" src="{{item.reviewerAvatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="review-info">
              <text class="review-name">{{item.reviewerName}}</text>
              <text class="review-time">{{item.timeText}}</text>
            </view>
            <view class="review-badge {{item.ratingClass}}">{{item.ratingLabel}}</view>
          </view>
          <text class="review-content" wx:if="{{item.comment}}">{{item.comment}}</text>
        </view>
      </view>
      <view class="reviews-empty" wx:else>
        <text class="reviews-empty-icon">💬</text>
        <text class="reviews-empty-text">暂无评价，完成分享后可获得评价</text>
      </view>
    </view>

    <!-- 发布时间 -->
    <view class="time-row">
      发布于 {{timeLabel}}  ·  👁 {{product.viewCount || 0}} 次浏览
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view wx:if="{{isMine}}" class="bottom-bar-inner">
        <button class="bar-btn bar-btn-ghost" bindtap="editProduct">编辑</button>
        <button class="bar-btn bar-btn-danger" bindtap="removeProduct">下架</button>
      </view>
      <view wx:else class="bottom-bar-inner">
        <view class="fav-btn" bindtap="toggleFav">
          <text class="fav-icon">{{isFav ? '🩷' : '🤍'}}</text>
          <text class="fav-label" style="color:{{isFav ? '#FF453A' : ''}}">收藏</text>
        </view>
        <!-- 代购按钮（有代购且有库存） -->
        <button
          wx:if="{{product.daigou && product.daigou.enabled && product.daigou.stock > 0}}"
          class="bar-btn bar-btn-buy"
          bindtap="initiateBuy"
        >🛒 ¥{{product.daigou.price}} 立即购买</button>
        <!-- 代购已售罄但仍可互换 -->
        <block wx:elif="{{product.daigou && product.daigou.enabled && product.daigou.stock <= 0}}">
          <button class="bar-btn bar-btn-disabled" disabled style="flex:0 0 auto;width:auto;padding:0 24rpx;">已售罄</button>
          <button
            wx:if="{{featureFlags.feature_swap !== false}}"
            class="bar-btn bar-btn-swap"
            bindtap="initiateSwap"
          >🔄 我想要</button>
        </block>
        <!-- 无代购：互换按钮 -->
        <button
          wx:elif="{{featureFlags.feature_swap !== false}}"
          class="bar-btn bar-btn-swap"
          bindtap="initiateSwap"
        >🔄 我想要</button>
      </view>
    </view>
  </block>
</view>
