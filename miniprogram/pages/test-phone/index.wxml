<!-- pages/test-phone/index.wxml - 手机验证组件测试页面 -->
<view class="test-page">
  <view class="test-header">
    <view class="test-title">手机号验证组件测试</view>
    <view class="test-desc">快速验证手机号,提升信用分 +5</view>
  </view>

  <!-- 手机验证组件 -->
  <view class="test-section">
    <phone-verify 
      phone="{{phoneNumber}}" 
      verified="{{phoneVerified}}" 
      bind:verified="onPhoneVerified"
    />
  </view>

  <!-- 状态展示 -->
  <view class="test-section">
    <view class="status-card">
      <view class="status-title">验证状态</view>
      <view class="status-item">
        <text class="status-label">手机号:</text>
        <text class="status-value">{{phoneNumber || '未验证'}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">验证状态:</text>
        <text class="status-value {{phoneVerified ? 'verified' : 'unverified'}}">
          {{phoneVerified ? '已验证 ✓' : '未验证'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">信用分:</text>
        <text class="status-value">{{creditScore}}</text>
      </view>
    </view>
  </view>

  <!-- 功能说明 -->
  <view class="test-section">
    <view class="info-card">
      <view class="info-title">验证流程</view>
      <view class="info-item">
        <text class="info-num">1.</text>
        <text class="info-text">点击按钮授权微信手机号</text>
      </view>
      <view class="info-item">
        <text class="info-num">2.</text>
        <text class="info-text">微信自动验证,无需验证码</text>
      </view>
      <view class="info-item">
        <text class="info-num">3.</text>
        <text class="info-text">验证成功后获得信用分 +5</text>
      </view>
    </view>
  </view>

  <!-- 优势说明 -->
  <view class="test-section">
    <view class="success-card">
      <view class="success-title">✨ 微信原生方案优势</view>
      <view class="success-text">
        • 一键授权,快速便捷\n
        • 无需短信验证码\n
        • 无需付费短信服务\n
        • 更安全,更高效
      </view>
    </view>
  </view>
</view>
