/* pages/test-phone/index.wxss - 手机验证组件测试页面 */

.test-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 100%);
  padding: 32rpx;
  padding-top: calc(32rpx + env(safe-area-inset-top));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.test-header {
  text-align: center;
  margin-bottom: 48rpx;
  padding-top: 32rpx;
}

.test-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.test-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.test-section {
  margin-bottom: 32rpx;
}

/* 状态卡片 */
.status-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20rpx);
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.status-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.status-value.verified {
  color: #34C759;
}

.status-value.unverified {
  color: #FF9500;
}

/* 功能说明 */
.info-card {
  background: rgba(0, 122, 255, 0.1);
  border: 1rpx solid rgba(0, 122, 255, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20rpx);
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #007AFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

/* 注意事项 */
.warning-card {
  background: rgba(255, 149, 0, 0.1);
  border: 1rpx solid rgba(255, 149, 0, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20rpx);
}

.warning-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF9500;
  margin-bottom: 16rpx;
}

.warning-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.8;
  white-space: pre-line;
}

/* 优势说明 */
.success-card {
  background: rgba(52, 199, 89, 0.1);
  border: 1rpx solid rgba(52, 199, 89, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20rpx);
}

.success-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #34C759;
  margin-bottom: 16rpx;
}

.success-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
  white-space: pre-line;
}
