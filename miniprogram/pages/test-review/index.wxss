/* pages/test-review/index.wxss */
.container {
  padding: 20rpx;
}

.header {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}

.actions {
  margin-bottom: 30rpx;
}

.error {
  background: #ffeeee;
  border: 1rpx solid #ffcccc;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  color: #ff4444;
}

.section {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.result-item {
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.subtitle {
  display: block;
  margin: 20rpx 0 10rpx;
  font-weight: bold;
  color: #666;
}

.review-item {
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 15rpx;
  margin-bottom: 10rpx;
}

.review-item text {
  display: block;
  margin-bottom: 5rpx;
  font-size: 26rpx;
}

.no-data {
  color: #999;
  font-style: italic;
  text-align: center;
  padding: 20rpx;
}