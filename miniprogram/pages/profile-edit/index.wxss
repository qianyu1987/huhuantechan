/* pages/profile-edit/index.wxss - iOS 26 深色玻璃拟态风格 */
page {
  background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 50%, #0f0f1a 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

.profile-edit-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* ==================== 头部 Hero 区域 ==================== */
.header {
  padding: 60rpx 32rpx 40rpx;
  background: transparent;
}

.header-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
  display: block;
  text-shadow: 0 0 40rpx rgba(10, 132, 255, 0.3);
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
  letter-spacing: 0.5rpx;
}

/* ==================== 头像区域 ==================== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  margin: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.avatar-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.4);
}

.avatar-edit-icon {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #0A84FF 0%, #0051D5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 3rpx solid #0f0f1a;
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.4);
}

.avatar-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 20rpx;
  letter-spacing: 0.5rpx;
}

/* ==================== 玻璃卡片 ==================== */
.card {
  margin: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  padding: 28rpx 28rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.card-tip {
  font-size: 22rpx;
  color: #FF9500;
  font-weight: 500;
  margin-left: auto;
  background: rgba(255, 149, 0, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* ==================== 字段行 ==================== */
.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  min-height: 88rpx;
}

.field-row:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  flex-shrink: 0;
  flex-basis: 180rpx;
  letter-spacing: 0.3rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  padding-left: 24rpx;
}

.field-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.field-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  flex: 1;
}

.field-value text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
}

.field-value .placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* picker 外层重置，防止错位 */
picker {
  display: block;
}

picker .field-row {
  margin: 0;
  padding: 28rpx;
}

.value-emoji {
  font-size: 36rpx;
}

/* ==================== 详细信息卡片增强样式 ==================== */
.detail-card {
  overflow: visible;
}

/* 生日选择区域 - 重点突出 */
.birthday-section {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  margin: 20rpx;
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.12) 0%, rgba(255, 204, 0, 0.08) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 149, 0, 0.2);
  transition: all 0.2s ease;
}

.birthday-section:active:not(.locked) {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.18) 0%, rgba(255, 204, 0, 0.12) 100%);
}

.birthday-section.locked {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
}

.birthday-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9500 0%, #FFCC00 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.3);
}

.birthday-info {
  flex: 1;
  margin-left: 24rpx;
}

.birthday-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.birthday-value {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.birthday-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 300;
  margin-left: 12rpx;
}

.birthday-lock {
  font-size: 32rpx;
  opacity: 0.6;
  margin-left: 12rpx;
}

/* 省份选择区域 - 与生日样式统一 */
.province-section {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  margin: 8rpx 20rpx 20rpx 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.province-section:active:not(.locked) {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.province-section.locked {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
}

/* 已选择省份的特殊样式 */
.province-section.selected {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.12) 0%, rgba(48, 185, 77, 0.08) 100%);
  border-color: rgba(52, 199, 89, 0.25);
}

.province-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #34C759 0%, #30B94D 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.3);
}

.province-info {
  flex: 1;
  margin-left: 24rpx;
}

.province-info.selected {
  margin-left: 24rpx;
}

.province-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 4rpx;
  font-weight: 500;
}

.province-value {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.province-value .placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.province-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 300;
  margin-left: 12rpx;
}

.province-lock {
  font-size: 32rpx;
  opacity: 0.6;
  margin-left: 12rpx;
}

/* 省份徽章样式 */
.province-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.province-badge-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.province-value-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.province-value-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.province-locked-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.province-lock-icon {
  font-size: 20rpx;
}

.province-lock-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 属相/星座/年龄卡片组 */
.zodiac-cards {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx 24rpx;
}

.zodiac-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 140rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.2s ease;
}

.zodiac-card:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.96);
}

.zodiac-emoji {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}

.zodiac-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
  margin-bottom: 6rpx;
}

.zodiac-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* 年龄卡片特殊样式 */
.age-card {
  background: linear-gradient(135deg, rgba(10, 132, 255, 0.15) 0%, rgba(88, 86, 214, 0.1) 100%);
  border-color: rgba(10, 132, 255, 0.2);
}

.age-card .zodiac-emoji {
  font-size: 40rpx;
}

.age-card .zodiac-name {
  font-size: 36rpx;
  color: #0A84FF;
}

/* 卡片提示锁定状态 */
.card-tip-locked {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.5);
}

/* ==================== 性别选择按钮 ==================== */
.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  padding: 18rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  backdrop-filter: blur(10rpx);
}

.gender-btn.active {
  background: rgba(10, 132, 255, 0.2);
  color: #0A84FF;
  border-color: #0A84FF;
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.3),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.gender-btn:active {
  transform: scale(0.96);
}

/* ==================== 保存按钮 ==================== */
.save-section {
  padding: 32rpx;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 15, 26, 0.9);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.save-btn {
  height: 104rpx;
  background: linear-gradient(135deg, #0A84FF 0%, #0051D5 100%);
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.4),
              0 0 40rpx rgba(10, 132, 255, 0.2);
  transition: all 0.3s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.3);
}

/* ==================== 装饰元素 ==================== */
.profile-edit-page::before {
  content: '';
  position: fixed;
  top: -400rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.profile-edit-page::after {
  content: '';
  position: fixed;
  bottom: -300rpx;
  left: -200rpx;
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255, 45, 85, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* ==================== 省份选择弹窗 ====================*/
.province-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.province-modal.show {
  visibility: visible;
  opacity: 1;
}

.province-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
}

.province-modal-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: rgba(30, 30, 46, 0.95);
  backdrop-filter: blur(40rpx);
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.province-modal.show .province-modal-content {
  transform: translateY(0);
}

.province-modal-header {
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.province-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.province-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

/* 热门省份 */
.province-hot {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.province-hot-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.province-hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.province-hot-item {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.province-hot-item:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.12);
}

.province-hot-item.active {
  background: rgba(10, 132, 255, 0.3);
  border-color: #0A84FF;
  color: #0A84FF;
}

/* 省份列表 */
.province-list {
  flex: 1;
  max-height: 50vh;
  padding: 16rpx 0;
}

.province-group {
  margin-bottom: 8rpx;
}

.province-group-letter {
  padding: 12rpx 40rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #0A84FF;
  background: rgba(10, 132, 255, 0.1);
  position: sticky;
  top: 0;
}

.province-group-items {
  padding: 8rpx 0;
}

.province-item {
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  transition: all 0.2s ease;
}

.province-item:active {
  background: rgba(255, 255, 255, 0.06);
}

.province-item.active {
  color: #0A84FF;
  background: rgba(10, 132, 255, 0.15);
}

.province-item.active::after {
  content: ' ✓';
  color: #0A84FF;
}
