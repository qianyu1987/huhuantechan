/* pages/profile-edit/index.wxss */
.container {
  min-height: 100vh;
  background: #F2F2F7;
  padding: 20rpx;
}

/* 头像区域 */
.avatar-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 32rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #E5E5EA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder .iconfont {
  font-size: 60rpx;
  color: #8E8E93;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F2F2F7;
}

.avatar-tip {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 32rpx;
  color: #1C1C1E;
  font-weight: 500;
  flex-shrink: 0;
  width: 120rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #1C1C1E;
}

.form-input::placeholder {
  color: #8E8E93;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #1C1C1E;
}

.form-value.placeholder {
  color: #8E8E93;
}

.locked-tip {
  color: #E63946;
  font-size: 24rpx;
  margin-left: 10rpx;
}

.form-tip {
  font-size: 24rpx;
  color: #E63946;
  padding: 10rpx 0;
}

/* 保存按钮 */
.save-section {
  padding: 40rpx 30rpx;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #007AFF;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 45rpx;
  border: none;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F2F2F7;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.modal-close {
  font-size: 40rpx;
  color: #8E8E93;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.province-picker {
  height: 80rpx;
  background: #F2F2F7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #007AFF;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-default {
  background: #F2F2F7;
  color: #1C1C1E;
}

.btn-primary {
  background: #007AFF;
  color: #fff;
}
