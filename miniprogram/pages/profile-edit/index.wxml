<view class="container">
  <!-- 头像 -->
  <view class="avatar-section" bindtap="chooseAvatar">
    <text class="section-label">头像</text>
    <view class="avatar-wrapper">
      <view class="avatar-placeholder" wx:if="{{!avatarUrl}}">
        <text class="iconfont icon-user"></text>
      </view>
      <image wx:else class="avatar" src="{{avatarUrl}}" mode="aspectFill"/>
      <text class="avatar-tip">点击更换</text>
    </view>
  </view>

  <!-- 昵称 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{nickName}}" bindinput="onNickNameInput" maxlength="20"/>
    </view>
  </view>

  <!-- 家乡 -->
  <view class="form-section">
    <view class="form-item" bindtap="selectProvince">
      <text class="form-label">家乡</text>
      <view class="form-value {{provinceName ? '' : 'placeholder'}}">
        {{provinceName || '请选择家乡'}}
        <text wx:if="{{hasProvince}}" class="locked-tip">（已锁定）</text>
      </view>
    </view>
    <view class="form-tip" wx:if="{{hasProvince}}">
      * 家乡设置后无法修改
    </view>
    <view class="form-tip" wx:else>
      * 选择后无法修改，请谨慎选择
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button class="save-btn" bindtap="saveProfile">保存</button>
  </view>

  <!-- 省份选择弹窗 -->
  <view wx:if="{{showProvincePicker}}" class="modal-mask" bindtap="cancelProvince">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">选择家乡</text>
        <text class="modal-close" bindtap="cancelProvince">×</text>
      </view>
      <view class="modal-body">
        <picker mode="selector" range="{{provinces}}" range-key="name" value="{{provinceIndex}}" bindchange="onProvinceChange">
          <view class="province-picker">
            点击选择省份
          </view>
        </picker>
      </view>
      <view class="modal-footer">
        <button class="btn btn-default" bindtap="cancelProvince">取消</button>
        <button class="btn btn-primary" bindtap="confirmProvince">确认</button>
      </view>
    </view>
  </view>
</view>
