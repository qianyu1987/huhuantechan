/* pages/network-test/index.wxss */
.network-test-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.status-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.status-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.value.success {
  color: #07c160;
}

.value.error {
  color: #fa5151;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.test-btn {
  flex: 1;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.test-btn::after {
  border: none;
}

.logs-section {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.logs-title {
  font-size: 28rpx;
  font-weight: bold;
}

.logs-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #576b95;
}

.logs-list {
  height: 600rpx;
  padding: 20rpx;
}

.log-item {
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 10rpx;
  padding: 10rpx;
  background: #f9f9f9;
  border-radius: 6rpx;
}

.log-item.error {
  background: #fff3f3;
  color: #fa5151;
}

.log-item.success {
  background: #f0fff4;
  color: #07c160;
}

.log-item.info {
  background: #f0f7ff;
  color: #576b95;
}

.log-time {
  color: #999;
  margin-right: 10rpx;
}

.log-msg {
  word-break: break-all;
}
