<!-- pages/article-list/index.wxml - 文章列表 -->
<view class="page">
  <view class="header">
    <view class="back" bindtap="goBack">‹</view>
    <text class="title">最新资讯</text>
  </view>
  
  <scroll-view scroll-y class="content">
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    
    <view wx:for="{{articles}}" wx:key="_id" class="article-item" bindtap="goToDetail" data-id="{{item._id}}" data-url="{{item.sourceUrl}}">
      <image class="cover" src="{{item.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"/>
      <view class="info">
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <text class="article-time">{{item.publishTimeText}}</text>
      </view>
    </view>
    
    <view wx:if="{{!loading && articles.length === 0}}" class="empty">暂无文章</view>
  </scroll-view>
</view>