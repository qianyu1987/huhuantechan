/* pages/withdrawal/index.wxss - 提现页面样式 */

/* ===== 页面基础 ===== */
page {
  --color-bg: #F2F4F8;
  --color-card: #FFFFFF;
  --color-text: #1C1C1E;
  --color-sub: #636366;
  --color-hint: #8E8E93;
  --color-primary: #0A84FF;
  --color-green: #30D158;
  --color-red: #FF3B30;
  --color-orange: #FF9500;
  --radius-card: 24rpx;
  --radius-pill: 100rpx;
  --shadow-card: 0 2rpx 12rpx rgba(0,0,0,0.06);
  
  background: var(--color-bg);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.withdrawal-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top { height: 16rpx; }
.safe-bottom { height: 60rpx; }

/* ===== 返回头部 ===== */
.back-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.07);
}

.back-icon {
  font-size: 36rpx;
  color: #000;
  margin-right: 12rpx;
}

.back-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
}

/* ===== 提现概览 ===== */
.withdrawal-hero {
  position: relative;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #00C7BE 0%, #00A8A8 100%);
  color: #fff;
}

.withdrawal-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="2"/></svg>');
  opacity: 0.3;
}

.withdrawal-hero-content {
  position: relative;
  z-index: 1;
}

.withdrawal-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.withdrawal-hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 32rpx;
}

.balance-display {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 8rpx;
}

.balance-amount {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.balance-total {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

.threshold-info {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.threshold-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.threshold-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 滚动区域 ===== */
.withdrawal-scroll {
  height: calc(100vh - 400rpx);
}

/* ===== 通用样式 ===== */
.mx-lg { margin-left: 24rpx; margin-right: 24rpx; }
.mt-lg { margin-top: 24rpx; }

.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.glass-card {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
}

.section {
  padding: 32rpx;
}

.section-hd {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-emoji {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
}

.section-arrow {
  font-size: 32rpx;
  color: var(--color-hint);
}

.section-desc {
  font-size: 24rpx;
  color: var(--color-sub);
  display: block;
}

/* ===== 表单样式 ===== */
.withdrawal-form {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}

.amount-input-group {
  display: flex;
  align-items: center;
  background: rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.1);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.amount-prefix {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
  height: 100%;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-hint {
  font-size: 22rpx;
  color: var(--color-red);
  min-height: 30rpx;
}

/* ===== 手续费显示 ===== */
.fee-display {
  background: rgba(0,199,190,0.08);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-label {
  font-size: 24rpx;
  color: #666;
}

.fee-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-red);
}

.actual-amount {
  color: var(--color-green);
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 快捷金额 ===== */
.quick-amounts {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-amounts-label {
  font-size: 24rpx;
  color: var(--color-sub);
}

.quick-amounts-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-amount-btn {
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  background: rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.1);
  transition: all 0.2s ease;
}

.quick-amount-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.quick-amount-active {
  background: #00C7BE;
  border-color: #00C7BE;
  color: #fff;
}

/* ===== 提现说明 ===== */
.withdrawal-tips {
  background: rgba(0,199,190,0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #00A8A8;
  display: block;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

/* ===== 提交按钮 ===== */
.submit-btn-container {
  margin-top: 32rpx;
}

.submit-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  border: none;
  outline: none;
  width: 100%;
}

.submit-btn::after {
  border: none;
}

.submit-btn-active {
  background: linear-gradient(135deg, #00C7BE 0%, #00A8A8 100%);
  box-shadow: 0 8rpx 24rpx rgba(0,199,190,0.3);
}

.submit-btn-disabled {
  background: rgba(0,0,0,0.1);
  color: rgba(0,0,0,0.3);
}

.submit-btn-active:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ===== 加载状态 ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}