/* pages/dashboard/index.wxss - 运营数据看板样式 */

/* ── 全局 ── */
.page {
  background: #0d1117;
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
  color: #e6edf3;
}

/* ── 顶部栏 ── */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 16rpx;
}
.topbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.topbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #e6edf3;
}
.live-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(63,185,80,0.15);
  border: 1rpx solid rgba(63,185,80,0.3);
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
}
.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #3fb950;
  animation: livePulse 1.5s ease-in-out infinite;
}
@keyframes livePulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.live-text {
  font-size: 22rpx;
  color: #3fb950;
}
.topbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.update-time {
  font-size: 22rpx;
  color: #8b949e;
}
.refresh-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(139,148,158,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-hover {
  opacity: 0.6;
}
.refresh-icon {
  font-size: 32rpx;
  color: #8b949e;
  display: inline-block;
}
.refresh-icon.spin {
  animation: spin 1s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ── 时间范围 ── */
.range-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.range-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #8b949e;
  background: rgba(139,148,158,0.08);
  border: 1rpx solid rgba(139,148,158,0.15);
  transition: all 0.2s;
}
.range-btn.active {
  color: #58a6ff;
  background: rgba(88,166,255,0.12);
  border-color: rgba(88,166,255,0.35);
  font-weight: 600;
}

/* ── 骨架屏 ── */
.skeleton-wrap {
  padding: 0;
}
.skeleton-kpi-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.skeleton-card {
  background: #161b22;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #21262d;
}
.sk {
  border-radius: 8rpx;
  background: linear-gradient(90deg, #21262d 25%, #30363d 50%, #21262d 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 12rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.sk-label { height: 24rpx; width: 60%; }
.sk-value { height: 48rpx; width: 80%; }
.sk-sub { height: 20rpx; width: 50%; margin-bottom: 0; }
.skeleton-block {
  height: 240rpx;
  background: #161b22;
  border-radius: 20rpx;
  border: 1rpx solid #21262d;
  margin-bottom: 16rpx;
  overflow: hidden;
  position: relative;
}
.skeleton-block::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(48,54,61,0.5) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.skeleton-half-row {
  display: flex;
  gap: 16rpx;
}
.skeleton-block.half {
  flex: 1;
}

/* ── 错误提示 ── */
.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 60rpx 0;
  color: #8b949e;
}
.error-icon { font-size: 64rpx; }
.error-text { font-size: 28rpx; }
.retry-btn {
  padding: 16rpx 40rpx;
  border-radius: 20rpx;
  background: rgba(88,166,255,0.15);
  border: 1rpx solid rgba(88,166,255,0.4);
  color: #58a6ff;
  font-size: 28rpx;
}

/* ── KPI 卡片 ── */
.kpi-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.kpi-card {
  padding: 28rpx 24rpx 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid #21262d;
  background: #161b22;
}
.kpi-card.blue  { border-left: 4rpx solid #58a6ff; }
.kpi-card.green { border-left: 4rpx solid #3fb950; }
.kpi-card.purple { border-left: 4rpx solid #bc8cff; }
.kpi-card.orange { border-left: 4rpx solid #f78166; }
.kpi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.kpi-label {
  font-size: 22rpx;
  color: #8b949e;
}
.kpi-icon { font-size: 28rpx; }
.kpi-value {
  font-size: 52rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 8rpx;
  font-variant-numeric: tabular-nums;
}
.blue-text { color: #58a6ff; }
.green-text { color: #3fb950; }
.purple-text { color: #bc8cff; }
.orange-text { color: #f78166; }
.kpi-footer { display: flex; gap: 8rpx; flex-wrap: wrap; }
.kpi-change {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}
.kpi-change.up { background: rgba(63,185,80,0.1); color: #3fb950; }
.kpi-change.flat { background: rgba(139,148,158,0.1); color: #8b949e; }
.kpi-change.orange { background: rgba(247,129,102,0.1); color: #f78166; }

/* ── 通用卡片 ── */
.section-card {
  background: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}
.section-top-margin {
  margin-top: 8rpx;
  padding: 0 4rpx;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
}
.card-badge {
  font-size: 20rpx;
  color: #8b949e;
  background: rgba(139,148,158,0.1);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* ── 省份排行 ── */
.rank-list {}
.rank-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}
.rank-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  background: rgba(139,148,158,0.12);
  color: #8b949e;
}
.rank-num.gold   { background: rgba(255,214,10,0.15); color: #FFD60A; }
.rank-num.silver { background: rgba(198,198,200,0.15); color: #c6c6c8; }
.rank-num.bronze { background: rgba(205,127,50,0.15); color: #cd7f32; }
.rank-emoji { font-size: 28rpx; flex-shrink: 0; }
.rank-name { font-size: 26rpx; width: 80rpx; flex-shrink: 0; color: #e6edf3; }
.rank-bar-wrap {
  flex: 1;
  height: 10rpx;
  background: #21262d;
  border-radius: 5rpx;
  overflow: hidden;
}
.rank-bar {
  height: 100%;
  background: linear-gradient(90deg, #1f6feb, #58a6ff);
  border-radius: 5rpx;
  transition: width 0.6s ease;
}
.rank-count {
  font-size: 24rpx;
  color: #8b949e;
  width: 52rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ── 品类分布 ── */
.cat-grid {}
.cat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.cat-emoji { font-size: 32rpx; flex-shrink: 0; }
.cat-info { flex: 1; }
.cat-name { font-size: 24rpx; color: #e6edf3; display: block; margin-bottom: 8rpx; }
.cat-bar-wrap {
  height: 8rpx;
  background: #21262d;
  border-radius: 4rpx;
  overflow: hidden;
}
.cat-bar {
  height: 100%;
  background: linear-gradient(90deg, #388bfd, #bc8cff);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}
.cat-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 72rpx;
}
.cat-count { font-size: 24rpx; color: #e6edf3; font-weight: 600; }
.cat-pct { font-size: 20rpx; color: #8b949e; }

/* ── 信用等级 ── */
.credit-list {}
.credit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #1c2128;
  margin-bottom: 12rpx;
}
.credit-left { min-width: 120rpx; }
.credit-badge {
  display: inline-flex;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.credit-mid { flex: 1; }
.credit-bar-wrap {
  height: 8rpx;
  background: #21262d;
  border-radius: 4rpx;
  overflow: hidden;
}
.credit-bar {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.6s ease;
}
.credit-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 72rpx;
}
.credit-count { font-size: 24rpx; font-weight: 700; }
.credit-pct { font-size: 20rpx; color: #8b949e; }

/* ── 订单漏斗 ── */
.funnel-list {}
.funnel-item {
  margin-bottom: 20rpx;
}
.funnel-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.funnel-step { font-size: 26rpx; color: #e6edf3; }
.funnel-value { font-size: 24rpx; color: #8b949e; }
.funnel-bar-bg {
  height: 14rpx;
  background: #21262d;
  border-radius: 7rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}
.funnel-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #3fb950, #56d364);
  border-radius: 7rpx;
  transition: width 0.6s ease;
}
.funnel-pct {
  font-size: 20rpx;
  color: #3fb950;
  display: block;
  text-align: right;
}

/* ── 小指标 ── */
.sm-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.sm-item {
  background: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.sm-icon { font-size: 34rpx; }
.sm-val { font-size: 32rpx; font-weight: 800; font-variant-numeric: tabular-nums; }
.sm-label { font-size: 20rpx; color: #8b949e; }

/* ── 空数据 ── */
.empty-tip {
  text-align: center;
  color: #8b949e;
  font-size: 26rpx;
  padding: 40rpx 0;
}
