            <text class="ltc ltc-name">名称</text>
            <text class="ltc ltc-deposit">押金</text>
            <text class="ltc ltc-rate">费率</text>
            <text class="ltc ltc-limit">单笔限额</text>
          </view>
          <view class="lt-row"><text class="ltc ltc-lv lv0">🌱 Lv.1</text><text class="ltc ltc-name">新手代购</text><text class="ltc ltc-deposit gray">免押金</text><text class="ltc ltc-rate lv0">—</text><text class="ltc ltc-limit">¥200</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv1">🌿 Lv.2</text><text class="ltc ltc-name">见习代购</text><text class="ltc ltc-deposit gray">免押金</text><text class="ltc ltc-rate lv1">—</text><text class="ltc ltc-limit">¥500</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv2">⭐ Lv.3</text><text class="ltc ltc-name">普通代购</text><text class="ltc ltc-deposit gray">免押金</text><text class="ltc ltc-rate lv2">—</text><text class="ltc ltc-limit">¥1000</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv3">💫 Lv.4</text><text class="ltc ltc-name">资深代购</text><text class="ltc ltc-deposit">¥200</text><text class="ltc ltc-rate lv3">—</text><text class="ltc ltc-limit">¥3000</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv4">🥇 Lv.5</text><text class="ltc ltc-name">金牌代购</text><text class="ltc ltc-deposit">¥500</text><text class="ltc ltc-rate lv4">—</text><text class="ltc ltc-limit">¥10000</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv5">💎 Lv.6</text><text class="ltc ltc-name">钻石代购</text><text class="ltc ltc-deposit">¥2000</text><text class="ltc ltc-rate lv5">—</text><text class="ltc ltc-limit">¥50000</text></view>
          <view class="lt-row"><text class="ltc ltc-lv lv6">👑 Lv.7</text><text class="ltc ltc-name">传奇代购</text><text class="ltc ltc-deposit">¥5000</text><text class="ltc ltc-rate lv6">—</text><text class="ltc ltc-limit">不限</text></view>
        </view>
        <text class="lsv3-note">💡 自由代购(Lv.1-4)：靠积累订单自然升级 | 平台认证(Lv.5-7)：需管理员人工认定</text>
      </view>
      <view class="search-bar">
        <text class="search-icon-emoji">🔍</text>
        <input class="search-input-field" placeholder="搜索用户昵称" bindinput="onLevelUserSearch" value="{{levelUserKeyword}}" />
      </view>
      <view class="chip-bar">
        <view class="chip {{levelUserFilter === 'all' ? 'chip-active' : ''}}" bindtap="changeLevelUserFilter" data-filter="all">全部</view>
        <view class="chip {{levelUserFilter === 'verified' ? 'chip-active' : ''}}" bindtap="changeLevelUserFilter" data-filter="verified">✅ 已认证</view>
        <view class="chip {{levelUserFilter === 'has_deposit' ? 'chip-active' : ''}}" bindtap="changeLevelUserFilter" data-filter="has_deposit">💰 已押金</view>
        <view class="chip {{levelUserFilter === 'no_deposit' ? 'chip-active' : ''}}" bindtap="changeLevelUserFilter" data-filter="no_deposit">⚠️ 未押金</view>
      </view>
      <view wx:if="{{levelUsers.length === 0 && !levelUserLoading}}" class="empty-state">
        <text class="empty-emoji">👤</text>
        <text class="empty-label">暂无用户数据</text>
      </view>
      <view class="list-wrap">
        <view class="level-user-card-v3" wx:for="{{levelUsers}}" wx:key="_id">
          <view class="luv3-header">
            <image class="luv3-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="luv3-info">
              <text class="luv3-name">{{item.nickName}}</text>
              <view class="luv3-tags">
                <view class="lv-badge lv-badge-{{item.daigouLevel}}">{{item.daigouLevelName}}</view>
                <text class="luv3-credit">信用 {{item.creditScore}}</text>
                <text class="luv3-verify {{item.isDaigouVerified ? 'verified' : ''}}">{{item.isDaigouVerified ? '✅认证' : '未认证'}}</text>
              </view>
            </view>
            <view class="act-btn act-edit" catchtap="openLevelModal" data-openid="{{item.openid}}" data-index="{{index}}">调等级</view>
          </view>
          <view class="luv3-stats">
            <view class="luv3-stat"><text class="luv3-stat-val">¥{{item.depositPaid || 0}}</text><text class="luv3-stat-label">总押金</text></view>
            <view class="luv3-stat"><text class="luv3-stat-val {{item.depositBalance > 0 ? 'ok' : 'low'}}">¥{{item.depositBalance || 0}}</text><text class="luv3-stat-label">余额</text></view>
            <view class="luv3-stat"><text class="luv3-stat-val">{{item.completedOrders || 0}}</text><text class="luv3-stat-label">成交</text></view>
            <view class="luv3-stat"><text class="luv3-stat-val {{item.requiredDeposit > 0 ? 'need' : 'free'}}">¥{{item.requiredDeposit || 0}}</text><text class="luv3-stat-label">需押金</text></view>
          </view>
          <view class="luv3-deposit-row">
            <text class="luv3-deposit-label">💰 押金管理</text>
            <view style="display:flex;gap:8rpx;flex-wrap:wrap;">
              <view class="act-btn act-warning" catchtap="openDepositInputModal" data-openid="{{item.openid}}" data-index="{{index}}" data-mode="set">录入/修改</view>
              <view class="act-btn act-green" catchtap="openDepositInputModal" data-openid="{{item.openid}}" data-index="{{index}}" data-mode="add">补押金</view>
              <view class="act-btn act-danger" catchtap="openDepositInputModal" data-openid="{{item.openid}}" data-index="{{index}}" data-mode="refund">退押金</view>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{levelUserLoading}}" class="loading-row">⏳ 加载中...</view>
      <view wx:if="{{levelUserNoMore && levelUsers.length > 0}}" class="loading-row">已加载全部</view>
    </block>
  </block>

  <!-- ===== 邀请裂变配置（Tab=16）===== -->
  <block wx:if="{{currentTab === 16}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-state">
      <text class="empty-emoji">🔐</text>
      <text class="empty-label">需要超级管理员权限</text>
    </view>
    <block wx:else>
      <!-- 邀请裂变配置卡片 -->
      <view class="invite-config-card">
        <text class="invite-config-title">🎯 邀请裂变配置</text>
        <text class="invite-config-desc">设置邀请好友的现金奖励、积分奖励和提现门槛</text>
        
        <!-- 奖励金额配置 -->
        <view class="config-section">
          <text class="config-section-title">💰 现金奖励</text>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">邀请人奖励</text>
              <text class="config-item-desc">每成功邀请一位好友注册</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">¥</text>
              <input class="config-input" type="digit" value="{{inviteConfig.inviterReward}}" placeholder="0.30" bindinput="onInviterRewardInput" />
            </view>
          </view>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">被邀请人奖励</text>
              <text class="config-item-desc">新用户通过邀请码注册</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">¥</text>
              <input class="config-input" type="digit" value="{{inviteConfig.inviteeReward}}" placeholder="0.10" bindinput="onInviteeRewardInput" />
            </view>
          </view>
        </view>

        <!-- 积分奖励配置 -->
        <view class="config-section">
          <text class="config-section-title">⭐ 积分奖励</text>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">邀请人积分</text>
              <text class="config-item-desc">邀请成功后邀请人获得积分</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">分</text>
              <input class="config-input" type="number" value="{{inviteConfig.inviterPoints}}" placeholder="0" bindinput="onInviterPointsInput" />
            </view>
          </view>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">被邀请人积分</text>
              <text class="config-item-desc">新用户注册后获得积分</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">分</text>
              <input class="config-input" type="number" value="{{inviteConfig.inviteePoints}}" placeholder="0" bindinput="onInviteePointsInput" />
            </view>
          </view>
        </view>
        
        <!-- 提现配置 -->
        <view class="config-section">
          <text class="config-section-title">💳 提现配置</text>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">提现门槛</text>
              <text class="config-item-desc">最低提现金额</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">¥</text>
              <input class="config-input" type="digit" value="{{inviteConfig.withdrawalThreshold}}" placeholder="30.00" bindinput="onWithdrawalThresholdInput" />
            </view>
          </view>
        </view>
        
        <!-- 保存按钮 -->
        <view class="save-config-btn" bindtap="saveInviteConfig">
          <text>保存配置</text>
        </view>
        
        <!-- 配置说明 -->
        <view class="config-tips">
          <text class="config-tips-title">📝 配置说明</text>
          <view class="config-tips-list">
            <text class="config-tips-item">1. 奖励金额支持小数点后两位（如：0.30）</text>
            <text class="config-tips-item">2. 积分设为 0 表示不赠送积分</text>
            <text class="config-tips-item">3. 修改后立即生效，新邀请按新规则计算</text>
            <text class="config-tips-item">4. 历史邀请记录奖励保持不变</text>
            <text class="config-tips-item">5. 提现门槛为最低可提现金额</text>
          </view>
        </view>
      </view>
    </block>
  </block>

  <!-- ===== 纠纷处理（Tab=18）===== -->
  <block wx:if="{{currentTab === 18}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-state">
      <text class="empty-emoji">🔐</text>
      <text class="empty-label">需要超级管理员权限</text>
    </view>
    <block wx:else>
      <!-- 统计卡片 -->
      <view class="stats-cards">
        <view class="stats-card">
          <text class="stats-card-num">{{disputeStats.pending}}</text>
          <text class="stats-card-label">待处理</text>
        </view>
        <view class="stats-card">
          <text class="stats-card-num">{{disputeStats.processing}}</text>
          <text class="stats-card-label">处理中</text>
        </view>
        <view class="stats-card">
          <text class="stats-card-num">{{disputeStats.resolved}}</text>
          <text class="stats-card-label">已解决</text>
        </view>
        <view class="stats-card">
          <text class="stats-card-num">{{disputeStats.closed}}</text>
          <text class="stats-card-label">已关闭</text>
        </view>
      </view>

      <!-- 筛选标签 -->
      <view class="filter-tabs">
        <view class="filter-tab {{disputeFilter === '' ? 'active' : ''}}" bindtap="switchDisputeFilter" data-filter="">全部</view>
        <view class="filter-tab {{disputeFilter === 'pending' ? 'active' : ''}}" bindtap="switchDisputeFilter" data-filter="pending">待处理</view>
        <view class="filter-tab {{disputeFilter === 'processing' ? 'active' : ''}}" bindtap="switchDisputeFilter" data-filter="processing">处理中</view>
        <view class="filter-tab {{disputeFilter === 'resolved' ? 'active' : ''}}" bindtap="switchDisputeFilter" data-filter="resolved">已解决</view>
        <view class="filter-tab {{disputeFilter === 'closed' ? 'active' : ''}}" bindtap="switchDisputeFilter" data-filter="closed">已关闭</view>
      </view>

      <!-- 纠纷列表 -->
      <view class="dispute-list">
        <view wx:for="{{disputeList}}" wx:key="_id" class="dispute-item">
          <!-- 头部：状态和时间（可点击查看详情） -->
          <view class="dispute-header" bindtap="showDisputeDetail" data-item="{{item}}" style="cursor:pointer;">
            <view class="dispute-header-left">
              <text class="dispute-status {{item.status}}">{{item.statusLabel}}</text>
              <text class="dispute-type" wx:if="{{item.type}}">{{item.type}}</text>
            </view>
            <view style="display:flex;align-items:center;gap:12rpx;">
              <text class="dispute-time">{{item.createTimeText}}</text>
              <text style="font-size:26rpx;color:#0A84FF;font-weight:600;">查看 ›</text>
            </view>
          </view>
          
          <!-- 纠纷简要信息（始终显示） -->
          <view class="dispute-content">
            <view class="dispute-reason-wrap">
              <text class="dispute-reason-label">纠纷原因：</text>
              <text class="dispute-reason">{{item.reason}}</text>
            </view>
            <view class="dispute-desc-wrap" wx:if="{{item.description}}">
              <text class="dispute-desc-label">详细描述：</text>
              <text class="dispute-desc" style="display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden;">{{item.description}}</text>
            </view>
          </view>
          
          <!-- 操作按钮 -->
          <view class="dispute-actions" wx:if="{{item.status === 'pending' || item.status === 'processing'}}">
            <view class="dispute-btn close" bindtap="showDisputeModal" data-item="{{item}}" data-action="close">
              <text class="dispute-btn-icon">✕</text>
              <text>关闭纠纷</text>
            </view>
            <view class="dispute-btn resolve" bindtap="showDisputeModal" data-item="{{item}}" data-action="resolve">
              <text class="dispute-btn-icon">✓</text>
              <text>解决纠纷</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{disputeLoading && disputeList.length > 0}}">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view class="load-more" wx:if="{{!disputeLoading && disputeNoMore && disputeList.length > 0}}">
        <text>— 已经到底啦 —</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!disputeLoading && disputeList.length === 0}}" class="empty-state">
        <text class="empty-emoji">⚖️</text>
        <text class="empty-label">暂无纠纷记录</text>
      </view>
    </block>
  </block>

  <!-- ===== 举报管理（Tab=18）===== -->
  <block wx:if="{{currentTab === 18}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-state">
      <text class="empty-emoji">🔐</text>
      <text class="empty-label">需要超级管理员权限</text>
    </view>
    <block wx:else>
      <!-- 统计卡片 -->
      <view class="stats-cards">
        <view class="stats-card">
          <text class="stats-card-num">{{reportStats.pending}}</text>
          <text class="stats-card-label">待处理</text>
        </view>
        <view class="stats-card">
          <text class="stats-card-num">{{reportStats.handled}}</text>
          <text class="stats-card-label">已处理</text>
        </view>
        <view class="stats-card">
          <text class="stats-card-num">{{reportStats.rejected}}</text>
          <text class="stats-card-label">已驳回</text>
        </view>
      </view>

      <!-- 筛选标签 -->
      <view class="filter-tabs">
        <view class="filter-tab {{reportFilter === 'all' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="all">全部</view>
        <view class="filter-tab {{reportFilter === 'pending' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="pending">待处理</view>
        <view class="filter-tab {{reportFilter === 'handled' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="handled">已处理</view>
        <view class="filter-tab {{reportFilter === 'rejected' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="rejected">已驳回</view>
      </view>

      <!-- 举报列表 -->
      <view class="dispute-list">
        <view class="dispute-card" wx:for="{{reportList}}" wx:key="_id">
          <!-- 头部：状态和时间 -->
          <view class="dispute-header">
            <view class="dispute-header-left">
              <text class="dispute-status {{item.status}}">{{item.statusLabel}}</text>
              <text class="dispute-type">{{item.targetType === 'product' ? '商品举报' : '用户举报'}}</text>
            </view>
            <text class="dispute-time">{{item.createTimeText}}</text>
          </view>
          
          <!-- 举报人和被举报人信息 -->
          <view class="dispute-user">
            <image class="dispute-user-avatar" src="{{item.reporterAvatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="dispute-user-info">
              <text class="dispute-user-name">{{item.reporterName || '未知用户'}}</text>
              <text class="dispute-user-id">举报{{item.targetType === 'product' ? '商品' : '用户'}}: {{item.targetName || item.targetId}}</text>
            </view>
          </view>
          
          <!-- 举报内容 -->
          <view class="dispute-content">
            <view class="dispute-reason-wrap">
              <text class="dispute-reason-label">举报类型：</text>
              <text class="dispute-reason">{{item.reportTypeName}}</text>
            </view>
            <view class="dispute-desc-wrap" wx:if="{{item.description}}">
              <text class="dispute-desc-label">详细描述：</text>
              <text class="dispute-desc">{{item.description}}</text>
            </view>
          </view>
          
          <!-- 凭证图片 -->
          <view class="dispute-images" wx:if="{{item.images && item.images.length > 0}}">
            <text class="dispute-images-label">凭证图片：</text>
            <view class="dispute-images-list">
              <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" 
                     class="dispute-image" src="{{img}}" mode="aspectFill" 
                     bindtap="previewReportImage" data-url="{{img}}"/>
            </view>
          </view>
          
          <!-- 处理结果（已处理） -->
          <view class="dispute-result" wx:if="{{item.adminNote || item.punishmentLevel}}">
            <view class="dispute-result-header">
              <text class="dispute-result-title">✓ 处理结果</text>
              <text class="dispute-handle-time" wx:if="{{item.handleTimeText}}">{{item.handleTimeText}}</text>
            </view>
            <text class="dispute-result-text" wx:if="{{item.punishmentLevel}}">处罚等级：{{item.punishmentLevelName}}</text>
            <text class="dispute-note" wx:if="{{item.adminNote}}">备注：{{item.adminNote}}</text>
          </view>
          
          <!-- 操作按钮 -->
          <view class="dispute-actions" wx:if="{{item.status === 'pending'}}">
            <view class="dispute-btn close" bindtap="showReportModal" data-item="{{item}}" data-action="reject">
              <text class="dispute-btn-icon">✕</text>
              <text>驳回举报</text>
            </view>
            <view class="dispute-btn resolve" bindtap="showReportModal" data-item="{{item}}" data-action="handle">
              <text class="dispute-btn-icon">✓</text>
              <text>处理举报</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{reportLoading && reportList.length > 0}}">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view class="load-more" wx:if="{{!reportLoading && reportNoMore && reportList.length > 0}}">
        <text>— 已经到底啦 —</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!reportLoading && reportList.length === 0}}" class="empty-state">
        <text class="empty-emoji">🚨</text>
        <text class="empty-label">暂无举报记录</text>
      </view>
    </block>
  </block>

  <!-- 子模块底部安全区 -->
  <view class="safe-bottom" wx:if="{{currentTab > 0}}"></view>

  <!-- ===================================================================
       弹窗区域 - 统一用 modal-overlay + modal-box
  ==================================================================== -->

  <!-- 举报处理弹窗 -->
  <view wx:if="{{reportModalVisible}}" catchtap="closeReportModal" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view catchtap="stopPropagation" style="width:88%;max-width:680rpx;max-height:80vh;background:#fff;border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.3);display:flex;flex-direction:column;overflow:hidden;">
      <view style="display:flex;align-items:center;justify-content:space-between;padding:36rpx 32rpx 24rpx;background:#fff;border-bottom:1rpx solid rgba(0,0,0,0.06);">
        <text style="font-size:34rpx;font-weight:700;color:#1C1C1E;">{{reportModalAction === 'handle' ? '✓ 处理举报' : '✕ 驳回举报'}}</text>
        <view catchtap="closeReportModal" style="width:60rpx;height:60rpx;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#8E8E93;">✕</view>
      </view>
      <view style="flex:1;padding:28rpx 32rpx;overflow-y:auto;" wx:if="{{reportModalItem}}">
        <view style="display:flex;align-items:center;gap:16rpx;padding:20rpx 24rpx;background:rgba(255,59,48,0.06);border-radius:20rpx;margin-bottom:24rpx;">
          <text style="font-size:40rpx;">🚨</text>
          <view>
            <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">{{reportModalItem.reportTypeName}}</text>
            <text style="font-size:24rpx;color:#636366;display:block;">举报时间：{{reportModalItem.createTimeText}}</text>
          </view>
        </view>
        
        <!-- 处罚等级选择（仅处理时显示） -->
        <block wx:if="{{reportModalAction === 'handle'}}">
          <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">处罚等级</text>
          <view style="display:flex;flex-direction:column;gap:12rpx;margin-bottom:24rpx;">
            <view bindtap="selectPunishmentLevel" data-level="minor" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{reportPunishmentLevel === 'minor' ? '#30D158' : 'rgba(0,0,0,0.08)'}};background:{{reportPunishmentLevel === 'minor' ? 'rgba(48,209,88,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">轻微违规</text>
              <text style="font-size:24rpx;color:#636366;display:block;">警告/下架商品</text>
            </view>
            <view bindtap="selectPunishmentLevel" data-level="normal" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{reportPunishmentLevel === 'normal' ? '#FF9F0A' : 'rgba(0,0,0,0.08)'}};background:{{reportPunishmentLevel === 'normal' ? 'rgba(255,159,10,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">一般违规</text>
              <text style="font-size:24rpx;color:#636366;display:block;">扣积分10-20 / 扣信用分5-10 / 下架</text>
            </view>
            <view bindtap="selectPunishmentLevel" data-level="serious" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{reportPunishmentLevel === 'serious' ? '#FF3B30' : 'rgba(0,0,0,0.08)'}};background:{{reportPunishmentLevel === 'serious' ? 'rgba(255,59,48,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">严重违规</text>
              <text style="font-size:24rpx;color:#636366;display:block;">扣积分50-100 / 扣信用分20-50 / 封号7天</text>
            </view>
            <view bindtap="selectPunishmentLevel" data-level="critical" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{reportPunishmentLevel === 'critical' ? '#AF52DE' : 'rgba(0,0,0,0.08)'}};background:{{reportPunishmentLevel === 'critical' ? 'rgba(175,82,222,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">极其严重</text>
              <text style="font-size:24rpx;color:#636366;display:block;">永久封号 / 扣除全部积分和押金</text>
            </view>
          </view>
        </block>
        
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">处理备注（选填）</text>
        <textarea style="width:100%;height:160rpx;padding:20rpx 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:28rpx;color:#1C1C1E;box-sizing:border-box;" value="{{reportAdminNote}}" bindinput="onReportNoteInput" placeholder="请输入处理备注" />
      </view>
      <view style="display:flex;gap:16rpx;padding:24rpx 32rpx 36rpx;background:#fff;border-top:1rpx solid rgba(0,0,0,0.05);">
        <view catchtap="closeReportModal" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:rgba(0,0,0,0.06);color:#636366;">取消</view>
        <view catchtap="submitReportHandle" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:{{reportModalAction === 'handle' ? 'linear-gradient(135deg,#30D158 0%,#28B148 100%)' : 'linear-gradient(135deg,#FF3B30 0%,#E62E24 100%)'}};color:#fff;">确认{{reportModalAction === 'handle' ? '处理' : '驳回'}}</view>
      </view>
    </view>
  </view>

  <!-- 纠纷详情弹窗 -->
  <view wx:if="{{disputeDetailVisible}}" catchtap="closeDisputeDetail" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view catchtap="stopPropagation" style="width:92%;max-width:700rpx;max-height:88vh;background:#1C1C1E;border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.5);display:flex;flex-direction:column;overflow:hidden;" wx:if="{{disputeDetailItem}}">
      <!-- 弹窗头部 -->
      <view style="display:flex;align-items:center;justify-content:space-between;padding:32rpx 32rpx 24rpx;border-bottom:1rpx solid rgba(255,255,255,0.08);">
        <view style="display:flex;align-items:center;gap:16rpx;">
          <text style="font-size:36rpx;">⚖️</text>
          <text style="font-size:32rpx;font-weight:700;color:#fff;">纠纷详情</text>
        </view>
        <view catchtap="closeDisputeDetail" style="width:60rpx;height:60rpx;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:rgba(255,255,255,0.6);">✕</view>
      </view>
      <!-- 弹窗内容 -->
      <scroll-view scroll-y style="flex:1;padding:28rpx 32rpx;overflow-y:auto;">
        <!-- 状态 -->
        <view style="display:flex;align-items:center;gap:16rpx;margin-bottom:24rpx;">
          <text class="dispute-status {{disputeDetailItem.status}}" style="font-size:26rpx;">{{disputeDetailItem.statusLabel}}</text>
          <text style="font-size:24rpx;color:rgba(255,255,255,0.4);">{{disputeDetailItem.createTimeText}}</text>
        </view>

        <!-- 发起人信息 -->
        <view wx:if="{{disputeDetailItem.userInfo}}" style="display:flex;align-items:center;gap:16rpx;padding:20rpx 24rpx;background:rgba(255,255,255,0.06);border-radius:20rpx;margin-bottom:16rpx;">
          <image src="{{disputeDetailItem.userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" style="width:72rpx;height:72rpx;border-radius:50%;"/>
          <view>
            <text style="font-size:28rpx;font-weight:600;color:#fff;display:block;">{{disputeDetailItem.userInfo.nickName || '未知用户'}}</text>
            <text style="font-size:24rpx;color:rgba(255,255,255,0.4);display:block;">纠纷发起人</text>
          </view>
        </view>

        <!-- 纠纷原因 -->
        <view style="margin-bottom:16rpx;">
          <text style="font-size:24rpx;color:rgba(255,255,255,0.4);display:block;margin-bottom:8rpx;">纠纷原因</text>
          <text style="font-size:28rpx;color:#fff;display:block;">{{disputeDetailItem.reason}}</text>
        </view>

        <!-- 详细描述 -->
        <view wx:if="{{disputeDetailItem.description}}" style="margin-bottom:16rpx;padding:16rpx 20rpx;background:rgba(255,255,255,0.04);border-radius:16rpx;">
          <text style="font-size:24rpx;color:rgba(255,255,255,0.4);display:block;margin-bottom:8rpx;">详细描述</text>
          <text style="font-size:28rpx;color:rgba(255,255,255,0.85);display:block;line-height:1.6;">{{disputeDetailItem.description}}</text>
        </view>

        <!-- 凭证图片 -->
        <view wx:if="{{disputeDetailItem.images && disputeDetailItem.images.length > 0}}" style="margin-bottom:16rpx;">
          <text style="font-size:24rpx;color:rgba(255,255,255,0.4);display:block;margin-bottom:12rpx;">凭证图片</text>
          <view style="display:flex;flex-wrap:wrap;gap:12rpx;">
            <image wx:for="{{disputeDetailItem.images}}" wx:for-item="img" wx:key="*this"
                   src="{{img}}" mode="aspectFill"
                   style="width:160rpx;height:160rpx;border-radius:12rpx;"
                   bindtap="previewDisputeImage" data-url="{{img}}"/>
          </view>
        </view>

        <!-- 关联订单 -->
        <view wx:if="{{disputeDetailItem.orderInfo}}" style="margin-bottom:16rpx;padding:16rpx 20rpx;background:rgba(10,132,255,0.08);border-radius:16rpx;border:1rpx solid rgba(10,132,255,0.2);">
          <text style="font-size:24rpx;color:#0A84FF;display:block;margin-bottom:12rpx;">📦 关联订单</text>
          <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx;">
            <text style="font-size:26rpx;color:rgba(255,255,255,0.6);">状态：</text>
            <text style="font-size:26rpx;color:#fff;">{{disputeDetailItem.orderInfo.statusText || disputeDetailItem.orderInfo.status}}</text>
          </view>
          <view style="display:flex;align-items:center;gap:12rpx;">
            <text style="font-size:24rpx;color:rgba(255,255,255,0.4);">订单：{{disputeDetailItem.orderInfo._id}}</text>
            <text bindtap="copyOrderId" data-id="{{disputeDetailItem.orderInfo._id}}" style="font-size:22rpx;color:#0A84FF;">复制</text>
          </view>
        </view>

        <!-- 处理结果 -->
        <view wx:if="{{disputeDetailItem.result || disputeDetailItem.note}}" style="margin-bottom:16rpx;padding:16rpx 20rpx;background:rgba(48,209,88,0.08);border-radius:16rpx;">
          <text style="font-size:24rpx;color:#30D158;display:block;margin-bottom:8rpx;">✓ 处理结果</text>
          <text wx:if="{{disputeDetailItem.result}}" style="font-size:28rpx;color:#fff;display:block;">{{disputeDetailItem.result}}</text>
          <text wx:if="{{disputeDetailItem.note}}" style="font-size:24rpx;color:rgba(255,255,255,0.5);display:block;margin-top:8rpx;">备注：{{disputeDetailItem.note}}</text>
          <text wx:if="{{disputeDetailItem.handleTimeText}}" style="font-size:22rpx;color:rgba(255,255,255,0.3);display:block;margin-top:4rpx;">处理时间：{{disputeDetailItem.handleTimeText}}</text>
        </view>
      </scroll-view>
      <!-- 底部操作 -->
      <view wx:if="{{disputeDetailItem.status === 'pending' || disputeDetailItem.status === 'processing'}}" style="display:flex;gap:16rpx;padding:24rpx 32rpx 40rpx;border-top:1rpx solid rgba(255,255,255,0.08);">
        <view catchtap="showDisputeModalFromDetail" data-action="close" style="flex:1;height:88rpx;border-radius:44rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:600;background:rgba(255,69,58,0.15);color:#FF453A;">关闭纠纷</view>
        <view catchtap="showDisputeModalFromDetail" data-action="resolve" style="flex:1;height:88rpx;border-radius:44rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:600;background:linear-gradient(135deg,#30D158,#28B148);color:#fff;">解决纠纷</view>
      </view>
    </view>
  </view>

  <!-- 纠纷处理弹窗 -->
  <view wx:if="{{disputeModalVisible}}" catchtap="closeDisputeModal" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view catchtap="stopPropagation" style="width:88%;max-width:680rpx;max-height:85vh;background:#fff;border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.3);display:flex;flex-direction:column;overflow:hidden;">
      <view style="display:flex;align-items:center;justify-content:space-between;padding:36rpx 32rpx 24rpx;background:#fff;border-bottom:1rpx solid rgba(0,0,0,0.06);">
        <text style="font-size:34rpx;font-weight:700;color:#1C1C1E;">{{disputeModalAction === 'resolve' ? '✓ 解决纠纷' : '✕ 关闭纠纷'}}</text>
        <view catchtap="closeDisputeModal" style="width:60rpx;height:60rpx;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#8E8E93;">✕</view>
      </view>
      <view style="flex:1;padding:28rpx 32rpx;overflow-y:auto;" wx:if="{{disputeModalItem}}">
        <view style="display:flex;align-items:center;gap:16rpx;padding:20rpx 24rpx;background:rgba(255,159,10,0.06);border-radius:20rpx;margin-bottom:24rpx;">
          <text style="font-size:40rpx;">⚠️</text>
          <view>
            <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">{{disputeModalItem.reason}}</text>
            <text style="font-size:24rpx;color:#636366;display:block;">提交时间：{{disputeModalItem.createTimeText}}</text>
          </view>
        </view>

        <!-- 处罚选项（仅解决纠纷时显示） -->
        <block wx:if="{{disputeModalAction === 'resolve'}}">
          <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:16rpx;">处罚方式</text>
          <view style="display:flex;flex-direction:column;gap:12rpx;margin-bottom:24rpx;">
            <!-- 不处罚 -->
            <view bindtap="selectDisputePunishment" data-type="none" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{disputePunishmentType === 'none' ? '#30D158' : 'rgba(0,0,0,0.08)'}};background:{{disputePunishmentType === 'none' ? 'rgba(48,209,88,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">✓ 不处罚</text>
              <text style="font-size:24rpx;color:#636366;display:block;">仅记录纠纷，不对任何一方进行处罚</text>
            </view>
            <!-- 扣除积分 -->
            <view bindtap="selectDisputePunishment" data-type="points" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{disputePunishmentType === 'points' ? '#FF9F0A' : 'rgba(0,0,0,0.08)'}};background:{{disputePunishmentType === 'points' ? 'rgba(255,159,10,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">⚡ 扣除积分</text>
              <view wx:if="{{disputePunishmentType === 'points'}}" style="margin-top:12rpx;display:flex;align-items:center;gap:16rpx;">
                <text style="font-size:24rpx;color:#636366;">扣除数量：</text>
                <input type="number" style="flex:1;height:64rpx;padding:0 20rpx;background:#fff;border:1rpx solid rgba(0,0,0,0.1);border-radius:12rpx;font-size:28rpx;" value="{{disputePunishmentValue}}" bindinput="onDisputePunishmentValueInput" placeholder="请输入积分数" />
              </view>
              <text wx:else style="font-size:24rpx;color:#636366;display:block;">从责任方扣除积分</text>
            </view>
            <!-- 扣除信用分 -->
            <view bindtap="selectDisputePunishment" data-type="credit" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{disputePunishmentType === 'credit' ? '#FF3B30' : 'rgba(0,0,0,0.08)'}};background:{{disputePunishmentType === 'credit' ? 'rgba(255,59,48,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">📉 扣除信用分</text>
              <view wx:if="{{disputePunishmentType === 'credit'}}" style="margin-top:12rpx;display:flex;align-items:center;gap:16rpx;">
                <text style="font-size:24rpx;color:#636366;">扣除数量：</text>
                <input type="number" style="flex:1;height:64rpx;padding:0 20rpx;background:#fff;border:1rpx solid rgba(0,0,0,0.1);border-radius:12rpx;font-size:28rpx;" value="{{disputePunishmentValue}}" bindinput="onDisputePunishmentValueInput" placeholder="请输入信用分数" />
              </view>
              <text wx:else style="font-size:24rpx;color:#636366;display:block;">从责任方扣除信用分</text>
            </view>
            <!-- 扣除押金 -->
            <view bindtap="selectDisputePunishment" data-type="deposit" style="padding:20rpx 24rpx;border-radius:16rpx;border:2rpx solid {{disputePunishmentType === 'deposit' ? '#AF52DE' : 'rgba(0,0,0,0.08)'}};background:{{disputePunishmentType === 'deposit' ? 'rgba(175,82,222,0.08)' : 'rgba(0,0,0,0.03)'}};">
              <text style="font-size:28rpx;font-weight:600;color:#1C1C1E;display:block;">💰 扣除押金</text>
              <view wx:if="{{disputePunishmentType === 'deposit'}}" style="margin-top:12rpx;display:flex;align-items:center;gap:16rpx;">
                <text style="font-size:24rpx;color:#636366;">扣除金额(元)：</text>
                <input type="digit" style="flex:1;height:64rpx;padding:0 20rpx;background:#fff;border:1rpx solid rgba(0,0,0,0.1);border-radius:12rpx;font-size:28rpx;" value="{{disputePunishmentValue}}" bindinput="onDisputePunishmentValueInput" placeholder="请输入金额" />
              </view>
              <text wx:else style="font-size:24rpx;color:#636366;display:block;">从责任方扣除押金作为赔偿</text>
            </view>
          </view>

          <!-- 责任方选择 -->
          <block wx:if="{{disputePunishmentType && disputePunishmentType !== 'none'}}">
            <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">责任方</text>
            <view style="display:flex;gap:16rpx;margin-bottom:24rpx;">
              <view bindtap="selectDisputeResponsible" data-party="initiator" style="flex:1;padding:20rpx 16rpx;border-radius:16rpx;border:2rpx solid {{disputeResponsibleParty === 'initiator' ? '#007AFF' : 'rgba(0,0,0,0.08)'}};background:{{disputeResponsibleParty === 'initiator' ? 'rgba(0,122,255,0.08)' : '#fff'}};text-align:center;">
                <text style="font-size:26rpx;font-weight:600;color:{{disputeResponsibleParty === 'initiator' ? '#007AFF' : '#1C1C1E'}};display:block;">发起方</text>
                <text style="font-size:22rpx;color:#636366;display:block;margin-top:4rpx;">申请纠纷的用户</text>
              </view>
              <view bindtap="selectDisputeResponsible" data-party="responder" style="flex:1;padding:20rpx 16rpx;border-radius:16rpx;border:2rpx solid {{disputeResponsibleParty === 'responder' ? '#007AFF' : 'rgba(0,0,0,0.08)'}};background:{{disputeResponsibleParty === 'responder' ? 'rgba(0,122,255,0.08)' : '#fff'}};text-align:center;">
                <text style="font-size:26rpx;font-weight:600;color:{{disputeResponsibleParty === 'responder' ? '#007AFF' : '#1C1C1E'}};display:block;">被申请方</text>
                <text style="font-size:22rpx;color:#636366;display:block;margin-top:4rpx;">互换的另一方</text>
              </view>
              <view bindtap="selectDisputeResponsible" data-party="both" style="flex:1;padding:20rpx 16rpx;border-radius:16rpx;border:2rpx solid {{disputeResponsibleParty === 'both' ? '#007AFF' : 'rgba(0,0,0,0.08)'}};background:{{disputeResponsibleParty === 'both' ? 'rgba(0,122,255,0.08)' : '#fff'}};text-align:center;">
                <text style="font-size:26rpx;font-weight:600;color:{{disputeResponsibleParty === 'both' ? '#007AFF' : '#1C1C1E'}};display:block;">双方</text>
                <text style="font-size:22rpx;color:#636366;display:block;margin-top:4rpx;">双方各承担50%</text>
              </view>
            </view>
          </block>
        </block>

        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">处理结果说明</text>
        <input style="width:100%;height:92rpx;padding:0 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:30rpx;color:#1C1C1E;box-sizing:border-box;" value="{{disputeResult}}" bindinput="onDisputeResultInput" placeholder="请输入处理结果说明" />
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;margin-top:24rpx;">备注（选填）</text>
        <textarea style="width:100%;height:120rpx;padding:20rpx 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:28rpx;color:#1C1C1E;box-sizing:border-box;" value="{{disputeNote}}" bindinput="onDisputeNoteInput" placeholder="请输入备注信息" />
      </view>
      <view style="display:flex;gap:16rpx;padding:24rpx 32rpx 36rpx;background:#fff;border-top:1rpx solid rgba(0,0,0,0.05);">
        <view catchtap="closeDisputeModal" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:rgba(0,0,0,0.06);color:#636366;">取消</view>
        <view catchtap="submitDisputeHandle" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:{{disputeModalAction === 'resolve' ? 'linear-gradient(135deg,#30D158 0%,#28B148 100%)' : 'linear-gradient(135deg,#FF3B30 0%,#E62E24 100%)'}};color:#fff;">确认{{disputeModalAction === 'resolve' ? '解决' : '关闭'}}</view>
      </view>
    </view>
  </view>

  <!-- 用户编辑弹窗 -->
  <view wx:if="{{userEditModalVisible}}" catchtap="closeUserEditModal" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view class="modal-box" catchtap="stopPropagation" style="width:88%;max-width:680rpx;max-height:80vh;background:linear-gradient(135deg,#ffffff 0%,#f8f9fa 100%);border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.4);display:flex;flex-direction:column;overflow:hidden;">
      <view class="modal-hd" style="display:flex;align-items:center;justify-content:space-between;padding:36rpx 32rpx 24rpx;background:#fff;border-bottom:1rpx solid rgba(0,0,0,0.06);flex-shrink:0;">
        <text class="modal-title-text" style="font-size:34rpx;font-weight:700;color:#1C1C1E;">✏️ 编辑用户</text>
