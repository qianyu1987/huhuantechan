        <view class="filter-chip {{daigouOrderFilter === 'shipped' ? 'active' : ''}}" bindtap="changeDaigouOrderFilter" data-filter="shipped">🚚 已发货</view>
        <view class="filter-chip {{daigouOrderFilter === 'completed' ? 'active' : ''}}" bindtap="changeDaigouOrderFilter" data-filter="completed">✅ 已完成</view>
      </view>

      <view wx:if="{{daigouOrders.length === 0 && !daigouOrderLoading}}" class="empty-tip">🛒 暂无代购订单</view>
