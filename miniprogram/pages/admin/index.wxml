<!-- pages/admin/index.wxml - 管理后台 - iOS 27 液态玻璃风格 -->
<view class="admin-page">

  <!-- 顶部占位 -->
  <view class="admin-header-safe"></view>

  <!-- 顶部 Tab -->
  <scroll-view scroll-x class="admin-tabs" enhanced show-scrollbar="{{false}}" enable-flex>
    <view class="tab-item {{currentTab === index ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="index"
          bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </scroll-view>

  <!-- ===== 概览 ===== -->
  <block wx:if="{{currentTab === 0}}">
    <!-- 管理员徽章 -->
    <view class="hero-admin glass-card" wx:if="{{isSuperAdmin}}">
      <text class="hero-emoji">👑</text>
      <view class="hero-text">
        <text class="hero-title">超级管理员</text>
        <text class="hero-sub">管理面板 · 运营数据</text>
      </view>
    </view>

    <!-- 核心统计 -->
    <view class="stats-grid">
      <view class="stat-card glass-card sc-green">
        <text class="stat-emoji">👥</text>
        <view class="stat-num">{{stats.totalUsers}}</view>
        <view class="stat-label">用户总数</view>
      </view>
      <view class="stat-card glass-card sc-blue">
        <text class="stat-emoji">🎁</text>
        <view class="stat-num">{{stats.totalProducts}}</view>
        <view class="stat-label">特产总数</view>
      </view>
      <view class="stat-card glass-card sc-purple">
        <text class="stat-emoji">🎰</text>
        <view class="stat-num">{{stats.mysteryCount || 0}}</view>
        <view class="stat-label">神秘特产</view>
      </view>
      <view class="stat-card glass-card sc-orange">
        <text class="stat-emoji">🔄</text>
        <view class="stat-num">{{stats.activeSwaps}}</view>
        <view class="stat-label">进行中</view>
      </view>
      <view class="stat-card glass-card sc-red">
        <text class="stat-emoji">📝</text>
        <view class="stat-num">{{stats.pendingReviews}}</view>
        <view class="stat-label">待审核</view>
      </view>
      <view class="stat-card glass-card sc-teal">
        <text class="stat-emoji">💰</text>
        <view class="stat-num">{{daigouStats.total || 0}}</view>
        <view class="stat-label">代购订单</view>
      </view>
    </view>

    <!-- 性别统计 -->
    <view class="gender-stats glass-card">
      <view class="gender-card male">
        <text class="gender-icon">👨</text>
        <view class="gender-info">
          <text class="gender-num">{{stats.maleCount || 0}}</text>
          <text class="gender-label">男性用户</text>
        </view>
      </view>
      <view class="gender-divider"></view>
      <view class="gender-card female">
        <text class="gender-icon">👩</text>
        <view class="gender-info">
          <text class="gender-num">{{stats.femaleCount || 0}}</text>
          <text class="gender-label">女性用户</text>
        </view>
      </view>
    </view>

    <!-- 管理员快捷操作 -->
    <view class="card glass-card" wx:if="{{isSuperAdmin}}">
      <view class="section-hd">
        <text class="section-emoji">⚡</text>
        <text class="section-title">快捷管理</text>
      </view>
      <view class="action-grid">
        <view class="action-item ai-green" bindtap="switchTab" data-index="1">
          <text class="action-icon">👥</text><text>用户</text>
        </view>
        <view class="action-item ai-blue" bindtap="switchTab" data-index="2">
          <text class="action-icon">🎁</text><text>特产</text>
        </view>
        <view class="action-item ai-orange" bindtap="switchTab" data-index="3">
          <text class="action-icon">🔄</text><text>订单</text>
        </view>
        <view class="action-item ai-red" bindtap="switchTab" data-index="4">
          <text class="action-icon">📝</text><text>审核</text>
        </view>
        <view class="action-item ai-teal" bindtap="switchTab" data-index="5">
          <text class="action-icon">🪪</text><text>实名</text>
        </view>
        <view class="action-item ai-yellow" bindtap="switchTab" data-index="6">
          <text class="action-icon">💰</text><text>积分</text>
        </view>
        <view class="action-item ai-pink" bindtap="switchTab" data-index="7">
          <text class="action-icon">⭐</text><text>信用</text>
        </view>
        <view class="action-item ai-purple" bindtap="switchTab" data-index="8">
          <text class="action-icon">🎰</text><text>神秘</text>
        </view>
        <view class="action-item ai-blue" bindtap="switchTab" data-index="9">
          <text class="action-icon">🛒</text><text>代购</text>
        </view>
        <view class="action-item ai-gray" bindtap="switchTab" data-index="10">
          <text class="action-icon">⚙️</text><text>开关</text>
        </view>
      </view>

      <!-- 实名审核快捷入口 -->
      <view class="quick-entry {{daigouVerifyStats.pending > 0 ? 'has-pending' : ''}}" bindtap="switchTab" data-index="{{verifyTabIndex}}">
        <view class="quick-entry-left">
          <text class="quick-entry-icon">🪪</text>
          <view>
            <view class="quick-entry-title">实名审核</view>
            <view class="quick-entry-sub">
              <text wx:if="{{daigouVerifyStats.pending > 0}}" class="quick-badge">{{daigouVerifyStats.pending}} 待处理</text>
              <text wx:else class="quick-clear">暂无待审核</text>
            </view>
          </view>
        </view>
        <text class="quick-arrow">›</text>
      </view>

      <!-- 数据看板入口 -->
      <view class="quick-entry dashboard" bindtap="goDashboard">
        <view class="quick-entry-left">
          <text class="quick-entry-icon">📊</text>
          <view>
            <view class="quick-entry-title">运营数据看板</view>
            <view class="quick-entry-sub">省份排行 · 品类分布 · 订单漏斗</view>
          </view>
        </view>
        <text class="quick-arrow">›</text>
      </view>
    </view>

    <!-- 权限提示 -->
    <view class="card glass-card" wx:if="{{!isSuperAdmin}}">
      <view class="section-hd">
        <text class="section-emoji">🔐</text>
        <text class="section-title">权限提示</text>
      </view>
      <view class="perm-tip">
        <text class="perm-text">你当前不是超级管理员，无法使用全部功能</text>
        <view class="btn btn-purple" bindtap="initSuperAdmin">设为超级管理员</view>
      </view>
    </view>
  </block>

  <!-- ===== 用户管理 ===== -->
  <block wx:if="{{currentTab === 1}}">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索用户名" bindinput="onUserSearch" />
    </view>
    <view wx:if="{{users.length === 0 && !userLoading}}" class="empty-tip">
      <text class="empty-icon">👥</text>
      <text>暂无用户</text>
    </view>
    <view class="list-wrap">
      <view class="list-item glass-card" wx:for="{{users}}" wx:key="_id" bindtap="goToUserDetail" data-openid="{{item._openid}}">
        <image class="li-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="li-body">
          <view class="li-title">{{item.nickName || '未设置昵称'}}</view>
          <view class="li-sub">
            <text>📍 {{item.province || '未设置'}}</text>
            <text class="tag tag-credit {{item.creditLevel.class}}">⭐ {{item.creditScore || 100}}分</text>
          </view>
        </view>
        <view class="btn-group">
          <view class="btn-sm btn-blue" catchtap="openUserEdit" data-user="{{item}}" wx:if="{{isSuperAdmin}}">✏️</view>
          <view class="btn-sm btn-danger" catchtap="deleteUser" data-user="{{item}}" wx:if="{{isSuperAdmin}}">🗑️</view>
        </view>
        <text class="li-arrow">›</text>
      </view>
    </view>
    <view wx:if="{{userLoading}}" class="load-tip">⏳ 加载中...</view>
  </block>

  <!-- ===== 特产管理 ===== -->
  <block wx:if="{{currentTab === 2}}">
    <view class="filter-bar">
      <view class="filter-chip {{productFilter === 'all' ? 'active' : ''}}" bindtap="changeProductFilter" data-filter="all">📋 全部</view>
      <view class="filter-chip {{productFilter === 'active' ? 'active' : ''}}" bindtap="changeProductFilter" data-filter="active">✅ 展示中</view>
      <view class="filter-chip {{productFilter === 'mystery' ? 'active' : ''}}" bindtap="changeProductFilter" data-filter="mystery">🎰 神秘</view>
    </view>
    <view wx:if="{{products.length === 0 && !productLoading}}" class="empty-tip">
      <text class="empty-icon">🎁</text>
      <text>暂无特产</text>
    </view>
    <view class="list-wrap">
      <view class="list-item glass-card" wx:for="{{products}}" wx:key="_id" bindtap="goToProductDetail" data-id="{{item._id}}">
        <image class="li-cover" src="{{item.coverUrl}}" mode="aspectFill"/>
        <view class="li-body">
          <view class="li-title">{{item.name}}</view>
          <view class="li-sub">
            <text>📍 {{item.province}}</text>
            <text class="tag tag-status-{{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
        <view class="btn-group">
          <view class="btn-sm btn-blue" catchtap="openProductEdit" data-product="{{item}}" wx:if="{{isSuperAdmin}}">✏️</view>
          <view class="btn-sm btn-danger" catchtap="deleteProduct" data-id="{{item._id}}" wx:if="{{isSuperAdmin}}">🗑️</view>
        </view>
      </view>
    </view>
    <view wx:if="{{productLoading}}" class="load-tip">⏳ 加载中...</view>
  </block>

  <!-- ===== 订单管理 ===== -->
  <block wx:if="{{currentTab === 3}}">
    <view class="filter-bar">
      <view class="filter-chip {{orderFilter === 'all' ? 'active' : ''}}" bindtap="changeOrderFilter" data-filter="all">📋 全部</view>
      <view class="filter-chip {{orderFilter === 'pending' ? 'active' : ''}}" bindtap="changeOrderFilter" data-filter="pending">⏳ 待确认</view>
      <view class="filter-chip {{orderFilter === 'confirmed' ? 'active' : ''}}" bindtap="changeOrderFilter" data-filter="confirmed">📦 待发货</view>
      <view class="filter-chip {{orderFilter === 'shipped' ? 'active' : ''}}" bindtap="changeOrderFilter" data-filter="shipped">🚚 待收货</view>
      <view class="filter-chip {{orderFilter === 'completed' ? 'active' : ''}}" bindtap="changeOrderFilter" data-filter="completed">✅ 已完成</view>
    </view>

    <!-- 订单统计 -->
    <view class="stats-bar glass-card">
      <view class="stats-bar-item">
        <text class="stats-bar-num">{{orderStats.pending || 0}}</text>
        <text class="stats-bar-label">待处理</text>
      </view>
      <view class="stats-bar-divider"></view>
      <view class="stats-bar-item">
        <text class="stats-bar-num">{{orderStats.shipping || 0}}</text>
        <text class="stats-bar-label">进行中</text>
      </view>
      <view class="stats-bar-divider"></view>
      <view class="stats-bar-item">
        <text class="stats-bar-num">{{orderStats.completed || 0}}</text>
        <text class="stats-bar-label">已完成</text>
      </view>
    </view>

    <view wx:if="{{orders.length === 0 && !orderLoading}}" class="empty-tip">
      <text class="empty-icon">📋</text>
      <text>暂无订单记录</text>
    </view>
    <view class="order-list">
      <view class="order-card glass-card" wx:for="{{orders}}" wx:key="_id" bindtap="goToOrderDetail" data-id="{{item._id}}">
        <view class="order-card-header">
          <text class="order-id-label">🔖</text>
          <text class="order-id-value">{{item._id}}</text>
          <view class="order-status-badge status-{{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="order-card-body">
          <image class="order-product-img" src="{{item.productCover || '/images/default-product.png'}}" mode="aspectFill"/>
          <view class="order-product-detail">
            <text class="order-product-name">{{item.productName || '特产'}}</text>
            <text class="order-product-from">📍 {{item.productProvince || ''}}</text>
          </view>
        </view>
        <view class="order-card-footer">
          <view class="order-user-info">
            <image class="order-user-avatar" src="{{item.requesterAvatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <text class="order-user-name">{{item.requesterNick || '用户'}}</text>
          </view>
          <view class="order-actions">
            <text class="order-time">🕐 {{item.createTimeStr || ''}}</text>
            <view class="btn-sm btn-danger" catchtap="deleteOrder" data-id="{{item._id}}" wx:if="{{isSuperAdmin}}">🗑️</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{orderLoading}}" class="load-tip">⏳ 加载中...</view>
  </block>

  <!-- ===== 审核管理 ===== -->
  <block wx:if="{{currentTab === 4}}">
    <view class="stats-bar glass-card">
      <view class="stats-bar-item">
        <text class="stats-bar-num">{{pendingStats.autoBlocked || 0}}</text>
        <text class="stats-bar-label">🔒 自动拦截</text>
      </view>
      <view class="stats-bar-divider"></view>
      <view class="stats-bar-item">
        <text class="stats-bar-num">{{pendingStats.manualReview || 0}}</text>
        <text class="stats-bar-label">⏳ 待人工</text>
      </view>
    </view>

    <view class="filter-bar">
      <view class="filter-chip {{auditFilter === 'all' ? 'active' : ''}}" bindtap="changeAuditFilter" data-filter="all">📋 全部</view>
      <view class="filter-chip {{auditFilter === 'auto' ? 'active' : ''}}" bindtap="changeAuditFilter" data-filter="auto">🔒 自动拦截</view>
      <view class="filter-chip {{auditFilter === 'manual' ? 'active' : ''}}" bindtap="changeAuditFilter" data-filter="manual">⏳ 待人工</view>
    </view>

    <view wx:if="{{pendingProducts.length === 0 && !pendingLoading}}" class="empty-tip">🎉 暂无待审核产品</view>

    <view class="order-list">
      <view class="order-card glass-card" wx:for="{{pendingProducts}}" wx:key="_id">
        <view class="order-card-header">
          <text class="order-id-label">🎁</text>
          <text class="order-id-value">{{item._id}}</text>
          <view class="order-status-badge {{item.auditReason ? 'status-pending' : 'status-confirmed'}}">
            {{item.auditReason ? '🔒 已拦截' : '⏳ 待审核'}}
          </view>
        </view>
        <view class="order-card-body">
          <image class="order-product-img" src="{{item.coverUrl}}" mode="aspectFill"/>
          <view class="order-product-detail">
            <text class="order-product-name">{{item.name}}</text>
            <text class="order-product-from">📍 {{item.province || '未知'}} · {{item.categoryName}}</text>
          </view>
        </view>
        <view class="audit-reason" wx:if="{{item.auditReason}}">
          <text class="audit-reason-label">🚫 拦截原因：</text>
          <text class="audit-reason-text">{{item.auditReason}}</text>
        </view>
        <view class="order-card-footer">
          <view class="order-user-info">
            <image class="order-user-avatar" src="{{item.publisher.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <text class="order-user-name">{{item.publisher.nickName || '未知用户'}}</text>
          </view>
          <view class="audit-actions">
            <view class="btn-sm btn-green" catchtap="approvePendingProduct" data-id="{{item._id}}">✅ 通过</view>
            <view class="btn-sm btn-danger" catchtap="rejectPendingProduct" data-id="{{item._id}}">❌ 拒绝</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{pendingLoading}}" class="load-tip">⏳ 加载中...</view>
  </block>

  <!-- ===== 积分管理 ===== -->
  <block wx:if="{{currentTab === 6}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-tip">🔐 需要超级管理员权限</view>
    <block wx:else>
      <view class="stats-bar glass-card">
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{pointsStats.totalUsers || 0}}</text>
          <text class="stats-bar-label">👥 用户</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{pointsStats.totalPoints || 0}}</text>
          <text class="stats-bar-label">💰 积分总量</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{pointsStats.avgPoints || 0}}</text>
          <text class="stats-bar-label">📊 人均</text>
        </view>
      </view>

      <view class="search-bar">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索用户" bindinput="onPointsSearch" />
      </view>
      <view class="filter-bar">
        <view class="filter-chip {{pointsFilter === 'all' ? 'active' : ''}}" bindtap="changePointsFilter" data-filter="all">📋 全部</view>
        <view class="filter-chip {{pointsFilter === 'high' ? 'active' : ''}}" bindtap="changePointsFilter" data-filter="high">🏆 高积分</view>
        <view class="filter-chip {{pointsFilter === 'low' ? 'active' : ''}}" bindtap="changePointsFilter" data-filter="low">📉 低积分</view>
      </view>

      <view wx:if="{{pointsUsers.length === 0 && !pointsLoading}}" class="empty-tip">👥 暂无用户</view>

      <view class="order-list">
        <view class="order-card glass-card" wx:for="{{pointsUsers}}" wx:key="_id">
          <view class="order-card-header">
            <view class="rank-badge rank-{{item.rank}}" wx:if="{{item.rank <= 3}}">{{item.rank}}</view>
            <text class="order-id-value" wx:else>NO.{{item.rank}}</text>
            <view class="order-status-badge status-confirmed">💰 {{item.points || 0}}积分</view>
          </view>
          <view class="order-card-body">
            <image class="order-product-img" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="order-product-detail">
              <text class="order-product-name">{{item.nickName || '未知'}}</text>
              <text class="order-product-from">📊 当前: {{item.points || 0}} | 累计: {{item.totalPoints || 0}}</text>
            </view>
          </view>
          <view class="order-card-footer">
            <text class="order-time">🏆 排名 {{item.rank}}</text>
            <view class="audit-actions">
              <view class="btn-sm btn-green" catchtap="openPointsModal" data-user="{{item}}" data-action="add">➕</view>
              <view class="btn-sm btn-danger" catchtap="openPointsModal" data-user="{{item}}" data-action="deduct">➖</view>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{pointsLoading}}" class="load-tip">⏳ 加载中...</view>
    </block>
  </block>

  <!-- ===== 信用管理 ===== -->
  <block wx:if="{{currentTab === 7}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-tip">🔐 需要超级管理员权限</view>
    <block wx:else>
      <view class="stats-bar glass-card credit-bar">
        <view class="stats-bar-item">
          <text class="stats-bar-num" style="color: #22C55E">{{creditDist.excellent}}%</text>
          <text class="stats-bar-label">🌟 优秀</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num" style="color: #F59E0B">{{creditDist.good}}%</text>
          <text class="stats-bar-label">👍 良好</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num" style="color: #3B82F6">{{creditDist.normal}}%</text>
          <text class="stats-bar-label">⚡ 一般</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num" style="color: #EF4444">{{creditDist.poor}}%</text>
          <text class="stats-bar-label">⚠️ 较差</text>
        </view>
      </view>

      <view class="filter-bar">
        <view class="filter-chip {{creditFilter === 'all' ? 'active' : ''}}" bindtap="changeCreditFilter" data-filter="all">📋 全部</view>
        <view class="filter-chip {{creditFilter === 'excellent' ? 'active' : ''}}" bindtap="changeCreditFilter" data-filter="excellent">🌟 优秀</view>
        <view class="filter-chip {{creditFilter === 'good' ? 'active' : ''}}" bindtap="changeCreditFilter" data-filter="good">👍 良好</view>
        <view class="filter-chip {{creditFilter === 'poor' ? 'active' : ''}}" bindtap="changeCreditFilter" data-filter="poor">⚠️ 较差</view>
      </view>

      <view wx:if="{{creditUsers.length === 0 && !creditLoading}}" class="empty-tip">👥 暂无用户</view>

      <view class="order-list">
        <view class="order-card glass-card" wx:for="{{creditUsers}}" wx:key="_id">
          <view class="order-card-header">
            <text class="order-id-label">⭐</text>
            <text class="order-id-value">{{item.creditScore || 100}}分</text>
            <view class="order-status-badge status-{{item.creditLevel.class}}">{{item.creditLevel.text}}</view>
          </view>
          <view class="order-card-body">
            <image class="order-product-img" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="order-product-detail">
              <text class="order-product-name">{{item.nickName || '未知'}}</text>
              <view class="credit-bar-mini">
                <view class="credit-fill fill-{{item.creditLevel.class}}" style="width: {{item.creditScore}}%"></view>
                <text>{{item.creditScore}}分</text>
              </view>
            </view>
          </view>
          <view class="order-card-footer">
            <text class="order-time">{{item.creditLevel.text}}</text>
            <view class="btn-sm btn-blue" catchtap="openCreditModal" data-user="{{item}}">✏️ 编辑</view>
          </view>
        </view>
      </view>
      <view wx:if="{{creditLoading}}" class="load-tip">⏳ 加载中...</view>
    </block>
  </block>

  <!-- ===== 神秘特产 ===== -->
  <block wx:if="{{currentTab === 8}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-tip">🔐 需要超级管理员权限</view>
    <block wx:else>
      <view class="stats-bar glass-card">
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{mysteryStats.total || 0}}</text>
          <text class="stats-bar-label">📦 总数</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{mysteryStats.active || 0}}</text>
          <text class="stats-bar-label">✅ 展示中</text>
        </view>
        <view class="stats-bar-divider"></view>
        <view class="stats-bar-item">
          <text class="stats-bar-num">{{mysteryStats.inSwap || 0}}</text>
          <text class="stats-bar-label">🔄 分享中</text>
        </view>
      </view>

      <view class="filter-bar">
        <view class="filter-chip {{mysteryFilter === 'all' ? 'active' : ''}}" bindtap="changeMysteryFilter" data-filter="all">📋 全部</view>
        <view class="filter-chip {{mysteryFilter === 'active' ? 'active' : ''}}" bindtap="changeMysteryFilter" data-filter="active">✅ 展示中</view>
        <view class="filter-chip {{mysteryFilter === 'in_swap' ? 'active' : ''}}" bindtap="changeMysteryFilter" data-filter="in_swap">🔄 分享中</view>
        <view class="filter-chip {{mysteryFilter === 'removed' ? 'active' : ''}}" bindtap="changeMysteryFilter" data-filter="removed">❌ 已下架</view>
      </view>

      <view wx:if="{{mysteryProducts.length === 0 && !mysteryLoading}}" class="empty-tip">🎰 暂无神秘特产</view>

      <view class="mystery-grid">
        <view class="mystery-card glass-card" wx:for="{{mysteryProducts}}" wx:key="_id">
          <view class="mystery-cover">
            <image class="mystery-img" src="{{item.coverUrl}}" mode="aspectFill"/>
            <view class="mystery-status status-{{item.status}}">{{item.statusText}}</view>
          </view>
          <view class="mystery-body">
            <text class="mystery-name">{{item.name}}</text>
            <text class="mystery-location">📍 {{item.province}} {{item.city || ''}}</text>
          </view>
          <view class="mystery-actions">
            <view class="mystery-btn edit" catchtap="openMysteryEdit" data-product="{{item}}">✏️</view>
            <view class="mystery-btn delete" catchtap="deleteMystery" data-id="{{item._id}}">🗑️</view>
          </view>
        </view>
      </view>
      <view wx:if="{{mysteryLoading}}" class="load-tip">⏳ 加载中...</view>
    </block>
  </block>

  <!-- ===== 实名审核 ===== -->
  <block wx:if="{{currentTab === 5 && isSuperAdmin}}">
    <view class="stats-bar glass-card">
      <view class="stats-bar-item">
        <text class="stats-bar-num pending">{{daigouVerifyStats.pending || 0}}</text>
        <text class="stats-bar-label">⏳ 待审核</text>
      </view>
      <view class="stats-bar-divider"></view>
      <view class="stats-bar-item">
        <text class="stats-bar-num approved">{{daigouVerifyStats.approved || 0}}</text>
        <text class="stats-bar-label">✅ 已通过</text>
      </view>
      <view class="stats-bar-divider"></view>
      <view class="stats-bar-item">
        <text class="stats-bar-num rejected">{{daigouVerifyStats.rejected || 0}}</text>
        <text class="stats-bar-label">❌ 已拒绝</text>
      </view>
    </view>

    <view class="filter-bar">
      <view class="filter-chip {{daigouVerifyFilter === 'pending' ? 'active' : ''}}" bindtap="changeDaigouVerifyFilter" data-filter="pending">⏳ 待审核</view>
      <view class="filter-chip {{daigouVerifyFilter === 'approved' ? 'active' : ''}}" bindtap="changeDaigouVerifyFilter" data-filter="approved">✅ 已通过</view>
      <view class="filter-chip {{daigouVerifyFilter === 'rejected' ? 'active' : ''}}" bindtap="changeDaigouVerifyFilter" data-filter="rejected">❌ 已拒绝</view>
      <view class="filter-chip {{daigouVerifyFilter === 'all' ? 'active' : ''}}" bindtap="changeDaigouVerifyFilter" data-filter="all">📋 全部</view>
    </view>

    <view wx:if="{{daigouVerifyList.length === 0 && !daigouVerifyLoading}}" class="empty-tip">🪪 暂无审核记录</view>
    <view class="list-wrap">
      <view class="verify-item glass-card" wx:for="{{daigouVerifyList}}" wx:key="_id">
        <view class="verify-hd">
          <text class="verify-nick">{{item.nickName || '未知用户'}}</text>
          <view class="verify-status-badge status-{{item.status}}">{{item.status === 'pending' ? '⏳' : item.status === 'approved' ? '✅' : '❌'}} {{item.status === 'pending' ? '待审核' : item.status === 'approved' ? '已通过' : '已拒绝'}}</view>
        </view>
        <view class="verify-body">
          <view class="verify-field">👤 真实姓名: {{item.realName || '-'}}</view>
          <view class="verify-field">📱 手机号: {{item.phone || '-'}}</view>
          <view class="verify-field">🕐 提交时间: {{item.createTimeStr || '-'}}</view>
        </view>
        <view class="btn-group" wx:if="{{item.status === 'pending'}}">
          <view class="btn-sm btn-green" catchtap="approveDaigouVerify" data-id="{{item._id}}" data-openid="{{item.userOpenid}}">✅ 通过</view>
          <view class="btn-sm btn-danger" catchtap="rejectDaigouVerify" data-id="{{item._id}}" data-openid="{{item.userOpenid}}">❌ 拒绝</view>
        </view>
      </view>
    </view>
    <view wx:if="{{daigouVerifyLoading}}" class="load-tip">⏳ 加载中...</view>
  </block>

