<!-- pages/admin/index.wxml - 管理后台 v3 重设计 -->
<view class="admin-page theme-{{pageTheme}}">

  <!-- 安全区 -->
  <view class="safe-top"></view>

  <!-- ===== 卡片式导航首页（Tab=0）===== -->
  <block wx:if="{{currentTab === 0}}">
    <!-- 顶部 Hero -->
    <view class="hero-card">
      <view class="hero-left">
        <text class="hero-crown">👑</text>
        <view>
          <text class="hero-name">管理后台</text>
          <text class="hero-role">{{isSuperAdmin ? '超级管理员' : '普通管理员'}}</text>
        </view>
      </view>
      <view class="hero-stats-row">
        <view class="hero-stat">
          <text class="hero-stat-num">{{stats.totalUsers || 0}}</text>
          <text class="hero-stat-label">用户</text>
        </view>
        <view class="hero-stat-div"></view>
        <view class="hero-stat">
          <text class="hero-stat-num">{{stats.totalProducts || 0}}</text>
          <text class="hero-stat-label">特产</text>
        </view>
        <view class="hero-stat-div"></view>
        <view class="hero-stat">
          <text class="hero-stat-num">{{stats.activeSwaps || 0}}</text>
          <text class="hero-stat-label">进行中</text>
        </view>
      </view>
    </view>

    <!-- 统一待处理通知中心 -->
    <view class="notification-center" wx:if="{{notifications.totalCount > 0}}">
      <view class="nc-header">
        <view class="nc-badge" wx:if="{{notifications.totalCount > 0}}">{{notifications.totalCount}}</view>
        <text class="nc-title">待处理事项</text>
        <text class="nc-subtitle">点击快速跳转处理</text>
      </view>
      
      <view class="nc-grid">
        <!-- 待审核特产 -->
        <view class="nc-item nc-item-red" bindtap="goModule" data-tab="4" wx:if="{{notifications.pendingReview > 0}}">
          <text class="nci-icon">📝</text>
          <text class="nci-count">{{notifications.pendingReview}}</text>
          <text class="nci-label">特产审核</text>
        </view>
        
        <!-- 待实名认证 -->
        <view class="nc-item nc-item-orange" bindtap="goModule" data-tab="5" wx:if="{{notifications.daigouVerify > 0}}">
          <text class="nci-icon">🪪</text>
          <text class="nci-count">{{notifications.daigouVerify}}</text>
          <text class="nci-label">实名认证</text>
        </view>
        
        <!-- 待押金审批 -->
        <view class="nc-item nc-item-blue" bindtap="goModule" data-tab="10" wx:if="{{notifications.depositApply > 0}}">
          <text class="nci-icon">💰</text>
          <text class="nci-count">{{notifications.depositApply}}</text>
          <text class="nci-label">押金审批</text>
        </view>
        
        <!-- 待提现审批 -->
        <view class="nc-item nc-item-purple" bindtap="goModule" data-tab="11" wx:if="{{notifications.withdrawalApply > 0}}">
          <text class="nci-icon">🏧</text>
          <text class="nci-count">{{notifications.withdrawalApply}}</text>
          <text class="nci-label">提现审批</text>
        </view>
        
        <!-- 待充值审批 -->
        <view class="nc-item nc-item-green" bindtap="goModule" data-tab="12" wx:if="{{notifications.rechargeApply > 0}}">
          <text class="nci-icon">💳</text>
          <text class="nci-count">{{notifications.rechargeApply}}</text>
          <text class="nci-label">充值审批</text>
        </view>
        
        <!-- 待处理纠纷 -->
        <view class="nc-item nc-item-red" bindtap="goModule" data-tab="17" wx:if="{{notifications.userDisputes > 0}}">
          <text class="nci-icon">⚖️</text>
          <text class="nci-count">{{notifications.userDisputes}}</text>
          <text class="nci-label">纠纷处理</text>
        </view>
        
        <!-- 待处理举报 -->
        <view class="nc-item nc-item-pink" bindtap="goModule" data-tab="18" wx:if="{{notifications.reports > 0}}">
          <text class="nci-icon">🚨</text>
          <text class="nci-count">{{notifications.reports}}</text>
          <text class="nci-label">举报管理</text>
        </view>
      </view>
      
      <view class="nc-footer" bindtap="refreshNotifications">
        <text class="ncf-text">🔄 点击刷新</text>
      </view>
    </view>

    <!-- 功能模块卡片网格 -->
    <view class="module-section-title">功能模块</view>
    <view class="module-grid">

      <view class="module-card mc-blue" bindtap="goModule" data-tab="1">
        <view class="mc-icon-wrap mc-icon-blue">
          <text class="mc-icon">👥</text>
        </view>
        <text class="mc-name">用户管理</text>
        <text class="mc-desc">{{stats.totalUsers || 0}}人</text>
        <text class="mc-arrow">›</text>
        <!-- 最新用户列表 -->
        <view class="mc-latest-list" wx:if="{{stats.latestUsers && stats.latestUsers.length > 0}}">
          <view class="mc-latest-item" wx:for="{{stats.latestUsers}}" wx:key="index">
            <text class="mc-latest-name">{{item.nickName || '匿名用户'}}</text>
            <text class="mc-latest-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>

      <view class="module-card mc-green" bindtap="goModule" data-tab="2">
        <view class="mc-icon-wrap mc-icon-green">
          <text class="mc-icon">🎁</text>
        </view>
        <text class="mc-name">特产管理</text>
        <text class="mc-desc">{{stats.totalProducts || 0}}件</text>
        <text class="mc-arrow">›</text>
        <!-- 最新特产列表 -->
        <view class="mc-latest-list" wx:if="{{stats.latestProducts && stats.latestProducts.length > 0}}">
          <view class="mc-latest-item" wx:for="{{stats.latestProducts}}" wx:key="index">
            <text class="mc-latest-name">{{item.name || '未命名特产'}}</text>
            <text class="mc-latest-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>

      <view class="module-card mc-orange" bindtap="goModule" data-tab="3">
        <view class="mc-icon-wrap mc-icon-orange">
          <text class="mc-icon">🔄</text>
        </view>
        <text class="mc-name">订单管理</text>
        <text class="mc-desc">{{stats.activeSwaps || 0}}进行中</text>
        <text class="mc-arrow">›</text>
        <!-- 最新订单列表 -->
        <view class="mc-latest-list" wx:if="{{stats.latestOrders && stats.latestOrders.length > 0}}">
          <view class="mc-latest-item" wx:for="{{stats.latestOrders}}" wx:key="index">
            <text class="mc-latest-name">订单{{item._id ? item._id.substr(-6) : ''}}</text>
            <text class="mc-latest-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>

      <view class="module-card mc-red {{stats.pendingReviews > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="4">
        <view class="mc-icon-wrap mc-icon-red">
          <text class="mc-icon">📝</text>
        </view>
        <text class="mc-name">内容审核</text>
        <text class="mc-desc {{stats.pendingReviews > 0 ? 'mc-desc-alert' : ''}}">
          {{stats.pendingReviews > 0 ? stats.pendingReviews + '待处理' : '无待审核'}}
        </text>
        <text class="mc-badge" wx:if="{{stats.pendingReviews > 0}}">{{stats.pendingReviews}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-teal {{daigouVerifyStats.pending > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="5">
        <view class="mc-icon-wrap mc-icon-teal">
          <text class="mc-icon">🪪</text>
        </view>
        <text class="mc-name">实名审核</text>
        <text class="mc-desc {{daigouVerifyStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{daigouVerifyStats.pending > 0 ? daigouVerifyStats.pending + '待审核' : '无待审核'}}
        </text>
        <text class="mc-badge" wx:if="{{daigouVerifyStats.pending > 0}}">{{daigouVerifyStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-yellow" bindtap="goModule" data-tab="6">
        <view class="mc-icon-wrap mc-icon-yellow">
          <text class="mc-icon">💰</text>
        </view>
        <text class="mc-name">积分管理</text>
        <text class="mc-desc">发放/扣减</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-pink" bindtap="goModule" data-tab="7">
        <view class="mc-icon-wrap mc-icon-pink">
          <text class="mc-icon">⭐</text>
        </view>
        <text class="mc-name">信用管理</text>
        <text class="mc-desc">信用评分</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-purple" bindtap="goModule" data-tab="8">
        <view class="mc-icon-wrap mc-icon-purple">
          <text class="mc-icon">🎰</text>
        </view>
        <text class="mc-name">神秘特产</text>
        <text class="mc-desc">{{stats.mysteryCount || 0}}件</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-blue" bindtap="goModule" data-tab="9">
        <view class="mc-icon-wrap mc-icon-blue">
          <text class="mc-icon">🛒</text>
        </view>
        <text class="mc-name">代购管理</text>
        <text class="mc-desc">{{daigouStats.total || 0}}订单</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-orange {{depositApplyStats.pending > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="10">
        <view class="mc-icon-wrap mc-icon-orange">
          <text class="mc-icon">🔒</text>
        </view>
        <text class="mc-name">押金审批</text>
        <text class="mc-desc {{depositApplyStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{depositApplyStats.pending > 0 ? depositApplyStats.pending + '待审批' : '无待审批'}}
        </text>
        <text class="mc-badge" wx:if="{{depositApplyStats.pending > 0}}">{{depositApplyStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-purple" bindtap="goModule" data-tab="11">
        <view class="mc-icon-wrap mc-icon-purple">
          <text class="mc-icon">🏧</text>
        </view>
        <text class="mc-name">提现审批</text>
        <text class="mc-desc {{withdrawalStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{withdrawalStats.pending > 0 ? withdrawalStats.pending + '待审批' : '无待审批'}}
        </text>
        <text class="mc-badge" wx:if="{{withdrawalStats.pending > 0}}">{{withdrawalStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-green {{rechargeStats.pending > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="12">
        <view class="mc-icon-wrap mc-icon-green">
          <text class="mc-icon">💳</text>
        </view>
        <text class="mc-name">充值审批</text>
        <text class="mc-desc {{rechargeStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{rechargeStats.pending > 0 ? rechargeStats.pending + '待审批' : '钱包余额充值'}}
        </text>
        <text class="mc-badge" wx:if="{{rechargeStats.pending > 0}}">{{rechargeStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-gray" bindtap="goModule" data-tab="13">
        <view class="mc-icon-wrap mc-icon-gray">
          <text class="mc-icon">⚙️</text>
        </view>
        <text class="mc-name">功能开关</text>
        <text class="mc-desc">系统配置</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-gold" bindtap="goModule" data-tab="14">
        <view class="mc-icon-wrap mc-icon-gold">
          <text class="mc-icon">🏅</text>
        </view>
        <text class="mc-name">等级管理</text>
        <text class="mc-desc">代购等级</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-cyan" bindtap="goModule" data-tab="15">
        <view class="mc-icon-wrap mc-icon-cyan">
          <text class="mc-icon">🎯</text>
        </view>
        <text class="mc-name">邀请裂变</text>
        <text class="mc-desc">奖励配置</text>
        <text class="mc-arrow">›</text>
      </view>

      <view class="module-card mc-red {{disputeStats.pending > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="17">
        <view class="mc-icon-wrap mc-icon-red">
          <text class="mc-icon">⚖️</text>
        </view>
        <text class="mc-name">纠纷处理</text>
        <text class="mc-desc {{disputeStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{disputeStats.pending > 0 ? disputeStats.pending + '待处理' : '无待处理'}}
        </text>
        <text class="mc-badge" wx:if="{{disputeStats.pending > 0}}">{{disputeStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-pink {{reportStats.pending > 0 ? 'mc-badge-show' : ''}}" bindtap="goModule" data-tab="18">
        <view class="mc-icon-wrap mc-icon-pink">
          <text class="mc-icon">🚨</text>
        </view>
        <text class="mc-name">举报管理</text>
        <text class="mc-desc {{reportStats.pending > 0 ? 'mc-desc-alert' : ''}}">
          {{reportStats.pending > 0 ? reportStats.pending + '待处理' : '无待处理'}}
        </text>
        <text class="mc-badge" wx:if="{{reportStats.pending > 0}}">{{reportStats.pending}}</text>
        <text class="mc-arrow" wx:else>›</text>
      </view>

      <view class="module-card mc-orange" bindtap="goModule" data-tab="19" wx:if="{{isSuperAdmin}}">
        <view class="mc-icon-wrap mc-icon-orange">
          <text class="mc-icon">🔔</text>
        </view>
        <text class="mc-name">消息测试</text>
        <text class="mc-desc">订阅消息调试</text>
        <text class="mc-arrow">›</text>
      </view>

    </view>

    <!-- 数据看板入口 -->
    <view class="dashboard-btn" bindtap="goDashboard">
      <text class="dashboard-btn-icon">📊</text>
      <view class="dashboard-btn-text">
        <text class="dashboard-btn-title">运营数据看板</text>
        <text class="dashboard-btn-sub">省份排行 · 品类分布 · 订单漏斗</text>
      </view>
      <text class="dashboard-btn-arrow">›</text>
    </view>

    <!-- 权限提示（非超管） -->
    <view class="perm-card" wx:if="{{!isSuperAdmin}}">
      <text class="perm-icon">🔐</text>
      <text class="perm-text">你当前不是超级管理员，部分功能不可用</text>
      <view class="perm-btn" bindtap="initSuperAdmin">设为超级管理员</view>
      <view class="perm-btn perm-btn-secondary" bindtap="refreshAdminStatus" style="margin-top: 12rpx;">刷新权限状态</view>
    </view>

    <view class="safe-bottom"></view>
  </block>

  <!-- ===== 子模块通用页头（Tab > 0）===== -->
  <block wx:if="{{currentTab > 0}}">
    <view class="sub-header">
      <view class="sub-back" bindtap="goModule" data-tab="0">
        <text class="sub-back-icon">‹</text>
        <text class="sub-back-text">返回</text>
      </view>
      <text class="sub-title">{{tabs[currentTab] || '管理'}}</text>
      <view class="sub-placeholder"></view>
    </view>
  </block>

  <!-- ===== 用户管理（Tab=1）===== -->
  <block wx:if="{{currentTab === 1}}">
    <view class="search-bar">
      <text class="search-icon-emoji">🔍</text>
      <input class="search-input-field" placeholder="搜索用户昵称" bindinput="onUserSearch" />
    </view>
    <view class="list-wrap">
      <view wx:if="{{users.length === 0 && !userLoading}}" class="empty-state">
        <text class="empty-emoji">👥</text>
        <text class="empty-label">暂无用户数据</text>
      </view>
      <view class="list-card" wx:for="{{users}}" wx:key="_id" bindtap="goToUserDetail" data-openid="{{item._openid}}">
        <view class="lc-index">{{item.userIndex}}</view>
        <image class="lc-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="lc-body">
          <text class="lc-title">{{item.nickName || '微信用户'}}</text>
          <view class="lc-sub-row">
            <text class="lc-sub-text">📍 {{item.province || '未设置'}}</text>
            <view class="status-pill pill-{{item.creditLevel.class}}">⭐ {{item.creditScore || 100}}</view>
          </view>
          <view class="lc-time-row">
            <text class="lc-time-text">🕐 {{item.registerTime}}</text>
          </view>
        </view>
        <view class="lc-actions" wx:if="{{isSuperAdmin}}">
          <view class="act-btn act-edit" catchtap="openUserEdit" data-user="{{item}}">✏️</view>
          <view class="act-btn act-del" catchtap="deleteUser" data-user="{{item}}">🗑️</view>
        </view>
        <text class="lc-chevron" wx:else>›</text>
      </view>
    </view>
    <view wx:if="{{userLoading}}" class="loading-row">⏳ 加载中...</view>
  </block>

  <!-- ===== 特产管理（Tab=2）===== -->
  <block wx:if="{{currentTab === 2}}">
    <view class="chip-bar">
      <view class="chip {{productFilter === 'all' ? 'chip-active' : ''}}" bindtap="changeProductFilter" data-filter="all">全部</view>
      <view class="chip {{productFilter === 'active' ? 'chip-active' : ''}}" bindtap="changeProductFilter" data-filter="active">展示中</view>
      <view class="chip {{productFilter === 'mystery' ? 'chip-active' : ''}}" bindtap="changeProductFilter" data-filter="mystery">神秘</view>
    </view>
    <view class="list-wrap">
      <view wx:if="{{products.length === 0 && !productLoading}}" class="empty-state">
        <text class="empty-emoji">🎁</text>
        <text class="empty-label">暂无特产数据</text>
      </view>
      <view class="list-card" wx:for="{{products}}" wx:key="_id" bindtap="goToProductDetail" data-id="{{item._id}}">
        <view class="lc-index">{{item.productIndex}}</view>
        <image class="lc-cover" src="{{item.coverUrl}}" mode="aspectFill"/>
        <view class="lc-body">
          <text class="lc-title">{{item.name}}</text>
          <view class="lc-sub-row">
            <text class="lc-sub-text">📍 {{item.province}}</text>
            <text class="lc-time">{{item.createTimeText}}</text>
            <view class="status-pill pill-status-{{item.status}}">{{item.statusText}}</view>
          </view>
        </view>
        <view class="lc-actions" wx:if="{{isSuperAdmin}}">
          <view class="act-btn act-edit" catchtap="openProductEdit" data-product="{{item}}">✏️</view>
          <view class="act-btn act-del" catchtap="deleteProduct" data-id="{{item._id}}">🗑️</view>
        </view>
      </view>
    </view>
    <view wx:if="{{productLoading}}" class="loading-row">⏳ 加载中...</view>
  </block>

  <!-- ===== 订单管理（Tab=3）===== -->
  <block wx:if="{{currentTab === 3}}">
    <!-- 统计栏 -->
    <view class="stats-row-card">
      <view class="src-item">
        <text class="src-num src-orange">{{orderStats.pending || 0}}</text>
        <text class="src-label">待处理</text>
      </view>
      <view class="src-div"></view>
      <view class="src-item">
        <text class="src-num src-blue">{{orderStats.shipping || 0}}</text>
        <text class="src-label">进行中</text>
      </view>
      <view class="src-div"></view>
      <view class="src-item">
        <text class="src-num src-green">{{orderStats.completed || 0}}</text>
        <text class="src-label">已完成</text>
      </view>
    </view>
    <view class="chip-bar">
      <view class="chip {{orderFilter === 'all' ? 'chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="all">全部</view>
      <view class="chip {{orderFilter === 'pending' ? 'chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="pending">待确认</view>
      <view class="chip {{orderFilter === 'confirmed' ? 'chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="confirmed">待发货</view>
      <view class="chip {{orderFilter === 'shipped' ? 'chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="shipped">运输中</view>
      <view class="chip {{orderFilter === 'completed' ? 'chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="completed">已完成</view>
    </view>
    <view class="list-wrap">
      <view wx:if="{{orders.length === 0 && !orderLoading}}" class="empty-state">
        <text class="empty-emoji">📋</text>
        <text class="empty-label">暂无订单记录</text>
      </view>
      <view class="order-card-v3" wx:for="{{orders}}" wx:key="_id">
        <view class="lc-index">{{item.orderIndex}}</view>
        <!-- 订单头部：状态 + 时间 -->
        <view class="ocv3-header">
          <text class="ocv3-id">{{item._id ? item._id.substr(-8) : ''}}</text>
          <view class="status-pill pill-status-{{item.status}}">{{item.statusText}}</view>
        </view>
        <!-- 双方用户信息 -->
        <view style="display:flex;align-items:stretch;gap:12rpx;margin:16rpx 0;padding:0 4rpx;">
          <!-- 发起者 -->
          <view style="flex:1;background:rgba(10,132,255,0.08);border-radius:16rpx;padding:16rpx 14rpx;">
            <view style="display:flex;align-items:center;gap:10rpx;margin-bottom:8rpx;">
              <image src="{{item.initiatorAvatar || item.requesterAvatar || '/images/default-avatar.png'}}" mode="aspectFill" style="width:48rpx;height:48rpx;border-radius:50%;flex-shrink:0;"/>
              <text style="font-size:24rpx;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{item.initiatorNick || item.requesterNick || '发起者'}}</text>
            </view>
            <text wx:if="{{item.initiatorPhone}}" style="font-size:22rpx;color:rgba(255,255,255,0.5);display:block;">📱 {{item.initiatorPhone}}</text>
            <text wx:if="{{item.initiatorAddress}}" style="font-size:20rpx;color:rgba(255,255,255,0.4);display:block;margin-top:4rpx;word-break:break-all;">📍 {{item.initiatorAddress}}</text>
