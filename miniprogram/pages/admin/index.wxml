        <text class="form-label-v3" style="font-size: 24rpx; font-weight: 500; color: #666; display: block; margin-bottom: 10rpx;">省份</text>
        <picker mode="selector" range="{{provinceList}}" range-key="name" value="{{provinceIndex}}" bindchange="onUserProvinceChange">
          <view class="form-picker-v3" style="display: flex; align-items: center; justify-content: space-between; height: 88rpx; padding: 0 20rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); border-radius: 16rpx; font-size: 28rpx; color: #000; margin-bottom: 20rpx;">
            <text>{{provinceIndex >= 0 ? provinceList[provinceIndex].name : '请选择省份'}}</text>
            <text class="picker-chevron" style="color: #999; font-size: 22rpx;">▼</text>
          </view>
        </picker>
        <text class="form-label-v3" style="font-size: 24rpx; font-weight: 500; color: #666; display: block; margin-bottom: 10rpx;">性别</text>
