        </picker>
      </scroll-view>
      <view style="display:flex;gap:16rpx;padding:24rpx 32rpx 36rpx;background:#fff;border-top:1rpx solid rgba(0,0,0,0.05);">
        <view catchtap="closeMysteryModal" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:rgba(0,0,0,0.06);color:#636366;">取消</view>
        <view catchtap="saveMystery" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:linear-gradient(135deg,#0A84FF 0%,#007AFF 100%);color:#fff;">保存</view>
      </view>
    </view>
  </view>

  <!-- 调整代购等级弹窗 -->
  <view wx:if="{{levelModalVisible}}" catchtap="closeLevelModal" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view catchtap="stopPropagation" style="width:88%;max-width:680rpx;max-height:80vh;background:#fff;border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.3);display:flex;flex-direction:column;overflow:hidden;">
      <view style="display:flex;align-items:center;justify-content:space-between;padding:36rpx 32rpx 24rpx;background:#fff;border-bottom:1rpx solid rgba(0,0,0,0.06);">
        <text style="font-size:34rpx;font-weight:700;color:#1C1C1E;">🏅 调整代购等级</text>
        <view catchtap="closeLevelModal" style="width:60rpx;height:60rpx;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#8E8E93;">✕</view>
      </view>
      <scroll-view scroll-y style="flex:1;padding:28rpx 32rpx;max-height:58vh;" wx:if="{{levelModalUser}}">
        <view style="display:flex;align-items:center;gap:16rpx;padding:20rpx 24rpx;background:rgba(10,132,255,0.06);border-radius:20rpx;margin-bottom:24rpx;">
          <image style="width:76rpx;height:76rpx;border-radius:50%;background:#f2f4f8;" src="{{levelModalUser.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view>
            <text style="font-size:30rpx;font-weight:600;color:#1C1C1E;display:block;">{{levelModalUser.nickName}}</text>
            <text style="font-size:24rpx;color:#636366;display:block;">当前：{{levelModalUser.daigouLevelName}} · 积分 {{levelModalUser.points}}</text>
          </view>
        </view>
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">目标等级</text>
        <picker mode="selector" range="{{levelOptions}}" value="{{levelPickerIndex}}" bindchange="onLevelPickerChange">
          <view style="width:100%;height:92rpx;padding:0 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;display:flex;align-items:center;justify-content:space-between;box-sizing:border-box;">
            <text style="font-size:30rpx;color:#1C1C1E;">{{levelOptions[levelPickerIndex] || '请选择'}}</text>
            <text style="font-size:24rpx;color:#8E8E93;">▼</text>
          </view>
        </picker>
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;margin-top:24rpx;">调整原因（选填）</text>
        <input style="width:100%;height:92rpx;padding:0 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:30rpx;color:#1C1C1E;box-sizing:border-box;" placeholder="例如：手动升级审核" bindinput="onLevelReasonInput" value="{{levelReason}}" />
      </scroll-view>
      <view style="display:flex;gap:16rpx;padding:24rpx 32rpx 36rpx;background:#fff;border-top:1rpx solid rgba(0,0,0,0.05);">
        <view catchtap="closeLevelModal" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:rgba(0,0,0,0.06);color:#636366;">取消</view>
        <view catchtap="confirmLevelAdjust" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:linear-gradient(135deg,#FF9500 0%,#FF8800 100%);color:#fff;">确认调整</view>
      </view>
    </view>
  </view>

  <!-- 录入押金弹窗 -->
  <view wx:if="{{depositInputModalVisible}}" catchtap="closeDepositInputModal" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);z-index:999999;display:flex;align-items:center;justify-content:center;">
    <view catchtap="stopPropagation" style="width:88%;max-width:680rpx;max-height:80vh;background:#fff;border-radius:32rpx;box-shadow:0 20rpx 60rpx rgba(0,0,0,0.3);display:flex;flex-direction:column;overflow:hidden;">
      <view style="display:flex;align-items:center;justify-content:space-between;padding:36rpx 32rpx 24rpx;background:#fff;border-bottom:1rpx solid rgba(0,0,0,0.06);">
        <text style="font-size:34rpx;font-weight:700;color:#1C1C1E;">
          {{depositInputMode === 'add' ? '➕ 补押金' : depositInputMode === 'refund' ? '↩️ 退押金' : '💰 录入/修改押金'}}
        </text>
        <view catchtap="closeDepositInputModal" style="width:60rpx;height:60rpx;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#8E8E93;">✕</view>
      </view>
      <scroll-view scroll-y style="flex:1;padding:28rpx 32rpx;max-height:58vh;" wx:if="{{depositInputUser}}">
        <view style="display:flex;align-items:center;gap:16rpx;padding:20rpx 24rpx;background:rgba(10,132,255,0.06);border-radius:20rpx;margin-bottom:24rpx;">
          <image style="width:76rpx;height:76rpx;border-radius:50%;background:#f2f4f8;" src="{{depositInputUser.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view>
            <text style="font-size:30rpx;font-weight:600;color:#1C1C1E;display:block;">{{depositInputUser.nickName}}</text>
            <text style="font-size:24rpx;color:#636366;display:block;">当前押金：¥{{depositInputUser.depositPaid || 0}} · 余额：¥{{depositInputUser.depositBalance || 0}}</text>
          </view>
        </view>
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;">
          {{depositInputMode === 'add' ? '补入金额（元）' : depositInputMode === 'refund' ? '退款金额（元）' : '押金总额（元）'}}
        </text>
        <input style="width:100%;height:92rpx;padding:0 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:30rpx;color:#1C1C1E;box-sizing:border-box;" type="digit" placeholder="例如：200" bindinput="onDepositAmountInput" value="{{depositInputAmount}}" />
        <text style="font-size:26rpx;font-weight:500;color:#636366;display:block;margin-bottom:12rpx;margin-top:24rpx;">备注（选填）</text>
        <input style="width:100%;height:92rpx;padding:0 24rpx;background:rgba(0,0,0,0.03);border:1rpx solid rgba(0,0,0,0.08);border-radius:16rpx;font-size:30rpx;color:#1C1C1E;box-sizing:border-box;" placeholder="例如：线下转账已收款" bindinput="onDepositNoteInput" value="{{depositInputNote}}" />
        <view style="padding:18rpx 24rpx;border-radius:16rpx;font-size:26rpx;margin-top:24rpx;{{depositInputMode === 'refund' ? 'background:rgba(255,59,48,0.08);color:#CC0000;' : 'background:rgba(255,149,0,0.1);color:#CC7700;'}}">
          {{depositInputMode === 'add' ? '💡 补押金将累加到现有押金余额' : depositInputMode === 'refund' ? '⚠️ 退押金将从余额中扣减，不可撤销' : '💡 此操作直接设置押金总额'}}
        </view>
      </scroll-view>
      <view style="display:flex;gap:16rpx;padding:24rpx 32rpx 36rpx;background:#fff;border-top:1rpx solid rgba(0,0,0,0.05);">
        <view catchtap="closeDepositInputModal" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;background:rgba(0,0,0,0.06);color:#636366;">取消</view>
        <view catchtap="confirmDepositInput" style="flex:1;height:92rpx;border-radius:46rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;color:#fff;background:{{depositInputMode === 'refund' ? 'linear-gradient(135deg,#FF3B30 0%,#CC0000 100%)' : depositInputMode === 'add' ? 'linear-gradient(135deg,#30D158 0%,#248A3D 100%)' : 'linear-gradient(135deg,#FF9500 0%,#FF8800 100%)'}};">
          {{depositInputMode === 'add' ? '确认补押金' : depositInputMode === 'refund' ? '确认退押金' : '确认录入'}}
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 消息测试（Tab=19）===== -->
  <block wx:if="{{currentTab === 19}}">
    <view wx:if="{{!isSuperAdmin}}" class="empty-state">
      <text class="empty-emoji">🔐</text>
      <text class="empty-text">仅超级管理员可用</text>
    </view>
    <view wx:else class="msg-test-wrap">

      <!-- 说明 -->
      <view class="msg-test-tip">
        <text class="mtt-icon">💡</text>
        <text class="mtt-text">向自己（当前登录账号）发送各类订阅消息，验证模板字段是否正确。发送前需先在"我的"页面完成订阅授权。</text>
      </view>

      <!-- 查询模板字段 -->
      <view class="msg-test-item" style="background:rgba(0,122,255,0.05);border-radius:20rpx;margin-bottom:24rpx;">
        <view class="mti-left">
          <text class="mti-icon">🔍</text>
          <view>
            <text class="mti-name">查询模板字段</text>
            <text class="mti-desc">获取所有模板的真实字段名</text>
          </view>
        </view>
        <view class="mti-btn" style="background:linear-gradient(135deg,#007AFF,#0055CC);" bindtap="queryMsgTemplates">查询</view>
      </view>

      <!-- 模板字段结果 -->
      <view wx:if="{{templateQueryResult}}" style="background:#fff;border-radius:20rpx;padding:24rpx 32rpx;margin-bottom:32rpx;box-shadow:0 2rpx 16rpx rgba(0,0,0,0.06);">
        <text style="font-size:26rpx;color:#636366;font-family:monospace;white-space:pre-wrap;">{{templateQueryResult}}</text>
      </view>

      <!-- 消息类型列表 -->
      <view class="msg-test-list">

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">📦</text>
            <view>
              <text class="mti-name">发货通知</text>
              <text class="mti-desc">shipment · 发货状态/快递/单号</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'shipment' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="shipment">
            {{msgTestLoading === 'shipment' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">⭐</text>
            <view>
              <text class="mti-name">积分到账</text>
              <text class="mti-desc">points · 积分数量/说明</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'points' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="points">
            {{msgTestLoading === 'points' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">❌</text>
            <view>
              <text class="mti-name">订单取消</text>
              <text class="mti-desc">orderCancel · 取消原因/日期</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'orderCancel' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="orderCancel">
            {{msgTestLoading === 'orderCancel' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">💰</text>
            <view>
              <text class="mti-name">提现结果</text>
              <text class="mti-desc">withdrawal · 状态/金额/账号</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'withdrawal' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="withdrawal">
            {{msgTestLoading === 'withdrawal' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">🔔</text>
            <view>
              <text class="mti-name">活动通知</text>
              <text class="mti-desc">activity · 内容/开始/截止/备注</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'activity' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="activity">
            {{msgTestLoading === 'activity' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">🔄</text>
            <view>
              <text class="mti-name">互换申请</text>
              <text class="mti-desc">swapRequest · 申请人/特产/日期</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'swapRequest' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="swapRequest">
            {{msgTestLoading === 'swapRequest' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">✅</text>
            <view>
              <text class="mti-name">互换接受</text>
              <text class="mti-desc">swapAccept · 接受人/特产/日期</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'swapAccept' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="swapAccept">
            {{msgTestLoading === 'swapAccept' ? '发送中' : '测试'}}
          </view>
        </view>

        <view class="msg-test-item">
          <view class="mti-left">
            <text class="mti-icon">🚫</text>
            <view>
              <text class="mti-name">互换拒绝</text>
              <text class="mti-desc">swapReject · 拒绝人/特产/日期</text>
            </view>
          </view>
          <view class="mti-btn {{msgTestLoading === 'swapReject' ? 'loading' : ''}}" bindtap="testSendMsg" data-action="swapReject">
            {{msgTestLoading === 'swapReject' ? '发送中' : '测试'}}
          </view>
        </view>

      </view>

      <!-- 测试结果日志 -->
      <view class="msg-test-log" wx:if="{{msgTestLogs.length > 0}}">
        <view class="mtl-title">📋 发送记录</view>
        <view class="mtl-item {{item.success ? 'ok' : 'fail'}}" wx:for="{{msgTestLogs}}" wx:key="index">
          <text class="mtl-action">{{item.action}}</text>
          <text class="mtl-status">{{item.success ? '✅ 成功' : '❌ ' + item.error}}</text>
          <text class="mtl-time">{{item.time}}</text>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </block>

</view>
