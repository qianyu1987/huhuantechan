          </view>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">被邀请人奖励</text>
              <text class="config-item-desc">新用户通过邀请码注册</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">¥</text>
              <input class="config-input" type="digit" value="{{inviteConfig.inviteeReward}}" placeholder="0.10" bindinput="onInviteeRewardInput" />
            </view>
          </view>
        </view>
        
        <!-- 提现配置 -->
        <view class="config-section">
          <text class="config-section-title">💳 提现配置</text>
          
          <view class="config-item">
            <view class="config-item-label">
              <text class="config-item-name">提现门槛</text>
              <text class="config-item-desc">最低提现金额</text>
            </view>
            <view class="config-input-group">
              <text class="config-input-prefix">¥</text>
              <input class="config-input" type="digit" value="{{inviteConfig.withdrawalThreshold}}" placeholder="30.00" bindinput="onWithdrawalThresholdInput" />
            </view>
          </view>
        </view>
        
        <!-- 保存按钮 -->
        <view class="save-config-btn" bindtap="saveInviteConfig">
          <text>保存配置</text>
        </view>
        
        <!-- 配置说明 -->
        <view class="config-tips">
          <text class="config-tips-title">📝 配置说明</text>
          <view class="config-tips-list">
            <text class="config-tips-item">1. 奖励金额支持小数点后两位（如：0.30）</text>
            <text class="config-tips-item">2. 修改后立即生效，新邀请将按新规则计算奖励</text>
            <text class="config-tips-item">3. 历史邀请记录奖励金额保持不变</text>
            <text class="config-tips-item">4. 提现门槛为最低可提现金额，低于此金额无法提现</text>
          </view>
        </view>
      </view>
    </block>
  </block>

  <!-- 子模块底部安全区 -->
