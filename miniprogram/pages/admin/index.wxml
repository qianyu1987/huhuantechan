    <view class="modal-box" catchtap="stopPropagation" style="width: 88%; max-width: 680rpx; max-height: 78vh; background: white; border-radius: 28rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.25); display: flex; flex-direction: column; overflow: hidden;">
      <view class="modal-hd" style="display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 20rpx; border-bottom: 1rpx solid rgba(0,0,0,0.07); flex-shrink: 0;">
        <text class="modal-title-text" style="font-size: 32rpx; font-weight: 700; color: #000;">✏️ 编辑用户</text>
        <view class="modal-close-btn" catchtap="closeUserEditModal" style="width: 56rpx; height: 56rpx; border-radius: 50%; background: rgba(0,0,0,0.07); display: flex; align-items: center; justify-content: center;">✕</view>
