          <view class="gender-opt-v3 {{editingUser.gender == 1 ? 'g-active' : ''}}" catchtap="updateUserField" data-field="gender" data-value="{{1}}" style="flex: 1; height: 76rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); color: #666; transition: all 0.15s ease;">👨 男</view>
          <view class="gender-opt-v3 {{editingUser.gender == 2 ? 'g-active' : ''}}" catchtap="updateUserField" data-field="gender" data-value="{{2}}" style="flex: 1; height: 76rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); color: #666; transition: all 0.15s ease;">👩 女</view>
          <view class="gender-opt-v3 {{editingUser.gender == 0 ? 'g-active' : ''}}" catchtap="updateUserField" data-field="gender" data-value="{{0}}" style="flex: 1; height: 76rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); color: #666; transition: all 0.15s ease;">🔒 保密</view>
        </view>
        <text class="form-label-v3" style="font-size: 24rpx; font-weight: 500; color: #666; display: block; margin-bottom: 10rpx;">积分</text>
        <input class="form-input-v3" type="number" value="{{editingUser.points}}" bindinput="updateUserField" data-field="points" placeholder="积分数量" style="width: 100%; height: 88rpx; padding: 0 20rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); border-radius: 16rpx; font-size: 28rpx; color: #000; box-sizing: border-box; margin-bottom: 20rpx; display: block;" />
        <text class="form-label-v3" style="font-size: 24rpx; font-weight: 500; color: #666; display: block; margin-bottom: 10rpx;">信用分</text>
        <input class="form-input-v3" type="number" value="{{editingUser.creditScore}}" bindinput="updateUserField" data-field="creditScore" placeholder="0-100" style="width: 100%; height: 88rpx; padding: 0 20rpx; background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.1); border-radius: 16rpx; font-size: 28rpx; color: #000; box-sizing: border-box; margin-bottom: 20rpx; display: block;" />
      </scroll-view>
      <view class="modal-footer-btns" style="display: flex; gap: 16rpx; padding: 20rpx 32rpx 32rpx; flex-shrink: 0; border-top: 1rpx solid rgba(0,0,0,0.06);">
        <view class="mfb-cancel" catchtap="closeUserEditModal" style="flex: 1; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; background: rgba(0,0,0,0.06); color: #666;">取消</view>
        <view class="mfb-confirm" catchtap="saveUserEdit" style="flex: 1; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; background: #0A84FF; color: #fff; box-shadow: 0 4rpx 16rpx rgba(10,132,255,0.35);">保存</view>
      </view>
    </view>
  </view>

