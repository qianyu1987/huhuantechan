        </view>
        <text class="form-label-v3">押金总额（元）</text>
        <input class="form-input-v3" type="digit" placeholder="例如：200" bindinput="onDepositAmountInput" value="{{depositInputAmount}}" />
        <text class="form-label-v3">备注（选填）</text>
        <input class="form-input-v3" placeholder="例如：线下转账已收款" bindinput="onDepositNoteInput" value="{{depositInputNote}}" />
        <view class="deposit-hint-bar">💡 此操作直接更新押金余额，无需微信支付</view>
      </scroll-view>
      <view class="modal-footer-btns">
        <view class="mfb-cancel" catchtap="closeDepositInputModal">取消</view>
        <view class="mfb-confirm mfb-confirm-orange" catchtap="confirmDepositInput">确认录入</view>
      </view>
    </view>
  </view>

</view>
