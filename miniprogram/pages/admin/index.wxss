.ltc-rate    { width: 80rpx; font-size: 23rpx; text-align: center; font-weight: 700; }
.ltc-limit   { width: 80rpx; font-size: 22rpx; text-align: center; color: var(--color-sub); }
.gray { color: var(--color-muted) !important; }

.lv0 { color: var(--color-hint); }
.lv1 { color: #34C759; }
.lv2 { color: var(--color-green); }
.lv3 { color: var(--color-orange); }
.lv4 { color: #E58800; }
.lv5 { color: #007AFF; }
.lv6 { color: #5856D6; }

.lsv3-note {
