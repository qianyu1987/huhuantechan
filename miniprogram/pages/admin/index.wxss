}

/* ===== 等级用户卡 v3 ===== */
.level-user-card-v3 {
  background: var(--color-card);
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 20rpx;
  margin-bottom: 14rpx;
