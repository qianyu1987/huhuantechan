.mfb-confirm-orange:active { background: #CC7700; }

/* 押金录入提示条 */
.deposit-hint-bar {
  padding: 16rpx 20rpx;
  background: rgba(255, 149, 0, 0.08);
  border-radius: 12rpx;
  font-size: 24rpx;
