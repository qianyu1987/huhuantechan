/* ============================================================
   pages/admin/index.wxss  v3 重设计
   色调：白底 · 蓝色主色 · 分类彩色卡片
   弹窗：fixed + z-index:9999 + 白色实底（确保可见）
   ============================================================ */

/* ===== CSS 变量 ===== */
page {
  --color-bg:       #F2F4F8;
  --color-card:     #FFFFFF;
  --color-border:   rgba(0,0,0,0.07);
  --color-text:     #1C1C1E;
  --color-sub:      #636366;
  --color-hint:     #8E8E93;
  --color-muted:    #AEAEB2;
  --color-primary:  #0A84FF;
  --color-green:    #30D158;
  --color-orange:   #FF9500;
  --color-red:      #FF3B30;
  --color-purple:   #BF5AF2;
  --color-yellow:   #FFD60A;
  --radius-card:    24rpx;
  --radius-pill:    100rpx;
  --shadow-card:    0 2rpx 12rpx rgba(0,0,0,0.06);
  --shadow-modal:   0 24rpx 72rpx rgba(0,0,0,0.3);

  /* 信用/状态语义色 */
  --color-credit-excellent: #2E9E53;
  --color-credit-good:      #CC7700;
  --color-credit-normal:    #0A84FF;
  --color-credit-poor:      #FF3B30;

  background: var(--color-bg);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

/* ===== 页面基础 ===== */
.admin-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top  { height: 16rpx; }
.safe-bottom { height: 60rpx; }

/* ===== 邀请裂变配置样式 ===== */
.invite-config-card {
  margin: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.invite-config-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  display: block;
  margin-bottom: 8rpx;
}

.invite-config-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 32rpx;
}

.config-section {
  margin-bottom: 40rpx;
}

.config-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.08);
}

.config-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.config-item-label {
  flex: 1;
}

.config-item-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  display: block;
  margin-bottom: 4rpx;
}

.config-item-desc {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.config-input-group {
  display: flex;
  align-items: center;
  background: rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.1);
  border-radius: 16rpx;
  padding: 0 20rpx;
  width: 200rpx;
  height: 80rpx;
}

.config-input-prefix {
  font-size: 28rpx;
  color: #000;
  margin-right: 12rpx;
}

.config-input {
  flex: 1;
  font-size: 28rpx;
  color: #000;
  height: 100%;
}

.save-config-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #00C7BE 0%, #00A8A8 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin: 40rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0,199,190,0.3);
}

.save-config-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.config-tips {
  background: rgba(0,199,190,0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 32rpx;
}

.config-tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #00A8A8;
  display: block;
  margin-bottom: 16rpx;
}

.config-tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.config-tips-item {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

/* ===== Hero 卡片 ===== */
.hero-card {
  margin: 16rpx 24rpx 20rpx;
  padding: 28rpx 28rpx 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #5E5CE6 100%);
  border-radius: 28rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(10,132,255,0.3);
}

.hero-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hero-crown { font-size: 52rpx; }

.hero-name {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  color: #fff;
}

.hero-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  display: block;
  margin-top: 4rpx;
}

.hero-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.hero-stat { text-align: center; }

.hero-stat-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.hero-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-top: 4rpx;
}

.hero-stat-div {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.25);
}

/* ===== 待处理提醒 ===== */
.alert-bar {
  margin: 0 24rpx 16rpx;
  padding: 18rpx 24rpx;
  background: rgba(255,69,58,0.1);
  border: 1rpx solid rgba(255,69,58,0.25);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.alert-icon { font-size: 28rpx; }

.alert-text {
  font-size: 26rpx;
  color: var(--color-red);
  font-weight: 500;
}

/* ===== 模块网格标题 ===== */
.module-section-title {
  padding: 0 28rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-hint);
}

/* ===== 模块卡片网格 ===== */
.module-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.module-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 18rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(0,0,0,0.05);
  transition: transform 0.15s ease;
  overflow: visible;
}

.module-card:active { transform: scale(0.96); }

.mc-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.mc-icon { font-size: 38rpx; }

.mc-icon-blue   { background: rgba(10,132,255,0.12); }
.mc-icon-green  { background: rgba(48,209,88,0.12); }
.mc-icon-orange { background: rgba(255,159,10,0.12); }
.mc-icon-red    { background: rgba(255,69,58,0.12); }
.mc-icon-teal   { background: rgba(100,210,255,0.12); }
.mc-icon-yellow { background: rgba(255,214,10,0.12); }
.mc-icon-pink   { background: rgba(255,105,180,0.12); }
.mc-icon-purple { background: rgba(191,90,242,0.12); }
.mc-icon-gray   { background: rgba(142,142,147,0.12); }
.mc-icon-gold   { background: rgba(255,204,0,0.15); }
.mc-icon-cyan   { background: rgba(0,199,190,0.12); }

.mc-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.mc-desc {
  font-size: 22rpx;
  color: var(--color-hint);
}

.mc-desc-alert {
  color: var(--color-red) !important;
  font-weight: 600;
}

.mc-arrow {
  position: absolute;
  top: 14rpx;
  right: 16rpx;
  font-size: 28rpx;
  color: var(--color-muted);
  font-weight: 300;
}
.mc-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255,59,48,0.5);
}

/* ===== 数据看板入口 ===== */
.dashboard-btn {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(88,166,255,0.12) 0%, rgba(191,90,242,0.08) 100%);
  border: 1rpx solid rgba(88,166,255,0.25);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: opacity 0.15s;
}

.dashboard-btn:active { opacity: 0.75; }

.dashboard-btn-icon { font-size: 44rpx; }

.dashboard-btn-text { flex: 1; }

.dashboard-btn-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.dashboard-btn-sub {
  font-size: 22rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}

.dashboard-btn-arrow {
  font-size: 44rpx;
  color: var(--color-primary);
  font-weight: 300;
}

/* ===== 权限提示 ===== */
.perm-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: var(--shadow-card);
}

.perm-icon { font-size: 56rpx; }

.perm-text {
  font-size: 26rpx;
  color: var(--color-sub);
  text-align: center;
}

.perm-btn {
  padding: 18rpx 48rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #5E5CE6, var(--color-primary));
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 子模块页头 ===== */
.sub-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx 12rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 50;
}

.sub-back {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  background: rgba(10,132,255,0.08);
}

.sub-back-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 300;
  line-height: 1;
}

.sub-back-text {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.sub-placeholder { width: 100rpx; }

/* ===== 搜索栏 ===== */
.search-bar {
  margin: 16rpx 24rpx;
  padding: 0 20rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.search-icon-emoji { font-size: 28rpx; opacity: 0.4; }

.search-input-field {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  background: transparent;
}

/* ===== 筛选chip条 ===== */
.chip-bar {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.chip {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--color-sub);
  background: var(--color-card);
  border: 1rpx solid rgba(0,0,0,0.1);
  transition: all 0.15s ease;
}

.chip-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  font-weight: 600;
}

/* ===== 统计条（行式）===== */
.stats-row-card {
  margin: 16rpx 24rpx;
  padding: 20rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.src-item { text-align: center; }

.src-num {
  font-size: 36rpx;
  font-weight: 800;
  display: block;
  color: var(--color-text);
}

.src-label {
  font-size: 20rpx;
  color: var(--color-hint);
  margin-top: 2rpx;
  display: block;
}

.src-div {
  width: 1rpx;
  height: 40rpx;
  background: var(--color-border);
}

.src-blue   { color: var(--color-primary); }
.src-green  { color: var(--color-green); }
.src-orange { color: var(--color-orange); }
.src-red    { color: var(--color-red); }
.src-purple { color: var(--color-purple); }

/* ===== 通用列表 ===== */
.list-wrap {
  padding: 0 24rpx 24rpx;
}

.list-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 20rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: transform 0.15s ease;
}

.list-card:active { transform: scale(0.99); }

.lc-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #F2F4F8;
}

.lc-cover {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #F2F4F8;
}

.lc-body {
  flex: 1;
  min-width: 0;
}

.lc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lc-sub-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.lc-sub-text {
  font-size: 22rpx;
  color: var(--color-hint);
}

.lc-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.lc-chevron {
  font-size: 32rpx;
  color: #C7C7CC;
  font-weight: 300;
}

.lc-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

/* ===== 操作按钮 ===== */
.act-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  transition: transform 0.15s ease;
}

.act-btn:active { transform: scale(0.94); }

.act-edit    { background: rgba(10,132,255,0.12); color: #0A84FF; }
.act-del     { background: rgba(255,69,58,0.12); color: #FF3B30; }
.act-approve { background: rgba(48,209,88,0.12); color: #30D158; }
.act-warning { background: rgba(255,149,0,0.12); color: #FF9500; }

/* ===== 状态 Pill ===== */
.status-pill {
  padding: 5rpx 14rpx;
  border-radius: 100rpx;
  font-size: 21rpx;
  font-weight: 600;
}

/* 信用 - 统一用 pill-credit-* */
/* 通用状态 */
.pill-status-active       { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-status-in_swap      { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-status-swapped      { background: rgba(142,142,147,0.12);color: #636366; }
.pill-status-pending      { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-status-confirmed    { background: rgba(10,132,255,0.12);  color: #0A84FF; }
.pill-status-shipped      { background: rgba(191,90,242,0.12);  color: #9F35CC; }
.pill-status-completed    { background: rgba(48,209,88,0.12);   color: #2E9E53; }
.pill-status-cancelled    { background: rgba(142,142,147,0.12); color: #636366; }
.pill-status-refunding    { background: rgba(255,149,0,0.12);   color: #CC7700; }
.pill-status-refunded     { background: rgba(142,142,147,0.12); color: #636366; }
.pill-status-pending_shipment { background: rgba(10,132,255,0.12); color: #0A84FF; }

/* 审核 */
.pill-danger  { background: rgba(255,69,58,0.12);  color: #FF3B30; }
.pill-warning { background: rgba(255,159,10,0.12); color: #CC7700; }

/* 代购订单 */
.pill-dg-pending_payment  { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-dg-pending_shipment { background: rgba(10,132,255,0.12); color: #0A84FF; }
.pill-dg-shipped          { background: rgba(191,90,242,0.12); color: #9F35CC; }
.pill-dg-completed        { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-dg-cancelled        { background: rgba(142,142,147,0.12);color: #636366; }
.pill-dg-refunding        { background: rgba(255,69,58,0.12);  color: #FF3B30; }
.pill-dg-refunded         { background: rgba(142,142,147,0.12);color: #636366; }

/* 实名/押金 */
.pill-verify-pending  { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-verify-approved { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-verify-rejected { background: rgba(255,69,58,0.12);  color: #FF3B30; }
.pill-deposit-pending  { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-deposit-approved { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-deposit-rejected { background: rgba(255,69,58,0.12);  color: #FF3B30; }

/* 充值审批状态 pill */
.pill-recharge-pending   { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-recharge-approved  { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-recharge-rejected  { background: rgba(255,69,58,0.12);  color: #FF3B30; }
.pill-recharge-cancelled { background: rgba(142,142,147,0.12); color: #8E8E93; }

/* 充值金额高亮 */
.vc-amount-highlight { color: #FF9500; font-size: 32rpx; font-weight: 700; }
/* 单号字体 */
.vc-mono { font-size: 22rpx; color: #8E8E93; letter-spacing: 1rpx; }
/* 管理员备注 */
.vc-admin-note { color: #34C759; font-size: 24rpx; }
/* 时间文字 */
.vc-time { color: #8E8E93; font-size: 22rpx; }
/* 用户行（头像+昵称） */
.vc-user-row { display: flex; align-items: center; gap: 12rpx; }
.vc-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; }

/* 信用等级 */
.pill-credit-excellent { background: rgba(48,209,88,0.12);  color: #2E9E53; }
.pill-credit-good      { background: rgba(255,159,10,0.12); color: #CC7700; }
.pill-credit-normal    { background: rgba(10,132,255,0.12); color: #0A84FF; }
.pill-credit-poor      { background: rgba(255,69,58,0.12);  color: #FF3B30; }

/* ===== 订单卡片 v3 ===== */
.order-card-v3 {
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: transform 0.15s ease;
}

.order-card-v3:active { transform: scale(0.99); }

.ocv3-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.ocv3-id {
  font-size: 22rpx;
  color: #8E8E93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.ocv3-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.ocv3-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #F2F4F8;
}

.ocv3-info { flex: 1; min-width: 0; }

.ocv3-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
