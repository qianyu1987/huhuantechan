/* pages/admin/index.wxss - 管理后台样式 (iOS 26 深色主题) */

page {
  background: var(--color-bg);
}

.admin-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 顶部 Tab 栏 ===== */
.admin-tabs {
  display: flex;
  white-space: nowrap;
  background: var(--color-bg-secondary);
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  z-index: 100;
}

.admin-page .tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: auto;
  flex: none;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  position: relative;
  flex-direction: row;
  gap: 0;
  transition: color 0.2s;
}

.admin-page .tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.admin-page .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ===== 概览 - 统计卡片 ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 24rpx;
}

.stat-card {
  border-radius: var(--radius-xl);
  padding: 28rpx 24rpx;
  text-align: center;
  border: 1rpx solid var(--color-divider);
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 统计卡片颜色变体 */
.sc-green {
  background: rgba(48, 209, 88, 0.08);
}
.sc-green .stat-num { color: var(--color-secondary); }

.sc-blue {
  background: rgba(10, 132, 255, 0.08);
}
.sc-blue .stat-num { color: var(--color-primary); }

.sc-purple {
  background: rgba(191, 90, 242, 0.08);
}
.sc-purple .stat-num { color: var(--color-purple); }

.sc-orange {
  background: rgba(255, 159, 10, 0.08);
}
.sc-orange .stat-num { color: var(--color-warning); }

.sc-red {
  background: rgba(255, 69, 58, 0.08);
}
.sc-red .stat-num { color: var(--color-danger); }

/* ===== 卡片容器 ===== */
.admin-page .card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
}

.card-hd {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

/* ===== 权限提示 ===== */
.perm-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.perm-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.btn.btn-purple {
  background: rgba(191, 90, 242, 0.15);
  color: var(--color-purple);
  height: 72rpx;
  font-size: 26rpx;
}

.btn.btn-purple:active {
  background: rgba(191, 90, 242, 0.25);
}

/* ===== 管理员徽章 ===== */
.badge-admin {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(191, 90, 242, 0.2), rgba(94, 92, 230, 0.2));
  color: var(--color-purple);
}

/* ===== 快捷操作网格 ===== */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  border-radius: var(--radius-lg);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  transition: background 0.15s;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* 操作按钮颜色变体 */
.ai-green  { background: rgba(48, 209, 88, 0.1); }
.ai-blue   { background: rgba(10, 132, 255, 0.1); }
.ai-orange { background: rgba(255, 159, 10, 0.1); }
.ai-red    { background: rgba(255, 69, 58, 0.1); }
.ai-yellow { background: rgba(255, 214, 10, 0.1); }
.ai-teal   { background: rgba(100, 210, 255, 0.1); }
.ai-purple { background: rgba(191, 90, 242, 0.1); }

.ai-green:active  { background: rgba(48, 209, 88, 0.2); }
.ai-blue:active   { background: rgba(10, 132, 255, 0.2); }
.ai-orange:active { background: rgba(255, 159, 10, 0.2); }
.ai-red:active    { background: rgba(255, 69, 58, 0.2); }
.ai-yellow:active { background: rgba(255, 214, 10, 0.2); }
.ai-teal:active   { background: rgba(100, 210, 255, 0.2); }
.ai-purple:active { background: rgba(191, 90, 242, 0.2); }

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 16rpx 24rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--color-bg-tertiary);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text);
}

.ph {
  color: var(--color-text-quaternary);
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 24rpx;
}

.filter-chip {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-tertiary);
  transition: all 0.2s;
}

.filter-chip.active {
  background: rgba(10, 132, 255, 0.15);
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 通用列表 ===== */
.list-wrap {
  padding: 0 24rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 8rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-divider);
}

.list-item:active {
  background: var(--color-bg-tertiary);
}

.list-item.col {
  flex-direction: column;
  align-items: stretch;
}

/* 列表项元素 */
.li-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: var(--color-bg-tertiary);
  flex-shrink: 0;
}

.li-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  margin-right: 20rpx;
  background: var(--color-bg-tertiary);
  flex-shrink: 0;
}

.li-body {
  flex: 1;
  min-width: 0;
}

.li-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.li-sub {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  flex-wrap: wrap;
}

.li-arrow {
  font-size: 32rpx;
  color: var(--color-text-quaternary);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ===== Tag 标签（页面级覆盖） ===== */
.admin-page .tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-xs);
}

.tag-credit.credit-excellent { background: rgba(48, 209, 88, 0.12); color: var(--color-secondary); }
.tag-credit.credit-good { background: rgba(255, 159, 10, 0.12); color: var(--color-warning); }
.tag-credit.credit-normal { background: rgba(10, 132, 255, 0.12); color: var(--color-primary); }
.tag-credit.credit-poor { background: rgba(255, 69, 58, 0.12); color: var(--color-danger); }

.tag-status-active { background: rgba(48, 209, 88, 0.12); color: var(--color-secondary); }
.tag-status-in_swap { background: rgba(255, 159, 10, 0.12); color: var(--color-warning); }
.tag-status-swapped { background: rgba(142, 142, 147, 0.12); color: #8E8E93; }

.tag-mystery {
  background: rgba(191, 90, 242, 0.12);
  color: var(--color-purple);
}

/* ===== 按钮（页面级） ===== */
.btn-sm {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
  transition: opacity 0.15s;
}

.btn-sm:active {
  opacity: 0.7;
}

.btn-green {
  background: rgba(48, 209, 88, 0.15);
  color: var(--color-secondary);
}

.btn-muted {
  background: rgba(142, 142, 147, 0.15);
  color: #8E8E93;
}

.btn-blue {
  background: rgba(10, 132, 255, 0.15);
  color: var(--color-primary);
}

.btn-orange {
  background: rgba(255, 159, 10, 0.15);
  color: var(--color-warning);
}

.admin-page .btn-sm.btn-danger {
  background: rgba(255, 69, 58, 0.15);
  color: var(--color-danger);
}

.btn-group {
  display: flex;
  gap: 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ===== 订单行 ===== */
.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 4rpx 0;
}

.order-id {
  font-size: 22rpx;
  color: var(--color-text-quaternary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 380rpx;
}

.order-product {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}

.order-user {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* ===== 审核卡片 ===== */
.review-card {
  margin: 0 24rpx 12rpx;
  padding: 24rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-divider);
}

.rc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rc-user {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.rc-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: var(--color-text-quaternary);
}

.star.on {
  color: var(--color-yellow);
}

.rc-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.rc-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

/* ===== 空状态 / 加载提示 ===== */
.empty-tip {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--color-text-quaternary);
  font-size: 28rpx;
}

.load-tip {
  text-align: center;
  padding: 24rpx;
  color: var(--color-text-quaternary);
  font-size: 24rpx;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  max-width: 640rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-2xl);
  padding: 40rpx 32rpx 32rpx;
  z-index: 1001;
  border: 1rpx solid var(--color-divider);
}

.modal-lg {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-hd {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 8rpx;
}

.modal-user {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-field {
  margin-bottom: 20rpx;
}

.field-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
  display: block;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg-tertiary);
  border: 1rpx solid var(--color-divider);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.modal-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg-tertiary);
  border: 1rpx solid var(--color-divider);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

/* 弹窗按钮 */
.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.mbtn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
}

.mbtn:active {
  opacity: 0.7;
}

.mbtn-cancel {
  background: var(--color-bg-tertiary);
  color: var(--color-text-tertiary);
}

.mbtn-green {
  background: rgba(48, 209, 88, 0.15);
  color: var(--color-secondary);
}

.mbtn-orange {
  background: rgba(255, 159, 10, 0.15);
  color: var(--color-warning);
}

.mbtn-blue {
  background: rgba(10, 132, 255, 0.15);
  color: var(--color-primary);
}

.mbtn-purple {
  background: rgba(191, 90, 242, 0.15);
  color: var(--color-purple);
}

/* ===== Picker 选择器显示 ===== */
.picker-display {
  display: flex;
  align-items: center;
  line-height: 80rpx;
}

.picker-display::after {
  content: '›';
  margin-left: auto;
  font-size: 28rpx;
  color: var(--color-text-quaternary);
  transform: rotate(90deg);
}

/* ===== 功能开关管理 ===== */
.flag-mode-card {
  margin: 24rpx;
  padding: 32rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--color-divider);
}

.flag-mode-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.flag-mode-desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.flag-mode-status {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.flag-mode-status.mode-on {
  background: rgba(255, 69, 58, 0.12);
  color: var(--color-danger);
}

.flag-mode-status.mode-off {
  background: rgba(48, 209, 88, 0.12);
  color: var(--color-secondary);
}

.flag-mode-btns {
  display: flex;
  gap: 16rpx;
}

.flag-mode-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  font-weight: 500;
  transition: opacity 0.15s;
}

.flag-mode-btn:active {
  opacity: 0.7;
}

.flag-mode-btn.btn-review {
  background: rgba(255, 69, 58, 0.15);
  color: var(--color-danger);
}

.flag-mode-btn.btn-restore {
  background: rgba(48, 209, 88, 0.15);
  color: var(--color-secondary);
}

.flag-mode-btn.disabled {
  opacity: 0.35;
  pointer-events: none;
}

.flag-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  padding: 20rpx 24rpx 12rpx;
}

.flag-list {
  padding: 0 24rpx;
}

.flag-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  margin-bottom: 8rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-divider);
}

.flag-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.flag-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.flag-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.flag-switch {
  flex-shrink: 0;
}
