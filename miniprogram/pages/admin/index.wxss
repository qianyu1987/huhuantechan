/* ===== 功能开关 ===== */
.review-mode-card {
  margin: 16rpx 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

