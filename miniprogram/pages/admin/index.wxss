}

.luv3-stat-val.ok   { color: var(--color-green); }
.luv3-stat-val.low  { color: var(--color-red); }
.luv3-stat-val.rate { color: var(--color-orange); }

.luv3-stat-label { font-size: 20rpx; color: var(--color-hint); }

.luv3-deposit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.luv3-deposit-label { font-size: 24rpx; color: var(--color-sub); }

/* ===== 加载/空状态 ===== */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-emoji { font-size: 72rpx; }

.empty-label { font-size: 28rpx; color: var(--color-muted); }

.loading-row {
  text-align: center;
  padding: 28rpx;
  font-size: 24rpx;
  color: var(--color-muted);
}

.load-more-row { padding: 12rpx 24rpx 32rpx; }

.load-more-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(10,132,255,0.1);
  color: var(--color-primary);
  border: 1rpx solid rgba(10,132,255,0.2);
}

/* ============================================================
   弹窗系统 - 完全重写，确保可见
   ============================================================ */

/* 遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

/* 弹窗主体 - 纯白实底保证可见 */
.modal-box {
  width: 88%;
  max-width: 680rpx;
  max-height: 78vh;
  background: var(--color-card);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.25);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 弹窗头 */
.modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.07);
  flex-shrink: 0;
}

.modal-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.modal-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.07);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--color-sub);
}

.modal-close-btn:active { background: rgba(0,0,0,0.13); }

/* 弹窗内容区（可滚动） */
.modal-scroll-body {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
  max-height: 55vh;
}

/* 弹窗用户信息 */
.modal-user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.mui-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-bg);
}

.mui-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
}

.mui-sub {
  font-size: 22rpx;
  color: var(--color-sub);
  display: block;
}

/* 弹窗底部按钮 */
.modal-footer-btns {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 32rpx;
  flex-shrink: 0;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.mfb-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: rgba(0,0,0,0.06);
  color: var(--color-sub);
}

.mfb-cancel:active { background: rgba(0,0,0,0.1); }

.mfb-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(10,132,255,0.35);
}

.mfb-confirm:active { background: #0066CC; }

/* 橙色确认按钮（调等级/录入押金） */
