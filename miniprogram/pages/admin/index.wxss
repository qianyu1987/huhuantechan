  margin-bottom: 6rpx;
}

.luv3-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.lv-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 12rpx;
  border-radius: var(--radius-pill);
}

.lv-badge-0 { background: rgba(142,142,147,0.12); color: var(--color-sub); }
.lv-badge-1 { background: rgba(52,199,89,0.12);   color: #2E9E53; }
.lv-badge-2 { background: rgba(48,209,88,0.12);   color: #239E4A; }
.lv-badge-3 { background: rgba(255,149,0,0.12);   color: var(--color-credit-good); }
.lv-badge-4 { background: rgba(255,149,0,0.15);   color: #B06000; }
.lv-badge-5 { background: rgba(0,122,255,0.12);   color: #0055CC; }
.lv-badge-6 { background: rgba(88,86,214,0.12);   color: #4340A0; }

.luv3-credit   { font-size: 20rpx; color: var(--color-sub); }
.luv3-verify   { font-size: 20rpx; color: var(--color-hint); }
.luv3-verify.verified { color: var(--color-credit-excellent); }

.luv3-stats {
  display: flex;
  justify-content: space-around;
  padding: 14rpx 0;
