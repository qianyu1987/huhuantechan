/* pages/daigou-order/index.wxss - iOS 26 毛玻璃风格 */

/* ─────────── 基础 ─────────── */
page {
  background: #f0f2f7;
}

.page-root {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff7eb 0%, #ffe8cc 25%, #e8f4ff 65%, #f0f2f7 100%);
  position: relative;
  overflow-x: hidden;
}

/* ─────────── 毛玻璃 ─────────── */
.glass {
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    0 2rpx 16rpx rgba(0, 0, 0, 0.06),
    0 1rpx 0 rgba(255,255,255,0.85) inset;
}

/* ─────────── 背景光晕 ─────────── */
.bg-blob {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.blob-a {
  width: 500rpx; height: 500rpx;
  top: -150rpx; right: -120rpx;
  background: radial-gradient(circle, rgba(255,149,0,0.2) 0%, transparent 70%);
}
.blob-b {
  width: 400rpx; height: 400rpx;
  top: 400rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(10,132,255,0.15) 0%, transparent 70%);
}

/* ─────────── 加载 ─────────── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  gap: 20rpx;
}
.spinner-ring {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid rgba(255,149,0,0.2);
  border-top-color: #FF9500;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 26rpx;
  color: rgba(60,60,67,0.45);
}

/* ─────────── 状态英雄卡 ─────────── */
.hero-card {
  position: relative;
  z-index: 1;
  margin: 28rpx 24rpx 0;
  border-radius: 32rpx;
  padding: 44rpx 40rpx 36rpx;
  text-align: center;
  overflow: hidden;
}

/* 各状态背景渲染（毛玻璃叠加色调） */
.status-hero-pending_payment  { box-shadow: 0 4rpx 24rpx rgba(255,149,0,0.18), 0 1rpx 0 rgba(255,255,255,0.85) inset; }
.status-hero-pending_shipment { box-shadow: 0 4rpx 24rpx rgba(10,132,255,0.18), 0 1rpx 0 rgba(255,255,255,0.85) inset; }
.status-hero-shipped          { box-shadow: 0 4rpx 24rpx rgba(88,86,214,0.18), 0 1rpx 0 rgba(255,255,255,0.85) inset; }
.status-hero-completed        { box-shadow: 0 4rpx 24rpx rgba(48,209,88,0.18), 0 1rpx 0 rgba(255,255,255,0.85) inset; }
.status-hero-cancelled,
.status-hero-refunded         { box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08), 0 1rpx 0 rgba(255,255,255,0.85) inset; }
.status-hero-refunding        { box-shadow: 0 4rpx 24rpx rgba(255,69,58,0.18), 0 1rpx 0 rgba(255,255,255,0.85) inset; }

.hero-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}
.hero-text {
  font-size: 38rpx;
  font-weight: 800;
  color: #1c1c1e;
  margin-bottom: 10rpx;
}
.hero-desc {
  font-size: 24rpx;
  color: rgba(60,60,67,0.6);
  line-height: 1.6;
}

/* 积分提示 */
.points-tip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  background: rgba(255,149,0,0.1);
  border: 1rpx solid rgba(255,149,0,0.25);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}
.tip-icon { font-size: 26rpx; }
.tip-text {
  font-size: 24rpx;
  color: #FF9500;
  font-weight: 600;
}

.points-earned {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  background: rgba(48,209,88,0.1);
  border: 1rpx solid rgba(48,209,88,0.25);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}
.earned-icon { font-size: 26rpx; }
.earned-text {
  font-size: 24rpx;
  color: #30D158;
  font-weight: 600;
}

.my-points-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 16rpx;
}
.my-points-label {
  font-size: 22rpx;
  color: rgba(60,60,67,0.45);
}
.my-points-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #FF9500;
  font-variant-numeric: tabular-nums;
}
.my-points-icon { font-size: 24rpx; }

/* ─────────── 通用 section 卡 ─────────── */
.section-card {
  margin: 20rpx 24rpx 0;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  position: relative;
  z-index: 1;
}

.section-hd {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}
.section-icon { font-size: 28rpx; }
.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(60,60,67,0.5);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* ─────────── 地址 ─────────── */
.addr-row { }
.addr-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}
.addr-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1c1e;
}
.addr-phone {
  font-size: 26rpx;
  color: rgba(60,60,67,0.6);
}
.addr-detail {
  font-size: 26rpx;
  color: rgba(60,60,67,0.75);
  line-height: 1.55;
}

/* ─────────── 快递 ─────────── */
.express-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.express-company {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1c1e;
}
.express-no-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.express-no {
  font-size: 26rpx;
  color: rgba(60,60,67,0.65);
  font-family: monospace;
}
.copy-chip {
  font-size: 20rpx;
  color: #0A84FF;
  background: rgba(10,132,255,0.1);
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
  font-weight: 600;
}
.ship-time {
  font-size: 22rpx;
  color: rgba(60,60,67,0.4);
}

/* ─────────── 商品 ─────────── */
.product-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 0;
}
.product-img-wrap {
  width: 120rpx; height: 120rpx;
  border-radius: 18rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(0,0,0,0.04);
}
.product-img { width: 100%; height: 100%; }
.product-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.product-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF453A;
}
.points-value-hint {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.pv-icon { font-size: 22rpx; }
.pv-text {
  font-size: 22rpx;
  color: #FF9500;
  font-weight: 500;
}
.product-qty {
  font-size: 26rpx;
  color: rgba(60,60,67,0.4);
  flex-shrink: 0;
}
.remark-row {
  display: flex;
  gap: 8rpx;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(60,60,67,0.07);
}
.remark-label {
  font-size: 24rpx;
  color: rgba(60,60,67,0.45);
  flex-shrink: 0;
}
.remark-text {
  font-size: 24rpx;
  color: rgba(60,60,67,0.7);
  line-height: 1.5;
}

/* ─────────── 付款提示 ─────────── */
.payment-tip-card {
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 22rpx 28rpx;
  background: rgba(255,149,0,0.08) !important;
  border-color: rgba(255,149,0,0.25) !important;
  position: relative;
  z-index: 1;
}
/* 待付款紧急变体 */
.payment-tip-urgent {
  background: rgba(255,69,58,0.07) !important;
  border-color: rgba(255,69,58,0.22) !important;
}
.payment-tip-urgent .ptip-title {
  color: #FF453A;
}
/* 步骤行 */
.ptip-step-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.ptip-step-num {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(255,69,58,0.15);
  color: #FF453A;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 36rpx;
  text-align: center;
}
.ptip-step-text {
  font-size: 24rpx;
  color: rgba(60,60,67,0.75);
  line-height: 1.6;
  flex: 1;
}
/* 警告行 */
.ptip-warning {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(255,69,58,0.07);
  border-radius: 12rpx;
  border-left: 4rpx solid #FF453A;
}
.ptip-warn-icon { font-size: 24rpx; flex-shrink: 0; }
.ptip-warn-text {
  font-size: 22rpx;
  color: rgba(60,60,67,0.65);
  line-height: 1.5;
}
.ptip-hd {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}
.ptip-icon { font-size: 26rpx; }
.ptip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF9500;
}
.ptip-body {
  font-size: 24rpx;
  color: rgba(60,60,67,0.7);
  line-height: 1.6;
}
.ptip-price {
  font-weight: 700;
  color: #FF453A;
}
/* 联系卖家行 */
.ptip-contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.ptip-seller-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.ptip-seller-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.08);
}
.ptip-seller-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.ptip-seller-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(0,0,0,0.8);
}
.ptip-seller-level {
  font-size: 22rpx;
  color: rgba(0,0,0,0.45);
}
.ptip-contact-btn {
  background: #FF9500;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
}

/* ─────────── 订单信息 ─────────── */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(60,60,67,0.06);
}
.info-row:last-child { border-bottom: none; }
.info-key {
  font-size: 26rpx;
  color: rgba(60,60,67,0.5);
}
.info-val-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  max-width: 70%;
}
.info-val {
  font-size: 26rpx;
  color: #1c1c1e;
  text-align: right;
  word-break: break-all;
}
.mono {
  font-family: monospace;
  font-size: 22rpx;
  color: rgba(60,60,67,0.75);
  word-break: break-all;
}
.uid-text {
  font-size: 20rpx;
  color: rgba(60,60,67,0.5);
  max-width: 68%;
  text-align: right;
  word-break: break-all;
}
/* 金额颜色 */
.price-orange { color: #FF6B00; font-weight: 600; }
.price-bold   { font-size: 30rpx !important; }
.price-green  { color: #30D158; }
.price-line-through {
  color: rgba(60,60,67,0.4);
  text-decoration: line-through;
}
/* 订单总价分隔行 */
.info-row-total {
  border-top: 1rpx solid rgba(60,60,67,0.10) !important;
  padding-top: 14rpx !important;
  margin-top: 4rpx;
}
.info-key-bold {
  font-size: 27rpx !important;
  color: #1c1c1e !important;
  font-weight: 600;
}

/* ─────────── 安全免责提示 ─────────── */
.safety-notice-card {
  margin: 16rpx 24rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 59, 48, 0.05);
  border: 1.5rpx solid rgba(255, 59, 48, 0.22);
  border-left: 4rpx solid #FF3B30;
  overflow: hidden;
  position: relative;
  z-index: 1;
}
.notice-hd {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx 10rpx;
}
.notice-icon { font-size: 26rpx; }
.notice-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF3B30;
}
.notice-items {
  padding: 0 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.notice-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}
.n-dot {
  font-size: 20rpx;
  color: rgba(255,59,48,0.5);
  flex-shrink: 0;
  line-height: 1.6;
}
.n-text {
  font-size: 20rpx;
  color: rgba(60,60,67,0.65);
  line-height: 1.6;
  flex: 1;
}
.n-em {
  font-weight: 700;
  color: #FF3B30;
}

/* ─────────── 底部操作栏 ─────────── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  border-radius: 28rpx 28rpx 0 0;
  border-bottom: none;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  /* 覆盖 glass 的边框 */
  border-top: 1rpx solid rgba(255,255,255,0.8);
}

.action-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  text-align: center;
  box-sizing: border-box;
}
.action-btn::after { border: none; }
.full-btn { flex: 1; }

.btn-primary {
  background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255,149,0,0.4);
}
.btn-ghost {
  background: rgba(118,118,128,0.1);
  color: rgba(60,60,67,0.7);
}
.btn-danger {
  background: rgba(255,69,58,0.1);
  color: #FF453A;
}

.btn-points-hint {
  font-size: 22rpx;
  opacity: 0.9;
}

/* 含积分提示的按钮用 flex 居中 */
.btn-primary.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  line-height: normal;
}

/* ─────────── 发货抽屉 ─────────── */
.panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  transition: background 0.3s ease;
}
.mask-show {
  background: rgba(0,0,0,0.45);
}

.ship-drawer {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 101;
  border-radius: 36rpx 36rpx 0 0;
  padding: 16rpx 40rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}
.drawer-show {
  transform: translateY(0);
}

.drawer-handle {
  width: 72rpx;
  height: 6rpx;
  background: rgba(60,60,67,0.2);
  border-radius: 3rpx;
  margin: 12rpx auto 32rpx;
}
.drawer-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1c1c1e;
  text-align: center;
  margin-bottom: 40rpx;
}

.drawer-field { margin-bottom: 28rpx; }
.drawer-label {
  font-size: 24rpx;
  color: rgba(60,60,67,0.5);
  margin-bottom: 12rpx;
}
.drawer-input {
  background: rgba(118,118,128,0.08);
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 88rpx;
  font-size: 28rpx;
  color: #1c1c1e;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(60,60,67,0.08);
}
.input-ph { color: rgba(60,60,67,0.3); }

.drawer-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
}
.drawer-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: 90rpx;
  box-sizing: border-box;
}
.drawer-btn::after { border: none; }

.btn-cancel {
  background: rgba(118,118,128,0.1);
  color: rgba(60,60,67,0.65);
}
.btn-confirm {
  background: linear-gradient(135deg, #FF9500 0%, #FF6B00 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255,149,0,0.4);
}

/* ─────────── 评价状态行 ─────────── */
.review-status-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.5);
  border-radius: 16rpx;
  padding: 16rpx 0;
  margin-top: 16rpx;
}
.rs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.rs-icon { font-size: 28rpx; }
.rs-label { font-size: 22rpx; color: rgba(60,60,67,0.6); }
.rs-status { font-size: 22rpx; font-weight: 600; }
.rs-done .rs-status { color: #30D158; }
.rs-pending .rs-status { color: #FF9500; }
.rs-wait .rs-status { color: rgba(60,60,67,0.4); }
.rs-divider { width: 1rpx; height: 48rpx; background: rgba(0,0,0,0.08); }

/* ─────────── 评价按钮 ─────────── */
.btn-review {
  background: linear-gradient(135deg, #30D158 0%, #0A84FF 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(48,209,88,0.3);
  font-size: 26rpx;
}

/* ─────────── 等级徽章 ─────────── */
.level-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 12rpx;
}

.level-badge.v1 {
  background: #34C759;
}

.level-badge.v2 {
  background: #007AFF;
}

.level-badge.v3 {
  background: #5856D6;
}

.level-badge.v4 {
  background: #FF9500;
}

.level-name {
  font-size: 24rpx;
  color: #1C1C1E;
  font-weight: 500;
}

/* ─────────── 押金状态 ─────────── */
.deposit-status {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.deposit-active {
  background: #E8F5E9;
  color: #388E3C;
}

.deposit-inactive {
  background: #FFEBEE;
  color: #C62828;
}

.deposit-amount {
  font-size: 24rpx;
  color: #FF9500;
  font-weight: 500;
}
