/* pages/daigou-verify/index.wxss */
page { background: #000; color: #fff; }

.page-root { min-height: 100vh; padding: 24rpx; padding-top: 0; box-sizing: border-box; position: relative; }
.bg-blob { position: fixed; border-radius: 50%; filter: blur(80rpx); pointer-events: none; z-index: 0; }
.blob-a { width: 500rpx; height: 500rpx; background: radial-gradient(circle, rgba(0,122,255,0.25) 0%, transparent 70%); top: -100rpx; right: -100rpx; }
.blob-b { width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(88,86,214,0.2) 0%, transparent 70%); bottom: 200rpx; left: -100rpx; }
.glass { background: rgba(28,28,30,0.75); backdrop-filter: blur(20px); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 24rpx; position: relative; z-index: 1; }

.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; gap: 20rpx; }
.spinner-ring { width: 60rpx; height: 60rpx; border: 4rpx solid rgba(255,255,255,0.15); border-top-color: #0A84FF; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: rgba(255,255,255,0.5); font-size: 28rpx; }

/* 状态英雄卡 */
.status-hero { padding: 48rpx 36rpx; margin-bottom: 24rpx; text-align: center; }
.hero-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 12rpx; }
.hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.55); display: block; margin-bottom: 24rpx; }
.approved-hero .hero-title { color: #30D158; }
.pending-hero .hero-title { color: #FF9500; }

.verify-info-row { display: flex; align-items: center; gap: 16rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.verify-info-row:last-child { border-bottom: none; }
.vi-key { font-size: 26rpx; color: rgba(255,255,255,0.5); min-width: 120rpx; text-align: right; }
.vi-val { font-size: 28rpx; color: #fff; }
.vi-val.mono { font-family: 'SF Mono', monospace; letter-spacing: 2rpx; }

/* 拒绝提示 */
.reject-notice { padding: 28rpx 32rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(255,59,48,0.35); }
.reject-icon { font-size: 36rpx; margin-right: 12rpx; }
.reject-title { font-size: 28rpx; font-weight: 600; color: #FF453A; }
.reject-reason { display: block; font-size: 24rpx; color: rgba(255,255,255,0.6); margin-top: 12rpx; }

/* 等级卡 */
.level-card { padding: 32rpx; margin-bottom: 24rpx; }
.level-hd { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.level-icon { font-size: 52rpx; }
.level-info { flex: 1; }
.level-name { font-size: 30rpx; font-weight: 700; display: block; }
.level-trust { font-size: 22rpx; color: rgba(255,255,255,0.55); display: block; margin-top: 6rpx; }
.level-badge { padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 600; }
.badge-cert { background: rgba(255,215,0,0.2); color: #FFD700; border: 1rpx solid rgba(255,215,0,0.3); }
.badge-free { background: rgba(52,199,89,0.15); color: #34C759; border: 1rpx solid rgba(52,199,89,0.25); }
.level-privileges { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 20rpx; }
.priv-item { display: flex; align-items: center; gap: 10rpx; }
.priv-dot { color: rgba(255,255,255,0.4); font-size: 24rpx; }
.priv-text { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.level-btn-row { text-align: center; }
.level-view-btn { background: transparent; border: 1rpx solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); font-size: 24rpx; padding: 14rpx 36rpx; border-radius: 20rpx; }

/* 介绍卡 */
.intro-card { padding: 32rpx; margin-bottom: 24rpx; }
.intro-hd { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.intro-icon { font-size: 40rpx; }
.intro-title { font-size: 28rpx; font-weight: 600; color: #fff; }
.intro-items { display: flex; flex-direction: column; gap: 14rpx; }
.intro-row { display: flex; align-items: flex-start; gap: 14rpx; }
.ir-dot { font-size: 24rpx; color: #0A84FF; min-width: 32rpx; font-weight: 700; }
.ir-text { font-size: 25rpx; color: rgba(255,255,255,0.7); line-height: 1.6; flex: 1; }

/* 表单卡 */
.form-card { padding: 32rpx; margin-bottom: 24rpx; }
.form-hd { margin-bottom: 28rpx; }
.form-title { font-size: 30rpx; font-weight: 600; color: #fff; }

.field-row { margin-bottom: 28rpx; display: flex; flex-direction: column; }
.field-label { font-size: 26rpx; color: rgba(255,255,255,0.7); margin-bottom: 12rpx; display: block; line-height: 1.5; }
.required { color: #FF453A; margin-left: 4rpx; }
.field-input {
  display: block;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #fff;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.5;
  min-height: 88rpx;
}
.field-input.mono { letter-spacing: 2rpx; }
.ph { color: rgba(255,255,255,0.25); }

/* 上传区域 */
.upload-section { margin-bottom: 32rpx; }
.upload-label { font-size: 26rpx; color: rgba(255,255,255,0.7); display: block; margin-bottom: 8rpx; }
.upload-hint { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 16rpx; }
.upload-box {
  width: 100%;
  height: 280rpx;
  background: rgba(255,255,255,0.05);
  border: 2rpx dashed rgba(255,255,255,0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s;
}
.upload-box.has-image { border-style: solid; border-color: rgba(10,132,255,0.5); }
.upload-img { width: 100%; height: 100%; object-fit: cover; border-radius: 18rpx; }
.img-replace {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.55);
  text-align: center;
  padding: 12rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}
.upload-loading { display: flex; flex-direction: column; align-items: center; gap: 16rpx; color: rgba(255,255,255,0.5); font-size: 24rpx; }
.mini-spinner { width: 40rpx; height: 40rpx; border: 3rpx solid rgba(255,255,255,0.15); border-top-color: #0A84FF; border-radius: 50%; animation: spin 1s linear infinite; }
.upload-placeholder { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.upload-plus { font-size: 64rpx; color: rgba(255,255,255,0.2); line-height: 1; }
.upload-desc { font-size: 26rpx; color: rgba(255,255,255,0.45); }
.upload-eg { font-size: 22rpx; color: rgba(255,255,255,0.25); }

/* 隐私声明 */
.privacy-note { display: flex; align-items: flex-start; gap: 12rpx; background: rgba(0,122,255,0.1); border: 1rpx solid rgba(0,122,255,0.2); border-radius: 16rpx; padding: 20rpx 24rpx; margin-top: 12rpx; }
.pn-icon { font-size: 28rpx; flex-shrink: 0; }
.pn-text { font-size: 22rpx; color: rgba(255,255,255,0.6); line-height: 1.6; flex: 1; }

/* 按钮 */
.submit-btn { width: 100%; padding: 32rpx; border-radius: 24rpx; font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; border: none; }
.primary-btn { background: linear-gradient(135deg, #0A84FF 0%, #5856D6 100%); color: #fff; }
.ghost-btn { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); border: 1rpx solid rgba(255,255,255,0.15); }
