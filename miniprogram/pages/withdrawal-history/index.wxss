/* pages/withdrawal-history/index.wxss - 提现记录页面样式 */

/* ===== 页面基础 ===== */
page {
  --color-bg: #F2F4F8;
  --color-card: #FFFFFF;
  --color-text: #1C1C1E;
  --color-sub: #636366;
  --color-hint: #8E8E93;
  --color-primary: #0A84FF;
  --color-green: #30D158;
  --color-red: #FF3B30;
  --color-orange: #FF9500;
  --color-cyan: #00C7BE;
  --radius-card: 24rpx;
  --radius-pill: 100rpx;
  --shadow-card: 0 2rpx 12rpx rgba(0,0,0,0.06);
  
  background: var(--color-bg);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.withdrawal-history-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top { height: 16rpx; }
.safe-bottom { height: 60rpx; }

/* ===== 返回头部 ===== */
.back-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.07);
  position: relative;
}

.back-icon {
  font-size: 36rpx;
  color: #000;
  margin-right: 12rpx;
}

.back-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
}

.page-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
}

/* ===== 状态筛选 ===== */
.status-filter {
  display: flex;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.07);
  overflow-x: auto;
  white-space: nowrap;
}

.status-filter::-webkit-scrollbar {
  display: none;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: var(--color-sub);
  background: rgba(0,0,0,0.04);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-active {
  background: var(--color-cyan);
  color: #fff;
}

/* ===== 滚动区域 ===== */
.history-scroll {
  height: calc(100vh - 200rpx);
}

/* ===== 通用样式 ===== */
.mx-lg { margin-left: 24rpx; margin-right: 24rpx; }
.mt-sm { margin-top: 16rpx; }

.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.glass-card {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
}

/* ===== 记录列表 ===== */
.record-list {
  padding: 24rpx 0;
}

.record-item {
  padding: 32rpx;
}

.record-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.07);
}

.record-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.record-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-no {
  font-size: 22rpx;
  color: var(--color-sub);
}

.record-status {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.record-status.pending {
  background: rgba(255,159,10,0.12);
  color: #FF9500;
}

.record-status.approved {
  background: rgba(48,209,88,0.12);
  color: #30D158;
}

.record-status.rejected {
  background: rgba(255,69,58,0.12);
  color: #FF3B30;
}

.record-status.cancelled {
  background: rgba(142,142,147,0.12);
  color: #8E8E93;
}

/* ===== 记录信息 ===== */
.record-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-sub);
  flex-shrink: 0;
  margin-right: 20rpx;
}

.info-value {
  font-size: 24rpx;
  color: var(--color-text);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

/* ===== 操作按钮 ===== */
.record-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.07);
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.action-cancel {
  background: rgba(255,69,58,0.12);
  color: #FF3B30;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-sub);
}

/* ===== 加载更多 ===== */
.load-more {
  padding: 40rpx 24rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-sub);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--color-hint);
}