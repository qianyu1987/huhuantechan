/* pages/my-products/index.wxss - iOS 26 深色玻璃风 */

/* 功能未开放占位 */
.feature-disabled-wrap { display:flex; flex-direction:column; align-items:center; justify-content:center; padding-top:280rpx; }
.feature-disabled-icon { font-size:96rpx; margin-bottom:32rpx; }
.feature-disabled-title { font-size:36rpx; font-weight:700; color:var(--color-text); margin-bottom:16rpx; }
.feature-disabled-desc { font-size:26rpx; color:var(--color-text-tertiary); margin-bottom:48rpx; }
.feature-disabled-btn { padding:16rpx 48rpx; background:var(--color-bg-tertiary); border-radius:var(--radius-full); font-size:28rpx; color:var(--color-text-secondary); }

.container {
  background: var(--color-bg);
  min-height: 100vh;
}

/* ===== 顶部 Header - 神秘特产主题 ===== */
.page-header {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(138, 43, 226, 0.15) 0%, rgba(10, 132, 255, 0.08) 50%, transparent 100%);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.header-glow {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(138, 43, 226, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: glowPulse 4s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.2); opacity: 1; }
}

.header-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.particle {
  position: absolute;
  font-size: 32rpx;
  opacity: 0.4;
  animation: float 6s ease-in-out infinite;
}

.particle:nth-child(1) { top: 20%; left: 10%; animation-delay: 0s; }
.particle:nth-child(2) { top: 60%; left: 85%; animation-delay: 1s; }
.particle:nth-child(3) { top: 30%; left: 75%; animation-delay: 2s; }
.particle:nth-child(4) { top: 70%; left: 15%; animation-delay: 3s; }
.particle:nth-child(5) { top: 15%; left: 60%; animation-delay: 4s; }

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-emoji-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.header-emoji {
  font-size: 72rpx;
  z-index: 1;
  animation: emojiBounce 2s ease-in-out infinite;
}

@keyframes emojiBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.emoji-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 2rpx solid rgba(138, 43, 226, 0.3);
  border-radius: 50%;
  animation: ringExpand 2s ease-out infinite;
}

.emoji-ring::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border: 2rpx solid rgba(10, 132, 255, 0.2);
  border-radius: 50%;
}

@keyframes ringExpand {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0; }
}

.header-title-wrap {
  text-align: center;
  margin-bottom: 32rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 20rpx rgba(138, 43, 226, 0.3);
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.header-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
  background: rgba(120, 120, 128, 0.12);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 20rpx 48rpx;
  border-radius: var(--radius-2xl);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.header-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.header-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: linear-gradient(180deg, transparent, rgba(255,255,255,0.2), transparent);
}

/* ===== 标签栏 - 玻璃效果 ===== */
.tabs-bar {
  background: rgba(30, 30, 32, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  padding: 20rpx 0;
  gap: 16rpx;
}

.tab-item {
  padding: 14rpx 32rpx;
  border-radius: var(--radius-full);
  background: rgba(120, 120, 128, 0.16);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-item.active {
  background: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.35);
}

.tab-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: #FFFFFF;
  font-weight: 600;
}

/* ===== 统计栏 ===== */
.stats-bar {
  padding: 24rpx 20rpx 8rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* ===== 产品列表 ===== */
.products-list {
  padding: 16rpx 24rpx 40rpx;
}

.product-card {
  background: rgba(120, 120, 128, 0.16);
  border-radius: var(--radius-2xl);
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow:
    0 4rpx 24rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
}

/* ===== 产品图片 ===== */
.product-image-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.product-image-wrap.mystery-wrap {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* ===== 神秘特产视觉 ===== */
.mystery-visual {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 神秘特产渐变背景 */
.mystery-visual.purple {
  background: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #1a0a2e 100%);
}

.mystery-visual.blue {
  background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0a1628 100%);
}

.mystery-visual.green {
  background: linear-gradient(135deg, #0a1f0a 0%, #1a3a1a 50%, #0a1f0a 100%);
}

.mystery-visual.red {
  background: linear-gradient(135deg, #1f0a0a 0%, #3a1a1a 50%, #1f0a0a 100%);
}

.mystery-visual.gold {
  background: linear-gradient(135deg, #1f1a0a 0%, #3a3015 50%, #1f1a0a 100%);
}

.mystery-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(138, 43, 226, 0.4) 0%, rgba(138, 43, 226, 0.1) 40%, transparent 70%);
  border-radius: 50%;
  animation: mysteryGlow 3s ease-in-out infinite;
}

@keyframes mysteryGlow {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
}

.mystery-stars {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.star {
  position: absolute;
  font-size: 28rpx;
  opacity: 0.6;
  animation: starTwinkle 2s ease-in-out infinite;
}

.star:nth-child(1) { top: 20%; left: 20%; animation-delay: 0s; }
.star:nth-child(2) { top: 60%; right: 25%; animation-delay: 0.7s; }
.star:nth-child(3) { bottom: 25%; left: 30%; animation-delay: 1.4s; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.mystery-box {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.mystery-emoji {
  font-size: 100rpx;
  animation: boxFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 20rpx rgba(0,0,0,0.3));
}

@keyframes boxFloat {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-15rpx) rotate(5deg); }
}

.mystery-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 3rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 50%;
  animation: ringPulse 2s ease-out infinite;
}

.mystery-ring::before {
  content: '';
  position: absolute;
  top: 15rpx;
  left: 15rpx;
  right: 15rpx;
  bottom: 15rpx;
  border: 2rpx solid rgba(138, 43, 226, 0.3);
  border-radius: 50%;
}

@keyframes ringPulse {
  0% { transform: scale(0.9); opacity: 1; }
  100% { transform: scale(1.4); opacity: 0; }
}

.mystery-tag-float {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 28rpx;
  background: linear-gradient(90deg, rgba(138, 43, 226, 0.3), rgba(10, 132, 255, 0.3));
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 20rpx rgba(138, 43, 226, 0.3);
}

/* ===== 状态标签 - 玻璃胶囊 ===== */
.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  letter-spacing: 1rpx;
}

.status-active {
  background: rgba(48, 209, 88, 0.2);
  color: #30D158;
  border-color: rgba(48, 209, 88, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(48, 209, 88, 0.2);
}

.status-in_swap {
  background: rgba(255, 159, 10, 0.2);
  color: #FF9F0A;
  border-color: rgba(255, 159, 10, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 10, 0.2);
}

.status-swapped {
  background: rgba(88, 86, 214, 0.2);
  color: #8E8AFF;
  border-color: rgba(88, 86, 214, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(88, 86, 214, 0.2);
}

.status-removed {
  background: rgba(255, 69, 58, 0.2);
  color: #FF453A;
  border-color: rgba(255, 69, 58, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(255, 69, 58, 0.2);
}

/* ===== 产品信息 - 居中 ===== */
.product-info {
  padding: 24rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
  text-align: center;
  letter-spacing: -0.2rpx;
  line-height: 1.3;
}

/* 标签行 */
.product-tags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}

.location-tag {
  background: rgba(10, 132, 255, 0.1);
  color: var(--color-primary);
  border: 1rpx solid rgba(10, 132, 255, 0.15);
}

.category-tag {
  background: rgba(48, 209, 88, 0.1);
  color: #30D158;
  border: 1rpx solid rgba(48, 209, 88, 0.15);
}

/* 底栏：数据 + 时间 */
.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding-top: 4rpx;
}

.product-stats {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stat-item {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.product-time {
  font-size: 22rpx;
  color: var(--color-text-quaternary);
  font-weight: 500;
}

/* ===== 操作按钮 - 玻璃风格 ===== */
.product-actions {
  display: flex;
  justify-content: center;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid var(--color-divider);
  gap: 16rpx;
}

.action-btn {
  min-width: 160rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(120, 120, 128, 0.16);
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 0;
  padding: 0 32rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
  background: rgba(120, 120, 128, 0.32);
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: rgba(10, 132, 255, 0.15);
  color: var(--color-primary);
  border-color: rgba(10, 132, 255, 0.2);
}

.action-btn.primary:active {
  background: rgba(10, 132, 255, 0.3);
}

.action-btn.danger {
  background: rgba(255, 69, 58, 0.1);
  color: #FF453A;
  border-color: rgba(255, 69, 58, 0.15);
}

.action-btn.danger:active {
  background: rgba(255, 69, 58, 0.25);
}

/* ===== 加载更多 ===== */
.loading-more, .no-more {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 40rpx;
  font-weight: 500;
}

.empty-btn {
  background: linear-gradient(180deg, #0A84FF 0%, #0066CC 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 56rpx;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.3);
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  transform: scale(0.97);
}

/* ===== 加载中 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
}

.loading-state .loading-spinner {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 20rpx;
  margin-right: 0;
}

.loading-state text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* 代购角标 - 橙色渐变 */
.daigou-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF9F0A 0%, #FF6B35 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  z-index: 2;
}
