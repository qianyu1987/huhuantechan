/* pages/daigou-order-list/index.wxss - iOS 26 毛玻璃风格 */

/* ─────────── 基础 ─────────── */
page {
  background: #f0f2f7;
}

.page-root {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff7eb 0%, #ffe8cc 30%, #e8f4ff 65%, #f0f2f7 100%);
  position: relative;
  overflow: hidden;
}

/* ─────────── 毛玻璃通用 ─────────── */
.glass {
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    0 2rpx 16rpx rgba(0, 0, 0, 0.06),
    0 1rpx 0 rgba(255,255,255,0.9) inset;
}

/* ─────────── 顶部英雄区 ─────────── */
.top-hero {
  position: relative;
  padding: 24rpx 28rpx 0;
  z-index: 1;
}

/* 背景光晕 */
.hero-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.blob-1 {
  width: 400rpx; height: 400rpx;
  top: -120rpx; right: -80rpx;
  background: radial-gradient(circle, rgba(255,149,0,0.22) 0%, transparent 70%);
}
.blob-2 {
  width: 300rpx; height: 300rpx;
  top: 100rpx; left: -60rpx;
  background: radial-gradient(circle, rgba(10,132,255,0.15) 0%, transparent 70%);
}

/* 积分徽章 */
.points-badge {
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 2;
  active-opacity: 0.7;
}
.points-icon {
  font-size: 40rpx;
  line-height: 1;
}
.points-info {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.points-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF9500;
  font-variant-numeric: tabular-nums;
}
.points-label {
  font-size: 22rpx;
  color: rgba(60,60,67,0.55);
  font-weight: 500;
}
.credit-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  margin-left: auto;
  flex-shrink: 0;
}
.credit-high { background: #30D158; box-shadow: 0 0 8rpx rgba(48,209,88,0.5); }
.credit-mid  { background: #FF9500; box-shadow: 0 0 8rpx rgba(255,149,0,0.5); }
.credit-low  { background: #FF453A; box-shadow: 0 0 8rpx rgba(255,69,58,0.5); }

/* 角色切换器 */
.role-switcher {
  display: flex;
  align-items: center;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 2;
}

.role-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  border-radius: 18rpx;
  transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
}
.role-item.role-active {
  background: rgba(255, 149, 0, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(255,149,0,0.35);
}
.role-icon {
  font-size: 32rpx;
}
.role-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(60,60,67,0.7);
  transition: color 0.2s;
}
.role-item.role-active .role-text {
  color: #fff;
}
.role-badge {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  min-width: 30rpx;
  height: 30rpx;
  background: #FF453A;
  border-radius: 15rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}
.role-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(60,60,67,0.12);
}

/* 小统计 */
.mini-stats {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
  position: relative;
  z-index: 2;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #1c1c1e;
  font-variant-numeric: tabular-nums;
}
.stat-num.stat-warn { color: #FF9500; }
.stat-label {
  font-size: 20rpx;
  color: rgba(60,60,67,0.45);
}
.stat-sep {
  width: 1rpx;
  height: 40rpx;
  background: rgba(60,60,67,0.1);
}

/* ─────────── 状态筛选 ─────────── */
.filter-wrap {
  padding: 16rpx 0 8rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(240, 242, 247, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.status-scroll {
  white-space: nowrap;
}
.status-tabs {
  display: flex;
  padding: 4rpx 24rpx;
  gap: 12rpx;
  white-space: nowrap;
}
.s-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: rgba(60,60,67,0.6);
  font-weight: 500;
  flex-shrink: 0;
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.6);
  transition: all 0.2s ease;
}
.s-tab-active {
  background: rgba(255, 149, 0, 0.12);
  border-color: rgba(255,149,0,0.3);
  color: #FF9500;
  font-weight: 700;
}
.tab-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}
.dot-orange { background: #FF9500; }
.dot-blue   { background: #0A84FF; }
.dot-purple { background: #5856D6; }
.dot-green  { background: #30D158; }
.dot-red    { background: #FF453A; }

/* ─────────── 安全横幅提示 ─────────── */
.safety-banner {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 12rpx 24rpx 0;
  padding: 14rpx 20rpx;
  background: rgba(255, 59, 48, 0.06);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 59, 48, 0.18);
  border-left: 3rpx solid #FF3B30;
}
.banner-icon { font-size: 24rpx; flex-shrink: 0; }
.banner-text {
  font-size: 20rpx;
  color: rgba(255, 59, 48, 0.75);
  line-height: 1.5;
  flex: 1;
}

/* ─────────── 内容区 ─────────── */
.content-area {
  padding: 8rpx 0;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 20rpx;
}
.spinner-ring {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid rgba(255,149,0,0.2);
  border-top-color: #FF9500;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.spinner-ring-sm {
  width: 36rpx; height: 36rpx;
  border: 3rpx solid rgba(255,149,0,0.2);
  border-top-color: #FF9500;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 26rpx;
  color: rgba(60,60,67,0.45);
}

/* 空态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 16rpx;
}
.empty-illus {
  font-size: 100rpx;
  filter: grayscale(20%);
}
.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(60,60,67,0.65);
}
.empty-sub {
  font-size: 24rpx;
  color: rgba(60,60,67,0.4);
  text-align: center;
  padding: 0 60rpx;
}

/* 订单滚动区 */
.order-scroll {
  height: calc(100vh - 500rpx);
  padding: 0 24rpx;
}

/* ─────────── 订单卡片 ─────────── */
.order-card {
  border-radius: 28rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: transform 0.18s cubic-bezier(0.34,1.56,0.64,1);
}
.card-hover {
  transform: scale(0.978);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.06);
}

/* 卡片顶部 */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx 14rpx;
  border-bottom: 1rpx solid rgba(60,60,67,0.06);
}
.order-no-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.order-no-icon { font-size: 24rpx; }
.order-no {
  font-size: 22rpx;
  color: rgba(60,60,67,0.4);
  font-family: monospace;
}

/* 状态芯片 */
.status-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.chip-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}
.chip-pending_payment  { color: #FF9500; background: rgba(255,149,0,0.12); }
.chip-pending_shipment { color: #0A84FF; background: rgba(10,132,255,0.12); }
.chip-shipped          { color: #5856D6; background: rgba(88,86,214,0.12); }
.chip-completed        { color: #30D158; background: rgba(48,209,88,0.12); }
.chip-cancelled,
.chip-refunded         { color: rgba(60,60,67,0.4); background: rgba(60,60,67,0.07); }
.chip-refunding        { color: #FF453A; background: rgba(255,69,58,0.12); }

/* 卡片中部 */
.card-body {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 20rpx;
}
.product-img-wrap {
  position: relative;
  width: 110rpx; height: 110rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(0,0,0,0.04);
}
.product-img {
  width: 100%; height: 100%;
}
.img-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}
.mask-done   { background: rgba(48,209,88,0.4); color: #fff; }
.mask-cancel { background: rgba(0,0,0,0.35); color: #fff; }

.product-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.product-price {
  font-size: 30rpx;
  font-weight: 800;
  color: #FF453A;
}
.points-reward {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.points-hint {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.reward-icon { font-size: 22rpx; }
.reward-text {
  font-size: 22rpx;
  color: #FF9500;
  font-weight: 600;
}
.card-arrow {
  flex-shrink: 0;
}
.arrow-icon {
  font-size: 44rpx;
  color: rgba(60,60,67,0.2);
  font-weight: 300;
}

/* 卡片底部 */
.card-footer {
  padding: 10rpx 28rpx 18rpx;
  border-top: 1rpx solid rgba(60,60,67,0.05);
}
.order-time {
  font-size: 20rpx;
  color: rgba(60,60,67,0.35);
}

/* 加载更多 & 结尾 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  font-size: 22rpx;
  color: rgba(60,60,67,0.4);
}
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 22rpx;
  color: rgba(60,60,67,0.3);
}
.end-line {
  flex: 1;
  height: 1rpx;
  background: rgba(60,60,67,0.1);
}
