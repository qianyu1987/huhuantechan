/* pages/user-profile/index.wxss - 用户公开主页 - iOS 26 深色风格 */

.profile-page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 16rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* Hero区域 */
.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-gender {
  font-size: 28rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.hero-gender.gender-male {
  background: rgba(10, 132, 255, 0.15);
}

.hero-gender.gender-female {
  background: rgba(255, 45, 85, 0.15);
}

/* ===== Hero 区域 ===== */
.hero-section {
  position: relative;
  background: linear-gradient(135deg, #1C1C1E 0%, #2C2C2E 100%);
  padding: 32rpx 20rpx;
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
  overflow: hidden;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* 背景光晕 */
.hero-section::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -10%;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -5%;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(175, 82, 222, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.hero-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
}

.hero-avatar:active {
  transform: scale(0.95);
}

.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.5rpx;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.hero-loc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.hero-dot {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.hero-join {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

/* ===== 统计行 ===== */
.stats-row {
  display: flex;
  align-items: center;
  margin: 24rpx 24rpx 0;
  background: rgba(120, 120, 128, 0.16);
  border-radius: var(--radius-xl);
  padding: 24rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.15);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-num.credit-high { color: #30D158; }
.stat-num.credit-mid { color: #FF9F0A; }
.stat-num.credit-low { color: #FF453A; }

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  font-weight: 500;
}

/* ===== 通用卡片区域 ===== */
.section-card {
  margin: 24rpx 24rpx 0;
  background: rgba(120, 120, 128, 0.16);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -0.2rpx;
}

.section-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* ===== 省份集章 ===== */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.badge-text {
  font-size: 18rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* ===== TA的特产 - 横向滚动卡片 ===== */
.products-section {
  background: rgba(120, 120, 128, 0.10);
  padding-bottom: 24rpx;
}

.product-scroll {
  display: flex;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.product-card {
  position: relative;
  display: inline-block;
  width: 280rpx;
  flex-shrink: 0;
  background: rgba(28, 28, 30, 0.95);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1rpx solid rgba(255, 55, 95, 0.15);
  box-shadow:
    0 4rpx 24rpx rgba(255, 55, 95, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  margin-right: 20rpx;
  vertical-align: top;
}

.product-card:active {
  transform: scale(0.96);
  box-shadow:
    0 8rpx 40rpx rgba(255, 55, 95, 0.25),
    0 2rpx 12rpx rgba(0, 0, 0, 0.5);
  border-color: rgba(255, 55, 95, 0.35);
}

/* 粉色光晕层 */
.card-glow {
  position: absolute;
  top: -40%;
  left: 50%;
  transform: translateX(-50%);
  width: 140%;
  height: 120rpx;
  background: radial-gradient(ellipse, rgba(255, 55, 95, 0.08) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* 封面容器 - padding-bottom 实现 1:1 */
.card-cover-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: var(--color-bg-tertiary);
}

.card-cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

/* 神秘特产封面 */
.mystery-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.mystery-cover.color-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.mystery-cover.color-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.mystery-cover.color-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.mystery-cover.color-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.mystery-cover.color-5 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.mystery-cover.color-6 { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
.mystery-cover.color-7 { background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%); }
.mystery-cover.color-8 { background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%); }
.mystery-cover.color-9 { background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%); }
.mystery-cover.color-10 { background: linear-gradient(135deg, #c471f5 0%, #fa71cd 100%); }

.mystery-emoji {
  font-size: 64rpx;
}

.mystery-prov-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 700;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.25);
}

/* 卡片信息区 */
.card-body {
  position: relative;
  z-index: 1;
  padding: 14rpx 14rpx 16rpx;
}

.card-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.card-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 状态标签 */
.card-status-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  padding: 2rpx 14rpx;
  border-radius: var(--radius-full);
  line-height: 1.7;
}

.card-status-tag.status-active {
  background: rgba(48, 209, 88, 0.15);
  color: #30D158;
}

.card-status-tag.status-swap {
  background: rgba(255, 159, 10, 0.15);
  color: #FF9F0A;
}

.card-status-tag.status-done {
  background: rgba(142, 142, 147, 0.15);
  color: #8E8E93;
}

.card-loc-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 14rpx;
  border-radius: var(--radius-full);
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 120rpx;
}

/* ===== 评价列表 ===== */
.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-item {
  padding: 20rpx;
  background: rgba(120, 120, 128, 0.08);
  border-radius: var(--radius-lg);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.review-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-secondary);
}

.review-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.review-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.review-time {
  font-size: 20rpx;
  color: var(--color-text-quaternary);
}

.review-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
}

.review-badge.good {
  background: rgba(48, 209, 88, 0.12);
  color: #30D158;
}

.review-badge.bad {
  background: rgba(255, 69, 58, 0.12);
  color: #FF453A;
}

.review-content {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
  padding-left: 70rpx;
}

/* ===== 空状态 ===== */
.empty-hint {
  padding: 40rpx 20rpx;
  text-align: center;
  color: var(--color-text-quaternary);
  font-size: 26rpx;
}

/* ===== 安全底部 ===== */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
