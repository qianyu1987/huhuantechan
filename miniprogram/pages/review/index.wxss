/* pages/review/index.wxss - 评价页面样式 - 生动活泼版 */

page {
  background: #F2F2F7;
  min-height: 100vh;
}

.review-page {
  padding: 20rpx;
  padding-bottom: 60rpx;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 - 简化版 */
.top-decoration {
  position: fixed;
  top: -50rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  pointer-events: none;
  z-index: 0;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.3;
}

.circle-1 {
  width: 100rpx;
  height: 100rpx;
  background: #007AFF;
  top: 30rpx;
  left: 30rpx;
}

.circle-2 {
  width: 60rpx;
  height: 60rpx;
  background: #34C759;
  top: 80rpx;
  left: 100rpx;
}

.circle-3 {
  width: 40rpx;
  height: 40rpx;
  background: #FF9500;
  top: 130rpx;
  left: 50rpx;
}

/* 卡片通用样式 - iOS 风格 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #E5E5EA;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #000;
}

.card-subtitle {
  font-size: 24rpx;
  color: #8E8E93;
  margin-left: auto;
}

/* 标题区 - iOS 简洁风格 */
.header-section {
  text-align: center;
  padding: 20rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 8rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: #8E8E93;
}

/* 互换特产卡片 */
.exchange-card {
  background: #fff;
  border: 1rpx solid #E5E5EA;
}

.exchange-label {
  text-align: center;
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.exchange-products {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.product-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #F2F2F7;
}

/* 神秘特产样式 */
.product-mystery {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-mystery .mystery-emoji {
  font-size: 48rpx;
}

.product-mystery.color-1 { background: linear-gradient(135deg, #FF6B6B, #FFB4B4); }
.product-mystery.color-2 { background: linear-gradient(135deg, #4ECDC4, #A8EDEA); }
.product-mystery.color-3 { background: linear-gradient(135deg, #45B7D1, #96E6FF); }
.product-mystery.color-4 { background: linear-gradient(135deg, #96CEB4, #D4F1D4); }
.product-mystery.color-5 { background: linear-gradient(135deg, #FFEAA7, #FFF5D1); }
.product-mystery.color-6 { background: linear-gradient(135deg, #DDA0DD, #F0D0F0); }
.product-mystery.color-7 { background: linear-gradient(135deg, #98D8C8, #C8F0E8); }
.product-mystery.color-8 { background: linear-gradient(135deg, #F7DC6F, #FFF3B0); }
.product-mystery.color-9 { background: linear-gradient(135deg, #BB8FCE, #E0C8F0); }
.product-mystery.color-10 { background: linear-gradient(135deg, #F0B27A, #FAD8B0); }

.product-name {
  font-size: 24rpx;
  color: #3C3C43;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.exchange-arrow {
  width: 50rpx;
  height: 50rpx;
  background: #F2F2F7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exchange-arrow text {
  color: #8E8E93;
  font-size: 28rpx;
}

/* 评分卡片 - iOS 风格 */
.rating-card {
  background: #fff;
  border: 1rpx solid #E5E5EA;
}

.ios-star-container {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin: 30rpx 0;
}

.ios-star-item {
  padding: 8rpx;
}

.ios-star {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.ios-star:active {
  transform: scale(0.9);
}

.ios-star text {
  position: absolute;
  font-size: 56rpx;
  line-height: 1;
}

.star-empty {
  color: #E5E5EA !important;
}

.star-fill {
  position: absolute;
  overflow: hidden;
  color: #FFB800;
}

.star-fill text {
  color: #FFB800;
}

.ios-star.active .star-empty {
  color: #FFB800 !important;
}

/* 评分提示 - iOS 风格药丸 */
.rating-hint {
  text-align: center;
}

.rating-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.rating-pill.good {
  background: rgba(52, 199, 89, 0.15);
  color: #34C759;
}

.rating-pill.normal {
  background: rgba(255, 204, 0, 0.15);
  color: #FF9500;
}

.rating-pill.bad {
  background: rgba(255, 59, 48, 0.15);
  color: #FF3B30;
}

/* 标签卡片 */
.tags-card {
  background: #fff;
  border: 1rpx solid #E5E5EA;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #F2F2F7;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #333;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
  position: relative;
  overflow: hidden;
}

.tag-item.active,
.tag-item.tag-active,
.tag-item.tag-selected {
  background: #007AFF !important;
  color: #fff !important;
  border-color: #007AFF !important;
  transform: scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.35);
}



.tag-item.active .tag-text {
  font-weight: 600;
}

/* 标签点击波纹效果 */
.tag-item::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.3s ease, height 0.3s ease;
  opacity: 0;
}

.tag-item:active::after {
  width: 200rpx;
  height: 200rpx;
  opacity: 1;
}

.tag-icon {
  font-size: 28rpx;
}

.tag-text {
  font-weight: 500;
}

/* 内容输入卡片 */
.content-card {
  background: #fff;
  border: 1rpx solid #E5E5EA;
}

.input-wrapper {
  position: relative;
}

.content-input {
  width: 100%;
  height: 220rpx;
  padding: 24rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid #E5E5EA;
  transition: all 0.3s ease;
  color: #333;
}

.content-input:focus {
  border-color: #007AFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.15);
}

.content-input::-webkit-placeholder {
  color: #999;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.emoji-hint {
  font-size: 28rpx;
  opacity: 0.5;
}

.content-count {
  font-size: 24rpx;
  color: #999;
}

/* 匿名评价卡片 */
.anonymous-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  border: 1rpx solid #E5E5EA;
}

.anonymous-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.anonymous-icon {
  font-size: 36rpx;
}

.anonymous-label {
  font-size: 28rpx;
  color: #3C3C43;
  font-weight: 500;
}

.anonymous-switch {
  transform: scale(0.9);
}

/* 提交按钮 - iOS 风格 */
.submit-section {
  margin-top: 40rpx;
  padding: 0 10rpx;
}

.btn-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: #007AFF;
  border-radius: 14rpx;
  border: none;
  transition: all 0.2s ease;
}

.btn-submit:active {
  background: #0063CC;
}

.btn-submit.disabled {
  background: #C7C7CC;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 感谢语 */
.thanks-section {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5EA;
  border-top-color: #007AFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #8E8E93;
}

/* 成功弹窗 - iOS 风格 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.success-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 60rpx;
  text-align: center;
  animation: scaleIn 0.4s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

@keyframes scaleIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 8rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #8E8E93;
  margin-bottom: 20rpx;
}

.success-stats {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: rgba(52, 199, 89, 0.15);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #34C759;
  font-weight: 600;
}
