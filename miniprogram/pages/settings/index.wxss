/* pages/settings/index.wxss - 设置 - iOS 26 毛玻璃风格 */

.settings-page {
  min-height: 100vh;
  background: #000000;
  position: relative;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse 80% 50% at 20% 0%, rgba(10, 132, 255, 0.08) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
}

/* 导航栏 */
.glass-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(30, 30, 32, 0.7);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #0A84FF;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.nav-placeholder {
  width: 60rpx;
}

/* 滚动区域 */
.settings-scroll {
  position: relative;
  z-index: 1;
  padding: 40rpx 24rpx;
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 菜单列表 */
.menu-list {
  background: rgba(60, 60, 64, 0.35);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: background 0.2s ease;
}

.menu-item:active {
  background: rgba(120, 120, 128, 0.2);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger .menu-text {
  color: #FF453A;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #FFFFFF;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cache-size {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
}

/* 开关样式 */
.menu-switch {
  transform: scale(0.85);
}

.menu-switch .wx-switch-input {
  background: rgba(120, 120, 128, 0.4) !important;
  border-color: rgba(120, 120, 128, 0.4) !important;
}

.menu-switch .wx-switch-input.wx-switch-input-checked {
  background: #0A84FF !important;
  border-color: #0A84FF !important;
}
