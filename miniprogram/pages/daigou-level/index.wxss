/* pages/daigou-level/index.wxss */
page { background: #000; color: #fff; }
.page-root { min-height: 100vh; padding: 24rpx; box-sizing: border-box; position: relative; }
.bg-blob { position: fixed; border-radius: 50%; filter: blur(80rpx); pointer-events: none; z-index: 0; }
.blob-a { width: 500rpx; height: 500rpx; background: radial-gradient(circle, rgba(0,122,255,0.2) 0%, transparent 70%); top: -100rpx; right: -100rpx; }
.blob-b { width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(255,149,0,0.15) 0%, transparent 70%); bottom: 300rpx; left: -100rpx; }
.glass { background: rgba(28,28,30,0.75); backdrop-filter: blur(20px); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 24rpx; position: relative; z-index: 1; }
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; gap: 20rpx; }
.spinner-ring { width: 60rpx; height: 60rpx; border: 4rpx solid rgba(255,255,255,0.15); border-top-color: #0A84FF; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: rgba(255,255,255,0.5); font-size: 28rpx; }

/* 我的等级卡 */
.my-level-card { padding: 32rpx; margin-bottom: 24rpx; }
.my-level-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.ml-label { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.ml-badge { padding: 6rpx 16rpx; border-radius: 16rpx; font-size: 22rpx; font-weight: 600; }
.badge-cert { background: rgba(255,215,0,0.15); color: #FFD700; }
.badge-free { background: rgba(52,199,89,0.12); color: #34C759; }
.my-level-main { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.ml-icon { font-size: 64rpx; }
.ml-info { flex: 1; }
.ml-name { font-size: 32rpx; font-weight: 700; display: block; }
.ml-trust { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 8rpx; }
.my-stats-row { display: flex; align-items: center; background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 20rpx 0; }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 32rpx; font-weight: 700; color: #fff; display: block; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 50rpx; background: rgba(255,255,255,0.1); }

/* 类型对比 */
.type-compare { padding: 28rpx; margin-bottom: 24rpx; }
.type-hd { margin-bottom: 20rpx; }
.type-title { font-size: 28rpx; font-weight: 600; color: #fff; }
.type-row { display: flex; gap: 0; }
.type-item { flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 8rpx; padding: 16rpx 12rpx; }
.type-icon { font-size: 44rpx; }
.type-name { font-size: 26rpx; font-weight: 600; color: #fff; }
.type-desc { font-size: 22rpx; color: rgba(255,255,255,0.55); line-height: 1.5; }
.free-type .type-range { background: rgba(52,199,89,0.15); color: #34C759; padding: 6rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
.cert-type .type-range { background: rgba(255,215,0,0.15); color: #FFD700; padding: 6rpx 16rpx; border-radius: 12rpx; font-size: 22rpx; }
.type-divider { width: 1rpx; background: rgba(255,255,255,0.1); margin: 16rpx 0; }

/* 等级卡列表 */
.levels-list { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 24rpx; }
.level-card { padding: 28rpx; }
.current-level { border-color: rgba(0,122,255,0.5) !important; box-shadow: 0 0 0 2rpx rgba(0,122,255,0.25); }
.lc-hd { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx; }
.lc-icon { font-size: 52rpx; flex-shrink: 0; }
.lc-meta { flex: 1; }
.lc-name-row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-bottom: 8rpx; }
.lc-name { font-size: 28rpx; font-weight: 700; }
.lc-type { padding: 4rpx 12rpx; border-radius: 10rpx; font-size: 20rpx; font-weight: 600; }
.type-cert { background: rgba(255,215,0,0.15); color: #FFD700; }
.type-free { background: rgba(52,199,89,0.12); color: #34C759; }
.lc-trust { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.current-tag { padding: 6rpx 16rpx; background: linear-gradient(135deg, #0A84FF, #5856D6); color: #fff; border-radius: 12rpx; font-size: 20rpx; font-weight: 600; flex-shrink: 0; }

.lc-requires { margin-bottom: 16rpx; }
.req-hd { margin-bottom: 12rpx; }
.req-title { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.req-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.req-item { background: rgba(255,255,255,0.06); border-radius: 12rpx; padding: 10rpx 16rpx; display: flex; gap: 8rpx; align-items: center; }
.req-key { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.req-val { font-size: 22rpx; color: #fff; font-weight: 600; }

.lc-limits { display: flex; gap: 16rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.limit-item { display: flex; align-items: center; gap: 8rpx; }
.limit-icon { font-size: 22rpx; }
.limit-text { font-size: 22rpx; color: rgba(255,255,255,0.6); }

.lc-privileges { display: flex; flex-direction: column; gap: 8rpx; border-top: 1rpx solid rgba(255,255,255,0.08); padding-top: 16rpx; }
.priv-item { display: flex; align-items: center; gap: 10rpx; }
.priv-dot { font-size: 22rpx; font-weight: 700; }
.priv-text { font-size: 22rpx; color: rgba(255,255,255,0.65); }

/* 信用分说明 */
.credit-explain { padding: 28rpx; }
.ce-hd { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.ce-icon { font-size: 36rpx; }
.ce-title { font-size: 28rpx; font-weight: 600; color: #fff; }
.ce-items { display: flex; flex-direction: column; gap: 14rpx; }
.ce-row { display: flex; align-items: center; gap: 16rpx; }
.ce-tag { min-width: 80rpx; text-align: center; padding: 6rpx 12rpx; border-radius: 10rpx; font-size: 22rpx; font-weight: 600; }
.ce-tag.good { background: rgba(48,209,88,0.15); color: #30D158; }
.ce-tag.neutral { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
.ce-tag.bad { background: rgba(255,59,48,0.12); color: #FF453A; }
.ce-desc { font-size: 24rpx; color: rgba(255,255,255,0.7); }

/* 申请押金卡片 */
.apply-deposit-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  margin-top: 24rpx;
  border: 1.5rpx solid rgba(255,149,0,0.35);
  background: rgba(255,149,0,0.08) !important;
}
.adc-icon { font-size: 44rpx; margin-right: 20rpx; }
.adc-info { flex: 1; }
.adc-title { font-size: 28rpx; font-weight: 600; color: #FF9F0A; margin-bottom: 4rpx; display: block; }
.adc-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; }
.adc-arrow { font-size: 36rpx; color: #FF9F0A; font-weight: 700; }
