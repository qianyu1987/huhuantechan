/* pages/admin-webview/index.wxss */
.container {
  width: 100%;
  height: 100vh;
  background: #0d1117;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

web-view {
  width: 100%;
  height: 100vh;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(88, 166, 255, 0.2);
  border-top-color: #58a6ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #e6edf3;
  margin-top: 8rpx;
}

.loading-sub {
  font-size: 22rpx;
  color: #8b949e;
}

/* 错误状态 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 0 60rpx;
}

.error-icon {
  font-size: 64rpx;
}

.error-msg {
  font-size: 26rpx;
  color: #f78166;
  text-align: center;
  line-height: 1.6;
}

.retry-btn {
  margin-top: 10rpx;
  padding: 16rpx 48rpx;
  background: #238636;
  color: #fff;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.help-text {
  margin-top: 8rpx;
}

.help-text text {
  font-size: 22rpx;
  color: #8b949e;
  text-align: center;
}
