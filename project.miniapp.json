{
  "miniVersion": "v2",
  "name": "互换特产",
  "version": "0.0.1",
  "versionCode": 10,
  "i18nFilePath": "i18n",
  "mini-ohos": {
    "sdkVersion": "0.5.1"
  },
  "mini-android": {
    "resourcePath": "miniapp/android/nativeResources",
    "sdkVersion": "1.6.24",
    "toolkitVersion": "0.11.0",
    "useExtendedSdk": {
      "media": false,
      "bluetooth": false,
      "network": false,
      "scanner": false,
      "xweb": false
    },
    "icons": {
      "hdpi": "miniprogram/images/android/android-icon-72.png",
      "xhdpi": "miniprogram/images/android/android-icon-96.png",
      "xxhdpi": "miniprogram/images/android/android-icon-144.png",
      "xxxhdpi": "miniprogram/images/android/android-icon-192.png"
    },
    "splashscreen": {
      "hdpi": "miniprogram/images/android/splash-screen-new.png",
      "xhdpi": "miniprogram/images/android/splash-screen-new.png",
      "xxhdpi": "miniprogram/images/splash-screen-new.png"
    },
    "enableVConsole": "open",
    "privacy": {
      "enable": true
    },
    "gdt": {
      "splashAd_fetchDelay": 0
    },
    "officialPlugins": {
      "imPush": {
        "enable": false
      }
    }
  },
  "mini-ios": {
    "sdkVersion": "1.6.29",
    "toolkitVersion": "0.0.9",
    "useExtendedSdk": {
      "WeAppOpenFuns": true,
      "WeAppNetwork": false,
      "WeAppBluetooth": false,
      "WeAppMedia": false,
      "WeAppLBS": false,
      "WeAppOthers": false
    },
    "enableVConsole": "open",
    "icons": {
      "mainIcon120": "miniprogram/images/ios/icon_mainIcon120.png",
      "mainIcon180": "miniprogram/images/ios/icon_mainIcon180.png",
      "spotlightIcon80": "miniprogram/images/ios/icon_spotlightIcon80.png",
      "spotlightIcon120": "miniprogram/images/ios/icon_spotlightIcon120.png",
      "settingsIcon58": "miniprogram/images/ios/icon_settingsIcon58.png",
      "settingsIcon87": "miniprogram/images/ios/icon_settingsIcon87.png",
      "notificationIcon40": "miniprogram/images/ios/icon_notificationIcon40.png",
      "notificationIcon60": "miniprogram/images/ios/icon_notificationIcon60.png",
      "appStore1024": "miniprogram/images/ios/icon_appStore1024.png"
    },
    "splashScreen": {
      "customImage": "miniprogram/images/ios/splash_custom.png"
    },
    "privacy": {
      "enable": false
    },
    "enableOpenUrlNavigate": true
  }
}
